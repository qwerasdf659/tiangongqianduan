<!-- custom-tab-bar/index.wxml - 纯自定义底部导航栏 -->
<view class="tabbar-wrap">
  <view class="tabbar">
    <view
      class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
      wx:for="{{list}}"
      wx:key="pagePath"
      data-index="{{index}}"
      catchtap="onTabTap"
      hover-class="none"
    >
      <view class="tab-icon-wrap">
        <image
          class="tab-icon"
          src="{{selected === index ? item.iconActive : item.icon}}"
          mode="aspectFit"
        />
      </view>
      <text class="tab-label">{{item.text}}</text>
    </view>
  </view>
  <view class="tabbar-safe-area"></view>
</view>
