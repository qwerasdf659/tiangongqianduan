{
  "pages": [
    "pages/lottery/lottery",
    "pages/exchange/exchange",
    "pages/user/user",
    "pages/diy/diy",
    "pages/camera/camera",
    "pages/webview/webview"
  ],
  "subpackages": [
    {
      "root": "packageLottery",
      "name": "lottery",
      "pages": ["_placeholder/_placeholder"]
    },
    {
      "root": "packageExchange",
      "name": "exchange",
      "pages": [
        "exchange-detail/exchange-detail",
        "exchange-orders/exchange-orders",
        "exchange-order-detail/exchange-order-detail",
        "_placeholder/_placeholder"
      ]
    },
    {
      "root": "packageUser",
      "name": "user-services",
      "pages": [
        "chat/chat",
        "points-detail/points-detail",
        "feedback/feedback",
        "feedback/detail",
        "feedback/list",
        "disputes/disputes",
        "disputes/detail",
        "disputes/create",
        "notifications/notifications",
        "backpack/inventory/inventory",
        "records/trade-upload-records/trade-upload-records",
        "agreement/agreement",
        "barter/barter",
        "growth-level/growth-level"
      ]
    },
    {
      "root": "packageAdmin",
      "name": "admin",
      "pages": [
        "consume-submit/consume-submit",
        "audit-list/audit-list",
        "scan-verify/scan-verify",
        "customer-service/customer-service"
      ]
    },
    {
      "root": "packageAd",
      "name": "ad",
      "pages": ["ad-campaigns/ad-campaigns", "ad-create/ad-create", "ad-detail/ad-detail"]
    },
    {
      "root": "packageDIY",
      "name": "diy",
      "pages": [
        "diy-select/diy-select",
        "diy-templates/diy-templates",
        "diy-design/diy-design",
        "diy-result/diy-result",
        "diy-works/diy-works",
        "diy-3d-preview/diy-3d-preview"
      ]
    }
  ],
  "preloadRule": {
    "pages/lottery/lottery": {
      "network": "all",
      "packages": ["lottery"]
    },
    "pages/exchange/exchange": {
      "network": "all",
      "packages": ["lottery", "exchange", "diy"]
    },
    "pages/diy/diy": {
      "network": "all",
      "packages": ["diy"]
    },
    "pages/camera/camera": {
      "network": "all",
      "packages": ["lottery"]
    },
    "pages/user/user": {
      "network": "all",
      "packages": ["user-services", "admin", "lottery", "exchange", "ad"]
    }
  },
  "window": {
    "navigationStyle": "custom",
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "天工平台",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#ffffff",
    "enablePullDownRefresh": true,
    "onReachBottomDistance": 50
  },
  "tabBar": {
    "custom": true,
    "color": "#BFBFBF",
    "selectedColor": "#A0724A",
    "backgroundColor": "#fff",
    "borderStyle": "black",
    "position": "bottom",
    "list": [
      {
        "pagePath": "pages/lottery/lottery",
        "text": "回馈",
        "iconPath": "images/icons/transparent.png",
        "selectedIconPath": "images/icons/transparent.png"
      },
      {
        "pagePath": "pages/camera/camera",
        "text": "发现",
        "iconPath": "images/icons/transparent.png",
        "selectedIconPath": "images/icons/transparent.png"
      },
      {
        "pagePath": "pages/exchange/exchange",
        "text": "商城",
        "iconPath": "images/icons/transparent.png",
        "selectedIconPath": "images/icons/transparent.png"
      },
      {
        "pagePath": "pages/diy/diy",
        "text": "DIY",
        "iconPath": "images/icons/transparent.png",
        "selectedIconPath": "images/icons/transparent.png"
      },
      {
        "pagePath": "pages/user/user",
        "text": "我的",
        "iconPath": "images/icons/transparent.png",
        "selectedIconPath": "images/icons/transparent.png"
      }
    ]
  },
  "networkTimeout": {
    "request": 15000,
    "downloadFile": 15000
  },
  "usingComponents": {
    "maintenance-overlay": "/components/maintenance-overlay/maintenance-overlay",
    "custom-navbar": "/components/custom-navbar/custom-navbar"
  },
  "debug": false,
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "renderer": "skyline",
  "rendererOptions": {
    "skyline": {
      "defaultDisplayBlock": true,
      "defaultContentBox": true
    }
  },
  "componentFramework": "glass-easel",
  "lazyCodeLoading": "requiredComponents",
  "permission": {
    "scope.userLocation": {
      "desc": "您的位置信息将用于小程序位置接口的效果展示"
    }
  }
}
