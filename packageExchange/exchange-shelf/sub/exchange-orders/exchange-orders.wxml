<!--兑换订单管理组件（Phase 3：确认收货 + 评价）-->
<!--后端API: GET /api/v4/backpack/exchange/orders-->
<view class="exchange-orders-overlay" wx:if="{{visible}}" catchtap="onClose">
  <view class="exchange-orders-panel" catchtap="">
    <!-- 面板头部 -->
    <view class="eo-header">
      <text class="eo-title">我的订单</text>
      <view class="eo-close" bindtap="onClose">
        <text class="eo-close-icon">✕</text>
      </view>
    </view>

    <!-- 状态筛选Tab -->
    <view class="eo-tabs">
      <view
        wx:for="{{statusTabs}}"
        wx:key="key"
        class="eo-tab {{currentTab === item.key ? 'active' : ''}}"
        data-tab="{{item.key}}"
        bindtap="onTabChange"
      >
        <text class="eo-tab-text">{{item.label}}</text>
      </view>
    </view>

    <!-- 订单列表 -->
    <scroll-view
      class="eo-scroll"
      scroll-y="{{true}}"
      bindscrolltolower="onLoadMore"
      lower-threshold="100"
    >
      <!-- 加载中 -->
      <view class="eo-loading" wx:if="{{loading && orders.length === 0}}">
        <loading-spinner />
        <text class="eo-loading-text">加载订单中...</text>
      </view>

      <!-- 空状态 -->
      <view class="eo-empty" wx:if="{{!loading && orders.length === 0}}">
        <text class="eo-empty-icon">📦</text>
        <text class="eo-empty-text">暂无兑换订单</text>
        <text class="eo-empty-hint">去兑换中心挑选喜欢的商品吧</text>
      </view>

      <!-- 订单卡片列表 -->
      <view class="eo-list" wx:if="{{orders.length > 0}}">
        <view class="eo-card" wx:for="{{orders}}" wx:key="order_no">
          <!-- 订单头部（状态标签 + 订单号） -->
          <view class="eo-card-header">
            <view class="eo-status-badge" style="background: {{item._statusColor}}">
              <text class="eo-status-text">{{item._statusLabel}}</text>
            </view>
            <text class="eo-order-no">{{item.order_no}}</text>
          </view>

          <!-- 商品信息 -->
          <view class="eo-card-body">
            <view class="eo-product-info">
              <text class="eo-product-name">{{item._productName}}</text>
              <text class="eo-product-pay" wx:if="{{item._payInfo}}">消耗: {{item._payInfo}}</text>
            </view>
            <view class="eo-time-info">
              <text class="eo-time" wx:if="{{item._createTime}}">下单: {{item._createTime}}</text>
              <text class="eo-time" wx:if="{{item._shippedTime}}">发货: {{item._shippedTime}}</text>
            </view>
          </view>

          <!-- 自动确认提示 -->
          <view class="eo-auto-tip" wx:if="{{item._isAutoConfirmed}}">
            <text class="eo-auto-text">系统已自动确认收货（发货满7天）</text>
          </view>

          <!-- 已评价展示 -->
          <view class="eo-rating-display" wx:if="{{item.status === 'rated' && item._ratingStars}}">
            <text class="eo-rating-label">我的评价</text>
            <text class="eo-rating-stars">{{item._ratingStars}}</text>
          </view>

          <!-- 操作按钮区域 -->
          <view class="eo-card-actions" wx:if="{{item._canConfirmReceipt || item._canRate}}">
            <!-- 已发货 → 确认收货 -->
            <view
              class="eo-action-btn confirm-btn"
              wx:if="{{item._canConfirmReceipt}}"
              data-order_no="{{item.order_no}}"
              data-product_name="{{item._productName}}"
              bindtap="onConfirmReceipt"
            >
              <text class="eo-action-text">确认收货</text>
            </view>

            <!-- 已收货 → 评价 -->
            <view
              class="eo-action-btn rate-btn"
              wx:if="{{item._canRate}}"
              data-order_no="{{item.order_no}}"
              data-product_name="{{item._productName}}"
              bindtap="onOpenRating"
            >
              <text class="eo-action-text">评价</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多 / 没有更多 -->
      <view class="eo-footer" wx:if="{{orders.length > 0}}">
        <text class="eo-footer-text" wx:if="{{loading}}">加载中...</text>
        <text class="eo-footer-text" wx:elif="{{noMore}}">— 没有更多订单 —</text>
      </view>
    </scroll-view>
  </view>
</view>

<!-- ====== 评价弹窗 ====== -->
<view class="rating-overlay" wx:if="{{showRatingModal}}" catchtap="closeRatingModal">
  <view class="rating-modal" catchtap="">
    <view class="rating-header">
      <text class="rating-title">评价商品</text>
      <view class="rating-close" bindtap="closeRatingModal">
        <text class="rating-close-icon">✕</text>
      </view>
    </view>

    <text class="rating-product">{{ratingProductName}}</text>

    <!-- 星级选择 -->
    <view class="rating-stars-row">
      <view
        wx:for="{{[1,2,3,4,5]}}"
        wx:key="*this"
        class="rating-star {{ratingScore >= item ? 'selected' : ''}}"
        data-score="{{item}}"
        bindtap="onSelectStar"
      >
        <text class="star-icon">{{ratingScore >= item ? '★' : '☆'}}</text>
      </view>
    </view>
    <text class="rating-hint" wx:if="{{ratingScore === 0}}">请点击星星评分</text>
    <text class="rating-hint" wx:elif="{{ratingScore === 1}}">非常差</text>
    <text class="rating-hint" wx:elif="{{ratingScore === 2}}">较差</text>
    <text class="rating-hint" wx:elif="{{ratingScore === 3}}">一般</text>
    <text class="rating-hint" wx:elif="{{ratingScore === 4}}">满意</text>
    <text class="rating-hint" wx:elif="{{ratingScore === 5}}">非常满意</text>

    <!-- 提交按钮 -->
    <view class="rating-actions">
      <view
        class="rating-submit-btn {{ratingScore === 0 || ratingSubmitting ? 'disabled' : ''}}"
        bindtap="onSubmitRating"
      >
        <text class="rating-submit-text">{{ratingSubmitting ? '提交中...' : '提交评价'}}</text>
      </view>
    </view>
  </view>
</view>
