<!-- lucky-space 幸运空间子组件 — 瀑布流商品展示 -->
<view class="lucky-space-content waterfall-market-container">
  <!-- 搜索筛选区域 -->
  <view class="search-filter-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索商品名称..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
    </view>

    <view class="filter-buttons" wx:if="{{basicFilters.length > 0}}">
      <view
        wx:for="{{basicFilters}}"
        wx:key="value"
        class="filter-btn {{currentFilter === item.value ? 'active' : ''}}"
        data-filter="{{item.value}}"
        bindtap="onFilterChange"
        >{{item.label}}</view
      >
      <view
        class="filter-btn advanced-filter-btn {{showAdvancedFilter ? 'active' : ''}}"
        bindtap="onToggleAdvancedFilter"
        >高级筛选 {{showAdvancedFilter ? '▲' : '▼'}}</view
      >
    </view>

    <!-- 高级筛选面板 -->
    <view class="advanced-filter-panel" wx:if="{{showAdvancedFilter}}">
      <view class="filter-row" wx:if="{{categoryOptions.length > 0}}">
        <text class="filter-label">商品分类</text>
        <view class="filter-options">
          <view
            wx:for="{{categoryOptions}}"
            wx:key="value"
            class="option-btn {{categoryFilter === item.value ? 'active' : ''}} {{filtersCount && filtersCount.categories && item.value !== 'all' && filtersCount.categories[item.value] === 0 ? 'filter-disabled' : ''}}"
            data-category="{{item.value}}"
            bindtap="onCategoryFilterChange"
            >{{item.label}}<text wx:if="{{filtersCount && filtersCount.categories && filtersCount.categories[item.value] !== undefined}}" class="filter-count"> ({{filtersCount.categories[item.value]}})</text></view
          >
        </view>
      </view>
      <view class="filter-row" wx:if="{{costRangeOptions.length > 0}}">
        <text class="filter-label">价格区间</text>
        <view class="filter-options">
          <view
            wx:for="{{costRangeOptions}}"
            wx:key="label"
            class="option-btn {{costRangeIndex === index ? 'active' : ''}} {{filtersCount && filtersCount.cost_ranges && index > 0 && filtersCount.cost_ranges[index] === 0 ? 'filter-disabled' : ''}}"
            data-index="{{index}}"
            bindtap="onCostRangeChange"
            >{{item.label}}<text wx:if="{{filtersCount && filtersCount.cost_ranges && filtersCount.cost_ranges[index] !== undefined}}" class="filter-count"> ({{filtersCount.cost_ranges[index]}})</text></view
          >
        </view>
      </view>
      <view class="filter-row" wx:if="{{stockStatusOptions.length > 0}}">
        <text class="filter-label">库存状态</text>
        <view class="filter-options">
          <view
            wx:for="{{stockStatusOptions}}"
            wx:key="value"
            class="option-btn {{stockStatus === item.value ? 'active' : ''}} {{filtersCount && filtersCount.stock_statuses && item.value !== 'all' && filtersCount.stock_statuses[item.value] === 0 ? 'filter-disabled' : ''}}"
            data-status="{{item.value}}"
            bindtap="onStockStatusChange"
            >{{item.label}}<text wx:if="{{filtersCount && filtersCount.stock_statuses && filtersCount.stock_statuses[item.value] !== undefined}}" class="filter-count"> ({{filtersCount.stock_statuses[item.value]}})</text></view
          >
        </view>
      </view>
      <view class="filter-row" wx:if="{{sortByOptions.length > 0}}">
        <text class="filter-label">排序方式</text>
        <view class="filter-options">
          <view
            wx:for="{{sortByOptions}}"
            wx:key="value"
            class="option-btn {{sortBy === item.value ? 'active' : ''}}"
            data-sort="{{item.value}}"
            bindtap="onSortByChange"
            >{{item.label}}</view
          >
        </view>
      </view>
      <view class="filter-actions">
        <view class="reset-btn" bindtap="onResetFilters">重置筛选</view>
      </view>
    </view>
  </view>

  <!-- 骨架屏加载态 -->
  <view class="skeleton-grid" wx:if="{{loading}}">
    <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="skeleton-image"></view>
      <view class="skeleton-body">
        <view class="skeleton-line medium"></view>
        <view class="skeleton-line short"></view>
        <view class="skeleton-line short"></view>
      </view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="unified-cards-grid {{viewMode === 'list' ? 'grid-list-mode' : ''}}" wx:if="{{!loading}}">
    <view
      wx:for="{{filteredProducts}}"
      wx:key="exchange_item_id"
      class="unified-card {{effects.grain ? 'grain-overlay' : ''}} {{effects.holo && item._isLegendary ? 'holo-effect' : ''}} {{effects.rotatingBorder && item._isLimited ? 'rotating-border' : ''}} {{effects.fullbleed && item._hasImage ? 'fullbleed-mode' : ''}} {{viewMode === 'list' ? 'list-mode' : ''}} animate-in"
      data-product="{{item}}"
      data-card-index="{{index}}"
      data-tab="lucky"
      bindtap="onProductTap"
      bindtouchstart="onCardTouchStart"
    >
      <!-- 涟漪效果层 -->
      <view
        wx:if="{{effects.ripple && item._rippleActive}}"
        class="ripple-layer ripple-active"
        style="left:{{item._rippleX}}px;top:{{item._rippleY}}px"
      ></view>

      <!-- 类型色条 -->
      <view
        class="type-bar {{item.cost_asset_code === 'POINTS' ? 'asset' : (item.is_lucky ? 'lucky' : 'item')}}"
      ></view>

      <!-- 图片区域 -->
      <view class="card-image-area">
        <image
          wx:if="{{item._hasImage}}"
          src="{{item.image}}"
          mode="aspectFill"
          lazy-load="{{true}}"
          data-index="{{index}}"
          binderror="onImageError"
        />
        <view
          wx:else
          class="image-fallback {{item.cost_asset_code === 'POINTS' ? 'asset-type' : 'item-type'}}"
        >
          <text class="fallback-icon">{{item.cost_asset_code === 'POINTS' ? '🪙' : '🎁'}}</text>
          <text class="fallback-name">{{item.item_name}}</text>
        </view>
        <!-- 标签 -->
        <view wx:if="{{item.is_hot}}" class="badge-tag hot">热销</view>
        <view wx:elif="{{item.is_new}}" class="badge-tag new">新品</view>
        <view wx:elif="{{item.is_limited}}" class="badge-tag limited">限量</view>
      </view>

      <!-- 内容区 -->
      <view class="card-body">
        <text class="product-name">{{item.item_name}}</text>
        <text class="product-desc" wx:if="{{item.sell_point}}">{{item.sell_point}}</text>

        <!-- 价格行 -->
        <view class="price-row">
          <text class="price-unit">{{item._priceLabel || '积分'}}</text>
          <text class="price-current">{{item.cost_amount}}</text>
          <text class="price-original" wx:if="{{item.original_price}}"
            >{{item.original_price}}</text
          >
        </view>

        <!-- 库存进度条 -->
        <view class="stock-bar" wx:if="{{item.stock !== undefined}}">
          <view
            class="stock-fill {{item.stock > 50 ? 'fill-high' : (item.stock > 10 ? 'fill-medium' : 'fill-low')}}"
            style="width:{{item.stock > 0 ? (item.stock > 100 ? 100 : item.stock) : 0}}%"
          ></view>
        </view>
        <text
          class="stock-text {{item.stock > 50 ? 'stock-high' : (item.stock > 10 ? 'stock-medium' : (item.stock > 0 ? 'stock-low' : 'stock-out'))}}"
        >
          {{item.stock > 0 ? ('库存 ' + item.stock) : '已售罄'}}
        </text>

        <!-- CTA 按钮 -->
        <view class="cta-btn {{item.stock <= 0 ? 'btn-disabled' : ''}}">
          {{item.stock > 0 ? '立即兑换' : '已售罄'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态（非加载中且无数据时显示） -->
  <empty-state wx:if="{{!loading && filteredProducts.length === 0}}" />

  <!-- 分页 -->
  <pagination
    wx:if="{{totalPages > 1}}"
    current="{{currentPage}}"
    total="{{totalPages}}"
    bind:change="onPaginationChange"
  />
</view>
