<!-- exchange-market 交易市场组件 -->
<view class="exchange-content">
  <!-- 🔒 固定头部区域 -->
  <view class="header exchange-market-sticky-header">
    <!-- 资产余额独占一行：横向可滚动，动态适配任意数量资产 -->
    <view class="asset-balances-area">
      <scroll-view
        type="custom"
        class="asset-balances-scroll"
        scroll-x="{{true}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
      >
        <view class="asset-balances-row">
          <view class="asset-balance-item" wx:for="{{assetBalances}}" wx:key="asset_code">
            <text class="asset-name">{{item.display_name}}</text>
            <text class="asset-amount">{{item.available_amount}}</text>
          </view>
          <view
            wx:if="{{!assetBalances || assetBalances.length === 0}}"
            class="asset-balance-empty"
          >
            <text class="asset-name">暂无资产数据</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 操作按钮独占一行 -->
    <view class="header-quick-actions">
      <t-button
        theme="default"
        variant="outline"
        size="small"
        shape="round"
        bind:tap="onRefreshProducts"
        >刷新</t-button
      >
      <t-button
        theme="default"
        variant="outline"
        size="small"
        shape="round"
        bind:tap="onSortByPoints"
        >按售价排序</t-button
      >
      <view class="view-toggle">
        <view
          class="toggle-btn {{viewMode === 'grid' ? 'active' : ''}}"
          bindtap="onToggleViewMode"
          data-mode="grid"
          >⊞
        </view>
        <view
          class="toggle-btn {{viewMode === 'list' ? 'active' : ''}}"
          bindtap="onToggleViewMode"
          data-mode="list"
          >☰
        </view>
      </view>
    </view>

    <!-- 搜索框独占一行（后端未提供 keyword 查询能力前禁用，避免误导用户） -->
    <view class="header-search-box">
      <text class="header-search-icon">🔍</text>
      <input
        class="header-search-input"
        placeholder="交易市场搜索待后端提供接口"
        value="{{searchKeyword}}"
        disabled="{{true}}"
      />
    </view>

    <!-- 筛选功能 -->
    <view class="search-filter">
      <view class="filter-buttons">
        <button
          wx:for="{{marketTypeFilters}}"
          wx:key="value"
          class="filter-btn {{currentFilter === item.value ? 'active' : ''}} {{filtersCount && filtersCount.listing_kinds && item.value !== 'all' && filtersCount.listing_kinds[item.value] === 0 ? 'filter-disabled' : ''}}"
          bindtap="onFilterChange"
          data-filter="{{item.value}}"
        >
          {{item.label}}<text
            wx:if="{{filtersCount && filtersCount.listing_kinds && filtersCount.listing_kinds[item.value] !== undefined}}"
            class="filter-count"
          >
            ({{filtersCount.listing_kinds[item.value]}})</text
          >
        </button>
        <button
          class="advanced-filter-btn {{showAdvancedFilter ? 'active' : ''}}"
          bindtap="onToggleAdvancedFilter"
        >
          高级筛选 {{showAdvancedFilter ? '▲' : '▼'}}
        </button>
      </view>

      <view class="advanced-filter-panel" wx:if="{{showAdvancedFilter}}">
        <view
          class="filter-row"
          wx:if="{{facetsData && facetsData.categories && facetsData.categories.length > 0}}"
        >
          <text class="filter-label">物品分类</text>
          <view class="filter-options">
            <view
              class="option-btn {{filterCategoryCode === '' ? 'active' : ''}}"
              data-code=""
              bindtap="onItemCategorySelect"
              >全部</view
            >
            <view
              wx:for="{{facetsData.categories}}"
              wx:key="code"
              class="option-btn {{filterCategoryCode === item.code ? 'active' : ''}} {{filtersCount && filtersCount.categories && filtersCount.categories[item.code] === 0 ? 'filter-disabled' : ''}}"
              data-code="{{item.code}}"
              bindtap="onItemCategorySelect"
              >{{item.display_name || item.code}}<text
                wx:if="{{filtersCount && filtersCount.categories && filtersCount.categories[item.code] !== undefined}}"
                class="filter-count"
              >
                ({{filtersCount.categories[item.code]}})</text
              ></view
            >
          </view>
        </view>
        <view
          class="filter-row"
          wx:if="{{facetsData && facetsData.rarities && facetsData.rarities.length > 0}}"
        >
          <text class="filter-label">稀有度</text>
          <view class="filter-options">
            <view
              class="option-btn {{filterRarityCode === '' ? 'active' : ''}}"
              data-code=""
              bindtap="onRaritySelect"
              >全部</view
            >
            <view
              wx:for="{{facetsData.rarities}}"
              wx:key="code"
              class="option-btn {{filterRarityCode === item.code ? 'active' : ''}} {{filtersCount && filtersCount.rarities && filtersCount.rarities[item.code] === 0 ? 'filter-disabled' : ''}}"
              data-code="{{item.code}}"
              bindtap="onRaritySelect"
              >{{item.display_name || item.code}}<text
                wx:if="{{filtersCount && filtersCount.rarities && filtersCount.rarities[item.code] !== undefined}}"
                class="filter-count"
              >
                ({{filtersCount.rarities[item.code]}})</text
              ></view
            >
          </view>
        </view>
        <!-- 品质等级筛选（后端 instance_attributes.quality_grade，仅物品类型有效） -->
        <view class="filter-row">
          <text class="filter-label">品质等级</text>
          <view class="filter-options">
            <view
              class="option-btn {{filterQualityGrade === '' ? 'active' : ''}}"
              data-grade=""
              bindtap="onQualityGradeSelect"
              >全部</view
            >
            <view
              class="option-btn {{filterQualityGrade === '完美无瑕' ? 'active' : ''}}"
              data-grade="完美无瑕"
              bindtap="onQualityGradeSelect"
              >完美无瑕</view
            >
            <view
              class="option-btn {{filterQualityGrade === '精良' ? 'active' : ''}}"
              data-grade="精良"
              bindtap="onQualityGradeSelect"
              >精良</view
            >
            <view
              class="option-btn {{filterQualityGrade === '良好' ? 'active' : ''}}"
              data-grade="良好"
              bindtap="onQualityGradeSelect"
              >良好</view
            >
            <view
              class="option-btn {{filterQualityGrade === '普通' ? 'active' : ''}}"
              data-grade="普通"
              bindtap="onQualityGradeSelect"
              >普通</view
            >
            <view
              class="option-btn {{filterQualityGrade === '微瑕' ? 'active' : ''}}"
              data-grade="微瑕"
              bindtap="onQualityGradeSelect"
              >微瑕</view
            >
          </view>
        </view>
        <view
          class="filter-row"
          wx:if="{{facetsData && facetsData.asset_groups && facetsData.asset_groups.length > 0}}"
        >
          <text class="filter-label">资产分组</text>
          <view class="filter-options">
            <view
              class="option-btn {{filterAssetGroupCode === '' ? 'active' : ''}}"
              data-code=""
              bindtap="onAssetGroupSelect"
              >全部</view
            >
            <view
              wx:for="{{facetsData.asset_groups}}"
              wx:key="code"
              class="option-btn {{filterAssetGroupCode === item.code ? 'active' : ''}} {{filtersCount && filtersCount.asset_groups && filtersCount.asset_groups[item.code] === 0 ? 'filter-disabled' : ''}}"
              data-code="{{item.code}}"
              bindtap="onAssetGroupSelect"
              >{{item.display_name || item.code}}<text
                wx:if="{{filtersCount && filtersCount.asset_groups && filtersCount.asset_groups[item.code] !== undefined}}"
                class="filter-count"
              >
                ({{filtersCount.asset_groups[item.code]}})</text
              ></view
            >
          </view>
        </view>
        <view class="filter-row">
          <text class="filter-label">价格区间</text>
          <view class="price-range-inputs">
            <input
              class="price-input"
              type="number"
              placeholder="最低价"
              value="{{filterMinPrice}}"
              bindinput="onMinPriceInput"
            />
            <text class="price-separator">—</text>
            <input
              class="price-input"
              type="number"
              placeholder="最高价"
              value="{{filterMaxPrice}}"
              bindinput="onMaxPriceInput"
            />
            <view class="price-confirm-btn" bindtap="onPriceRangeConfirm">确定</view>
          </view>
        </view>
        <view class="filter-row" wx:if="{{marketSortOptions.length > 0}}">
          <text class="filter-label">排序方式</text>
          <view class="filter-options">
            <view
              wx:for="{{marketSortOptions}}"
              wx:key="value"
              class="option-btn {{sortBy === item.value ? 'active' : ''}}"
              data-sort="{{item.value}}"
              bindtap="onSortByChange"
              >{{item.label}}</view
            >
          </view>
        </view>
        <view class="filter-actions">
          <t-button
            theme="danger"
            variant="outline"
            size="small"
            shape="round"
            bind:tap="onResetFilters"
            >重置筛选</t-button
          >
        </view>
      </view>
    </view>
  </view>

  <!--市场行情概览（可折叠，默认收起）-->
  <view class="market-chart-section" wx:if="{{showPriceChart}}">
    <price-chart asset-code="{{chartAssetCode}}" title="市场行情" canvas-height="{{160}}" />
  </view>
  <view class="market-chart-toggle" bindtap="onTogglePriceChart">
    <view class="chart-toggle-inner">
      <text class="chart-toggle-text">{{showPriceChart ? '收起行情' : '📈 查看市场行情'}}</text>
      <text class="chart-toggle-arrow">{{showPriceChart ? '︿' : '﹀'}}</text>
    </view>
  </view>

  <!--可滚动商品列表-->
  <scroll-view
    type="list"
    class="market-scroll-content"
    scroll-y="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    lower-threshold="120"
    bindscrolltolower="onScrollToLower"
  >
    <!-- 骨架屏加载态 -->
    <view class="skeleton-grid" wx:if="{{loading}}">
      <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-image"></view>
        <view class="skeleton-body">
          <view class="skeleton-line medium"></view>
          <view class="skeleton-line short"></view>
          <view class="skeleton-line short"></view>
        </view>
      </view>
    </view>

    <view
      wx:if="{{!loading}}"
      class="unified-cards-grid {{viewMode === 'list' ? 'grid-list-mode' : ''}}"
    >
      <block wx:for="{{filteredProducts}}" wx:key="market_listing_id">
        <!-- Feed 广告卡片（穿插在商品列表中） -->
        <view
          wx:if="{{item._isAdItem}}"
          class="unified-card feed-ad-card animate-in {{viewMode === 'list' ? 'list-mode' : ''}}"
          data-ad="{{item._adData}}"
          bindtap="onExchangeFeedAdTap"
        >
          <view class="type-bar ad-type"></view>
          <view class="card-image-area">
            <image
              class="card-image-area-image"
              wx:if="{{item.image}}"
              src="{{item.image}}"
              mode="aspectFill"
              lazy-load="{{true}}"
            />
            <view wx:else class="image-fallback ad-fallback">
              <text class="fallback-icon">📢</text>
              <text class="fallback-name">{{item.item_name}}</text>
            </view>
            <view class="type-capsule ad-capsule">广告</view>
          </view>
          <view class="card-body">
            <text class="product-name">{{item.item_name}}</text>
            <view class="ad-action-row" wx:if="{{item._adData.link_url}}">
              <text class="ad-action-text">查看详情 ›</text>
            </view>
          </view>
        </view>

        <!-- 普通商品卡片 -->
        <view
          wx:else
          class="unified-card {{effects.grain ? 'grain-overlay' : ''}} {{effects.holo && item._isLegendary ? 'holo-effect' : ''}} {{effects.rotatingBorder && item._isLimited ? 'rotating-border' : ''}} {{effects.fullbleed && item._hasImage ? 'fullbleed-mode' : ''}} {{viewMode === 'list' ? 'list-mode' : ''}} animate-in"
          data-product="{{item}}"
          data-card-index="{{index}}"
          bindtap="onProductTap"
          bindtouchstart="onCardTouchStart"
        >
          <view
            wx:if="{{effects.ripple && item._rippleActive}}"
            class="ripple-layer ripple-active"
            style="left:{{item._rippleX}}px;top:{{item._rippleY}}px"
          ></view>
          <view
            class="type-bar {{item.listing_kind === 'fungible_asset' ? 'asset' : 'item'}}"
          ></view>

          <view class="card-image-area">
            <image
              class="card-image-area-image"
              wx:if="{{item.imageStatus !== 'error'}}"
              src="{{item.image}}"
              mode="aspectFill"
              lazy-load="{{true}}"
              data-index="{{index}}"
              binderror="onImageError"
              bindload="onImageLoad"
            />
            <view
              wx:else
              class="image-fallback {{item.listing_kind === 'fungible_asset' ? 'asset-type' : 'item-type'}}"
            >
              <text class="fallback-icon"
                >{{item.listing_kind === 'fungible_asset' ? '🪙' : '🎁'}}</text
              >
              <text class="fallback-name">{{item.item_name}}</text>
            </view>
            <!-- 角标（优先级: 置顶 > 推荐 > 稀有度） -->
            <view wx:if="{{item.is_pinned}}" class="badge-tag pinned">置顶</view>
            <view wx:elif="{{item.is_recommended}}" class="badge-tag recommended">推荐</view>
            <view wx:elif="{{item._rarityClass}}" class="badge-tag {{item._rarityClass}}"
              >{{item.offer_item_rarity}}</view
            >
            <view
              class="type-capsule {{item.listing_kind === 'fungible_asset' ? 'asset-capsule' : 'item-capsule'}}"
            >
              {{item.listing_kind === 'fungible_asset' ? '资产' : '物品'}}</view
            >
          </view>

          <view class="card-body">
            <text class="product-name">{{item.item_name}}</text>
            <text class="product-desc">{{item.description}}</text>
            <!-- 品质等级标签（后端 instance_attributes.quality_grade） -->
            <view class="quality-row" wx:if="{{item._qualityGrade}}">
              <view class="quality-badge" style="background-color:{{item._qualityColorHex}}">
                <text class="quality-text">{{item._qualityGrade}}</text>
              </view>
              <text class="quality-score" wx:if="{{item._qualityScore}}"
                >{{item._qualityScore}}分</text
              >
              <text class="pattern-id" wx:if="{{item._patternId}}">纹理#{{item._patternId}}</text>
            </view>
            <!-- 限量编号（后端 serial_number + edition_total） -->
            <text class="edition-text" wx:if="{{item._editionText}}">{{item._editionText}}</text>
            <view class="price-row">
              <text class="price-unit">{{item._priceLabel || '积分'}}</text>
              <text class="price-current">{{item.price_amount}}</text>
            </view>
            <view class="seller-info" wx:if="{{item.seller_nickname}}">
              <text class="seller-label">卖家：{{item.seller_nickname}}</text>
            </view>
            <view class="cta-btn">立即购买</view>
          </view>
        </view>
      </block>
    </view>

    <t-empty wx:if="{{!loading && filteredProducts.length === 0}}" description="暂无可购买的商品">
      <view slot="image">🛍️</view>
      <t-button
        slot="action"
        theme="primary"
        shape="round"
        size="small"
        bind:tap="onRefreshProducts"
        >刷新列表</t-button
      >
    </t-empty>

    <view class="loading-more" wx:if="{{loadingMore}}">
      <t-loading loading="{{true}}" text="加载更多商品..." theme="spinner" size="40rpx" />
    </view>
  </scroll-view>

  <!-- 我的交易管理 — 底部快捷操作栏 -->
  <view class="trade-manage-bar">
    <view class="manage-bar-inner">
      <view class="manage-bar-left" bindtap="onGoToMyListings">
        <text class="manage-bar-icon">📋</text>
        <text class="manage-bar-text">我的挂单</text>
        <view class="manage-bar-badge" wx:if="{{myOnSaleCount > 0}}">
          <text class="manage-bar-badge-text">{{myOnSaleCount > 99 ? '99+' : myOnSaleCount}}</text>
        </view>
      </view>
      <view class="manage-bar-divider"></view>
      <view class="manage-bar-right" bindtap="onGoToInventory">
        <text class="manage-bar-icon">📦</text>
        <text class="manage-bar-text">去上架</text>
      </view>
    </view>
  </view>

  <!-- 购买确认弹窗 -->
  <exchange-confirm
    visible="{{showConfirm}}"
    product="{{selectedProduct}}"
    quantity="{{1}}"
    currentBalance="{{selectedProductBalance}}"
    currentBalanceLabel="{{selectedProductBalanceLabel}}"
    submitting="{{purchasing}}"
    bind:confirm="onConfirmPurchase"
    bind:close="onCancelPurchase"
  />

  <!-- 购买结果弹窗 -->
  <exchange-result
    visible="{{showResult}}"
    success="{{true}}"
    orderData="{{resultData}}"
    bind:close="onCloseResult"
  >
    <view
      slot="extra"
      class="escrow-tip"
      wx:if="{{resultData && resultData.product && resultData.product.listing_kind === 'item'}}"
    >
      <text class="escrow-tip-icon">🔑</text>
      <text class="escrow-tip-text"
        >本次为实物交易，请联系卖方获取6位担保码后点击"确认收货"完成交易</text
      >
      <view
        class="escrow-confirm-btn"
        bindtap="onOpenEscrowInput"
        data-trade_order_id="{{resultData.tradeOrderId}}"
      >
        <text class="escrow-confirm-text">输入担保码</text>
      </view>
    </view>
  </exchange-result>

  <!-- 担保码输入弹窗（Phase 4：买方确认收货） -->
  <escrow-code-dialog
    visible="{{showEscrowInput}}"
    value="{{escrowInputCode}}"
    submitting="{{escrowSubmitting}}"
    bind:close="onCloseEscrowInput"
    bind:inputchange="onEscrowCodeInput"
    bind:submit="onSubmitEscrowCode"
  />
</view>
