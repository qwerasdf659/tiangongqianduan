<!--
  е…‘жҚўе•Ҷе“ҒиҜҰжғ…йЎ?вҖ?B+Cж··еҗҲж–№жЎҲпјҲзҷҪеә•еҜҶжҺ?+ жёёжҲҸеҢ–и§Ҷи§үпјү
  еҗҺз«ҜAPI: GET /api/v4/exchange/items/:exchange_item_id
  е“Қеә”еұӮзә§: res.data.itemпјҲAPIClient з»ҹдёҖи§ЈеҢ…еҗҺпјү

  еҚҒеӨ§еҢәеқ—:
    в‘?еӣҫзүҮеҢ? в‘?ж ҮзӯҫеҢ? в‘?д»·ж јеҢ? в‘?еұһжҖ§еҢә
    в‘?д»Ӣз»ҚеҢ? в‘?еұ•зӨәеӣ? в‘?дҪҝз”ЁиҜҙжҳҺ  в‘?зӣёе…іжҺЁиҚҗ
    в‘?ж Үзӯҫдә? в‘?еҗёеә•ж“ҚдҪңж ?-->
<custom-navbar title="е•Ҷе“ҒиҜҰжғ…" bgColor="#5B7A5E" textColor="#ffffff" showBack="{{true}}" />

<scroll-view type="list" scroll-y class="page-scroll-view">
  <!-- йЎөйқўж ҮйўҳеҢ?-->
  <view class="ed-page-header">
    <text class="ed-page-header-title">е•Ҷе“ҒиҜҰжғ…</text>
    <view class="header-decor-icon">
      <t-icon name="shop" size="128rpx" color="rgba(139, 115, 85, 0.12)" />
    </view>
  </view>
  <!-- еҠ иҪҪзҠ¶жҖ?-->
  <view class="ed-loading" wx:if="{{loading}}">
    <t-loading loading="{{true}}" text="еҠ иҪҪдё?.." theme="spinner" size="48rpx" />
  </view>

  <!-- й”ҷиҜҜзҠ¶жҖ?-->
  <view class="ed-error" wx:elif="{{hasError}}">
    <t-icon name="error-triangle-filled" size="48rpx" class="ed-error-icon" />
    <text class="ed-error-msg">{{errorMessage}}</text>
    <button class="ed-retry-btn" size="mini" bindtap="onGoBack">иҝ”еӣһ</button>
  </view>

  <!-- иҜҰжғ…дё»дҪ“ -->
  <view class="ed-container" wx:elif="{{product}}">
    <!-- в‘?еӣҫзүҮеҢ? еӨҡеӣҫиҪ®ж’ӯ / еҚ•еӣҫеұ•зӨә / emojiеҚ дҪҚ -->
    <view class="ed-hero-section {{product._rarityClass || ''}}">
      <!-- зЁҖжңүеәҰж°ӣеӣҙе…үж•Ҳ: epic=зҙ«иүІи„үеҶІ legendary=йҮ‘иүІи„үеҶІ -->
      <view
        class="ed-rarity-glow {{product._glowType === 'epic' ? 'ed-glow-epic' : 'ed-glow-legendary'}}"
        wx:if="{{product._glowType !== 'none'}}"
      ></view>

      <!-- еӨҡеӣҫиҪ®ж’ӯ -->
      <block wx:if="{{swiperImages.length > 1}}">
        <swiper
          class="ed-swiper"
          indicator-dots="{{false}}"
          autoplay="{{true}}"
          interval="{{4000}}"
          circular="{{true}}"
          bindchange="onSwiperChange"
        >
          <swiper-item wx:for="{{swiperImages}}" wx:key="media_id">
            <image
              class="ed-hero-image"
              src="{{item.url}}"
              mode="aspectFill"
              data-index="{{index}}"
              bindtap="onPreviewImage"
              binderror="onImageError"
            />
          </swiper-item>
        </swiper>
        <!-- иҮӘе®ҡд№үжҢҮзӨәеҷЁ -->
        <view class="ed-swiper-dots">
          <view
            wx:for="{{swiperImages}}"
            wx:key="media_id"
            class="ed-swiper-dot {{swiperCurrent === index ? 'ed-dot-active' : ''}}"
          ></view>
        </view>
      </block>

      <!-- еҚ•еӣҫеұ•зӨә -->
      <block wx:elif="{{swiperImages.length === 1}}">
        <image
          class="ed-hero-image"
          src="{{swiperImages[0].url}}"
          mode="aspectFill"
          data-index="0"
          bindtap="onPreviewImage"
          binderror="onImageError"
        />
      </block>

      <!-- emojiеҚ дҪҚпјҲж— еӣҫзүҮпј?-->
      <view wx:else class="ed-hero-fallback">
        <t-icon name="gift" size="32rpx" class="ed-fallback-emoji" />
        <text class="ed-fallback-name">{{product.item_name}}</text>
      </view>

      <!-- зЁҖжңүеәҰи§’ж ҮпјҲcommonдёҚжҳҫзӨәпјү -->
      <view
        class="ed-rarity-badge"
        wx:if="{{rarityStyle && product.rarity_code !== 'common'}}"
        style="background-color: {{rarityStyle.colorHex}};"
      >
        <text>{{rarityStyle.displayName}}</text>
      </view>
    </view>

    <!-- в‘?ж ҮзӯҫеҢ? gameйЈ?еҪ©иүІеңҶи§’+emoji) / plainйЈ?зҒ°еә•й»‘еӯ—)пјҢж•°жҚ®жәҗ: displayTags з»ҹдёҖж•°з»„ -->
    <view class="ed-tags-row" wx:if="{{displayTags.length > 0}}">
      <block wx:if="{{tagStyleType === 'game'}}">
        <view wx:for="{{displayTags}}" wx:key="text" class="ed-tag ed-tag-{{item.style_type}}">
          <text class="ed-tag-text">{{item.emoji ? item.emoji + ' ' : ''}}{{item.text}}</text>
        </view>
      </block>
      <block wx:else>
        <view wx:for="{{displayTags}}" wx:key="text" class="ed-tag ed-tag-plain">
          <text class="ed-tag-text">{{item.text}}</text>
        </view>
      </block>
    </view>

    <!-- е•Ҷе“ҒдҝЎжҒҜеҚЎзүҮпјҲз©әй—?+ еҗҚз§° + в‘?д»·ж јеҢәпјү -->
    <view class="ed-info-card">
      <view class="ed-space-label">
        <text
          class="ed-space-label-text"
          wx:if="{{rarityStyle && product.rarity_code !== 'common'}}"
          >вҳ?{{rarityStyle.displayName}} В· {{product._spaceLabel}}</text
        >
        <text class="ed-space-label-text" wx:else>{{product._spaceLabel}}</text>
      </view>

      <text class="ed-product-name">{{product.item_name}}</text>

      <!-- в‘?д»·ж јеҢ? еӨ§еҸ·жёҗеҸҳж•°еӯ— + еҲ’зәҝеҺҹд»· + зңҒXXж Үзӯҫ -->
      <view class="ed-price-section">
        <text class="ed-price-amount">{{product.cost_amount}}</text>
        <text class="ed-price-unit">{{product._priceLabel || 'з§ҜеҲҶ'}}</text>
        <view
          class="ed-original-price"
          wx:if="{{product.original_price && product.original_price > product.cost_amount}}"
        >
          <text class="ed-original-value">{{product.original_price}}</text>
          <text class="ed-discount-tag">зңҒ{{product.original_price - product.cost_amount}}</text>
        </view>
      </view>

      <!-- Phase 4: дјҳжғ еҲёиЎҢпјҲеҗҺз«?coupons ж•°з»„жңүеҖјж—¶жёІжҹ“пј?-->
      <view class="ed-coupon-row" wx:if="{{coupons.length > 0}}">
        <view wx:for="{{coupons}}" wx:key="coupon_id" class="ed-coupon-item">
          <t-icon name="discount" size="28rpx" class="ed-coupon-icon" />
          <text class="ed-coupon-text">{{item.text || item.display_name}}</text>
        </view>
      </view>

      <!-- Phase 4: ж»ЎеҮҸ/жҙ»еҠЁдҝЎжҒҜпјҲеҗҺз«?promotions ж•°з»„жңүеҖјж—¶жёІжҹ“пј?-->
      <view class="ed-promotion-row" wx:if="{{promotions.length > 0}}">
        <view wx:for="{{promotions}}" wx:key="promotion_id" class="ed-promotion-item">
          <t-icon name="discount" size="28rpx" class="ed-promotion-icon" />
          <text class="ed-promotion-text">{{item.text || item.display_name}}</text>
        </view>
      </view>

      <!-- Phase 4: йў„и®ЎеҲ°жүӢд»·пјҲestimated_price < cost_amount ж—¶жёІжҹ“пјү -->
      <view
        class="ed-estimated-row"
        wx:if="{{estimatedPrice > 0 && estimatedPrice < product.cost_amount}}"
      >
        <text class="ed-estimated-label">йў„и®ЎеҲ°жүӢд»?/text>
        <view class="ed-estimated-value">
          <text class="ed-estimated-num">{{estimatedPrice}}</text>
          <text class="ed-estimated-unit">{{product._priceLabel || 'з§ҜеҲҶ'}}</text>
        </view>
      </view>
    </view>

    <!-- й“ёйҖ ж ҮиҜҶпјҲеҗҺз«Ҝ mint_instance=true ж—¶еұ•зӨәпјҢиЎЁзӨәе…‘жҚўеҗҺе°Ҷй“ёйҖ зү©е“Ғе®һдҫӢиҝӣе…ҘиғҢеҢ…пјү -->
    <view class="ed-mint-badge" wx:if="{{product._mintInstance}}">
      <t-icon name="edit" size="32rpx" class="ed-mint-icon" />
      <text class="ed-mint-text">е…‘жҚўеҗҺе°Ҷй“ёйҖ дё“еұһзү©е“Ғе®һдҫ?В· еҸҜеңЁдәӨжҳ“еёӮеңәжҢӮзүҢ</text>
    </view>

    <!-- в‘?еұһжҖ§еҢә: gridзҪ‘ж јеҚЎзүҮжЁЎејҸ / listж–Үеӯ—еҲ—иЎЁжЁЎејҸ -->
    <view class="ed-attrs-card">
      <text class="ed-section-title">е•Ҷе“ҒдҝЎжҒҜ</text>

      <!-- grid зҪ‘ж јеҚЎзүҮжЁЎејҸ -->
      <view class="ed-attrs-grid" wx:if="{{attrDisplayMode === 'grid'}}">
        <view class="ed-attr-item">
          <text class="ed-attr-value">{{product.stock}}</text>
          <text class="ed-attr-label">еә“еӯҳ</text>
        </view>
        <view class="ed-attr-item" wx:if="{{showSoldCount}}">
          <text class="ed-attr-value">{{product.sold_count}}</text>
          <text class="ed-attr-label">е·Іе”®</text>
        </view>
        <view class="ed-attr-item" wx:if="{{product._categoryDisplayName}}">
          <text class="ed-attr-value">{{product._categoryDisplayName}}</text>
          <text class="ed-attr-label">еҲҶзұ»</text>
        </view>
        <view class="ed-attr-item" wx:if="{{rarityStyle}}">
          <text class="ed-attr-value" style="color: {{rarityStyle.colorHex}};"
            >{{rarityStyle.displayName}}</text
          >
          <text class="ed-attr-label">е“ҒиҙЁ</text>
        </view>
        <view class="ed-attr-item" wx:if="{{product.has_warranty}}">
          <t-icon name="secured-filled" size="28rpx" class="ed-attr-value" />
          <text class="ed-attr-label">еҗ«дҝқдҝ?/text>
        </view>
        <view class="ed-attr-item" wx:if="{{product.free_shipping}}">
          <t-icon name="shop" size="32rpx" class="ed-attr-value" />
          <text class="ed-attr-label">еҢ…йӮ®</text>
        </view>
      </view>

      <!-- list ж–Үеӯ—еҲ—иЎЁжЁЎејҸ -->
      <view class="ed-attrs-list" wx:else>
        <view class="ed-attr-row">
          <text class="ed-attr-row-label">еә“еӯҳ</text>
          <text class="ed-attr-row-value">{{product.stock}} д»?/text>
        </view>
        <view class="ed-attr-row" wx:if="{{showSoldCount}}">
          <text class="ed-attr-row-label">е·Іе”®</text>
          <text class="ed-attr-row-value">{{product.sold_count}} д»?/text>
        </view>
        <view class="ed-attr-row" wx:if="{{product._categoryDisplayName}}">
          <text class="ed-attr-row-label">еҲҶзұ»</text>
          <text class="ed-attr-row-value">{{product._categoryDisplayName}}</text>
        </view>
        <view class="ed-attr-row" wx:if="{{rarityStyle}}">
          <text class="ed-attr-row-label">е“ҒиҙЁ</text>
          <text class="ed-attr-row-value" style="color: {{rarityStyle.colorHex}};"
            >{{rarityStyle.displayName}}</text
          >
        </view>
        <view class="ed-attr-row" wx:if="{{product.has_warranty}}">
          <text class="ed-attr-row-label">дҝқдҝ®</text>
          <text class="ed-attr-row-value"
            ><t-icon name="secured-filled" size="28rpx" color="#4CAF50" /> еҗ«дҝқдҝ?/text
          >
        </view>
        <view class="ed-attr-row" wx:if="{{product.free_shipping}}">
          <text class="ed-attr-row-label">зү©жөҒ</text>
          <text class="ed-attr-row-value"><t-icon name="shop" size="28rpx" /> еҢ…йӮ®</text>
        </view>
      </view>

      <!-- еә“еӯҳиҝӣеәҰжқЎпјҲstock > 0 дё?sold_count > 0 ж—¶жҳҫзӨәпјү -->
      <view class="ed-stock-bar-wrap" wx:if="{{product.stock > 0 && product.sold_count > 0}}">
        <view class="ed-stock-bar-bg">
          <view class="ed-stock-bar-fill" style="width: {{stockPercent}}%;"></view>
        </view>
        <text class="ed-stock-bar-text">еә“еӯҳеү©дҪҷ {{stockPercent}}%</text>
      </view>
    </view>

    <!-- SKU и§„ж јйҖүжӢ©еҢәпјҲеӨҡи§„ж је•Ҷе“ҒжҳҫзӨәпјҢеҚ•е“Ғе•Ҷе“ҒиҮӘеҠЁйҡҗи—Ҹпј?-->
    <view class="ed-sku-card" wx:if="{{hasMultiSku && skuList.length > 1}}">
      <text class="ed-section-title">и§„ж јйҖүжӢ©</text>
      <view class="ed-sku-options">
        <view
          class="ed-sku-item {{selectedSkuId === item.sku_id ? 'ed-sku-selected' : ''}} {{item.stock <= 0 ? 'ed-sku-disabled' : ''}}"
          wx:for="{{skuList}}"
          wx:key="sku_id"
          data-sku-id="{{item.sku_id}}"
          bindtap="onSelectSku"
        >
          <text class="ed-sku-label">{{item._specLabel || 'й»ҳи®Ө'}}</text>
          <text class="ed-sku-price">{{item.cost_amount}} {{product._priceLabel || 'з§ҜеҲҶ'}}</text>
          <text class="ed-sku-stock" wx:if="{{item.stock <= 5 && item.stock > 0}}"
            >д»…еү©{{item.stock}}д»?/text
          >
          <text class="ed-sku-stock ed-sku-soldout" wx:if="{{item.stock <= 0}}">е·Іе”®зҪ?/text>
        </view>
      </view>
      <view class="ed-sku-selected-info" wx:if="{{selectedSkuInfo}}">
        <text class="ed-sku-selected-text"
          >е·ІйҖ? {{selectedSkuInfo._specLabel || 'й»ҳи®Ө'}} | {{selectedSkuInfo.cost_amount}}
          {{product._priceLabel || 'з§ҜеҲҶ'}}</text
        >
      </view>
    </view>

    <!-- в‘?е•Ҷе“Ғд»Ӣз»ҚеҢ? еҚ–зӮ№й«ҳдә® + зәҜж–Үеӯ?/ й•ҝеӣҫ / ж··жҺ’ -->
    <view
      class="ed-desc-card"
      wx:if="{{product.sell_point || product.description || detailImages.length > 0}}"
    >
      <text class="ed-section-title">е•Ҷе“Ғд»Ӣз»Қ</text>

      <!-- еҚ–зӮ№й«ҳдә®пјҲйҮ‘еә•еҚЎзүҮпјү -->
      <view class="ed-sell-point" wx:if="{{product.sell_point}}">
        <t-icon name="star" size="32rpx" class="ed-sell-point-icon" />
        <text class="ed-sell-point-text">{{product.sell_point}}</text>
      </view>

      <!-- ж–Үеӯ—жҸҸиҝ° -->
      <text class="ed-description" wx:if="{{product.description}}">{{product.description}}</text>

      <!-- иҜҰжғ…й•ҝеӣҫпјҲdetail_imagesпјҢеҗ«еҸҜйҖ?caption иҜҙжҳҺж–Үеӯ—пј?-->
      <view class="ed-detail-images" wx:if="{{detailImages.length > 0}}">
        <view wx:for="{{detailImages}}" wx:key="media_id" class="ed-detail-img-wrap">
          <image
            class="ed-detail-img"
            src="{{item.url}}"
            mode="widthFix"
            data-index="{{index}}"
            bindtap="onPreviewDetailImage"
            lazy-load="{{true}}"
          />
          <text wx:if="{{item.caption}}" class="ed-detail-img-caption">{{item.caption}}</text>
        </view>
      </view>
    </view>

    <!-- в‘?еұ•зӨәеӣҫеҢә: 0еј йҡҗи—?/ 1еј еҚ•еӣ?/ 2-4еј зҪ‘ж ?/ 5+еј жЁӘж»?-->
    <view class="ed-showcase-card" wx:if="{{showcaseImages.length > 0}}">
      <text class="ed-section-title">е•Ҷе“Ғеұ•зӨә</text>

      <!-- еҚ•еӣҫ -->
      <view class="ed-showcase-single" wx:if="{{showcaseImages.length === 1}}">
        <image
          class="ed-showcase-img-single"
          src="{{showcaseImages[0].url}}"
          mode="widthFix"
          data-index="0"
          bindtap="onPreviewShowcaseImage"
          lazy-load="{{true}}"
        />
      </view>

      <!-- 2-4еј? дёӨеҲ—зҪ‘ж ј -->
      <view class="ed-showcase-grid" wx:elif="{{showcaseImages.length <= 4}}">
        <image
          wx:for="{{showcaseImages}}"
          wx:key="media_id"
          class="ed-showcase-img-grid"
          src="{{item.url}}"
          mode="aspectFill"
          data-index="{{index}}"
          bindtap="onPreviewShowcaseImage"
          lazy-load="{{true}}"
        />
      </view>

      <!-- 5+еј? жЁӘеҗ‘еҸҜж»ҡеҠ?-->
      <scroll-view
        type="custom"
        wx:else
        class="ed-showcase-scroll"
        scroll-x="{{true}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
      >
        <view class="ed-showcase-scroll-inner">
          <image
            wx:for="{{showcaseImages}}"
            wx:key="media_id"
            class="ed-showcase-img-scroll"
            src="{{item.url}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onPreviewShowcaseImage"
            lazy-load="{{true}}"
          />
        </view>
      </scroll-view>
    </view>

    <!-- в‘?дҪҝз”ЁиҜҙжҳҺеҢәпјҲд»…еҗҺз«ҜжҸҗдҫ?usage_rules ж—¶еұ•зӨәпјү -->
    <view class="ed-rules-card" wx:if="{{usageRules.length > 0}}">
      <text class="ed-section-title">дҪҝз”ЁиҜҙжҳҺ</text>
      <view class="ed-rules-list">
        <view class="ed-rule-item" wx:for="{{usageRules}}" wx:key="*this">
          <text class="ed-rule-num">{{index + 1}}</text>
          <text class="ed-rule-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- в‘?зӣёе…іжҺЁиҚҗеҢәпјҲеҗҢеҲҶзұ»е•Ҷе“ҒпјҢж— з»“жһңж—¶ж•ҙдёӘеҢәеқ—дёҚжёІжҹ“пјү -->
    <view class="ed-related-card" wx:if="{{relatedProducts.length > 0}}">
      <text class="ed-section-title">зӣёе…іжҺЁиҚҗ</text>
      <view class="ed-related-grid">
        <view
          class="ed-related-item"
          wx:for="{{relatedProducts}}"
          wx:key="exchange_item_id"
          data-item-id="{{item.exchange_item_id}}"
          bindtap="onTapRelatedProduct"
        >
          <image
            wx:if="{{item._hasImage}}"
            class="ed-related-img"
            src="{{item._mainImage}}"
            mode="aspectFill"
          />
          <view wx:else class="ed-related-img-fallback">
            <t-icon name="gift" size="32rpx" class="ed-related-img-fallback-text" />
          </view>
          <view class="ed-related-info">
            <text class="ed-related-name">{{item.item_name}}</text>
            <view class="ed-related-price">
              <text class="ed-related-price-num">{{item.cost_amount}}</text>
              <text class="ed-related-price-unit">{{item._priceLabel}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- в‘?ж Үзӯҫдә‘пјҲеҗҺз«Ҝ tags еӯ—ж®өпјҢж— ж Үзӯҫж—¶дёҚжёІжҹ“пј?-->
    <view class="ed-tags-card" wx:if="{{product.tags && product.tags.length > 0}}">
      <text class="ed-section-title">е•Ҷе“Ғж Үзӯҫ</text>
      <view class="ed-tag-cloud">
        <view class="ed-cloud-tag" wx:for="{{product.tags}}" wx:key="*this">
          <text class="ed-tag-text ed-cloud-tag-text">#{{item}}</text>
        </view>
      </view>
    </view>

    <!-- еә•йғЁеҚ дҪҚпјҲйҳІжӯўиў«еӣәе®ҡж ҸйҒ®жҢЎпјү -->
    <view class="ed-bottom-spacer"></view>
  </view>
</scroll-view>

<!-- в‘?еҗёеә•ж“ҚдҪңж ? дҪҷйўқ + е®ўжңҚ + е…‘жҚўжҢүй’® -->
<view class="ed-bottom-bar" wx:if="{{product && !loading && !hasError}}">
  <view class="ed-balance-info">
    <text class="ed-balance-label">{{product._priceLabel || 'дҪҷйўқ'}}</text>
    <text class="ed-balance-value">{{currentBalance}}</text>
  </view>

  <!-- еҫ®дҝЎе®ўжңҚжҢүй’®пјҲopen-type="contact" жӢүиө·еҫ®дҝЎе®ўжңҚпј?-->
  <button class="ed-service-btn" open-type="contact" plain="{{true}}">
    <t-icon name="chat" size="28rpx" class="ed-service-icon" />
    <text class="ed-service-text">е®ўжңҚ</text>
  </button>

  <!-- Phase 4: иҙӯзү©иҪҰжҢүй’®пјҲй…ҚзҪ®й©ұеҠЁпјҢжҡӮйҡҗи—ҸпјҢеҗҜз”ЁеҗҺж”№дёә wx:if="{{showCartButton}}"пј?-->
  <view class="ed-cart-btn" wx:if="{{false}}">
    <t-icon name="shop" size="28rpx" class="ed-cart-icon" />
    <text class="ed-cart-text">иҙӯзү©иҪ?/text>
  </view>

  <view
    class="ed-exchange-btn {{product.stock <= 0 ? 'ed-btn-soldout' : (balanceInsufficient ? 'ed-btn-disabled' : '')}}"
    bindtap="onExchange"
  >
    <text wx:if="{{product.stock <= 0}}">е·Іе”®зҪ?/text>
    <text wx:elif="{{balanceInsufficient}}">дҪҷйўқдёҚи¶і</text>
    <text wx:else>з«ӢеҚіе…‘жҚў</text>
  </view>
</view>

<!-- е…‘жҚўзЎ®и®Өеј№зӘ— -->
<exchange-confirm
  visible="{{showConfirm}}"
  product="{{product}}"
  quantity="{{exchangeQuantity}}"
  selectedSkuInfo="{{selectedSkuInfo}}"
  currentBalance="{{currentBalance}}"
  currentBalanceLabel="{{product._priceLabel || 'з§ҜеҲҶ'}}"
  submitting="{{exchanging}}"
  bind:confirm="onConfirmExchange"
  bind:close="onCloseConfirm"
  bind:quantitychange="onQuantityChange"
/>
