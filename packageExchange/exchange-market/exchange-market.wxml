<!-- exchange-market 交易市场组件 -->
<!-- CSS变量通过 style="{{marketThemeStyle}}" 注入 -->
<view class="exchange-content" style="{{marketThemeStyle}}">
  <!-- 🔒 固定头部区域 -->
  <view class="header exchange-market-sticky-header">
    <!-- 资产余额独占一行：横向可滚动，动态适配任意数量资产 -->
    <view class="asset-balances-area">
      <scroll-view class="asset-balances-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="asset-balances-row">
          <view class="asset-balance-item" wx:for="{{assetBalances}}" wx:key="asset_code">
            <text class="asset-name">{{item.display_name}}</text>
            <text class="asset-amount">{{item.available_amount}}</text>
          </view>
          <view wx:if="{{!assetBalances || assetBalances.length === 0}}" class="asset-balance-empty">
            <text class="asset-name">暂无资产数据</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 操作按钮独占一行 -->
    <view class="header-quick-actions">
      <view class="header-action-btn" bindtap="onRefreshProducts">🔄 刷新</view>
      <view class="header-action-btn" bindtap="onSortByPoints">📊 按售价排序</view>
      <view class="view-toggle">
        <view class="toggle-btn {{viewMode === 'grid' ? 'active' : ''}}" bindtap="onToggleViewMode" data-mode="grid">⊞
        </view>
        <view class="toggle-btn {{viewMode === 'list' ? 'active' : ''}}" bindtap="onToggleViewMode" data-mode="list">☰
        </view>
      </view>
    </view>

    <!-- 搜索框独占一行 -->
    <view class="header-search-box">
      <text class="header-search-icon">🔍</text>
      <input class="header-search-input" placeholder="搜索商品名称..." value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>

    <!-- 筛选功能 -->
    <view class="search-filter">
      <view class="filter-buttons">
        <button wx:for="{{marketTypeFilters}}" wx:key="value"
          class="filter-btn {{currentFilter === item.value ? 'active' : ''}}" bindtap="onFilterChange"
          data-filter="{{item.value}}">
          {{item.label}}
        </button>
        <button class="advanced-filter-btn {{showAdvancedFilter ? 'active' : ''}}" bindtap="onToggleAdvancedFilter">
          高级筛选 {{showAdvancedFilter ? '▲' : '▼'}}
        </button>
      </view>

      <view class="advanced-filter-panel" wx:if="{{showAdvancedFilter}}">
        <view class="filter-row" wx:if="{{marketCategoryFilters.length > 0}}">
          <text class="filter-label">挂单类型</text>
          <view class="filter-options">
            <view wx:for="{{marketCategoryFilters}}" wx:key="value"
              class="option-btn {{categoryFilter === item.value ? 'active' : ''}}" data-category="{{item.value}}"
              bindtap="onCategoryFilterChange">{{item.label}}</view>
          </view>
        </view>
        <view class="filter-row" wx:if="{{marketSortOptions.length > 0}}">
          <text class="filter-label">排序方式</text>
          <view class="filter-options">
            <view wx:for="{{marketSortOptions}}" wx:key="value"
              class="option-btn {{sortBy === item.value ? 'active' : ''}}" data-sort="{{item.value}}"
              bindtap="onSortByChange">{{item.label}}</view>
          </view>
        </view>
        <view class="filter-actions">
          <view class="reset-btn" bindtap="onResetFilters">重置筛选</view>
        </view>
      </view>
    </view>
  </view>

  <!--市场行情概览（可折叠，默认收起）-->
  <view class="market-chart-section" wx:if="{{showPriceChart}}">
    <price-chart asset-code="{{chartAssetCode}}" title="市场行情" canvas-height="{{160}}" />
  </view>
  <view class="market-chart-toggle" bindtap="onTogglePriceChart">
    <view class="chart-toggle-inner">
      <text class="chart-toggle-text">{{showPriceChart ? '收起行情' : '📈 查看市场行情'}}</text>
      <text class="chart-toggle-arrow">{{showPriceChart ? '︿' : '﹀'}}</text>
    </view>
  </view>

  <!--可滚动商品列表-->
  <scroll-view class="market-scroll-content" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <loading-spinner wx:if="{{loading}}" />

    <view wx:else class="unified-cards-grid {{viewMode === 'list' ? 'grid-list-mode' : ''}}">
      <view wx:for="{{filteredProducts}}" wx:key="listing_id"
        class="unified-card {{effects.grain ? 'grain-overlay' : ''}} {{effects.holo && item._isLegendary ? 'holo-effect' : ''}} {{effects.rotatingBorder && item._isLimited ? 'rotating-border' : ''}} {{effects.fullbleed && item._hasImage ? 'fullbleed-mode' : ''}} {{viewMode === 'list' ? 'list-mode' : ''}} animate-in"
        data-product="{{item}}" data-card-index="{{index}}" bindtap="onProductTap" bindtouchstart="onCardTouchStart">
        <view wx:if="{{effects.ripple && item._rippleActive}}" class="ripple-layer ripple-active"
          style="left:{{item._rippleX}}px;top:{{item._rippleY}}px"></view>
        <view class="type-bar {{item.listing_kind === 'fungible_asset' ? 'asset' : 'item'}}"></view>

        <view class="card-image-area">
          <image wx:if="{{item.imageStatus !== 'error'}}" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"
            data-index="{{index}}" binderror="onImageError" bindload="onImageLoad" />
          <view wx:else class="image-fallback {{item.listing_kind === 'fungible_asset' ? 'asset-type' : 'item-type'}}">
            <text class="fallback-icon">{{item.listing_kind === 'fungible_asset' ? '🪙' : '🎁'}}</text>
            <text class="fallback-name">{{item.item_name}}</text>
          </view>
          <view wx:if="{{item._rarityClass}}" class="badge-tag {{item._rarityClass}}">{{item.offer_item_rarity}}</view>
          <view class="type-capsule {{item.listing_kind === 'fungible_asset' ? 'asset-capsule' : 'item-capsule'}}">
            {{item.listing_kind === 'fungible_asset' ? '资产' : '物品'}}</view>
        </view>

        <view class="card-body">
          <text class="product-name">{{item.item_name}}</text>
          <text class="product-desc">{{item.description}}</text>
          <view class="price-row">
            <text class="price-unit">{{item._priceLabel || '积分'}}</text>
            <text class="price-current">{{item.price_amount}}</text>
          </view>
          <view class="seller-info" wx:if="{{item.seller_nickname}}">
            <text class="seller-label">卖家：{{item.seller_nickname}}</text>
          </view>
          <view class="cta-btn">立即购买</view>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{!loading && filteredProducts.length === 0}}" />

    <pagination wx:if="{{totalPages > 1}}" current="{{currentPage}}" total="{{totalPages}}"
      bind:change="onPaginationChange" />
  </scroll-view>

  <!-- 我的交易管理 — 底部快捷操作栏 -->
  <view class="trade-manage-bar">
    <view class="manage-bar-inner">
      <view class="manage-bar-left" bindtap="onGoToMyListings">
        <text class="manage-bar-icon">📋</text>
        <text class="manage-bar-text">我的挂单</text>
        <view class="manage-bar-badge" wx:if="{{myOnSaleCount > 0}}">
          <text>{{myOnSaleCount > 99 ? '99+' : myOnSaleCount}}</text>
        </view>
      </view>
      <view class="manage-bar-divider"></view>
      <view class="manage-bar-right" bindtap="onGoToInventory">
        <text class="manage-bar-icon">📦</text>
        <text class="manage-bar-text">去上架</text>
      </view>
    </view>
  </view>

  <!-- 购买确认弹窗 -->
  <view class="confirm-overlay" wx:if="{{showConfirm}}" bindtap="onCancelPurchase">
    <view class="confirm-modal" catchtap="">
      <view class="confirm-header">
        <text class="confirm-title">确认购买</text>
        <view class="confirm-close" bindtap="onCancelPurchase">✕</view>
      </view>
      <view class="confirm-body" wx:if="{{selectedProduct}}">
        <view class="confirm-product-info">
          <image class="confirm-product-image" src="{{selectedProduct.image}}" mode="aspectFill"
            binderror="onConfirmImageError" />
          <view class="confirm-product-detail">
            <text class="confirm-product-name">{{selectedProduct.item_name}}</text>
            <text class="confirm-product-price">{{selectedProduct.price_amount}} {{selectedProduct._priceLabel ||
              '积分'}}</text>
          </view>
        </view>
        <view class="confirm-balance-row">
          <text class="confirm-balance-label">当前余额</text>
          <text class="confirm-balance-value">{{selectedProductBalance}} {{selectedProductBalanceLabel}}</text>
        </view>
      </view>
      <view class="confirm-footer">
        <view class="confirm-cancel-btn" bindtap="onCancelPurchase">取消</view>
        <view class="confirm-submit-btn {{purchasing ? 'disabled' : ''}}" bindtap="onConfirmPurchase">{{purchasing ?
          '购买中...' : '确认购买'}}</view>
      </view>
    </view>
  </view>

  <!-- 购买结果弹窗 -->
  <view class="result-overlay" wx:if="{{showResult}}" bindtap="onCloseResult">
    <view class="result-modal" catchtap="">
      <view class="result-icon">✅</view>
      <text class="result-title">购买成功</text>
      <view class="result-detail" wx:if="{{resultData}}">
        <view class="result-row"><text class="result-label">商品</text><text
            class="result-value">{{resultData.product.item_name}}</text></view>
        <view class="result-row"><text class="result-label">支付</text><text class="result-value">{{resultData.payAmount}}
            {{resultData.product._priceLabel || '积分'}}</text></view>
      </view>
      <!--实物交易提示：买方需等待卖方提供担保码后确认收货（Phase 4）-->
      <view class="escrow-tip" wx:if="{{resultData.product.listing_kind === 'item'}}">
        <text class="escrow-tip-icon">🔑</text>
        <text class="escrow-tip-text">本次为实物交易，请联系卖方获取6位担保码后点击"确认收货"完成交易</text>
        <view class="escrow-confirm-btn" bindtap="onOpenEscrowInput" data-trade_order_id="{{resultData.tradeOrderId}}">
          <text class="escrow-confirm-text">输入担保码</text>
        </view>
      </view>
      <view class="result-footer">
        <view class="result-btn" bindtap="onCloseResult">确定</view>
      </view>
    </view>
  </view>

  <!-- 担保码输入弹窗（Phase 4：买方确认收货） -->
  <view class="escrow-input-overlay" wx:if="{{showEscrowInput}}" catchtap="onCloseEscrowInput">
    <view class="escrow-input-modal" catchtap="">
      <view class="escrow-input-header">
        <text class="escrow-input-title">输入担保码</text>
        <view class="escrow-input-close" bindtap="onCloseEscrowInput">
          <text>✕</text>
        </view>
      </view>
      <text class="escrow-input-hint">请输入卖方提供的6位数字担保码，确认后交易完成</text>
      <input class="escrow-input-field" type="number" maxlength="6" placeholder="请输入6位担保码" value="{{escrowInputCode}}"
        bindinput="onEscrowCodeInput" />
      <view class="escrow-input-actions">
        <view class="escrow-cancel-btn" bindtap="onCloseEscrowInput">
          <text>取消</text>
        </view>
        <view class="escrow-submit-btn {{escrowInputCode.length !== 6 || escrowSubmitting ? 'disabled' : ''}}"
          bindtap="onSubmitEscrowCode">
          <text>{{escrowSubmitting ? '确认中...' : '确认收货'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>