<!--
  е…‘жҚўи®ўеҚ•иҜҰжғ…йЎ?  еҗҺз«ҜAPI: GET /api/v4/exchange/orders/:order_no
-->
<custom-navbar title="и®ўеҚ•иҜҰжғ…" bgColor="#5B7A5E" textColor="#ffffff" showBack="{{true}}" />
<view class="detail-page">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- йЎөйқўж ҮйўҳеҢ?-->
    <view class="eod-page-header">
      <text class="eod-page-header-title">и®ўеҚ•иҜҰжғ…</text>
      <view class="header-decor-icon">
        <t-icon name="file-paste" size="128rpx" color="rgba(139, 115, 85, 0.12)" />
      </view>
    </view>
    <!-- еҠ иҪҪдё?-->
    <view class="page-loading" wx:if="{{loading}}">
      <t-loading loading="{{true}}" text="еҠ иҪҪи®ўеҚ•иҜҰжғ…..." theme="spinner" />
    </view>

    <!-- й”ҷиҜҜзҠ¶жҖ?-->
    <view class="error-wrapper" wx:if="{{!loading && hasError}}">
      <t-icon name="error-triangle-filled" size="48rpx" class="error-icon" />
      <text class="error-text">{{errorMessage}}</text>
      <view class="error-retry" bindtap="onRetry">
        <text class="error-retry-text">йҮҚиҜ•</text>
      </view>
      <view class="error-back" bindtap="onGoBack">
        <text class="error-back-text">иҝ”еӣһ</text>
      </view>
    </view>

    <!-- и®ўеҚ•иҜҰжғ…еҶ…е®№ -->
    <view class="detail-content" wx:if="{{!loading && !hasError && order}}">
      <!-- зҠ¶жҖҒеҚЎзү?-->
      <view class="status-card" style="background: {{statusColor}}">
        <view class="status-main">
          <text class="status-icon">{{statusIcon}}</text>
          <text class="status-label">{{statusLabel}}</text>
        </view>
        <text class="status-desc">{{statusDesc}}</text>
        <view class="source-tag-detail" wx:if="{{sourceLabel}}">
          <text class="source-tag-text">{{sourceLabel}}</text>
        </view>
      </view>

      <!-- е•Ҷе“ҒдҝЎжҒҜеҚЎзүҮ -->
      <view class="info-card">
        <view class="card-title-row">
          <text class="card-title">е•Ҷе“ҒдҝЎжҒҜ</text>
        </view>
        <view class="product-section">
          <image class="product-image" src="{{productImage}}" mode="aspectFill" />
          <view class="product-detail">
            <text class="product-name">{{productName}}</text>
            <text class="product-desc" wx:if="{{productDescription}}">{{productDescription}}</text>
            <text class="product-pay" wx:if="{{payInfo}}">ж¶ҲиҖ? {{payInfo}}</text>
          </view>
        </view>
      </view>

      <!-- и®ўеҚ•дҝЎжҒҜеҚЎзүҮ -->
      <view class="info-card">
        <view class="card-title-row">
          <text class="card-title">и®ўеҚ•дҝЎжҒҜ</text>
        </view>
        <view class="info-row">
          <text class="info-label">и®ўеҚ•еҸ?/text>
          <view class="info-value-row" bindtap="onCopyOrderNo">
            <text class="info-value">{{orderNo}}</text>
            <text class="copy-btn">еӨҚеҲ¶</text>
          </view>
        </view>
        <view class="info-row" wx:if="{{order.quantity}}">
          <text class="info-label">е…‘жҚўж•°йҮҸ</text>
          <text class="info-value">{{order.quantity}}</text>
        </view>
        <view class="info-row" wx:if="{{sourceLabel}}">
          <text class="info-label">и®ўеҚ•жқҘжәҗ</text>
          <text class="info-value">{{sourceLabel}}</text>
        </view>
      </view>

      <!-- ж—¶й—ҙзәҝеҚЎзү?-->
      <view class="info-card" wx:if="{{timeline.length > 0}}">
        <view class="card-title-row">
          <text class="card-title">и®ўеҚ•иҝӣеәҰ</text>
        </view>
        <view class="timeline-list">
          <view class="timeline-node" wx:for="{{timeline}}" wx:key="label">
            <view class="timeline-dot-wrap">
              <view
                class="timeline-dot {{item.dotClass}} {{index === timeline.length - 1 ? 'dot-active' : ''}}"
              ></view>
              <view class="timeline-line" wx:if="{{index < timeline.length - 1}}"></view>
            </view>
            <view class="timeline-body">
              <text class="timeline-label">{{item.label}}</text>
              <text class="timeline-time">{{item.time}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- зү©жөҒдҝЎжҒҜеҚЎзүҮпјҲжңүеҝ«йҖ’еҚ•еҸ·ж—¶еұ•зӨәпј?-->
      <view class="info-card" wx:if="{{hasShipping}}">
        <view class="card-title-row">
          <text class="card-title">зү©жөҒдҝЎжҒҜ</text>
          <view class="shipping-query-btn" bindtap="onQueryShippingTrack">
            <text class="shipping-query-text">{{shippingLoading ? 'жҹҘиҜўдё?..' : 'жҹҘиҜўзү©жөҒ'}}</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-label">еҝ«йҖ’е…¬еҸ?/text>
          <text class="info-value">{{shippingCompanyName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">еҝ«йҖ’еҚ•еҸ?/text>
          <view class="info-value-row" bindtap="onCopyShippingNo">
            <text class="info-value">{{shippingNo}}</text>
            <text class="copy-btn">еӨҚеҲ¶</text>
          </view>
        </view>
        <!-- зү©жөҒиҪЁиҝ№ж—¶й—ҙзә?-->
        <view class="shipping-track-list" wx:if="{{shippingTracks.length > 0}}">
          <view class="shipping-track-item" wx:for="{{shippingTracks}}" wx:key="time">
            <view class="track-dot-wrap">
              <view class="track-dot {{index === 0 ? 'track-dot-active' : ''}}"></view>
              <view class="track-line" wx:if="{{index < shippingTracks.length - 1}}"></view>
            </view>
            <view class="track-body">
              <text class="track-detail">{{item.detail}}</text>
              <text class="track-time">{{item.time}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- иҮӘеҠЁзЎ®и®ӨжҸҗзӨә -->
      <view class="info-card auto-confirm-card" wx:if="{{isAutoConfirmed}}">
        <text class="auto-confirm-text">зі»з»ҹе·ІиҮӘеҠЁзЎ®и®Өж”¶иҙ§пјҲеҸ‘иҙ§ж»?еӨ©жңӘж“ҚдҪңпј?/text>
      </view>

      <!-- е·ІиҜ„д»·еұ•зӨ?-->
      <view class="info-card" wx:if="{{order.status === 'rated' && ratingStars}}">
        <view class="card-title-row">
          <text class="card-title">жҲ‘зҡ„иҜ„д»·</text>
        </view>
        <view class="rating-show">
          <text class="rating-show-stars">{{ratingStars}}</text>
        </view>
      </view>

      <!-- еә•йғЁж“ҚдҪңеҢ?-->
      <view class="action-bar" wx:if="{{canCancel || canConfirmReceipt || canRate}}">
        <view
          class="action-btn-detail btn-cancel-detail"
          wx:if="{{canCancel}}"
          bindtap="onCancelOrder"
        >
          <text class="action-btn-text cancel-text">еҸ–ж¶Ҳи®ўеҚ•</text>
        </view>
        <view
          class="action-btn-detail btn-confirm-detail"
          wx:if="{{canConfirmReceipt}}"
          bindtap="onConfirmReceipt"
        >
          <text class="action-btn-text">зЎ®и®Өж”¶иҙ§</text>
        </view>
        <view class="action-btn-detail btn-rate-detail" wx:if="{{canRate}}" bindtap="onOpenRating">
          <text class="action-btn-text">еҺ»иҜ„д»?/text>
        </view>
      </view>

      <!-- еә•йғЁе®үе…ЁеҢәеҚ дҪ?-->
      <view class="safe-bottom" wx:if="{{canCancel || canConfirmReceipt || canRate}}"></view>
    </view>
  </scroll-view>
</view>

<!-- иҜ„д»·еј№зӘ— -->
<view class="rating-overlay" wx:if="{{showRatingModal}}" catchtap="onCloseRatingModal">
  <view class="rating-modal" catchtap="">
    <view class="rating-modal-header">
      <text class="rating-modal-title">иҜ„д»·е•Ҷе“Ғ</text>
      <view class="rating-modal-close" bindtap="onCloseRatingModal">
        <text>вң?/text>
      </view>
    </view>

    <text class="rating-product-name">{{productName}}</text>

    <view class="rating-stars-row">
      <view
        wx:for="{{[1,2,3,4,5]}}"
        wx:key="*this"
        class="rating-star {{ratingScore >= item ? 'selected' : ''}}"
        data-score="{{item}}"
        bindtap="onSelectStar"
      >
        <text class="star-icon">{{ratingScore >= item ? 'вҳ? : 'вҳ?}}</text>
      </view>
    </view>
    <text class="rating-hint">{{ratingHint}}</text>

    <view
      class="rating-submit-btn {{ratingScore === 0 || ratingSubmitting ? 'disabled' : ''}}"
      bindtap="onSubmitRating"
    >
      <text class="rating-submit-text">{{ratingSubmitting ? 'жҸҗдәӨдё?..' : 'жҸҗдәӨиҜ„д»·'}}</text>
    </view>
  </view>
</view>

<!-- рҹ”§ е…ЁеұҸз»ҙжҠӨйҒ®зҪ©пј?03 SYSTEM_MAINTENANCE ж—¶жҝҖжҙ»пјү -->
<maintenance-overlay />
