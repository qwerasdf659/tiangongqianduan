<!-- 通用筛选器组件 -->
<view class="exchange-filter">
  <view class="search-box">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="搜索商品"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
    />
  </view>

  <view class="filter-buttons" wx:if="{{basicFilters.length > 0}}">
    <view
      wx:for="{{basicFilters}}"
      wx:key="value"
      class="filter-btn {{currentFilter === item.value ? 'active' : ''}}"
      data-filter="{{item.value}}"
      bindtap="onFilterTap"
    >
      {{item.label}}
    </view>
    <view
      class="filter-btn advanced-btn {{showAdvanced ? 'active' : ''}}"
      bindtap="onToggleAdvanced"
      >高级筛选</view
    >
  </view>

  <view class="advanced-panel" wx:if="{{showAdvanced}}">
    <view class="filter-row" wx:if="{{categoryOptions.length > 0}}">
      <text class="filter-label">商品分类</text>
      <view class="filter-options">
        <view
          wx:for="{{categoryOptions}}"
          wx:key="value"
          class="option-btn {{categoryFilter === item.value ? 'active' : ''}}"
          data-category="{{item.value}}"
          bindtap="onCategoryTap"
          >{{item.label}}</view
        >
      </view>
    </view>

    <view class="filter-row" wx:if="{{costRangeOptions.length > 0}}">
      <text class="filter-label">价格区间</text>
      <view class="filter-options">
        <view
          wx:for="{{costRangeOptions}}"
          wx:key="label"
          class="option-btn {{costRangeIndex === index ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="onCostRangeTap"
          >{{item.label}}</view
        >
      </view>
    </view>

    <view class="filter-row" wx:if="{{sortByOptions.length > 0}}">
      <text class="filter-label">排序方式</text>
      <view class="filter-options">
        <view
          wx:for="{{sortByOptions}}"
          wx:key="value"
          class="option-btn {{sortBy === item.value ? 'active' : ''}}"
          data-sort="{{item.value}}"
          bindtap="onSortTap"
          >{{item.label}}</view
        >
      </view>
    </view>

    <view class="filter-actions">
      <view class="reset-btn" bindtap="onReset">重置筛选</view>
    </view>
  </view>
</view>
