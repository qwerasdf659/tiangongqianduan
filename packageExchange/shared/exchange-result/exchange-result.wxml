<!-- 兑换结果弹窗组件 -->
<view class="result-overlay" wx:if="{{visible}}" bindtap="onClose">
  <view class="result-modal" catchtap="">
    <view class="result-icon">{{success ? (_hasMinted ? '⚒️' : '✅') : '❌'}}</view>
    <text class="result-title">{{success ? (_hasMinted ? '铸造成功' : '兑换成功') : '兑换失败'}}</text>
    <text class="result-message" wx:if="{{message}}">{{message}}</text>

    <!-- 铸造物品详情（mint_instance=true 时展示品质、编号等实例属性） -->
    <view class="result-detail result-mint-detail" wx:if="{{_hasMinted && success}}">
      <view class="result-row" wx:if="{{_qualityGrade}}">
        <text class="result-label">品质等级</text>
        <text class="result-value result-quality-tag" style="color: {{_qualityColorHex}};">{{_qualityGrade}}</text>
      </view>
      <view class="result-row" wx:if="{{_qualityScore}}">
        <text class="result-label">品质分</text>
        <text class="result-value">{{_qualityScore}} 分</text>
      </view>
      <view class="result-row" wx:if="{{_editionText}}">
        <text class="result-label">限量编号</text>
        <text class="result-value">{{_editionText}}</text>
      </view>
      <view class="result-row" wx:if="{{_patternId}}">
        <text class="result-label">纹理编号</text>
        <text class="result-value">#{{_patternId}}</text>
      </view>
      <view class="result-row" wx:if="{{_trackingCode}}">
        <text class="result-label">追踪码</text>
        <text class="result-value">{{_trackingCode}}</text>
      </view>
      <view class="result-mint-tip">物品已进入背包，7天冷却期后可上架交易</view>
    </view>

    <!-- 普通订单详情（非铸造商品） -->
    <view class="result-detail" wx:elif="{{orderData && success}}">
      <view class="result-row" wx:if="{{orderData.product}}">
        <text class="result-label">商品名称</text>
        <text class="result-value">{{orderData.product.item_name}}</text>
      </view>
      <view class="result-row" wx:if="{{orderData.orderNo}}">
        <text class="result-label">订单编号</text>
        <text class="result-value">{{orderData.orderNo}}</text>
      </view>
      <view class="result-row" wx:if="{{orderData.payAmount}}">
        <text class="result-label">消耗</text>
        <text class="result-value">{{orderData.payAmount}} {{orderData.payAssetCode || '积分'}}</text>
      </view>
    </view>

    <view class="result-footer">
      <view class="result-btn result-btn-secondary" bindtap="onClose">关闭</view>
      <view class="result-btn result-btn-primary" wx:if="{{success && _hasMinted}}" bindtap="onViewBackpack">查看背包</view>
      <view class="result-btn result-btn-primary" wx:elif="{{success && orderData.orderNo}}" bindtap="onViewOrder">查看订单</view>
    </view>
  </view>
</view>
