<!-- components/qrcode/qrcode.wxml - V2动态身份二维码组件模板 -->

<view class="qrcode-container">
  <!-- 二维码标题 -->
  <view class="qrcode-header" wx:if="{{showTitle}}">
    <text class="qrcode-title">{{title}}</text>
  </view>

  <!-- 二维码显示区域 -->
  <view class="qrcode-wrapper">
    <!-- 加载中状态 -->
    <view class="qrcode-loading" wx:if="{{loading}}">
      <text class="loading-text">生成中...</text>
    </view>

    <!-- 二维码图片（未过期时显示） -->
    <block wx:elif="{{!expired && qrCodeImage}}">
      <image class="qrcode-image" src="{{qrCodeImage}}" mode="aspectFit"></image>

      <!-- 倒计时显示 -->
      <view class="qrcode-countdown">
        <text class="countdown-label">有效时间：</text>
        <text class="countdown-time {{countdown <= 60 ? 'countdown-urgent' : ''}}">{{countdownText}}</text>
      </view>

      <!-- 后端返回的提示文案 -->
      <view class="qrcode-tip" wx:if="{{note}}">
        <text>{{note}}</text>
      </view>
    </block>

    <!-- 已过期遮罩 -->
    <view class="qrcode-expired" wx:elif="{{expired}}">
      <text class="expired-icon">⚠️</text>
      <text class="expired-text">二维码已过期</text>
      <button class="refresh-btn-primary" bindtap="handleRefresh" size="mini" type="primary">
        点击刷新
      </button>
    </view>

    <!-- 错误提示 -->
    <view class="qrcode-error" wx:elif="{{errorMessage}}">
      <text class="error-icon">⚠️</text>
      <text class="error-text">{{errorMessage}}</text>
    </view>

    <!-- Canvas画布（用于生成二维码，生成后隐藏） -->
    <canvas canvas-id="qrCanvas" id="qrCanvas" class="qrcode-canvas"
      style="width: {{size}}px; height: {{size}}px;"></canvas>
  </view>

  <!-- 用户信息显示（可选） -->
  <view class="qrcode-info" wx:if="{{showUserInfo && userInfo}}">
    <text class="info-item">用户：{{userInfo.nickname}}</text>
    <text class="info-item">积分：{{userInfo.points}}</text>
  </view>

  <!-- 操作按钮（未过期且有图片时显示） -->
  <view class="qrcode-actions" wx:if="{{showActions && qrCodeImage && !expired}}">
    <button class="action-btn refresh-btn" bindtap="handleRefresh" size="mini">
      <text>🔄 刷新</text>
    </button>
    <button class="action-btn save-btn" bindtap="handleSave" size="mini">
      <text>💾 保存</text>
    </button>
  </view>
</view>
