<!-- 通用空状态组件 -->
<view class="empty-state">
  <text class="empty-icon">{{icon}}</text>
  <text class="empty-title">{{title}}</text>
  <text class="empty-subtitle" wx:if="{{subtitle}}">{{subtitle}}</text>
  <button class="empty-btn" wx:if="{{buttonText}}" bindtap="onRetry">{{buttonText}}</button>
</view>
