<!--
  两级分类联动选择器组件
  后端API: GET /api/v4/system/config/category-tree（CategoryDef.getTree()）
  降级方案: 使用 flatOptions 扁平分类列表（后端 product-filter API）
-->

<!-- 树形模式（后端支持两级分类时） -->
<view class="cascade-container" wx:if="{{treeLoaded}}">
  <!-- 一级分类横向滚动 -->
  <scroll-view class="parent-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      class="parent-item {{selectedCode === 'all' ? 'active' : ''}}"
      data-code="all"
      data-def-id=""
      bindtap="onTapParent"
    >
      <text class="parent-text">全部</text>
    </view>
    <view
      wx:for="{{categoryTree}}"
      wx:key="category_code"
      class="parent-item {{selectedCode === item.category_code || expandedParent === item.category_code ? 'active' : ''}}"
      data-code="{{item.category_code}}"
      data-def-id="{{item.category_def_id}}"
      bindtap="onTapParent"
    >
      <text class="parent-text">{{item.display_name}}</text>
      <text wx:if="{{item.children && item.children.length > 0}}" class="parent-arrow"
        >{{expandedParent === item.category_code ? '▲' : '▼'}}</text
      >
    </view>
  </scroll-view>

  <!-- 二级子分类展开区域 -->
  <view class="children-panel" wx:if="{{expandedParent}}">
    <block wx:for="{{categoryTree}}" wx:key="category_code">
      <view
        wx:if="{{item.category_code === expandedParent && item.children && item.children.length > 0}}"
        class="children-list"
      >
        <view
          wx:for="{{item.children}}"
          wx:for-item="child"
          wx:key="category_code"
          class="child-item {{selectedCode === child.category_code ? 'active' : ''}}"
          data-code="{{child.category_code}}"
          data-def-id="{{child.category_def_id}}"
          data-parent-code="{{item.category_code}}"
          bindtap="onTapChild"
        >
          <text class="child-text">{{child.display_name}}</text>
        </view>
      </view>
    </block>
  </view>
</view>

<!-- 扁平模式（降级方案: 后端不支持两级分类时） -->
<view class="cascade-container flat-mode" wx:elif="{{flatOptions.length > 0}}">
  <scroll-view class="parent-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{flatOptions}}"
      wx:key="value"
      class="parent-item {{selectedCode === item.value ? 'active' : ''}}"
      data-category="{{item.value}}"
      bindtap="onTapFlatCategory"
    >
      <text class="parent-text">{{item.label}}</text>
    </view>
  </scroll-view>
</view>
