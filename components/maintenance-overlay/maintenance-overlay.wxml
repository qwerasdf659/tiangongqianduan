<!-- 全屏遮罩 — 503 维护 / 强制更新 时阻断所有用户交互 -->
<view class="maintenance-overlay" wx:if="{{visible}}" catch:touchmove="preventTouchMove">
  <!-- 强制更新模式 -->
  <view class="maintenance-content maintenance-content--update" wx:if="{{forceUpdate}}">
    <view class="deco-blob deco-blob--1"></view>
    <view class="deco-blob deco-blob--2"></view>
    <view class="maintenance-icon maintenance-icon--update">
      <view class="icon-ring"></view>
      <t-icon name="arrow-up" size="60rpx" color="#fff" />
    </view>
    <view class="maintenance-title">发现新版本</view>
    <view class="maintenance-message">{{updateMessage}}</view>
    <button class="maintenance-retry-btn maintenance-retry-btn--update" bindtap="onUpdateConfirm">
      <t-icon name="refresh" size="32rpx" color="#fff" />
      <text class="btn-text">立即更新</text>
    </button>
  </view>

  <!-- 系统维护模式 -->
  <view class="maintenance-content" wx:else>
    <view class="maintenance-icon"><t-icon name="tools" size="64rpx" /></view>
    <view class="maintenance-title">系统维护中</view>
    <view class="maintenance-message">{{message}}</view>
    <button
      class="maintenance-retry-btn {{retrying ? 'is-disabled' : ''}}"
      disabled="{{retrying}}"
      bindtap="onRetry"
    >
      {{retrying ? '检测中...' : '点击重试'}}
    </button>
    <view class="maintenance-hint" wx:if="{{retryCount > 0}}"
      >已重试 {{retryCount}} 次，维护可能还需要一些时间</view
    >
  </view>
</view>
