<!-- 翻牌抽奖组件 -->
<view class="flipmulti-container">
  <view class="flipmulti-title">
    <text>选择 {{pickCount}} 张卡牌翻开</text>
  </view>

  <view class="flipmulti-hint">
    <text wx:if="{{phase === 'picking'}}">已选 {{selectedIndices.length}}/{{pickCount}}</text>
    <text wx:elif="{{phase === 'flipping'}}">翻牌中...</text>
    <text wx:else>翻牌完成!</text>
  </view>

  <view class="flipmulti-grid">
    <view class="flip-card {{item.selected ? 'selected' : ''}} {{item.flipped ? 'flipped' : ''}}"
      wx:for="{{cards}}" wx:key="index"
      data-index="{{item.index}}"
      bindtap="onTapCard">
      <view class="flip-inner">
        <view class="flip-face flip-back">
          <text class="flip-back-num">{{item.index + 1}}</text>
        </view>
        <view class="flip-face flip-front">
          <text class="flip-prize-icon">{{item.prize.icon || '🎁'}}</text>
          <text class="flip-prize-name">{{item.prize.name || '奖品'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="flipmulti-cost" wx:if="{{costPoints > 0}}">
    <text>消耗 {{costPoints}} 积分</text>
  </view>
</view>
