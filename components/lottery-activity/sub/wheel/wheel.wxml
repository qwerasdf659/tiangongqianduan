<!-- 转盘抽奖组件 -->
<view class="wheel-container">
  <!-- 转盘主体 -->
  <view class="wheel-wrapper">
    <!-- 外圈装饰灯 -->
    <view class="wheel-outer-ring">
      <view
        class="wheel-light"
        wx:for="{{16}}"
        wx:key="*this"
        style="transform: rotate({{index * 22.5}}deg) translateY(-292rpx);"
      ></view>
    </view>

    <!-- 转盘盘面（旋转层） -->
    <view
      class="wheel-plate"
      style="background: {{conicGradient}}; transform: rotate({{rotateAngle}}deg); transition: transform {{spinning ? '4s cubic-bezier(0.17, 0.67, 0.12, 0.99)' : 'none'}};"
    >
      <!-- 奖品文字（极坐标定位） -->
      <view
        class="wheel-prize"
        wx:for="{{prizes}}"
        wx:key="index"
        style="{{prizePositions[index]}}"
      >
        <text class="wheel-prize__icon">{{item.icon || '🎁'}}</text>
        <text class="wheel-prize__name">{{item.name || '奖品'}}</text>
      </view>
    </view>

    <!-- 顶部指针（固定不动） -->
    <view class="wheel-pointer">
      <view class="pointer-arrow"></view>
    </view>

    <!-- 中心按钮 -->
    <view class="wheel-center-btn {{spinning ? 'disabled' : ''}}" bindtap="onDraw">
      <text class="center-btn-text">{{spinning ? '...' : '抽奖'}}</text>
      <text class="center-btn-cost" wx:if="{{costPoints > 0 && !spinning}}"
        >{{costPoints}}积分</text
      >
    </view>
  </view>
</view>
