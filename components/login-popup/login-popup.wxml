<!-- 登录弹窗组件 - 底部半屏弹窗 -->
<view
  class="login-popup-mask {{visible ? 'show' : ''}}"
  bindtap="onMaskTap"
  catchtouchmove="preventScroll"
>
  <view class="login-popup-container {{visible ? 'show' : ''}}" catchtap="preventBubble">
    <!-- 腾讯云天御人机验证（发送验证码前置校验，生产环境强制；非生产后端放行可不弹）
         app-id 为天御 CaptchaAppId，需与后端 .env 的 CAPTCHA_APP_ID 一致 -->
    <t-captcha
      id="captcha"
      app-id="{{captchaAppId}}"
      bindverify="onCaptchaVerify"
      binderror="onCaptchaError"
    />

    <!-- 标题区域 -->
    <view class="popup-header">
      <!-- 后退按钮：仅验证码登录视图显示，点击返回微信一键登录选择界面 -->
      <view wx:if="{{mode === 'sms'}}" class="popup-back" bindtap="onSwitchToWechat">
        <t-icon name="chevron-left" size="44rpx" color="#1A1A1A" />
      </view>
      <!-- 关闭按钮：显著有效的「取消/不登录」入口，用户可随时关闭弹窗继续浏览（微信审核合规要求） -->
      <view class="popup-close" bindtap="onCloseTap" aria-role="button" aria-label="关闭登录">
        <t-icon name="close" size="44rpx" color="#999999" />
      </view>
      <text class="popup-title">登录</text>
      <text class="popup-subtitle">登录后即可参与回馈赚积分</text>
    </view>

    <!-- 微信一键登录视图（默认） -->
    <view class="login-view" wx:if="{{mode === 'wechat'}}">
      <!-- 协议勾选（点勾选圈=完成微信隐私授权，合并在弹窗内，无需微信官方隐私弹窗） -->
      <view class="agreement-row">
        <view class="agreement-check-wrap">
          <view class="agreement-checkbox {{agreementChecked ? 'checked' : ''}}">
            <t-icon wx:if="{{agreementChecked}}" name="check" size="24rpx" color="#fff" />
          </view>
          <button
            id="agree-privacy-btn-wechat"
            class="agreement-agree-btn"
            open-type="agreePrivacyAuthorization"
            bindagreeprivacyauthorization="onAgreePrivacy"
          ></button>
        </view>
        <view class="agreement-texts">
          <text class="agreement-text">我已阅读并同意</text>
          <text class="agreement-link" catchtap="onViewAgreement" data-type="user_agreement"
            >《用户协议》</text
          >
          <text class="agreement-text">和</text>
          <text class="agreement-link" catchtap="onViewAgreement" data-type="privacy_policy"
            >《隐私政策》</text
          >
        </view>
      </view>

      <!-- 微信一键登录按钮 -->
      <button
        class="login-btn wechat-btn {{loggingType === 'wechat' ? 'loading' : ''}}"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        disabled="{{!!loggingType}}"
      >
        <text wx:if="{{loggingType !== 'wechat'}}">手机号快捷登录</text>
        <text wx:else>登录中...</text>
      </button>

      <!-- 切换到验证码登录 -->
      <view class="switch-mode" bindtap="onSwitchToSms">
        <text class="switch-text">使用手机验证码登录</text>
      </view>
    </view>

    <!-- 验证码登录视图 -->
    <view class="login-view" wx:elif="{{mode === 'sms'}}">
      <!-- 手机号输入 -->
      <view class="input-group">
        <text class="input-label">手机号</text>
        <view class="input-row">
          <input
            class="input-field"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{mobile}}"
            bindinput="onMobileInput"
          />
        </view>
      </view>

      <!-- 验证码输入 -->
      <view class="input-group">
        <text class="input-label">验证码</text>
        <view class="input-row code-row">
          <input
            class="input-field code-input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            value="{{verificationCode}}"
            bindinput="onCodeInput"
          />
          <view
            class="send-code-btn {{countdown > 0 || sending ? 'disabled' : ''}}"
            bindtap="onSendCode"
          >
            <text>{{countdown > 0 ? countdown + 's' : '获取验证码'}}</text>
          </view>
        </view>
        <!-- 验证码有效期静态提示（O4） -->
        <text class="code-tip">验证码 5 分钟内有效</text>
      </view>

      <!-- 协议勾选（点勾选圈=完成微信隐私授权，合并在弹窗内） -->
      <view class="agreement-row">
        <view class="agreement-check-wrap">
          <view class="agreement-checkbox {{agreementChecked ? 'checked' : ''}}">
            <t-icon wx:if="{{agreementChecked}}" name="check" size="24rpx" color="#fff" />
          </view>
          <button
            id="agree-privacy-btn-sms"
            class="agreement-agree-btn"
            open-type="agreePrivacyAuthorization"
            bindagreeprivacyauthorization="onAgreePrivacy"
          ></button>
        </view>
        <view class="agreement-texts">
          <text class="agreement-text">我已阅读并同意</text>
          <text class="agreement-link" catchtap="onViewAgreement" data-type="user_agreement"
            >《用户协议》</text
          >
          <text class="agreement-text">和</text>
          <text class="agreement-link" catchtap="onViewAgreement" data-type="privacy_policy"
            >《隐私政策》</text
          >
        </view>
      </view>

      <!-- 验证码登录按钮 -->
      <button
        class="login-btn sms-btn {{loggingType === 'sms' ? 'loading' : ''}}"
        bindtap="onSmsLogin"
        disabled="{{!!loggingType}}"
      >
        <text wx:if="{{loggingType !== 'sms'}}">验证码登录</text>
        <text wx:else>登录中...</text>
      </button>
    </view>
  </view>
</view>
