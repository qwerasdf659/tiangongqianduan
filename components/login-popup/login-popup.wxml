<!-- 登录弹窗组件 - 底部半屏弹窗 -->
<view
  class="login-popup-mask {{visible ? 'show' : ''}}"
  bindtap="onMaskTap"
  catchtouchmove="preventScroll"
>
  <view class="login-popup-container {{visible ? 'show' : ''}}" catchtap="preventBubble">
    <!-- 标题区域 -->
    <view class="popup-header">
      <text class="popup-title">登录</text>
      <text class="popup-subtitle">登录后即可参与回馈赚积分</text>
    </view>

    <!-- 微信一键登录视图（默认） -->
    <view class="login-view" wx:if="{{mode === 'wechat'}}">
      <!-- 协议勾选 -->
      <view class="agreement-row" bindtap="onToggleAgreement">
        <view class="agreement-checkbox {{agreementChecked ? 'checked' : ''}}">
          <t-icon wx:if="{{agreementChecked}}" name="check" size="24rpx" color="#fff" />
        </view>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" catchtap="onViewAgreement" data-type="user_agreement"
          >《用户协议》</text
        >
        <text class="agreement-text">和</text>
        <text class="agreement-link" catchtap="onViewAgreement" data-type="privacy_policy"
          >《隐私政策》</text
        >
      </view>

      <!-- 微信一键登录按钮 -->
      <button
        class="login-btn wechat-btn {{loggingType === 'wechat' ? 'loading' : ''}}"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        disabled="{{!!loggingType}}"
      >
        <text wx:if="{{loggingType !== 'wechat'}}">微信一键登录</text>
        <text wx:else>登录中...</text>
      </button>

      <!-- 切换到验证码登录 -->
      <view class="switch-mode" bindtap="onSwitchToSms">
        <text class="switch-text">使用手机验证码登录</text>
      </view>
    </view>

    <!-- 验证码登录视图 -->
    <view class="login-view" wx:elif="{{mode === 'sms'}}">
      <!-- 手机号输入 -->
      <view class="input-group">
        <text class="input-label">手机号</text>
        <view class="input-row">
          <input
            class="input-field"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{mobile}}"
            bindinput="onMobileInput"
          />
        </view>
      </view>

      <!-- 验证码输入 -->
      <view class="input-group">
        <text class="input-label">验证码</text>
        <view class="input-row code-row">
          <input
            class="input-field code-input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            value="{{verificationCode}}"
            bindinput="onCodeInput"
          />
          <view
            class="send-code-btn {{countdown > 0 || sending ? 'disabled' : ''}}"
            bindtap="onSendCode"
          >
            <text>{{countdown > 0 ? countdown + 's' : '获取验证码'}}</text>
          </view>
        </view>
      </view>

      <!-- 协议勾选 -->
      <view class="agreement-row" bindtap="onToggleAgreement">
        <view class="agreement-checkbox {{agreementChecked ? 'checked' : ''}}">
          <t-icon wx:if="{{agreementChecked}}" name="check" size="24rpx" color="#fff" />
        </view>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" catchtap="onViewAgreement" data-type="user_agreement"
          >《用户协议》</text
        >
        <text class="agreement-text">和</text>
        <text class="agreement-link" catchtap="onViewAgreement" data-type="privacy_policy"
          >《隐私政策》</text
        >
      </view>

      <!-- 验证码登录按钮 -->
      <button
        class="login-btn sms-btn {{loggingType === 'sms' ? 'loading' : ''}}"
        bindtap="onSmsLogin"
        disabled="{{!!loggingType}}"
      >
        <text wx:if="{{loggingType !== 'sms'}}">验证码登录</text>
        <text wx:else>登录中...</text>
      </button>

      <!-- 切换回微信登录 -->
      <view class="switch-mode" bindtap="onSwitchToWechat">
        <text class="switch-text">返回微信一键登录</text>
      </view>
    </view>
  </view>
</view>
