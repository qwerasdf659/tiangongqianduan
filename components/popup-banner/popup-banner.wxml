<!--
  🎨 popup-banner.wxml - 弹窗横幅组件模板
  
  📐 显示模式由后端 display_mode 字段决定（运营在管理后台选择模板）：
    wide        → 宽屏模式（16:9）
    horizontal  → 横版模式（3:2）
    square      → 方图模式（1:1）
    tall        → 竖图模式（3:4）
    slim        → 窄长图模式（9:16）
    full_image  → 纯图模式，无白色卡片壳，图片即弹窗

  📐 图片显示模式：widthFix（动态适配）
    - 宽度撑满容器，高度由图片原始比例自动计算
    - 任何尺寸的图片都完整显示，不裁剪、不留白
    - 运营换图无需担心尺寸问题

  组件结构（常规模式 wide/horizontal/square/tall/slim）：
  ├─ 遮罩层（半透明毛玻璃背景，点击关闭）
  └─ 弹窗卡片（白色圆角卡片，居中悬浮）
     ├─ 关闭按钮（右上角圆形按钮）
     ├─ 横幅图片区域（按 display_mode 设置容器高度）
     ├─ 内容区域（标题+正文）
     ├─ 指示器（多个横幅时显示圆点）
     └─ 操作按钮区域

  组件结构（纯图模式 full_image）：
  ├─ 遮罩层
  └─ 纯图容器（无白色卡片壳）
     ├─ 关闭按钮
     ├─ 图片（自适应宽度，按原图比例显示）
     └─ 操作按钮（悬浮在图片底部）
-->

<!-- 弹窗最外层容器，visible控制是否渲染 -->
<view class="popup-banner-overlay {{animateIn ? 'animate-in' : ''}} {{animateOut ? 'animate-out' : ''}}"
  wx:if="{{visible && banners.length > 0}}" bindtap="handleOverlayTap">

  <!-- ============================== -->
  <!--  📐 纯图模式（full_image）     -->
  <!--  无白色卡片壳，图片即弹窗       -->
  <!-- ============================== -->
  <view class="popup-full-image-container" wx:if="{{banners[currentIndex].display_mode === 'full_image'}}"
    catchtap="preventBubble">
    <!-- 🔴 关闭按钮（右上角悬浮，纯图模式专用样式） -->
    <view class="popup-close-btn popup-close-btn-fullimage" bindtap="handleClose">
      <text class="close-icon">✕</text>
    </view>

    <!-- 🖼️ 纯图模式图片（宽度自适应，高度按原图比例）
         🔴 移除lazy-load：图片已在父页面预加载到缓存，无需懒加载 -->
    <image class="popup-full-image" wx:if="{{banners[currentIndex].image_url && !imageLoadFailed}}"
      src="{{banners[currentIndex].image_url}}" mode="widthFix" lazy-load="{{false}}" bindload="handleImageLoad"
      binderror="handleImageError" />

    <!-- 🔴 纯图模式图片加载失败时的降级显示 -->
    <view class="popup-decor-header popup-decor-header-fullimage" wx:if="{{imageLoadFailed}}">
      <view class="decor-circle decor-circle-1"></view>
      <view class="decor-circle decor-circle-2"></view>
      <view class="decor-circle decor-circle-3"></view>
      <text class="decor-emoji">🖼️</text>
      <text class="decor-fail-text">图片加载失败</text>
    </view>

    <!-- 📦 纯图模式尺寸信息（仅开发调试用，不展示给用户） -->
    <!-- <view class="popup-full-image-info" wx:if="{{banners[currentIndex].image_width}}">
      <text class="full-image-size-text">
        {{banners[currentIndex].image_width}}×{{banners[currentIndex].image_height}}
      </text>
    </view> -->

    <!-- ⚫ 多横幅指示器（纯图模式，2个及以上横幅时显示） -->
    <view class="popup-indicators popup-indicators-fullimage" wx:if="{{banners.length > 1}}">
      <block wx:for="{{banners}}" wx:key="index">
        <view class="indicator-dot {{currentIndex === index ? 'active' : ''}}"></view>
      </block>
      <text class="indicator-text indicator-text-fullimage">{{currentIndex + 1}} / {{banners.length}}</text>
    </view>

    <!-- 🔘 纯图模式操作按钮（悬浮在底部） -->
    <view class="popup-actions popup-actions-fullimage">
      <!-- 有链接时显示"查看详情"按钮 -->
      <button class="popup-action-btn primary" wx:if="{{banners[currentIndex].link_url}}" bindtap="handleAction">
        查看详情
      </button>

      <!-- 多个横幅时显示翻页按钮 -->
      <view class="popup-nav-row" wx:if="{{banners.length > 1}}">
        <!-- 上一条按钮 -->
        <button class="popup-action-btn secondary popup-nav-btn" wx:if="{{currentIndex > 0}}"
          bindtap="handlePrev">
          上一条
        </button>

        <!-- 下一条按钮 -->
        <button class="popup-action-btn secondary popup-nav-btn" wx:if="{{currentIndex < banners.length - 1}}"
          bindtap="handleNext">
          下一条
        </button>
      </view>
    </view>
  </view>

  <!-- ============================== -->
  <!--  🃏 常规模式（白色卡片壳）      -->
  <!--  wide/horizontal/square/tall/slim -->
  <!-- ============================== -->
  <view class="popup-banner-card" wx:if="{{banners[currentIndex].display_mode !== 'full_image'}}"
    catchtap="preventBubble">

    <!-- 🔴 关闭按钮（右上角悬浮） -->
    <view class="popup-close-btn" bindtap="handleClose">
      <text class="close-icon">✕</text>
    </view>

    <!-- 🖼️ 横幅图片区域（有image_url且图片未最终失败时显示）
         📐 动态适配方案：
         - 图片模式 widthFix：宽度撑满容器，高度由图片原始比例自动计算
         - 任何尺寸的图片都能完整显示，不裁剪、不留白
         - min-height 按 display_mode 设置，防止图片加载前布局闪烁
         - max-height: 1000rpx 安全上限，防止极端竖图撑爆弹窗
    -->
    <view class="popup-image-section image-{{banners[currentIndex].display_mode || 'wide'}}"
      wx:if="{{banners[currentIndex].image_url && !imageLoadFailed}}">
      <!-- 🔴 移除lazy-load：图片已在父页面预加载到缓存，无需懒加载 -->
      <image class="popup-image" src="{{banners[currentIndex].image_url}}" mode="widthFix" lazy-load="{{false}}"
        bindload="handleImageLoad" binderror="handleImageError" />
      <!-- 图片底部渐变遮罩（让文字更清晰） -->
      <view class="image-gradient-overlay"></view>
    </view>

    <!-- 🎨 装饰性顶部条纹（没有图片 或 图片加载失败时 显示渐变装饰作为降级） -->
    <view class="popup-decor-header" wx:if="{{!banners[currentIndex].image_url || imageLoadFailed}}">
      <view class="decor-circle decor-circle-1"></view>
      <view class="decor-circle decor-circle-2"></view>
      <view class="decor-circle decor-circle-3"></view>
      <text class="decor-emoji">🎉</text>
    </view>

    <!-- 📝 内容区域（仅当有正文内容时才显示） -->
    <view class="popup-content" wx:if="{{banners[currentIndex].content || banners[currentIndex].description}}">
      <!-- 正文 -->
      <text class="popup-desc">{{banners[currentIndex].content || banners[currentIndex].description}}</text>
    </view>

    <!-- ⚫ 多横幅指示器（2个及以上横幅时显示） -->
    <view class="popup-indicators" wx:if="{{banners.length > 1}}">
      <block wx:for="{{banners}}" wx:key="index">
        <view class="indicator-dot {{currentIndex === index ? 'active' : ''}}"></view>
      </block>
      <text class="indicator-text">{{currentIndex + 1}} / {{banners.length}}</text>
    </view>

    <!-- 🔘 操作按钮区域（仅当有按钮内容时才显示，避免空白留白） -->
    <view class="popup-actions" wx:if="{{banners[currentIndex].link_url || banners.length > 1}}">
      <!-- 有链接时显示"查看详情"按钮 -->
      <button class="popup-action-btn primary" wx:if="{{banners[currentIndex].link_url}}" bindtap="handleAction">
        查看详情
      </button>

      <!-- 多个横幅时显示翻页按钮 -->
      <view class="popup-nav-row" wx:if="{{banners.length > 1}}">
        <!-- 上一条按钮（不是第一条时显示） -->
        <button class="popup-action-btn secondary popup-nav-btn" wx:if="{{currentIndex > 0}}"
          bindtap="handlePrev">
          上一条
        </button>

        <!-- 下一条按钮（不是最后一条时显示） -->
        <button class="popup-action-btn secondary popup-nav-btn" wx:if="{{currentIndex < banners.length - 1}}"
          bindtap="handleNext">
          下一条
        </button>
      </view>
    </view>
  </view>
</view>