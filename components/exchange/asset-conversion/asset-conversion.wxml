<!-- 资产转换组件 — 统一资产转换规则（合成/分解/兑换） -->
<!-- 后端API: GET /api/v4/assets/conversion/rules, POST preview, POST convert -->
<view class="asset-conversion-container">
  <!-- 加载状态 -->
  <t-loading wx:if="{{pageLoading}}" loading="{{true}}" text="加载转换规则..." theme="spinner" />

  <!-- 错误/空状态 -->
  <t-empty
    wx:if="{{!pageLoading && rateList.length === 0}}"
    description="{{errorMessage || '当前没有开放的转换规则'}}"
  >
    <view slot="image">ℹ️</view>
    <t-button slot="action" theme="primary" shape="round" size="small" bind:tap="onRefreshRates"
      >刷新</t-button
    >
  </t-empty>

  <!-- 转换规则列表 -->
  <view class="rate-list" wx:if="{{!pageLoading && rateList.length > 0}}">
    <!-- 页面标题 + 历史入口 -->
    <view class="section-header">
      <view class="section-header__left">
        <text class="section-title">资产转换</text>
        <text class="section-subtitle">按规则转换虚拟资产</text>
      </view>
      <view class="section-header__right" bindtap="onViewExchangeHistory">
        <text class="history-link">转换记录 →</text>
      </view>
    </view>

    <!-- 转换类型 Tab 栏（多种类型时显示，按后端 conversion_type 分组） -->
    <t-tabs
      wx:if="{{conversionTabs.length > 1}}"
      value="{{activeTab}}"
      bind:change="onSwitchTab"
      theme="line"
      split="{{false}}"
      spaceEvenly="{{true}}"
      sticky="{{false}}"
      swipeable="{{false}}"
    >
      <t-tab-panel
        wx:for="{{conversionTabs}}"
        wx:key="type"
        value="{{item.type}}"
        label="{{item.label}}"
      >
      </t-tab-panel>
    </t-tabs>

    <!-- 转换规则卡片列表（按当前 Tab 过滤） -->
    <view
      wx:for="{{filteredRules}}"
      wx:key="conversion_rule_id"
      class="rate-card {{selectedRate && selectedRate.conversion_rule_id === item.conversion_rule_id ? 'rate-card--expanded' : ''}}"
      data-rate-id="{{item.conversion_rule_id}}"
      bindtap="onSelectRate"
    >
      <!-- 转换信息行 -->
      <view class="rate-card__header">
        <view class="rate-card__pair">
          <view class="rate-card__asset">
            <image class="rate-card__icon" src="{{item.fromIcon}}" mode="aspectFit" />
            <text class="rate-card__code">{{item.fromDisplayName || item.from_asset_code}}</text>
          </view>
          <view class="rate-card__arrow">
            <text class="arrow-icon">→</text>
          </view>
          <view class="rate-card__asset">
            <image class="rate-card__icon" src="{{item.toIcon}}" mode="aspectFit" />
            <text class="rate-card__code">{{item.toDisplayName || item.to_asset_code}}</text>
          </view>
        </view>
        <view class="rate-card__info">
          <text class="rate-card__rate">{{item.rate_display || item.rateText}}</text>
          <text class="rate-card__fee" wx:if="{{item.fee_rate > 0}}"
            >手续费 {{item.feePercent}}</text
          >
        </view>
      </view>

      <!-- 限额提示 -->
      <view
        class="rate-card__limits"
        wx:if="{{item.min_from_amount > 1 || item.max_from_amount || item.daily_user_limit}}"
      >
        <text wx:if="{{item.min_from_amount > 1}}" class="limit-tag"
          >最少 {{item.min_from_amount}}</text
        >
        <text wx:if="{{item.max_from_amount}}" class="limit-tag"
          >最多 {{item.max_from_amount}}</text
        >
        <text wx:if="{{item.daily_user_limit}}" class="limit-tag"
          >日限 {{item.daily_user_limit}}</text
        >
      </view>

      <!-- 展开的兑换面板 -->
      <view
        class="rate-card__panel"
        wx:if="{{selectedRate && selectedRate.conversion_rule_id === item.conversion_rule_id}}"
        catchtap=""
      >
        <!-- 输入区域 -->
        <view class="convert-input-section">
          <view class="convert-input-row">
            <text class="convert-input-label">兑换数量</text>
            <view class="convert-input-wrapper">
              <input
                class="convert-input"
                type="number"
                placeholder="输入{{item.fromDisplayName || item.from_asset_code}}数量"
                value="{{inputAmount}}"
                bindinput="onAmountInput"
              />
              <text class="convert-input-unit"
                >{{item.fromDisplayName || item.from_asset_code}}</text
              >
            </view>
            <view class="convert-input-max" bindtap="onFillMaxAmount" catchtap="onFillMaxAmount">
              <text class="max-btn">MAX</text>
            </view>
          </view>
        </view>

        <!-- 预览结果 — 响应字段: net_amount, sufficient, from_balance -->
        <view class="preview-section" wx:if="{{previewResult}}">
          <view class="preview-row">
            <text class="preview-label">消耗</text>
            <text class="preview-value preview-value--debit"
              >-{{previewResult.from_amount}} {{item.fromDisplayName || item.from_asset_code}}</text
            >
          </view>
          <view class="preview-row" wx:if="{{previewResult.fee_amount > 0}}">
            <text class="preview-label">手续费</text>
            <text class="preview-value preview-value--fee"
              >{{previewResult.fee_amount}} {{item.toDisplayName || item.to_asset_code}}</text
            >
          </view>
          <view class="preview-row preview-row--highlight">
            <text class="preview-label">实际获得</text>
            <text class="preview-value preview-value--credit"
              >+{{previewResult.net_amount}} {{item.toDisplayName || item.to_asset_code}}</text
            >
          </view>
          <view class="preview-row">
            <text class="preview-label">当前余额</text>
            <text class="preview-value"
              >{{previewResult.from_balance}} {{item.fromDisplayName || item.from_asset_code}}</text
            >
          </view>
        </view>

        <!-- 预览加载中 -->
        <view class="preview-loading" wx:if="{{previewing}}">
          <text class="preview-loading-text">计算中...</text>
        </view>

        <!-- 错误提示 -->
        <view class="error-tip" wx:if="{{errorMessage}}">
          <text class="error-text">{{errorMessage}}</text>
        </view>

        <!-- 兑换按钮 -->
        <view class="convert-action">
          <t-button
            theme="primary"
            shape="round"
            size="large"
            block="{{true}}"
            disabled="{{!previewResult || !previewResult.sufficient || converting}}"
            loading="{{converting}}"
            bind:tap="onConfirmConvert"
          >
            {{converting ? '兑换中...' : '确认兑换'}}
          </t-button>
        </view>
      </view>
    </view>
  </view>

  <!-- 兑换成功弹窗 -->
  <t-dialog
    visible="{{showResultPopup}}"
    title="转换成功"
    closeBtn="{{true}}"
    closeOnOverlayClick="{{true}}"
    confirmBtn="{{resultConfirmBtn}}"
    bind:confirm="onCloseResultPopup"
    bind:close="onCloseResultPopup"
  >
    <view slot="content" class="result-popup__detail" wx:if="{{convertResult}}">
      <view class="result-row">
        <text class="result-label">消耗</text>
        <text class="result-value result-value--debit">-{{convertResult.from_amount}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">获得</text>
        <text class="result-value result-value--credit">+{{convertResult.net_amount}}</text>
      </view>
    </view>
  </t-dialog>
</view>
