<!--packageUser/issues/issues.wxml - 用户工单进度查看页面-->
<custom-navbar title="我的工单" bgColor="#FF6B35" textColor="#ffffff" showBack="{{true}}" />
<view class="issues-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">我的工单</text>
    <text class="header-desc">查看客服工单处理进度</text>
  </view>

  <!-- 加载中骨架屏 -->
  <block wx:if="{{loadStatus === 'loading'}}">
    <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="issue-skeleton">
      <view class="skeleton-icon shimmer"></view>
      <view class="skeleton-body">
        <view class="skeleton-line skeleton-title shimmer"></view>
        <view class="skeleton-line skeleton-info shimmer"></view>
      </view>
    </view>
  </block>

  <!-- 加载失败 -->
  <t-empty wx:elif="{{loadStatus === 'error'}}" description="请检查网络连接后重试">
    <view slot="image">📡</view>
    <view slot="action" class="retry-btn" bindtap="retryLoad">重新加载</view>
  </t-empty>

  <!-- 空状态 -->
  <t-empty wx:elif="{{loadStatus === 'empty'}}" description="您还没有客服工单记录">
    <view slot="image">📋</view>
  </t-empty>

  <!-- 工单列表 -->
  <block wx:else>
    <view class="issues-summary">
      <text class="summary-text">共 {{totalCount}} 条工单</text>
    </view>

    <view wx:for="{{issues}}" wx:key="issueId" class="issue-card">
      <!-- 工单头部: 类型图标 + 标题 + 状态 -->
      <view class="issue-header">
        <view class="issue-type-badge">
          <text class="type-icon">{{item.issueTypeIcon}}</text>
        </view>
        <view class="issue-title-area">
          <text class="issue-title">{{item.title}}</text>
          <text class="issue-type-label">{{item.issueTypeText}}</text>
        </view>
        <view class="issue-status-badge status-{{item.status}}">
          <text class="status-text">{{item.statusText}}</text>
        </view>
      </view>

      <!-- 工单详情 -->
      <view class="issue-details">
        <view class="detail-row">
          <text class="detail-label">工单编号</text>
          <text class="detail-value">#{{item.issueId}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">优先级</text>
          <text class="detail-value priority-{{item.priority}}">{{item.priorityText}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">提交时间</text>
          <text class="detail-value">{{item.createdAt}}</text>
        </view>
        <view wx:if="{{item.resolvedAt}}" class="detail-row">
          <text class="detail-label">解决时间</text>
          <text class="detail-value">{{item.resolvedAt}}</text>
        </view>
      </view>

      <!-- 工单进度条 -->
      <view class="issue-progress">
        <view
          class="progress-step {{item.status === 'open' || item.status === 'processing' || item.status === 'resolved' || item.status === 'closed' ? 'step-active' : ''}}"
        >
          <view class="step-dot"></view>
          <text class="step-text">已提交</text>
        </view>
        <view
          class="progress-line {{item.status === 'processing' || item.status === 'resolved' || item.status === 'closed' ? 'line-active' : ''}}"
        >
        </view>
        <view
          class="progress-step {{item.status === 'processing' || item.status === 'resolved' || item.status === 'closed' ? 'step-active' : ''}}"
        >
          <view class="step-dot"></view>
          <text class="step-text">处理中</text>
        </view>
        <view
          class="progress-line {{item.status === 'resolved' || item.status === 'closed' ? 'line-active' : ''}}"
        >
        </view>
        <view
          class="progress-step {{item.status === 'resolved' || item.status === 'closed' ? 'step-active' : ''}}"
        >
          <view class="step-dot"></view>
          <text class="step-text">已解决</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more">
      <text class="load-more-text">上拉加载更多</text>
    </view>

    <view wx:else class="no-more">
      <text class="no-more-text">— 没有更多了 —</text>
    </view>
  </block>

  <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
  <maintenance-overlay />
</view>
