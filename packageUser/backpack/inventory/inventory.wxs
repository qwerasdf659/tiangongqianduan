/**
 * 📦 inventory.wxs - 库存管理页面模板辅助函数
 *
 * @description
 * 微信小程序WXS模块，用于WXML模板中的UI辅助逻辑。
 * WXS是微信小程序中唯一能在模板表达式中调用的脚本语言。
 *
 * 功能定位：仅处理UI辅助逻辑（图标选择、时间格式化、过期判断）
 * 业务数据显示统一使用后端返回的 *_display 字段（后端为权威来源）
 *
 * 注意：WXS语法与标准JavaScript有差异：
 *   - 不支持ES6+语法（箭头函数、const/let、模板字符串等）
 *   - 不支持Date构造函数，使用getDate()代替new Date()
 *   - 不支持对象解构等ES6特性
 *
 * @version 1.1.0
 * @since 2026-02-15
 */

/**
 * 根据物品类型获取显示图标（UI辅助逻辑）
 *
 * @param {string} item_type - 后端返回的物品类型（snake_case）
 * @returns {string} 对应的emoji图标
 *
 * 物品类型对照（来源：system_dictionaries 表 dict_type = 'item_type'）：
 *   prize         → 🏆 奖品
 *   product       → 📱 商品
 *   voucher       → 🎫 兑换券
 *   tradable_item → 🔄 可交易物品
 *   service       → 🎁 服务
 *   default       → 📦 通用物品
 */
function getItemIcon(item_type) {
  if (item_type === 'prize') return '🏆'
  if (item_type === 'product') return '📱'
  if (item_type === 'voucher') return '🎫'
  if (item_type === 'tradable_item') return '🔄'
  if (item_type === 'service') return '🎁'
  return '📦'
}

/**
 * 格式化时间为可读的日期字符串（按北京时区，UI辅助逻辑）
 *
 * 后端统一下发 UTC ISO8601 带 Z（对接文档 2026-06-25 B-2）。WXS 无 Intl，
 * 用「绝对时刻 + 8h 偏移取 UTC 分量」得到北京时间，不直接截串里数字。
 *
 * @param {string} timestamp - UTC ISO 时间字符串
 * @returns {string} 格式化后的北京时间（YYYY-MM-DD HH:mm）
 */
function formatTime(timestamp) {
  if (!timestamp) return ''

  var date = getDate(timestamp)
  if (isNaN(date.getTime())) return ''
  var bj = getDate(date.getTime() + 8 * 60 * 60 * 1000)
  var year = bj.getUTCFullYear()
  var month = bj.getUTCMonth() + 1
  var day = bj.getUTCDate()
  var hours = bj.getUTCHours()
  var minutes = bj.getUTCMinutes()

  var monthStr = month < 10 ? '0' + month : '' + month
  var dayStr = day < 10 ? '0' + day : '' + day
  var hourStr = hours < 10 ? '0' + hours : '' + hours
  var minuteStr = minutes < 10 ? '0' + minutes : '' + minutes

  return year + '-' + monthStr + '-' + dayStr + ' ' + hourStr + ':' + minuteStr
}

/**
 * 判断物品是否即将过期（3天内）（UI辅助逻辑）
 *
 * @param {string} expires_at - 过期时间（后端snake_case字段）
 * @returns {boolean} 是否即将过期
 */
function isExpiringSoon(expires_at) {
  if (!expires_at) return false

  var expireTime = getDate(expires_at).getTime()
  var nowTime = getDate().getTime()
  // 3天的毫秒数
  var threeDays = 3 * 24 * 60 * 60 * 1000

  return expireTime - nowTime < threeDays && expireTime > nowTime
}

// WXS模块导出
module.exports = {
  getItemIcon: getItemIcon,
  formatTime: formatTime,
  isExpiringSoon: isExpiringSoon
}
