/**
 * 📊 trade-upload-records.wxs - 积分活动记录页面模板辅助函数
 *
 * @description
 * 微信小程序WXS模块，用于WXML模板中的数据格式化和显示处理。
 * WXS是微信小程序中唯一能在模板中调用的脚本语言。
 *
 * 注意：WXS语法与标准JavaScript有差异：
 *   - 不支持ES6+语法（箭头函数、const/let、模板字符串等）
 *   - 不支持Date构造函数
 *   - 使用getDate()代替new Date()
 *
 * @version 1.1.0
 * @since 2026-02-07
 */

/**
 * 获取交易类型图标
 * 对齐后端 business_type 枚举值（数据库真实统计）
 *
 * @param {string} businessType - 后端 business_type 字段值
 * @returns {string} 对应的emoji图标
 */
function getTypeIcon(businessType) {
  if (!businessType) return 'file'
  if (businessType.indexOf('lottery') === 0) return 'gift'
  if (businessType.indexOf('exchange') === 0) return 'shop'
  if (businessType.indexOf('consumption') === 0) return 'money'
  if (businessType === 'admin_adjustment') return 'setting'
  if (businessType.indexOf('material_convert') === 0) return 'swap'
  if (businessType === 'merchant_points_reward') return 'home'
  if (businessType === 'opening_balance') return 'file-paste'
  if (businessType.indexOf('order_') === 0) return 'cart'
  if (businessType.indexOf('market_') === 0) return 'cart'
  return 'file'
}

/**
 * 格式化积分金额显示（正数前加+号）
 * 增加了空值安全检查，防止显示"undefined"
 *
 * @param {number} amount - 积分数值
 * @returns {string} 格式化后的金额字符串
 */
function formatAmount(amount) {
  // 🔴 安全检查：防止 undefined/null 导致显示 "undefined积分"
  if (amount === undefined || amount === null) return '0'
  if (typeof amount !== 'number') {
    // WXS不支持Number()构造函数，使用算术运算转换为数字
    var num = amount - 0
    if (isNaN(num)) return '0'
    amount = num
  }
  if (amount > 0) {
    return '+' + amount
  }
  return '' + amount
}

/**
 * 格式化时间为友好的相对时间（按北京时区展示）
 *
 * 后端统一下发 UTC ISO8601 带 Z（如 2026-06-24T19:14:09.000Z，对接文档 2026-06-25 B-2）。
 * WXS 不支持 Intl/toLocaleString，故用「绝对时刻 + 8h 偏移后取 UTC 分量」得到北京时间，
 * 绝不直接截取串里数字（那是 UTC 数字，差 8 小时）。
 *
 * @param {string|number} timestamp - UTC ISO 时间字符串或毫秒时间戳
 * @returns {string} 友好的时间描述（如"刚刚"、"5分钟前"、"3小时前"、"2月7日 14:30"）
 */
function formatTime(timestamp) {
  if (!timestamp) return ''

  // 🔴 安全检查：如果是对象类型，尝试转换为字符串
  if (typeof timestamp === 'object') {
    if (timestamp.val) {
      timestamp = timestamp.val
    } else if (timestamp.date) {
      timestamp = timestamp.date
    } else {
      return ''
    }
  }

  var date = getDate(timestamp)
  var now = getDate()
  var diff = now.getTime() - date.getTime()

  // 验证日期是否有效（getTime()返回NaN表示无效日期）
  if (isNaN(diff)) return ''

  // 1分钟内
  if (diff < 60000) {
    return '刚刚'
  }
  // 1小时内
  if (diff < 3600000) {
    return Math.floor(diff / 60000) + '分钟前'
  }
  // 1天内
  if (diff < 86400000) {
    return Math.floor(diff / 3600000) + '小时前'
  }

  // 超过1天，显示具体日期（北京时间：绝对时刻 + 8h 偏移后取 UTC 分量）
  var bj = getDate(date.getTime() + 8 * 60 * 60 * 1000)
  var month = bj.getUTCMonth() + 1
  var day = bj.getUTCDate()
  var hours = bj.getUTCHours()
  var minutes = bj.getUTCMinutes()
  var minuteStr = minutes < 10 ? '0' + minutes : '' + minutes
  var hourStr = hours < 10 ? '0' + hours : '' + hours

  return month + '月' + day + '日 ' + hourStr + ':' + minuteStr
}

// WXS模块导出
module.exports = {
  getTypeIcon: getTypeIcon,
  formatAmount: formatAmount,
  formatTime: formatTime
}
