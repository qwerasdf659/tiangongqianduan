<!--packageUser/records/trade-upload-records/trade-upload-records.wxml - 资产明细页面（多资产 Tab）-->
<custom-navbar title="资产明细" bgColor="#F5F0E8" textColor="#333333" showBack="{{true}}" />
<wxs src="./trade-upload-records.wxs" module="helpers" />
<view class="trade-upload-records-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <sticky-section>
      <!-- 页面头部 -->
      <view class="records-page-header">
        <text class="records-page-title">资产明细</text>
        <view class="header-decor-icon">
          <t-icon name="wallet" size="128rpx" color="rgba(139, 115, 85, 0.12)" />
        </view>
      </view>

      <!-- 资产 Tab（星石/红源晶碎片...，资产名读后端 display_name） -->
      <view class="asset-tabs-section" wx:if="{{assetTabs.length > 0}}">
        <t-tabs
          value="{{currentAssetCode}}"
          bind:change="onAssetTabChange"
          theme="line"
          split="{{false}}"
          sticky="{{false}}"
          swipeable="{{false}}"
        >
          <t-tab-panel
            wx:for="{{assetTabs}}"
            wx:key="asset_code"
            value="{{item.asset_code}}"
            label="{{item.display_name}}"
          ></t-tab-panel>
        </t-tabs>
      </view>

      <!-- 加载状态 -->
      <view class="loading-container" wx:if="{{loading}}">
        <view class="loading-content">
          <t-loading loading="{{true}}" text="加载中..." theme="spinner" />
        </view>
      </view>

      <view class="trade-tab-content" wx:if="{{!loading}}">
        <!-- 当前资产余额卡（名称/图标读后端字典） -->
        <view class="asset-balance-card" wx:if="{{currentAssetCode}}">
          <view class="asset-balance-left">
            <image
              wx:if="{{currentAssetIconUrl}}"
              class="asset-balance-icon"
              src="{{currentAssetIconUrl}}"
              mode="aspectFit"
            />
            <text class="asset-balance-label">可用{{currentAssetName}}</text>
          </view>
          <text class="asset-balance-value">{{currentAssetBalance}}</text>
        </view>

        <!-- 时间筛选 + 重置 -->
        <view class="filter-section">
          <view class="filter-content">
            <view class="time-filters">
              <view
                class="filter-chip {{currentTimeFilter === 'all' ? 'active' : ''}}"
                bind:tap="onTimeFilter"
                data-filter="all"
              >
                <text class="chip-text">全部</text>
              </view>
              <view
                class="filter-chip {{currentTimeFilter === 'today' ? 'active' : ''}}"
                bind:tap="onTimeFilter"
                data-filter="today"
              >
                <text class="chip-text">今天</text>
              </view>
              <view
                class="filter-chip {{currentTimeFilter === 'week' ? 'active' : ''}}"
                bind:tap="onTimeFilter"
                data-filter="week"
              >
                <text class="chip-text">本周</text>
              </view>
              <view
                class="filter-chip {{currentTimeFilter === 'month' ? 'active' : ''}}"
                bind:tap="onTimeFilter"
                data-filter="month"
              >
                <text class="chip-text">本月</text>
              </view>
            </view>

            <view class="filter-actions">
              <button class="filter-btn secondary" bind:tap="onResetFilters">
                <t-icon name="refresh" size="28rpx" class="btn-icon" />
                <text class="btn-text">重置</text>
              </button>
            </view>
          </view>
        </view>

        <!-- 搜索框 -->
        <view class="search-section">
          <view class="search-container">
            <view class="search-box">
              <t-icon name="search" size="28rpx" class="search-icon" />
              <input
                class="search-input"
                placeholder="搜索交易ID、描述..."
                placeholder-class="search-placeholder"
                value="{{searchKeyword}}"
                bind:input="onSearchInput"
              />
              <view class="search-clear" wx:if="{{searchKeyword}}" bind:tap="onResetFilters">
                <t-icon name="close-circle-filled" size="28rpx" />
              </view>
            </view>
          </view>
        </view>

        <!-- 记录数量提示（共 N 条以后端分页 total 为准，反映当前时间范围真实总数） -->
        <view class="records-count" wx:if="{{tradeTotal > 0}}">
          <text class="count-text">共 {{tradeTotal}} 条记录</text>
        </view>

        <!-- 页码翻页栏（后端分页，仅多页时显示） -->
        <exchange-pager
          current-page="{{tradePage}}"
          total-pages="{{tradeTotalPages}}"
          bind:pagechange="onTradePagerChange"
        />

        <!-- 交易记录列表 -->
        <view class="records-section">
          <view class="transaction-list">
            <block
              wx:if="{{filteredRecords.length > 0}}"
              wx:for="{{filteredRecords}}"
              wx:key="asset_transaction_id"
            >
              <view class="transaction-card" style="animation-delay: {{index * 60}}ms;">
                <view class="transaction-header">
                  <view class="transaction-left">
                    <view class="transaction-icon-wrapper {{item.category}}">
                      <t-icon name="{{helpers.getTypeIcon(item.business_type)}}" size="40rpx" />
                    </view>
                    <view class="transaction-info">
                      <text class="transaction-title">{{item.displayTitle || '交易记录'}}</text>
                      <text class="transaction-desc" wx:if="{{item.description}}"
                        >{{item.description}}</text
                      >
                      <text class="transaction-time">{{helpers.formatTime(item.created_at)}}</text>
                      <text class="transaction-no" wx:if="{{item.transaction_no}}"
                        >{{item.transaction_no}}</text
                      >
                    </view>
                  </view>
                  <view class="transaction-right">
                    <text class="amount-value {{item.category}}"
                      >{{helpers.formatAmount(item.delta_amount)}} {{item.displayAssetName}}</text
                    >
                  </view>
                </view>

                <!-- 操作按钮 -->
                <view class="transaction-actions">
                  <button class="action-btn detail" bind:tap="onViewDetail" data-record="{{item}}">
                    <t-icon name="file-paste" size="28rpx" class="btn-icon" />
                    <text class="btn-text">详情</text>
                  </button>
                </view>
              </view>
            </block>

            <!-- 空状态 -->
            <view class="empty-state" wx:if="{{filteredRecords.length === 0}}">
              <view class="empty-content">
                <view class="empty-icon-wrapper">
                  <t-empty description="暂无资产流水">
                    <text slot="description">参与活动或兑换后，资产流水将显示在这里</text>
                  </t-empty>
                </view>
                <button class="activity-action-btn" bind:tap="goToActivity">
                  <t-icon name="thumb-up" size="28rpx" class="btn-icon" />
                  <text class="btn-text">去逛逛</text>
                </button>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 🔴 刷新提示 -->
      <view class="refresh-hint" wx:if="{{refreshing}}">
        <view class="refresh-content">
          <view class="refresh-spinner"></view>
          <text class="refresh-text">刷新中...</text>
        </view>
      </view>

      <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
      <maintenance-overlay />
    </sticky-section>
  </scroll-view>
</view>
