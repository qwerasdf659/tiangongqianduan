<!--packageUser/barter/barter.wxml - 以物易物页面-->
<custom-navbar title="以物易物" bgColor="#F5F0E8" textColor="#333333" showBack="{{true}}" />
<view class="barter-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-text">
        <text class="header-title">以物易物</text>
        <text class="header-desc">用仓库里的旧物，按官方配方合成新物</text>
      </view>
      <view class="header-decor-icon">
        <t-icon name="gift" size="128rpx" color="rgba(139, 115, 85, 0.12)" />
      </view>
    </view>

    <!-- 加载中骨架屏 -->
    <block wx:if="{{loadStatus === 'loading'}}">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="recipe-skeleton">
        <view class="skeleton-line skeleton-title shimmer"></view>
        <view class="skeleton-line skeleton-info shimmer"></view>
      </view>
    </block>

    <!-- 加载失败 -->
    <t-empty wx:elif="{{loadStatus === 'error'}}" description="请检查网络连接后重试">
      <view slot="image"><t-icon name="wifi" size="120rpx" color="var(--td-brand-color)" /></view>
      <view slot="action" class="retry-btn" bindtap="retryLoad">重新加载</view>
    </t-empty>

    <!-- 空状态 -->
    <t-empty wx:elif="{{loadStatus === 'empty'}}" description="暂无可用的以物易物配方">
      <view slot="image"><t-icon name="gift" size="120rpx" color="var(--td-brand-color)" /></view>
      <view slot="action" class="retry-btn" bindtap="goToInventory">查看我的仓库</view>
    </t-empty>

    <!-- 配方列表 -->
    <block wx:else>
      <view class="recipe-card" wx:for="{{recipes}}" wx:key="recipe_code">
        <view class="recipe-header">
          <text class="recipe-name">{{item.name}}</text>
          <text class="recipe-code">#{{item.recipe_code}}</text>
        </view>
        <view class="recipe-require">
          <text class="require-label">所需旧物</text>
          <text class="require-value">{{item._requiredQuantity}} 件</text>
        </view>
        <view class="recipe-owned">
          <text class="owned-label">我持有</text>
          <text class="owned-value {{item._canMake ? 'owned-enough' : 'owned-short'}}"
            >{{item._ownedCount}} 件</text
          >
        </view>
        <view
          class="recipe-btn {{item._canMake ? '' : 'recipe-btn-disabled'}}"
          data-code="{{item.recipe_code}}"
          bindtap="onMakeRecipe"
        >
          <text>{{item._canMake ? '去合成' : '旧物不足'}}</text>
        </view>
      </view>
    </block>

    <!-- 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
    <maintenance-overlay />
  </scroll-view>

  <!-- 选择旧物弹窗 -->
  <view class="select-overlay" wx:if="{{showSelectPanel}}" catchtap="onCloseSelectPanel">
    <view class="select-panel" catchtap="">
      <view class="select-header">
        <text class="select-title">选择旧物</text>
        <view class="select-close" catchtap="onCloseSelectPanel">
          <t-icon name="close" size="40rpx" color="var(--tg-text-tertiary)" />
        </view>
      </view>
      <view class="select-tip" wx:if="{{activeRecipe}}">
        <text class="select-tip-text"
          >合成「{{activeRecipe.name}}」需选择 {{activeRecipe._requiredQuantity}} 件，已选
          {{selectedItemIds.length}} 件</text
        >
      </view>

      <scroll-view scroll-y class="candidate-scroll">
        <view
          class="candidate-item {{item._selected ? 'candidate-selected' : ''}}"
          wx:for="{{candidateItems}}"
          wx:key="item_id"
          data-id="{{item.item_id}}"
          bindtap="onToggleItem"
        >
          <view class="candidate-info">
            <text class="candidate-name">{{item.item_name}}</text>
            <text class="candidate-code">{{item.tracking_code}}</text>
          </view>
          <view class="candidate-check">
            <t-icon
              wx:if="{{item._selected}}"
              name="check-circle-filled"
              size="40rpx"
              color="var(--td-brand-color)"
            />
            <view wx:else class="candidate-uncheck"></view>
          </view>
        </view>
      </scroll-view>

      <view
        class="submit-btn {{selectedItemIds.length === activeRecipe._requiredQuantity && !submitting ? '' : 'submit-btn-disabled'}}"
        bindtap="onSubmitBarter"
      >
        <text>{{submitting ? '合成中...' : '确认合成'}}</text>
      </view>
    </view>
  </view>
</view>
