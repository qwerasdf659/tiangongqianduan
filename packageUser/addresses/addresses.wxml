<!--packageUser/addresses/addresses.wxml - 收货地址管理页-->
<custom-navbar
  title="{{selectMode ? '选择收货地址' : '收货地址'}}"
  bgColor="#F5F0E8"
  textColor="#333333"
  showBack="{{true}}"
/>
<view class="addresses-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 加载中骨架屏 -->
    <block wx:if="{{loadStatus === 'loading'}}">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="addr-skeleton">
        <view class="skeleton-line skeleton-title shimmer"></view>
        <view class="skeleton-line skeleton-info shimmer"></view>
      </view>
    </block>

    <!-- 加载失败 -->
    <t-empty wx:elif="{{loadStatus === 'error'}}" description="请检查网络连接后重试">
      <view slot="image"
        ><t-icon name="wifi-off" size="120rpx" color="var(--td-brand-color)"
      /></view>
      <view slot="action" class="retry-btn" bindtap="retryLoad">重新加载</view>
    </t-empty>

    <!-- 空状态 -->
    <t-empty wx:elif="{{loadStatus === 'empty'}}" description="还没有收货地址">
      <view slot="image"
        ><t-icon name="location" size="120rpx" color="var(--td-brand-color)"
      /></view>
      <view slot="action" class="retry-btn" bindtap="onAddAddress">新增地址</view>
    </t-empty>

    <!-- 地址列表 -->
    <block wx:else>
      <view
        wx:for="{{addresses}}"
        wx:key="address_id"
        class="addr-card"
        data-id="{{item.address_id}}"
        bindtap="onSelectAddress"
      >
        <view class="addr-main">
          <view class="addr-top-row">
            <text class="addr-name">{{item.receiver_name}}</text>
            <text class="addr-phone">{{item.receiver_phone}}</text>
            <view wx:if="{{item.is_default}}" class="addr-default-tag">默认</view>
          </view>
          <text class="addr-detail"
            >{{item.province}}{{item.city}}{{item.district}}{{item.detail_address}}</text
          >
        </view>

        <!-- 操作行（选择模式下隐藏，避免误触） -->
        <view wx:if="{{!selectMode}}" class="addr-actions" catchtap="">
          <view
            class="addr-action-item"
            wx:if="{{!item.is_default}}"
            data-id="{{item.address_id}}"
            catchtap="onSetDefault"
          >
            <t-icon name="check-circle" size="32rpx" />
            <text class="addr-action-text">设默认</text>
          </view>
          <view class="addr-action-item" data-id="{{item.address_id}}" catchtap="onEditAddress">
            <t-icon name="edit" size="32rpx" />
            <text class="addr-action-text">编辑</text>
          </view>
          <view
            class="addr-action-item addr-action-delete"
            data-id="{{item.address_id}}"
            catchtap="onDeleteAddress"
          >
            <t-icon name="delete" size="32rpx" />
            <text class="addr-action-text">删除</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
    <maintenance-overlay />
  </scroll-view>

  <!-- 底部新增按钮 -->
  <view class="addr-footer">
    <view class="addr-add-btn" bindtap="onAddAddress">
      <t-icon name="add" size="36rpx" color="#ffffff" />
      <text class="addr-add-text">新增收货地址</text>
    </view>
  </view>
</view>

<!-- 地址表单半屏面板 -->
<view class="form-overlay" wx:if="{{showForm}}" catchtap="onCloseForm">
  <view class="form-panel" catchtap="">
    <view class="form-header">
      <text class="form-title">{{formTitle}}</text>
      <view class="form-close" catchtap="onCloseForm">
        <t-icon name="close" size="40rpx" color="var(--tg-text-tertiary)" />
      </view>
    </view>

    <view class="form-body">
      <view class="form-row">
        <text class="form-label">收货人</text>
        <input
          class="form-input"
          placeholder="请填写收货人姓名"
          value="{{formReceiverName}}"
          data-field="formReceiverName"
          bindinput="onFormInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">手机号</text>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="请填写收货人手机号"
          value="{{formReceiverPhone}}"
          data-field="formReceiverPhone"
          bindinput="onFormInput"
        />
      </view>
      <view class="form-row">
        <text class="form-label">所在地区</text>
        <picker
          mode="region"
          value="{{[formProvince, formCity, formDistrict]}}"
          bindchange="onRegionChange"
        >
          <view class="form-picker">
            <text class="{{formProvince ? 'form-picker-value' : 'form-picker-placeholder'}}"
              >{{formProvince ? (formProvince + formCity + formDistrict) : '请选择省 / 市 /
              区'}}</text
            >
            <t-icon name="chevron-right" size="32rpx" color="var(--tg-text-tertiary)" />
          </view>
        </picker>
      </view>
      <view class="form-row form-row-textarea">
        <text class="form-label">详细地址</text>
        <textarea
          class="form-textarea"
          placeholder="街道、门牌号等"
          value="{{formDetailAddress}}"
          data-field="formDetailAddress"
          bindinput="onFormInput"
          maxlength="120"
          auto-height
        ></textarea>
      </view>
      <view class="form-row form-row-switch" bindtap="onToggleDefault">
        <text class="form-label">设为默认地址</text>
        <view class="form-switch {{formIsDefault ? 'switch-on' : ''}}">
          <view class="form-switch-dot"></view>
        </view>
      </view>
    </view>

    <view class="form-footer">
      <view class="form-submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmitForm">
        <text>{{submitting ? '保存中...' : '保存'}}</text>
      </view>
    </view>
  </view>
</view>
