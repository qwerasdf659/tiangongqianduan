<!--packageUser/chat/chat.wxml - 用户端聊天会话列表界面 V6.0 UI优化版-->
<custom-navbar title="在线客服" bgColor="#667eea" textColor="#ffffff" showBack="{{true}}" />
<view class="chat-sessions-container">
  <!-- 顶部搜索栏 -->
  <view class="search-header">
    <view class="search-bar">
      <view class="search-icon">🔍</view>
      <input
        class="search-input"
        placeholder="搜索聊天记录"
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <view wx:if="{{searchKeyword}}" class="clear-search" bindtap="clearSearch">✕</view>
    </view>
    <view class="new-chat-btn" bindtap="startNewChat">
      <text class="new-chat-icon">✚</text>
    </view>
  </view>

  <!-- 会话列表主体 -->
  <scroll-view
    class="sessions-list"
    scroll-y="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <!-- ===== 状态1：加载中 - 骨架屏（非搜索模式下显示） ===== -->
    <block wx:if="{{sessionLoadStatus === 'loading' && !isSearching}}">
      <view
        wx:for="{{[1,2,3,4,5,6]}}"
        wx:key="*this"
        class="session-skeleton"
        style="animation-delay: {{index * 80}}ms;"
      >
        <view class="skeleton-avatar shimmer"></view>
        <view class="skeleton-content">
          <view class="skeleton-line skeleton-line-name shimmer"></view>
          <view class="skeleton-line skeleton-line-msg shimmer"></view>
        </view>
        <view class="skeleton-time shimmer"></view>
      </view>
    </block>

    <!-- ===== 状态2：加载失败 - 错误+重试（非搜索模式下显示） ===== -->
    <view wx:elif="{{sessionLoadStatus === 'error' && !isSearching}}" class="error-state">
      <view class="error-icon-wrapper">
        <text class="error-icon-text">📡</text>
      </view>
      <text class="error-title">会话加载失败</text>
      <text class="error-desc">请检查网络连接后重试</text>
      <view class="retry-btn" bindtap="retryLoadSession">
        <text class="retry-btn-text">重新加载</text>
      </view>
    </view>

    <!-- ===== 状态3：搜索模式 - 搜索结果列表（对标微信消息搜索） ===== -->
    <block wx:elif="{{isSearching}}">
      <!-- 搜索加载中 -->
      <view wx:if="{{searchLoading}}" class="search-loading-state">
        <t-loading loading="{{true}}" text="搜索中..." theme="spinner" size="40rpx" />
      </view>

      <!-- 搜索无结果 -->
      <view wx:elif="{{searchResults.length === 0}}" class="search-empty-state">
        <view class="search-empty-icon-wrapper">
          <text class="search-empty-icon">🔍</text>
        </view>
        <text class="search-empty-title">未找到相关消息</text>
        <text class="search-empty-desc">换个关键词试试</text>
      </view>

      <!-- 搜索结果列表 -->
      <block wx:else>
        <view class="search-results-header">
          <text class="search-results-label">聊天记录</text>
          <text class="search-results-count">{{searchTotal}}条结果</text>
        </view>

        <view
          wx:for="{{searchResults}}"
          wx:key="chatMessageId"
          class="search-result-item"
          data-session-id="{{item.sessionId}}"
          data-message-id="{{item.chatMessageId}}"
          bindtap="onSearchResultTap"
        >
          <!-- 头像 -->
          <view class="result-avatar">
            <view class="avatar-bg customer-service-bg avatar-sm">
              <text class="avatar-icon avatar-icon-sm">🎧</text>
            </view>
          </view>

          <!-- 搜索结果内容 -->
          <view class="result-content">
            <!-- 第一行：发送者标签 + 时间 -->
            <view class="result-main-row">
              <text
                class="result-sender-tag {{item.senderType === 'user' ? 'sender-self' : 'sender-admin'}}"
                >{{item.senderLabel}}</text
              >
              <text class="result-time">{{item.time}}</text>
            </view>
            <!-- 第二行：消息内容（关键词高亮） -->
            <view class="result-message-row">
              <rich-text class="result-message-text" nodes="{{item.highlightContent}}"></rich-text>
            </view>
            <!-- 第三行：来源会话 -->
            <view class="result-source-row">
              <text class="result-source-text">来自：在线客服</text>
            </view>
          </view>
        </view>
      </block>
    </block>

    <!-- ===== 状态4：正常模式 - 会话列表 ===== -->
    <block wx:else>
      <!-- 空状态：暂无会话 -->
      <view wx:if="{{sessions.length === 0}}" class="error-state">
        <t-empty description="暂无会话记录">
          <text slot="description">点击右上角"+"开始新的客服咨询</text>
        </t-empty>
      </view>

      <!-- 会话列表（直接渲染后端sessions数组） -->
      <view
        wx:for="{{sessions}}"
        wx:key="sessionId"
        class="session-item {{item.unread > 0 ? 'has-unread' : ''}}"
        data-id="{{item.sessionId}}"
        bindtap="onSessionTap"
        style="animation-delay: {{index * 60}}ms;"
      >
        <!-- 头像区域 -->
        <view class="session-avatar">
          <view class="avatar-bg customer-service-bg">
            <text class="avatar-icon">{{item.icon}}</text>
          </view>
          <!-- 在线状态指示器（已结束的会话显示灰色） -->
          <view
            class="online-indicator {{item.status === 'closed' ? 'indicator-offline' : ''}}"
          ></view>
        </view>

        <!-- 会话内容 -->
        <view class="session-content">
          <view class="session-info">
            <!-- 名称 + 状态标签 -->
            <view class="session-name-row">
              <text class="session-name">{{item.name}}</text>
              <view class="session-status-tag status-{{item.status}}">
                <view class="status-tag-dot"></view>
                <text class="status-tag-text">{{item.statusText}}</text>
              </view>
            </view>
            <text wx:if="{{item.time}}" class="session-time">{{item.time}}</text>
          </view>
          <view class="session-preview">
            <text class="last-message">{{item.preview || '暂无消息'}}</text>
            <view wx:if="{{item.unread > 0}}" class="unread-count">
              {{item.unread > 99 ? '99+' : item.unread}}
            </view>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>
</view>

<!-- ===== 聊天弹窗（全屏覆盖） ===== -->
<view class="chat-modal {{showChatModal ? 'show' : ''}}" bindtap="onModalMaskTap">
  <view class="modal-content" catchtap="onModalContentTap">
    <!-- 聊天头部 - 优化版 -->
    <view class="chat-header">
      <view class="header-left">
        <view class="back-btn-wrapper" bindtap="closeChatModal">
          <text class="back-btn">←</text>
        </view>
        <view class="current-session-avatar">
          <view class="avatar-bg customer-service-bg">
            <text class="avatar-icon">{{currentChatIcon}}</text>
          </view>
          <!-- 在线状态点 -->
          <view class="header-online-dot {{wsConnected ? 'online' : 'offline'}}"></view>
        </view>
        <view class="session-detail">
          <text class="session-name">{{currentChatName}}</text>
          <view class="session-status-row">
            <view class="status-dot {{wsConnected ? 'dot-online' : 'dot-offline'}}"></view>
            <text class="session-status-text"
              >{{sessionStatus === 'active' ? '对话中' : (sessionStatus === 'waiting' ?
              '等待接入...' : (sessionStatus === 'closed' ? '已结束' : (wsConnected ? '已连接' :
              '连接中...')))}}</text
            >
          </view>
        </view>
      </view>
      <view class="header-right">
        <view class="more-btn-wrapper" bindtap="showChatMenu">
          <text class="more-btn">⋯</text>
        </view>
      </view>
    </view>

    <!-- 连接状态横幅（断线时显示） -->
    <view wx:if="{{!wsConnected && showChatModal}}" class="connection-banner">
      <view class="banner-content">
        <view class="banner-spinner"></view>
        <text class="banner-text">正在重新连接...</text>
      </view>
    </view>

    <!-- 消息列表 -->
    <scroll-view
      class="chat-messages"
      scroll-y="{{true}}"
      scroll-into-view="{{scrollToBottom ? 'message-bottom' : ''}}"
      scroll-with-animation="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
      catchtap="onMessagesAreaTap"
      bindscroll="onChatScroll"
    >
      <!-- 历史消息加载中 -->
      <view wx:if="{{isLoadingHistory}}" class="loading-history">
        <t-loading loading="{{true}}" text="加载历史消息..." theme="spinner" size="40rpx" />
      </view>

      <!-- 欢迎卡片（无历史消息时展示） -->
      <view
        wx:if="{{(chatLoadStatus === 'empty' || chatLoadStatus === 'success') && messages.length === 0 && !isLoadingHistory}}"
        class="welcome-card"
      >
        <view class="welcome-avatar-wrapper">
          <view class="welcome-avatar">
            <text class="welcome-avatar-icon">🎧</text>
          </view>
          <view class="welcome-pulse"></view>
        </view>
        <text class="welcome-title">{{currentChatName}}</text>
        <text class="welcome-subtitle">很高兴为您服务</text>
        <view class="welcome-tips">
          <view class="tip-item">
            <text class="tip-icon">⏱</text>
            <text class="tip-text">工作时间：9:00-18:00</text>
          </view>
          <view class="tip-item">
            <text class="tip-icon">💡</text>
            <text class="tip-text">请描述您的问题，我们会尽快回复</text>
          </view>
        </view>
        <view wx:if="{{!quickRepliesAvailable}}" class="quick-reply-unavailable-card">
          <text class="quick-reply-unavailable-text">{{quickRepliesUnavailableMessage}}</text>
        </view>
      </view>

      <!-- 聊天加载失败 -->
      <view
        wx:if="{{chatLoadStatus === 'error' && messages.length === 0 && !isLoadingHistory}}"
        class="chat-error-state"
      >
        <text class="chat-error-icon">⚠️</text>
        <text class="chat-error-text">消息加载失败</text>
        <text class="chat-error-desc">请检查网络后重试</text>
      </view>

      <!-- 消息列表 -->
      <view
        wx:for="{{messages}}"
        wx:key="messageId"
        class="message-item {{item.isOwn ? 'own-message' : 'other-message'}}"
      >
        <!-- 时间分割线 -->
        <view wx:if="{{item.showTime}}" class="time-divider">
          <text class="time-text">{{item.timeText}}</text>
        </view>

        <!-- 系统消息（独立展示，不走气泡布局） -->
        <view wx:if="{{item.messageType === 'system'}}" class="system-message-wrapper">
          <text class="system-message-text">{{item.content}}</text>
        </view>

        <!-- 普通消息内容 -->
        <view wx:else class="message-content">
          <!-- 对方头像 -->
          <view wx:if="{{!item.isOwn}}" class="message-avatar">
            <view class="avatar-bg customer-service-bg">
              <text class="avatar-icon">{{currentChatIcon}}</text>
            </view>
          </view>

          <!-- 消息气泡区域 -->
          <view class="message-bubble-area">
            <!-- 消息气泡 -->
            <view class="message-bubble {{item.isOwn ? 'own-bubble' : 'other-bubble'}}">
              <!-- 文字消息 -->
              <text
                wx:if="{{item.messageType === 'text'}}"
                class="message-text"
                user-select="{{true}}"
                >{{item.content}}</text
              >

              <!-- 图片消息 -->
              <image
                wx:if="{{item.messageType === 'image'}}"
                class="message-image"
                src="{{item.attachments[0].url || item.content}}"
                mode="widthFix"
                bindtap="previewImage"
                data-src="{{item.attachments[0].url || item.content}}"
              ></image>
            </view>

            <!-- 消息状态（自己发送的消息） -->
            <view wx:if="{{item.isOwn}}" class="message-status-row">
              <text wx:if="{{item.status === 'sending'}}" class="status-label sending">发送中</text>
              <text wx:if="{{item.status === 'sent'}}" class="status-label sent">已发送</text>
              <text wx:if="{{item.status === 'delivered'}}" class="status-label delivered"
                >已送达</text
              >
              <text wx:if="{{item.status === 'read'}}" class="status-label read">已读</text>
              <text
                wx:if="{{item.status === 'failed'}}"
                class="status-label failed"
                bindtap="resendMessage"
                data-message-id="{{item.messageId}}"
                >发送失败，点击重试</text
              >
            </view>
          </view>
        </view>
      </view>

      <!-- 输入状态指示器 -->
      <view wx:if="{{showTypingIndicator}}" class="typing-indicator">
        <view class="typing-avatar">
          <view class="avatar-bg customer-service-bg">
            <text class="avatar-icon">{{currentChatIcon}}</text>
          </view>
        </view>
        <view class="typing-bubble">
          <view class="typing-animation">
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
          </view>
        </view>
      </view>

      <!-- M1: 满意度评分内嵌卡片（非弹窗，融入聊天流底部） -->
      <view wx:if="{{showSatisfactionCard && !satisfactionSubmitted}}" class="satisfaction-card">
        <view class="satisfaction-header">
          <text class="satisfaction-title">请为本次服务评分</text>
          <view class="satisfaction-dismiss" bindtap="dismissSatisfaction">
            <text class="dismiss-icon">✕</text>
          </view>
        </view>
        <view class="satisfaction-stars">
          <view
            wx:for="{{[1,2,3,4,5]}}"
            wx:key="*this"
            class="star-item"
            data-score="{{item}}"
            bindtap="onSelectSatisfactionScore"
          >
            <text class="star-icon {{satisfactionScore >= item ? 'star-active' : 'star-inactive'}}"
              >{{satisfactionScore >= item ? '★' : '☆'}}</text
            >
          </view>
        </view>
        <view class="satisfaction-labels">
          <text class="satisfaction-label"
            >{{satisfactionScore === 0 ? '点击星星评分' : satisfactionScore === 1 ? '非常不满意' :
            satisfactionScore === 2 ? '不满意' : satisfactionScore === 3 ? '一般' :
            satisfactionScore === 4 ? '满意' : '非常满意'}}</text
          >
        </view>
        <view class="satisfaction-actions">
          <button
            class="satisfaction-submit-btn {{satisfactionScore > 0 ? 'active' : 'disabled'}}"
            disabled="{{satisfactionScore === 0}}"
            bindtap="submitSatisfaction"
          >
            <text>提交评价</text>
          </button>
        </view>
      </view>

      <!-- 评分已提交状态 -->
      <view wx:if="{{satisfactionSubmitted}}" class="satisfaction-done">
        <text class="satisfaction-done-icon">✅</text>
        <text class="satisfaction-done-text">感谢您的评价</text>
      </view>

      <!-- 滚动锚点 -->
      <view id="message-bottom" style="height: 20rpx"></view>
    </scroll-view>

    <!-- 回到底部浮动按钮（滚动时显示） -->
    <view wx:if="{{showScrollBottomBtn}}" class="scroll-bottom-fab" catchtap="scrollToLatest">
      <text class="fab-arrow">↓</text>
      <view wx:if="{{newMsgCount > 0}}" class="fab-badge"
        >{{newMsgCount > 99 ? '99+' : newMsgCount}}</view
      >
    </view>

    <!-- 快捷回复区域（有消息时显示在输入框上方） -->
    <view
      wx:if="{{showQuickReplies && messages.length > 0 && quickRepliesAvailable}}"
      class="quick-replies-bar"
      catchtap="onQuickRepliesBarTap"
    >
      <scroll-view
        class="quick-replies-scroll"
        scroll-x="{{true}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
      >
        <view class="quick-replies-list"></view>
      </scroll-view>
      <view class="quick-replies-toggle" bindtap="toggleQuickReplies">
        <text class="toggle-icon">{{showQuickReplies ? '▾' : '▴'}}</text>
      </view>
    </view>

    <!-- 输入区域 - 重新设计 -->
    <view class="chat-input-area" catchtap="onInputAreaTap">
      <view class="input-main-row" catchtap="onInputToolbarTap">
        <!-- 附件按钮（展开/折叠工具栏） -->
        <view class="expand-btn {{showToolbar ? 'active' : ''}}" catchtap="toggleToolbar">
          <text class="expand-icon">{{showToolbar ? '×' : '+'}}</text>
        </view>

        <!-- 输入框 -->
        <view class="input-wrapper" catchtap="onInputWrapperTap">
          <textarea
            class="message-input"
            placeholder="输入消息..."
            placeholder-class="input-placeholder"
            value="{{inputContent}}"
            bindinput="onInputChange"
            bindfocus="onInputFocus"
            bindblur="onInputBlur"
            bindconfirm="onInlineSendTap"
            confirm-type="send"
            auto-height="{{true}}"
            show-confirm-bar="{{false}}"
            maxlength="500"
            catchtap="onTextareaTap"
          >
          </textarea>
        </view>

        <!-- 发送按钮 -->
        <view
          class="send-btn {{inputContent.trim() ? 'active' : 'inactive'}}"
          catchtap="onInlineSendTap"
        >
          <text class="send-btn-icon">{{inputContent.trim() ? '➤' : '🎤'}}</text>
        </view>
      </view>

      <!-- 展开的工具栏面板 -->
      <view class="toolbar-panel {{showToolbar ? 'show' : ''}}">
        <view class="toolbar-grid">
          <view class="toolbar-item" bindtap="sendImage">
            <view class="toolbar-item-icon-wrapper">
              <text class="toolbar-item-icon">📷</text>
            </view>
            <text class="toolbar-item-label">相册</text>
          </view>
          <view class="toolbar-item" bindtap="sendImage">
            <view class="toolbar-item-icon-wrapper">
              <text class="toolbar-item-icon">📸</text>
            </view>
            <text class="toolbar-item-label">拍照</text>
          </view>
          <view class="toolbar-item" bindtap="sendLocation">
            <view class="toolbar-item-icon-wrapper">
              <text class="toolbar-item-icon">📍</text>
            </view>
            <text class="toolbar-item-label">位置</text>
          </view>
          <view class="toolbar-item" bindtap="sendFile">
            <view class="toolbar-item-icon-wrapper">
              <text class="toolbar-item-icon">📎</text>
            </view>
            <text class="toolbar-item-label">文件</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
  <maintenance-overlay />
</view>
