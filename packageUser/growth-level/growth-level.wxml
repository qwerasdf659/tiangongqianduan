<!--packageUser/growth-level/growth-level.wxml - 成长等级页面-->
<custom-navbar title="成长等级" bgColor="#F5F0E8" textColor="#333333" showBack="{{true}}" />
<view class="growth-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-text">
        <text class="header-title">成长等级</text>
        <text class="header-desc">累计积分越多，等级越高，解锁更多权益</text>
      </view>
      <view class="header-decor-icon">
        <t-icon name="chart-bar" size="128rpx" color="rgba(139, 115, 85, 0.12)" />
      </view>
    </view>

    <!-- 加载中骨架屏 -->
    <block wx:if="{{loadStatus === 'loading'}}">
      <view class="level-skeleton">
        <view class="skeleton-badge shimmer"></view>
        <view class="skeleton-line skeleton-title shimmer"></view>
        <view class="skeleton-line skeleton-info shimmer"></view>
      </view>
    </block>

    <!-- 加载失败 -->
    <t-empty wx:elif="{{loadStatus === 'error'}}" description="请检查网络连接后重试">
      <view slot="image"><t-icon name="wifi" size="120rpx" color="var(--td-brand-color)" /></view>
      <view slot="action" class="retry-btn" bindtap="retryLoad">重新加载</view>
    </t-empty>

    <!-- 成长等级内容 -->
    <block wx:else>
      <!-- 当前等级卡片（hero-{level_key} 按等级主题化配色，v1~v9 各有材质色） -->
      <view class="current-card hero-{{currentLevelKey}}">
        <!-- 装饰光斑（Skyline 不支持伪元素，用真实节点实现） -->
        <view class="hero-decor hero-decor-top"></view>
        <view class="hero-decor hero-decor-bottom"></view>
        <view class="current-badge badge-{{currentLevelKey}}">
          <t-icon name="user-vip-filled" size="60rpx" color="#FFFFFF" />
        </view>
        <text class="current-level-name">{{currentLevelName || '暂无等级'}}</text>
        <!-- 等级序号（来自后端 levels[] 数组位置，纯展示） -->
        <text class="current-level-index" wx:if="{{currentLevelIndex > 0}}"
          >第 {{currentLevelIndex}} 级 · 共 {{levels.length}} 级</text
        >
        <!-- 等级位置指示点：filled 数量 = 当前序号 -->
        <view class="level-dots" wx:if="{{levels.length > 0}}">
          <view
            class="level-dot {{index < currentLevelIndex ? 'level-dot-filled' : ''}}"
            wx:for="{{levels}}"
            wx:key="levelKey"
          ></view>
        </view>
        <!-- 累计积分：displayPoints 为数字滚动动画中间帧，最终值恒等于后端 history_total_points -->
        <view class="current-points">
          <text class="current-points-num">{{displayPoints}}</text>
          <text class="current-points-unit">累计积分</text>
        </view>
        <!-- 当前等级积分加成倍率（后端 current_earn_multiplier，营销激励公开信息） -->
        <view class="current-multiplier" wx:if="{{currentMultiplierText}}">
          <t-icon name="upload" size="26rpx" color="#B8860B" />
          <text class="current-multiplier-text">{{currentMultiplierText}}</text>
        </view>
        <!-- 升级进度条（仅 UI 可视化，数字文案以后端 next_level 差值为准；progressFillPercent 为填充动画中间值，最终等于 progressPercent） -->
        <view class="progress-track" wx:if="{{progressPercent >= 0}}">
          <view class="progress-fill" style="width: {{progressFillPercent}}%"></view>
        </view>
        <!-- 升级提示（后端 next_level 差值字段，顶档不下发则不展示） -->
        <view class="next-level-hint" wx:if="{{nextLevelText}}">
          <t-icon name="arrow-up-circle" size="28rpx" color="#C5A572" />
          <text class="next-level-hint-text">{{nextLevelText}}</text>
        </view>
        <!-- 顶档荣耀提示（levels[] 末位即当前等级时展示） -->
        <view class="next-level-hint top-level-hint" wx:if="{{isTopLevel}}">
          <t-icon name="verified-filled" size="28rpx" color="#B8860B" />
          <text class="next-level-hint-text top-level-hint-text">已达最高等级</text>
        </view>
      </view>

      <!-- 等级阶梯（奖章时间轴：medal-{level_key} 按等级材质配色，未达档位锁定置灰） -->
      <view class="ladder-section" wx:if="{{levels.length > 0}}">
        <view class="section-title-row">
          <text class="section-title">等级阶梯</text>
          <text class="section-subtitle">共 {{levels.length}} 级</text>
        </view>
        <view class="ladder-list">
          <!-- 逐项入场动画（animation-delay 按序号递增）+ 点击弹出该档等级详情 -->
          <view
            class="ladder-item ladder-enter {{item.isCurrent ? 'ladder-current' : ''}} {{item.isReached ? 'ladder-reached' : ''}}"
            style="animation-delay: {{index * 60}}ms"
            wx:for="{{levels}}"
            wx:key="levelKey"
            data-index="{{index}}"
            hover-class="ladder-item-hover"
            hover-stay-time="120"
            bindtap="onLadderItemTap"
          >
            <view class="ladder-rail">
              <view
                class="ladder-medal medal-{{item.levelKey}} {{item.isReached ? '' : 'medal-locked'}}"
              >
                <t-icon
                  wx:if="{{item.isReached}}"
                  name="user-vip-filled"
                  size="26rpx"
                  color="#FFFFFF"
                />
                <t-icon wx:else name="lock-on-filled" size="22rpx" color="#BBBBBB" />
              </view>
              <view class="ladder-line" wx:if="{{index < levels.length - 1}}"></view>
            </view>
            <view class="ladder-body">
              <view class="ladder-row-card">
                <view class="ladder-text-col">
                  <view class="ladder-name-row">
                    <text class="ladder-name">{{item.levelName}}</text>
                    <text class="ladder-current-tag" wx:if="{{item.isCurrent}}">当前等级</text>
                  </view>
                  <view class="ladder-meta-row">
                    <text class="ladder-threshold" wx:if="{{item.thresholdText}}"
                      >{{item.thresholdText}}</text
                    >
                    <!-- 该档积分加成倍率（后端 earn_multiplier，营销激励公开信息） -->
                    <text class="ladder-multiplier" wx:if="{{item.multiplierText}}"
                      >{{item.multiplierText}}</text
                    >
                  </view>
                </view>
                <view class="ladder-trailing">
                  <t-icon
                    wx:if="{{item.isReached && !item.isCurrent}}"
                    name="check-circle-filled"
                    size="32rpx"
                    color="#C5A572"
                  />
                  <!-- 右侧箭头：提示该行可点击查看等级详情 -->
                  <t-icon name="chevron-right" size="32rpx" color="var(--tg-text-tertiary)" />
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 成长规则说明（文案依据已拍板业务决议：拍板① 1元≈1积分、拍板⑦ 等级终身有效只增不减） -->
      <view class="rules-section">
        <view class="section-title-row">
          <text class="section-title">成长规则</text>
        </view>
        <view class="rule-item">
          <view class="rule-icon-wrap">
            <t-icon name="wallet" size="32rpx" color="#C5A572" />
          </view>
          <view class="rule-text-col">
            <text class="rule-title">消费积累成长值</text>
            <text class="rule-desc">在店内消费即可累计积分，1 元约等于 1 积分</text>
          </view>
        </view>
        <view class="rule-item">
          <view class="rule-icon-wrap">
            <t-icon name="chart-bar" size="32rpx" color="#C5A572" />
          </view>
          <view class="rule-text-col">
            <text class="rule-title">等级只升不降</text>
            <text class="rule-desc">成长等级由累计积分决定，终身有效、只增不减</text>
          </view>
        </view>
        <view class="rule-item">
          <view class="rule-icon-wrap">
            <t-icon name="gift" size="32rpx" color="#C5A572" />
          </view>
          <view class="rule-text-col">
            <text class="rule-title">等级越高权益越多</text>
            <text class="rule-desc">升级解锁更多会员权益，详情以平台公示为准</text>
          </view>
        </view>
      </view>

      <!-- 占位提示：阈值未定稿时说明门槛数字为何不显示 -->
      <view class="threshold-hint" wx:if="{{!thresholdsConfirmed}}">
        <t-icon name="info-circle-filled" size="28rpx" color="var(--tg-text-tertiary)" />
        <text class="threshold-hint-text">各等级积分门槛正在确认中，敬请期待</text>
      </view>
    </block>

    <!-- 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
    <maintenance-overlay />
  </scroll-view>

  <!-- 等级详情弹窗（内容均为后端已下发字段的展示加工：奖章材质/等级名/门槛/倍率/达成状态） -->
  <t-popup
    visible="{{levelDetailVisible}}"
    placement="center"
    bind:visible-change="onLevelDetailVisibleChange"
  >
    <view class="level-detail-modal" wx:if="{{levelDetail}}">
      <view class="level-detail-close" bindtap="onLevelDetailClose">
        <t-icon name="close" size="36rpx" color="var(--tg-text-tertiary)" />
      </view>
      <!-- 该档奖章（medal-v1~v9 与阶梯同一套材质体系，未达档位锁定置灰） -->
      <view
        class="level-detail-medal medal-{{levelDetail.levelKey}} {{levelDetail.isReached ? '' : 'medal-locked'}}"
      >
        <t-icon
          wx:if="{{levelDetail.isReached}}"
          name="user-vip-filled"
          size="56rpx"
          color="#FFFFFF"
        />
        <t-icon wx:else name="lock-on-filled" size="48rpx" color="#BBBBBB" />
      </view>
      <text class="level-detail-name">{{levelDetail.levelName}}</text>
      <!-- 达成状态标签（isCurrent/isReached 由后端 current_level_key 与 levels[] 顺序派生） -->
      <view
        class="level-detail-status {{levelDetail.isCurrent ? 'status-current' : levelDetail.isReached ? 'status-reached' : 'status-locked'}}"
      >
        <text wx:if="{{levelDetail.isCurrent}}">当前等级</text>
        <text wx:elif="{{levelDetail.isReached}}">已达成</text>
        <text wx:else>未解锁</text>
      </view>
      <view class="level-detail-rows">
        <!-- 门槛（后端 min_history_points；阈值未定稿时 thresholdText 为空不展示该行） -->
        <view class="level-detail-row" wx:if="{{levelDetail.thresholdText}}">
          <text class="level-detail-label">升级门槛</text>
          <text class="level-detail-value">{{levelDetail.thresholdText}}</text>
        </view>
        <!-- 积分加成倍率（后端 earn_multiplier，营销激励公开信息） -->
        <view class="level-detail-row" wx:if="{{levelDetail.multiplierText}}">
          <text class="level-detail-label">积分加成</text>
          <text class="level-detail-value level-detail-multiplier"
            >{{levelDetail.multiplierText}}</text
          >
        </view>
      </view>
      <!-- 阈值未定稿时的占位说明（与页面底部占位提示同一业务口径） -->
      <text class="level-detail-hint" wx:if="{{!thresholdsConfirmed}}"
        >积分门槛正在确认中，敬请期待</text
      >
    </view>
  </t-popup>
</view>
