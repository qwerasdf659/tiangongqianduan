<!--
  反馈列表页面 - 查看全部反馈历史
-->
<view class="feedback-list-page">
  <!-- 空状态 -->
  <view wx:if="{{!loading && feedbacks.length === 0}}" class="empty-state">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无反馈记录</text>
    <button class="new-feedback-btn" bindtap="onNewFeedback">提交反馈</button>
  </view>

  <!-- 反馈列表 -->
  <view wx:else class="list-container">
    <view
      wx:for="{{feedbacks}}"
      wx:key="feedback_id"
      class="feedback-item"
      bindtap="onFeedbackTap"
      data-id="{{item.feedback_id}}"
    >
      <view class="item-header">
        <text class="status-tag status-{{item.status}}"
          >{{statusMap[item.status] || item.status}}</text
        >
        <text class="item-time">{{item.created_at}}</text>
      </view>
      <view class="item-content">
        <text class="category-label">{{item.category}}</text>
        <text class="content-preview">{{item.content}}</text>
      </view>
      <view wx:if="{{item.reply_content}}" class="reply-indicator">
        <text class="reply-badge">已回复</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="loading-more">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && feedbacks.length > 0}}" class="no-more">
      <text class="no-more-text">— 已显示全部反馈 —</text>
    </view>
  </view>
</view>
