<scroll-view class="category-nav" scroll-x enhanced show-scrollbar="{{false}}">
  <view
    wx:for="{{categories}}"
    wx:key="id"
    class="category-item {{activeId === item.id ? 'active' : ''}}"
    bind:tap="onSelect"
    data-id="{{item.id}}"
  >
    <view class="category-icon-wrap" wx:if="{{item.icon}}">
      <image class="category-icon" src="{{item.icon}}" mode="aspectFit" />
    </view>
    <text class="category-name">{{item.name}}</text>
  </view>
</scroll-view>
