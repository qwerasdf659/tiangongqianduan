<view class="bead-card {{disabled ? 'disabled' : ''}}" bind:tap="onTap" data-bead="{{bead}}">
  <!-- 宝石预览（优先使用图片，无图片时显示材质色块） -->
  <view class="bead-preview">
    <block wx:if="{{bead.image_url}}">
      <image class="bead-image" src="{{bead.thumbnail_url || bead.image_url}}" mode="aspectFit" />
    </block>
    <block wx:else>
      <view
        class="bead-color-preview"
        style="width: {{previewSize}}rpx; height: {{previewSize}}rpx;"
      />
    </block>
  </view>

  <!-- 信息区 -->
  <view class="bead-info">
    <text class="bead-name">{{bead.name}}</text>
    <text class="bead-spec">{{bead.diameter}}mm · {{bead.material}}</text>
    <view class="bead-price-row">
      <text class="bead-price">{{bead.price}}</text>
      <text class="bead-unit">💎</text>
    </view>
  </view>

  <!-- 库存不足 -->
  <view wx:if="{{bead.stock <= 0}}" class="bead-sold-out">
    <text>售罄</text>
  </view>
</view>
