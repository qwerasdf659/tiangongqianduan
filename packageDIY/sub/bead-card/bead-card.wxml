<view class="bead-card {{disabled ? 'disabled' : ''}}" bind:tap="onTap" data-bead="{{bead}}">
  <!-- 宝石预览（优先后端 image_media.public_url 真实图片，无图时显示材质色块 fallback） -->
  <view class="bead-preview">
    <image wx:if="{{bead.image_media.public_url}}" class="bead-image" src="{{bead.image_media.public_url}}" mode="aspectFill" lazy-load />
    <view wx:else class="bead-color-preview" style="width: {{previewSize}}rpx; height: {{previewSize}}rpx;" />
  </view>

  <!-- 信息区（使用后端蛇形字段名） -->
  <view class="bead-info">
    <text class="bead-name">{{bead.display_name}}</text>
    <text class="bead-spec">{{bead.diameter}}mm · {{bead.material_name}}</text>
    <view class="bead-price-row">
      <text class="bead-price">{{bead.price}}</text>
      <text class="bead-unit">星石</text>
    </view>
  </view>

  <!-- 库存不足（stock=0时售罄，stock=-1表示无限库存） -->
  <view wx:if="{{bead.stock === 0}}" class="bead-sold-out">
    <text>售罄</text>
  </view>
</view>
