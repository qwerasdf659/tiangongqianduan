<!--
  XR-Frame 3D 珠子手串渲染组件
  动态渲染珠子圆环 + 弹力绳 + PBR 材质
-->
<xr-scene id="xr-scene" bind:ready="onSceneReady" bind:tick="onTick">
  <!-- 材质资源定义（动态生成） -->
  <xr-assets>
    <!-- 绳子材质 -->
    <xr-asset-material
      asset-id="mat-rope"
      effect="standard"
      uniforms="u_baseColorFactor:0.6 0.55 0.45 1.0,u_metallicFactor:0.0,u_roughnessFactor:0.8"
    />
    <!-- 动态珠子材质 -->
    <xr-asset-material
      wx:for="{{materials}}"
      wx:key="assetId"
      asset-id="{{item.assetId}}"
      effect="standard"
      uniforms="{{item.uniforms}}"
      states="cullOn:false"
    />
  </xr-assets>

  <!-- 相机：支持触摸旋转 -->
  <xr-camera
    id="main-camera"
    position="{{cameraPosition}}"
    target="0 0 0"
    clear-color="0.97 0.95 0.92 1"
    camera-orbit-control=""
  />

  <!-- 光照系统 -->
  <xr-light type="ambient" color="1 1 1" intensity="0.5" />
  <xr-light type="directional" rotation="40 70 0" color="1 1 1" intensity="0.7" />
  <xr-light type="directional" rotation="-30 -50 0" color="0.9 0.92 1" intensity="0.3" />
  <xr-light type="point" position="0 2 2" color="1 0.98 0.95" intensity="0.4" range="8" />

  <!-- 手串主体节点（可整体旋转） -->
  <xr-node id="bracelet">
    <!-- 珠子球体 -->
    <xr-mesh
      wx:for="{{beadNodes}}"
      wx:key="index"
      geometry="sphere"
      material="{{item.matId}}"
      position="{{item.position}}"
      scale="{{item.scale}}"
    />

    <!-- 弹力绳段 -->
    <xr-mesh
      wx:for="{{ropeSegments}}"
      wx:key="index"
      geometry="sphere"
      material="mat-rope"
      position="{{item.position}}"
      scale="{{item.scale}}"
      rotation="{{item.rotation}}"
    />
  </xr-node>
</xr-scene>
