<custom-navbar title="工作台" bgColor="#ffffff" textColor="#000000" showBack="{{true}}" />
<view class="diy-design-page">
  <!-- 加载态 -->
  <view wx:if="{{loading}}" class="loading-full">
    <t-loading loading="{{true}}" text="加载模板中..." theme="spinner" />
  </view>

  <block wx:else>
    <!-- ===== 上半部分：预览区 + 参数面板 ===== -->
    <view class="workspace-area">
      <!-- 右上角操作按钮 -->
      <view class="action-buttons">
        <view class="action-btn action-btn-dark" bind:tap="onSubmit">
          <text>完成</text>
        </view>
        <view class="action-btn action-btn-primary" bind:tap="onSaveDraft">
          <text>保存</text>
        </view>
      </view>

      <!-- 预览画布（居中圆形区域） -->
      <view class="preview-section">
        <shape-renderer
          id="shapeRenderer"
          width="{{canvasWidth}}"
          height="{{canvasHeight}}"
          bind:beadtap="onBeadTap"
          bind:slottap="onSlotTap"
        />
      </view>

      <!-- 右侧参数面板 -->
      <view class="params-panel">
        <view class="param-row">
          <text class="param-label">适用手围</text>
          <text class="param-value">{{selectedSizeDisplay || '0.0cm'}}</text>
        </view>
        <view class="param-row">
          <text class="param-label">重量</text>
          <text class="param-value">{{totalWeight || '0.00g'}}</text>
        </view>
        <view class="param-row">
          <text class="param-label">价格</text>
          <text class="param-value price-highlight">¥{{totalPrice || '0.00'}}</text>
        </view>
        <view wx:if="{{!isSlotMode}}" class="param-row">
          <text class="param-label">手围</text>
          <text class="param-value">{{braceletSize || '16cm'}}</text>
        </view>
        <view wx:if="{{!isSlotMode}}" class="param-row">
          <text class="param-label">戴法</text>
          <text class="param-value">{{wearStyle || '单圈'}}</text>
        </view>
        <view wx:if="{{!isSlotMode}}" class="param-row">
          <text class="param-label">最大周长</text>
          <text class="param-value">{{maxPerimeter || '17.6cm'}}</text>
        </view>
      </view>
    </view>

    <!-- 左侧工具栏（浮动） -->
    <view class="side-tools">
      <view
        class="side-tool-item"
        bind:tap="onSizeChange"
        wx:if="{{!isSlotMode && sizeOptions.length > 0}}"
      >
        <text class="side-tool-icon">⊕</text>
        <text class="side-tool-label">手围设置</text>
      </view>
      <view class="side-tool-item" bind:tap="onToggleToolbox">
        <text class="side-tool-icon">⊞</text>
        <text class="side-tool-label">工具箱</text>
      </view>
    </view>

    <!-- 工具箱弹出面板 -->
    <view wx:if="{{showToolbox}}" class="toolbox-panel">
      <view class="toolbox-item {{canUndo ? '' : 'disabled'}}" bind:tap="onUndo">
        <text>↩ 撤销</text>
      </view>
      <view class="toolbox-item {{canRedo ? '' : 'disabled'}}" bind:tap="onRedo">
        <text>↪ 重做</text>
      </view>
      <view class="toolbox-item" bind:tap="onClearDesign">
        <text>🗑 清空</text>
      </view>
      <view wx:if="{{highlightedCount > 0}}" class="toolbox-item" bind:tap="onDeleteSelected">
        <text>✕ 删除选中({{highlightedCount}})</text>
      </view>
    </view>

    <!-- ===== 下半部分：素材选择面板 ===== -->
    <view class="material-panel">
      <!-- 素材类型Tab栏（饰品/配饰/吊坠/搜索/购物车） -->
      <view class="material-type-tabs">
        <view
          class="material-type-tab {{activeMaterialType === 'beads' ? 'active' : ''}}"
          bind:tap="onMaterialTypeChange"
          data-type="beads"
        >
          <text>饰品</text>
        </view>
        <view
          class="material-type-tab {{activeMaterialType === 'accessories' ? 'active' : ''}}"
          bind:tap="onMaterialTypeChange"
          data-type="accessories"
        >
          <text>配饰</text>
        </view>
        <view
          class="material-type-tab {{activeMaterialType === 'pendants' ? 'active' : ''}}"
          bind:tap="onMaterialTypeChange"
          data-type="pendants"
        >
          <text>吊坠</text>
        </view>
        <view class="material-type-tab" bind:tap="onToggleSearch">
          <text>🔍</text>
        </view>
        <view class="material-type-tab" bind:tap="onShowCart">
          <text>🛒</text>
        </view>
      </view>

      <!-- 搜索栏（点击搜索图标时展开） -->
      <view wx:if="{{showSearch}}" class="search-bar">
        <input
          class="search-input"
          placeholder="搜索材料名称"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
        />
      </view>

      <!-- 提示条 -->
      <view wx:if="{{showMaterialTip}}" class="material-tip">
        <text class="tip-icon">💡</text>
        <text class="tip-text">长按材料可查看实拍图</text>
        <view class="tip-close" bind:tap="onCloseMaterialTip">
          <text>×</text>
        </view>
      </view>

      <!-- 素材内容区：左侧分类 + 右侧网格 -->
      <view class="material-content">
        <!-- 左侧分类列表 -->
        <scroll-view
          type="list"
          class="material-groups"
          scroll-y
          enhanced
          show-scrollbar="{{false}}"
        >
          <view
            class="group-item {{activeGroupCode === '' ? 'active' : ''}}"
            bind:tap="onGroupChange"
            data-group-code=""
          >
            <text>全部</text>
          </view>
          <view
            wx:for="{{materialGroups}}"
            wx:key="group_code"
            class="group-item {{activeGroupCode === item.group_code ? 'active' : ''}}"
            bind:tap="onGroupChange"
            data-group-code="{{item.group_code}}"
          >
            <text>{{item.display_name}}</text>
          </view>
        </scroll-view>

        <!-- 右侧素材网格 -->
        <scroll-view
          type="list"
          class="material-grid-wrap"
          scroll-y
          enhanced
          show-scrollbar="{{false}}"
        >
          <view class="material-grid">
            <view wx:for="{{filteredBeads}}" wx:key="diy_material_id" class="material-item">
              <bead-card bead="{{item}}" bind:select="onBeadSelect" />
            </view>
          </view>
          <view wx:if="{{filteredBeads.length === 0}}" class="material-empty">
            <t-empty description="暂无素材" />
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 飞入动画 -->
    <fly-animation id="flyAnim" bind:complete="onFlyComplete" />
  </block>
</view>
