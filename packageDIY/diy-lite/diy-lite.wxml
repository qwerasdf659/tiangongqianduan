<!--
  diy-lite 手串设计台（生产页）
  顶部信息条(费用/尺码/容量条) + 中央 bracelet-tray + 底部选珠区(素材Tab+左竖分类+右网格+搜索)
  + 底部双CTA(保存草稿/完成设计→diy-result支付) + 弹窗
  数据来源：后端 /api/v4/diy/（模板/珠子/作品），前端不写死业务数据
-->
<view class="diy-lite-page">
  <custom-navbar title="自由定制饰品" />

  <!-- 加载态 -->
  <view wx:if="{{loading}}" class="load-state">
    <text class="load-state-text">加载款式与珠子素材中...</text>
  </view>

  <block wx:else>
    <!-- 顶部信息条：费用 + 颗数 + 尺码 + 容量进度条 -->
    <view class="topbar">
      <view class="topbar-row">
        <view class="topbar-price">
          <text class="price-label">费用</text>
          <text class="price-value">{{costText}}</text>
        </view>
        <view class="topbar-meta">
          <text class="meta-item">{{beadCount}} 颗</text>
          <view
            class="meta-pill"
            bindtap="onOpenSize"
            wx:if="{{!isSlotMode && sizeOptions.length > 0}}"
          >
            <text class="meta-pill-text">尺码 {{selectedSizeDisplay}}</text>
          </view>
          <!-- 镶嵌模式：槽位进度 + 当前激活槽位 -->
          <view class="meta-pill" wx:if="{{isSlotMode}}">
            <text class="meta-pill-text"
              >已镶 {{filledSlotCount}}/{{totalSlotCount}}{{activeSlotLabel ? ' · ' +
              activeSlotLabel : ''}}</text
            >
          </view>
        </view>
      </view>
      <!-- 容量进度条（颗数兜底防呆，拍板 Q1：已选颗数 / 当前尺码 bead_count） -->
      <block wx:if="{{capacityLimited}}">
        <view class="capacity-bar {{isFull ? 'capacity-bar-shake' : ''}}">
          <view
            class="capacity-fill {{isFull ? 'capacity-fill-full' : ''}} {{nearFull ? 'capacity-fill-near' : ''}}"
            style="width: {{capacityPercent}}%"
          ></view>
        </view>
        <text class="capacity-text"
          >已排 {{beadCount}}/{{capacityBeads}} 颗{{capacityTip ? ' · ' + capacityTip : ''}}</text
        >
      </block>
      <!-- 长度/重量实时联动（手围驱动 §3.3/§3.4：已排/目标/差值 + 累计克重，估算值统一带"约"） -->
      <view class="length-row" wx:if="{{!isSlotMode && showLengthRow}}">
        <text class="length-item">已排 {{usedLengthText}}</text>
        <text class="length-item" wx:if="{{targetLengthText}}">目标 {{targetLengthText}}</text>
        <text
          class="length-item {{lengthOver ? 'length-item-over' : 'length-item-diff'}}"
          wx:if="{{lengthDiffText}}"
          >{{lengthDiffText}}</text
        >
        <text class="length-item" wx:if="{{weightText}}">{{weightText}}</text>
      </view>
      <!-- 物理数据不完整的如实标注（§7-4：不编造默认值、不参与精确计算，文案由 TS 预计算） -->
      <text class="length-note" wx:if="{{!isSlotMode && physicalNote}}">{{physicalNote}}</text>
      <!-- 实时数量引导文案（结合后端 min_beads 与剩余可加颗数） -->
      <text class="fill-hint {{isFull || nearFull ? 'fill-hint-highlight' : ''}}"
        >{{fillHint}}</text
      >
    </view>

    <!-- 中央渲染舞台：串珠=bracelet-tray；镶嵌=shape-renderer(底图+槽位，状态在 diyStore) -->
    <view class="stage" style="background: {{bgColor}}">
      <bracelet-tray
        wx:if="{{!isSlotMode}}"
        id="braceletTray"
        beads="{{selectedBeads}}"
        preview3d="{{preview3d}}"
        capacityMm="{{trayCapacityMm}}"
        scattered="{{scattered}}"
        bind:remove="onTrayRemove"
        bind:reorder="onTrayReorder"
        bind:beadtap="onTrayBeadTap"
        bind:selectionchange="onTraySelectionChange"
      />
      <view class="slot-stage" wx:if="{{isSlotMode}}">
        <shape-renderer
          id="shapeRenderer"
          canvasWidth="{{canvasWidth}}"
          canvasHeight="{{canvasHeight}}"
          bind:slottap="onSlotTap"
        />
      </view>
      <!-- 悬浮操作钮（3D/散开/转一圈/拍照/五行为手串专属，镶嵌模式隐藏） -->
      <view class="stage-tools">
        <view class="tool-btn {{canUndo ? '' : 'tool-btn-disabled'}}" bindtap="onUndo">
          <text class="tool-btn-text">撤销</text>
        </view>
        <view class="tool-btn {{canRedo ? '' : 'tool-btn-disabled'}}" bindtap="onRedo">
          <text class="tool-btn-text">重做</text>
        </view>
        <view
          wx:if="{{!isSlotMode}}"
          class="tool-btn {{preview3d ? 'tool-btn-active' : ''}}"
          bindtap="onToggle3d"
        >
          <text class="tool-btn-text">3D</text>
        </view>
        <view
          wx:if="{{!isSlotMode}}"
          class="tool-btn {{scattered ? 'tool-btn-active' : ''}} {{beadCount > 0 ? '' : 'tool-btn-disabled'}}"
          bindtap="onToggleScatter"
        >
          <text class="tool-btn-text">{{scattered ? '收拢' : '散开'}}</text>
        </view>
        <view
          wx:if="{{!isSlotMode}}"
          class="tool-btn {{beadCount > 0 ? '' : 'tool-btn-disabled'}}"
          bindtap="onSpinShow"
        >
          <text class="tool-btn-text">旋转</text>
        </view>
        <view
          wx:if="{{!isSlotMode}}"
          class="tool-btn {{beadCount > 0 ? '' : 'tool-btn-disabled'}}"
          bindtap="onExportPhoto"
        >
          <text class="tool-btn-text">拍照</text>
        </view>
        <view
          wx:if="{{!isSlotMode}}"
          class="tool-btn {{beadCount > 0 ? '' : 'tool-btn-disabled'}}"
          bindtap="onOpenWuxing"
        >
          <text class="tool-btn-text">五行</text>
        </view>
        <view class="tool-btn" bindtap="onOpenGuide">
          <text class="tool-btn-text">教程</text>
        </view>
        <view
          class="tool-btn tool-btn-clear {{beadCount > 0 ? '' : 'tool-btn-disabled'}}"
          bindtap="onClearAll"
        >
          <text class="tool-btn-text">清空</text>
        </view>
      </view>
      <!-- 空态引导：一键成串（手串专属） -->
      <view class="empty-guide" wx:if="{{!isSlotMode && beadCount === 0}}" bindtap="onRandomFill">
        <text class="empty-guide-text">✨ 一键成串 · 随机搭配</text>
      </view>

      <!-- 多选批量删除栏（轻点手串珠子可多选，手串专属） -->
      <view class="selection-bar" wx:if="{{!isSlotMode && selectedCount > 0}}">
        <text class="selection-bar-count">已选 {{selectedCount}} 颗</text>
        <view class="selection-bar-btn selection-bar-delete" bindtap="onDeleteSelected">
          <text class="selection-bar-btn-text">删除选中</text>
        </view>
        <view class="selection-bar-btn" bindtap="onClearSelection">
          <text class="selection-bar-btn-text selection-bar-cancel-text">取消</text>
        </view>
      </view>

      <!-- 缩放控制（手串专属：＋/－步进，画布上双指捏合也可缩放） -->
      <view class="zoom-ctrl" wx:if="{{!isSlotMode}}">
        <view class="zoom-btn" bindtap="onZoomIn">
          <text class="zoom-btn-text">＋</text>
        </view>
        <view class="zoom-btn" bindtap="onZoomOut">
          <text class="zoom-btn-text">－</text>
        </view>
      </view>

      <!-- 背景切换 -->
      <view class="bg-switch">
        <view
          wx:for="{{bgOptions}}"
          wx:key="*this"
          class="bg-dot {{bgColor === item ? 'bg-dot-active' : ''}}"
          style="background: {{item}}"
          data-color="{{item}}"
          bindtap="onSwitchBg"
        ></view>
      </view>
    </view>

    <!-- 底部选珠区：素材类型Tab + 搜索 + 左竖分类 + 右网格 -->
    <view class="panel">
      <!-- 素材类型 Tab（饰品/配饰/吊坠，对齐 diy-design；配饰/吊坠素材待后端提供） -->
      <view class="mtype-tabs">
        <view
          wx:for="{{materialTypeTabs}}"
          wx:key="key"
          class="mtype-tab {{activeMaterialType === item.key ? 'mtype-tab-active' : ''}}"
          data-type="{{item.key}}"
          bindtap="onMaterialTypeChange"
        >
          <text class="mtype-tab-text">{{item.label}}</text>
        </view>
      </view>
      <!-- 素材提示条（可关闭，对齐旧版工作台"长按材料可查看实拍图"） -->
      <view class="material-tip" wx:if="{{showMaterialTip}}">
        <text class="material-tip-text">💡 长按素材可查看详情大图</text>
        <view class="material-tip-close" bindtap="onCloseMaterialTip">
          <text class="material-tip-close-text">×</text>
        </view>
      </view>
      <view class="search-bar">
        <input
          class="search-input"
          placeholder="搜索素材名称"
          value="{{keyword}}"
          bindinput="onSearchInput"
          confirm-type="search"
        />
        <view class="search-clear" wx:if="{{keyword}}" bindtap="onSearchClear">
          <text class="search-clear-text">清除</text>
        </view>
      </view>

      <view class="panel-body">
        <!-- 左侧竖分类（按当前素材大类下的 group_code 聚合，来自后端素材数据） -->
        <scroll-view
          class="cat-side"
          scroll-y
          enhanced
          show-scrollbar="{{false}}"
          wx:if="{{categories.length > 0}}"
        >
          <view
            wx:for="{{categories}}"
            wx:key="key"
            class="cat-side-item {{activeCategory === item.key && !keyword ? 'cat-side-item-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onSwitchCategory"
          >
            <text class="cat-side-text">{{item.label}}</text>
          </view>
        </scroll-view>

        <!-- 右侧珠子网格 -->
        <scroll-view class="grid-side" scroll-y enhanced show-scrollbar="{{false}}">
          <view class="grid-inner">
            <view
              wx:for="{{groups}}"
              wx:for-item="group"
              wx:for-index="gIndex"
              wx:key="name"
              class="bead-card {{group.skus[group.sizeIndex]._disabled ? 'bead-card-disabled' : ''}}"
              data-group="{{gIndex}}"
              bindtap="onSelectBead"
              bindlongpress="onBeadLongPress"
            >
              <view class="bead-card-thumb-wrap">
                <image
                  class="bead-card-thumb"
                  src="{{group.skus[group.sizeIndex].image}}"
                  mode="aspectFit"
                />
                <view class="bead-card-badge" wx:if="{{group.usedCount > 0}}">
                  <text class="bead-card-badge-text">{{group.usedCount}}</text>
                </view>
                <!-- 售罄遮罩（后端 stock===0 时显示） -->
                <view class="bead-card-soldout" wx:if="{{group.skus[group.sizeIndex].stock === 0}}">
                  <text class="bead-card-soldout-text">售罄</text>
                </view>
              </view>
              <text class="bead-card-name">{{group.name}}</text>
              <!-- 尺码 +/- 切换 -->
              <view class="size-switch" catchtap="">
                <view
                  class="size-btn"
                  data-group="{{gIndex}}"
                  data-dir="-1"
                  catchtap="onSwitchSize"
                >
                  <text class="size-btn-text">-</text>
                </view>
                <text class="size-current">{{group.skus[group.sizeIndex].sizeText}}</text>
                <view class="size-btn" data-group="{{gIndex}}" data-dir="1" catchtap="onSwitchSize">
                  <text class="size-btn-text">+</text>
                </view>
              </view>
              <text class="bead-card-price"
                >{{group.skus[group.sizeIndex].price}}
                {{group.skus[group.sizeIndex].priceLabel}}</text
              >
            </view>
            <view class="grid-empty" wx:if="{{groups.length === 0}}">
              <!-- 空态文案由 TS 预计算（gridEmptyText）：配饰/吊坠素材属后端业务数据，未接入前如实显示空态 -->
              <text class="grid-empty-text">{{gridEmptyText}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 底部主 CTA：保存草稿 + 完成设计（对齐 diy-design 生产闭环） -->
    <view class="cta-bar">
      <view class="cta-summary">
        <text class="cta-price">{{costText}}</text>
        <text class="cta-count">共 {{beadCount}} 颗</text>
      </view>
      <view class="cta-actions">
        <view
          class="cta-btn cta-btn-ghost {{beadCount > 0 ? '' : 'cta-btn-disabled'}}"
          bindtap="onSaveDraft"
        >
          <text class="cta-btn-ghost-text">保存草稿</text>
        </view>
        <view class="cta-btn {{canSubmit ? '' : 'cta-btn-disabled'}}" bindtap="onSubmit">
          <text class="cta-btn-text">完成设计</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 珠子详情弹窗（meaning/weight/energy/pairing 为后端可选字段，缺失时对应行隐藏） -->
  <view
    class="modal-mask"
    wx:if="{{detailVisible}}"
    catchtap="onCloseDetail"
    catchtouchmove="onCloseDetail"
  >
    <view class="detail-card" catchtap="">
      <image
        class="detail-image"
        src="{{detailBead.image}}"
        mode="aspectFit"
        wx:if="{{detailBead}}"
      />
      <text class="detail-name">{{detailBead.name}}</text>
      <view class="detail-tags">
        <text class="detail-tag">{{detailBead.categoryLabel}}</text>
        <text class="detail-tag">{{detailBead.sizeText}}</text>
        <text class="detail-tag" wx:if="{{detailBead.weight}}">约 {{detailBead.weight}}g</text>
      </view>
      <text class="detail-meaning" wx:if="{{detailBead.meaning}}">{{detailBead.meaning}}</text>
      <view class="detail-attrs" wx:if="{{detailBead.energy || detailBead.pairing}}">
        <view class="detail-attr-row" wx:if="{{detailBead.energy}}">
          <text class="detail-attr-label">能量属性</text>
          <text class="detail-attr-value">{{detailBead.energy}}</text>
        </view>
        <view class="detail-attr-row" wx:if="{{detailBead.pairing}}">
          <text class="detail-attr-label">搭配建议</text>
          <text class="detail-attr-value">{{detailBead.pairing}}</text>
        </view>
      </view>
      <view class="detail-footer">
        <text class="detail-price">{{detailBead.price}} {{detailBead.priceLabel}}</text>
        <view class="detail-add-btn" catchtap="onDetailAdd">
          <text class="detail-add-text">加入手串</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 尺码/手围选择弹窗（底部半屏；档位来自后端 sizing_rules.size_options，手围驱动 §3.1） -->
  <view
    class="sheet-mask"
    wx:if="{{sizeVisible}}"
    catchtap="onCloseSize"
    catchtouchmove="onCloseSize"
  >
    <view class="wrist-card wrist-card-sheet" catchtap="">
      <text class="wrist-title">选择{{sizeTermLabel}}尺码</text>
      <!-- 测量引导入口（前端静态图文，跳转教程"量手围"Tab，§3.1） -->
      <view class="wrist-measure-link" catchtap="onOpenMeasureGuide">
        <text class="wrist-measure-link-text">不确定{{sizeTermLabel}}？查看测量方法 ›</text>
      </view>
      <view class="wear-options size-options">
        <view
          wx:for="{{sizeOptions}}"
          wx:key="label"
          class="wear-item wear-item-column {{!customSizeActive && sizeIndex === index ? 'wear-item-active' : ''}}"
          data-index="{{index}}"
          bindtap="onSelectSize"
        >
          <text class="wear-item-text">{{item.display}}</text>
          <!-- 档位手围/目标串长（后端毫米字段换算展示，未配置时该行隐藏） -->
          <text class="wear-item-meta" wx:if="{{item.metaText}}">{{item.metaText}}</text>
        </view>
      </view>

      <!-- 自定义手围估算（§3.2 珠径智能算珠：输入 cm + 选珠径 → 后端 estimate 返回参考颗数；
           本地演示模式无后端接口，隐藏该区域） -->
      <block wx:if="{{!localMode && customDiameterOptions.length > 0}}">
        <view class="custom-wrist">
          <text class="custom-wrist-label">自定义{{sizeTermLabel}}</text>
          <view class="custom-wrist-row">
            <input
              class="custom-wrist-input"
              type="digit"
              placeholder="如 15.5"
              value="{{customWristInput}}"
              bindinput="onCustomWristInput"
            />
            <text class="custom-wrist-unit">cm</text>
          </view>
          <view class="custom-diameter-row">
            <text class="custom-diameter-label">主珠径</text>
            <view class="custom-diameter-options">
              <view
                wx:for="{{customDiameterOptions}}"
                wx:key="*this"
                class="custom-diameter-item {{customDiameterIndex === index ? 'custom-diameter-item-active' : ''}}"
                data-index="{{index}}"
                catchtap="onSelectCustomDiameter"
              >
                <text class="custom-diameter-item-text">{{item}}mm</text>
              </view>
            </view>
          </view>
          <view
            class="custom-estimate-btn {{estimating ? 'custom-estimate-btn-disabled' : ''}}"
            catchtap="onEstimateSize"
          >
            <text class="custom-estimate-btn-text"
              >{{estimating ? '估算中...' : '算一算参考颗数'}}</text
            >
          </view>
          <!-- 估算结果（后端权威换算，展示带"约"） -->
          <text class="custom-estimate-result" wx:if="{{estimateText}}">{{estimateText}}</text>
          <view class="custom-use-btn" wx:if="{{estimateReady}}" catchtap="onUseEstimate">
            <text class="custom-use-btn-text">使用该{{sizeTermLabel}}</text>
          </view>
        </view>
      </block>

      <text class="wrist-note" wx:if="{{capacityLimited}}"
        >当前尺码最多可放 {{capacityBeads}}
        颗（兜底防呆，由款式规则规定）。串长以"目标长度"为准，超出会提示调整。</text
      >
      <view class="wrist-confirm" catchtap="onCloseSize">
        <text class="wrist-confirm-text">确定</text>
      </view>
    </view>
  </view>

  <!-- 五行雷达图弹窗（数据依赖后端 five_elements，缺失显示空态） -->
  <view
    class="modal-mask"
    wx:if="{{wuxingVisible}}"
    catchtap="onCloseWuxing"
    catchtouchmove="onCloseWuxing"
  >
    <view class="wuxing-card" catchtap="">
      <text class="wuxing-title">五行分析</text>
      <!-- 有数据：绘制雷达图 + 占比摘要 -->
      <view wx:if="{{wuxingHasData}}" class="wuxing-body">
        <canvas type="2d" id="wuxingCanvas" class="wuxing-canvas"></canvas>
        <text class="wuxing-summary">{{wuxingSummary}}</text>
        <text class="wuxing-note">五行相生：木生火 · 火生土 · 土生金 · 金生水 · 水生木</text>
      </view>
      <!-- 无数据：空态提示（绝不用假数据） -->
      <view wx:else class="wuxing-empty">
        <text class="wuxing-empty-title">暂无五行数据</text>
        <text class="wuxing-empty-desc">五行属性需由后端下发，接入后自动显示分布雷达图</text>
      </view>
      <view class="wuxing-confirm" catchtap="onCloseWuxing">
        <text class="wuxing-confirm-text">知道了</text>
      </view>
    </view>
  </view>

  <!-- 教程引导弹窗 -->
  <view
    class="modal-mask"
    wx:if="{{guideVisible}}"
    catchtap="onCloseGuide"
    catchtouchmove="onCloseGuide"
  >
    <view class="guide-card" catchtap="">
      <!-- 四 Tab 使用指南（玩法/量手围/珠子尺寸/天然瑕疵） -->
      <view class="guide-tabs">
        <view
          wx:for="{{guideTabs}}"
          wx:key="key"
          class="guide-tab {{guideTabIndex === index ? 'guide-tab-active' : ''}}"
          data-index="{{index}}"
          bindtap="onSwitchGuideTab"
        >
          <text class="guide-tab-text">{{item.title}}</text>
        </view>
      </view>
      <view class="guide-list">
        <text wx:for="{{guideTabs[guideTabIndex].items}}" wx:key="*this" class="guide-item"
          >{{item}}</text
        >
      </view>
      <view class="guide-confirm" catchtap="onCloseGuide">
        <text class="guide-confirm-text">开始设计</text>
      </view>
    </view>
  </view>

  <!-- 镶嵌模式填槽飞入动画（素材卡 → 槽位舞台，串珠模式由 bracelet-tray 自带 DOM 飞入） -->
  <fly-animation id="flyAnim" bind:complete="onFlyComplete" />

  <!-- 登录弹窗（保存/提交前鉴权，对齐 diy-design） -->
  <login-popup
    visible="{{loginPopupVisible}}"
    bind:close="onLoginPopupClose"
    bind:loginsuccess="onLoginSuccess"
  />
</view>
