<custom-navbar title="我的设计" bgColor="#ffffff" textColor="#000000" showBack="{{true}}" />
<view class="diy-works-page">
  <!-- 状态筛选 Tab -->
  <view class="status-tabs">
    <view
      class="status-tab {{currentStatus === item.key ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onStatusTabTap"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <t-loading wx:if="{{loading}}" loading="{{true}}" text="加载中..." theme="spinner" />

  <!-- 加载失败 -->
  <view class="error-wrap" wx:elif="{{hasError}}">
    <text class="error-text">{{errorMessage}}</text>
    <view class="retry-btn" bindtap="_loadWorks">
      <text>重试</text>
    </view>
  </view>

  <!-- 空状态 -->
  <t-empty wx:elif="{{isEmpty}}" description="去设计你的第一件专属饰品吧">
    <view slot="image">🎨</view>
    <view slot="description">暂无设计作品</view>
  </t-empty>

  <!-- 作品列表 -->
  <view class="works-list" wx:else>
    <view
      class="work-card"
      wx:for="{{works}}"
      wx:key="diy_work_id"
      data-index="{{index}}"
      bindtap="onWorkTap"
    >
      <!-- 卡片头部: 作品名称 + 状态标签 -->
      <view class="work-card-header">
        <text class="work-name">{{item._templateName}}</text>
        <text class="work-status {{item._statusColor}}">{{item._statusLabel}}</text>
      </view>

      <!-- 卡片内容: 珠子数量 + 创建时间 -->
      <view class="work-card-body">
        <view class="work-info-row">
          <text class="work-info-label">珠子数量</text>
          <text class="work-info-value">{{item._beadCount}}颗</text>
        </view>
        <view class="work-info-row">
          <text class="work-info-label">创建时间</text>
          <text class="work-info-value">{{item._createdDate}}</text>
        </view>
        <!-- 费用明细（有 total_cost 时展示） -->
        <view class="work-info-row" wx:if="{{item.total_cost.length > 0}}">
          <text class="work-info-label">费用</text>
          <view class="work-cost-list">
            <text
              class="work-cost-item"
              wx:for="{{item.total_cost}}"
              wx:for-item="cost"
              wx:key="asset_code"
              >{{cost.amount}} {{cost.asset_code}}</text
            >
          </view>
        </view>
      </view>

      <!-- 卡片底部: 操作提示 -->
      <view class="work-card-footer">
        <text class="work-action-hint" wx:if="{{item.status === 'draft'}}">点击继续编辑</text>
        <text class="work-action-hint" wx:elif="{{item.status === 'frozen'}}">点击完成或取消</text>
        <text class="work-action-hint" wx:elif="{{item.status === 'completed'}}">点击查看详情</text>
        <text class="work-action-hint" wx:else>点击查看</text>
        <text class="work-arrow">></text>
      </view>
    </view>
  </view>
</view>
