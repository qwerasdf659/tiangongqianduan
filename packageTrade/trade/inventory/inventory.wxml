<!--packageTrade/trade/inventory/inventory.wxml - 我的仓库页面（游戏仓库 + 电商融合风格）-->
<!--
  后端字段（snake_case）:
  item_id, tracking_code, item_type, item_type_display, item_name, item_value,
  status, status_display, rarity_code, rarity_display, rarity_color,
  item_description, acquired_at, expires_at, has_redemption_code, allowed_actions,
  merchant_id, merchant_name（多商家架构P1，LEFT JOIN merchants表，可null）

  操作标志（由后端 allowed_actions 数组驱动，前端仅做 Array.includes() 转布尔）：
  can_use           = allowed_actions.includes('use')
  can_generate_code = allowed_actions.includes('redeem') && !has_redemption_code
  can_view_code     = has_redemption_code && allowed_actions.includes('redeem')
  can_sell          = allowed_actions.includes('sell')
-->
<custom-navbar title="我的仓库" bgColor="#ffffff" textColor="#000000" showBack="{{true}}" />

<!-- 🔴 引入WXS模板辅助函数（仅用于图标、时间格式化、过期判断等UI逻辑） -->
<wxs module="helper" src="./inventory.wxs" />

<view class="warehouse-page">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- ====== 顶部仓库总览卡片 ====== -->
    <view class="warehouse-overview">
      <view class="overview-card">
        <!-- 仓库等级徽标 -->
        <view class="warehouse-badge">
          <text class="badge-icon">🏰</text>
          <text class="badge-label">我的仓库</text>
        </view>
      </view>
    </view>

    <!-- ====== 资产货币栏（轻量横排） ====== -->
    <view class="asset-bar" wx:if="{{backpackAssets.length > 0}}">
      <scroll-view
        type="custom"
        class="asset-bar-scroll"
        scroll-x="true"
        enhanced="true"
        show-scrollbar="false"
      >
        <view class="asset-bar-list">
          <view
            class="asset-chip"
            wx:for="{{backpackAssets}}"
            wx:key="asset_code"
            bind:tap="onSellAsset"
            data-asset="{{item}}"
          >
            <image class="asset-chip-icon-img" src="{{item.icon_path}}" mode="aspectFit" />
            <text class="asset-chip-name">{{item.display_name}}</text>
            <text class="asset-chip-num">{{item.available_amount}}</text>
            <text class="asset-chip-frozen" wx:if="{{item.frozen_amount > 0}}"
              >冻{{item.frozen_amount}}</text
            >
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ====== 物品分类标签页（胶囊式） ====== -->
    <view class="category-tabs-wrapper">
      <scroll-view
        type="custom"
        class="category-tabs-scroll"
        scroll-x="true"
        enhanced="true"
        show-scrollbar="false"
      >
        <view class="category-tabs">
          <view
            class="tab-pill {{currentCategory === 'all' ? 'active' : ''}}"
            bind:tap="onCategoryChange"
            data-category="all"
          >
            <text class="tab-pill-icon">📦</text>
            <text class="tab-pill-label">全部</text>
            <text class="tab-pill-count">{{categoryStats.all}}</text>
          </view>
          <view
            class="tab-pill {{currentCategory === 'prize' ? 'active' : ''}}"
            bind:tap="onCategoryChange"
            data-category="prize"
          >
            <text class="tab-pill-icon">🏆</text>
            <text class="tab-pill-label">奖品</text>
            <text class="tab-pill-count">{{categoryStats.prize}}</text>
          </view>
          <view
            class="tab-pill {{currentCategory === 'voucher' ? 'active' : ''}}"
            bind:tap="onCategoryChange"
            data-category="voucher"
          >
            <text class="tab-pill-icon">🎫</text>
            <text class="tab-pill-label">兑换券</text>
            <text class="tab-pill-count">{{categoryStats.voucher}}</text>
          </view>
          <view
            class="tab-pill {{currentCategory === 'product' ? 'active' : ''}}"
            bind:tap="onCategoryChange"
            data-category="product"
          >
            <text class="tab-pill-icon">📱</text>
            <text class="tab-pill-label">商品</text>
            <text class="tab-pill-count">{{categoryStats.product}}</text>
          </view>
          <view
            class="tab-pill {{currentCategory === 'tradable_item' ? 'active' : ''}}"
            bind:tap="onCategoryChange"
            data-category="tradable_item"
          >
            <text class="tab-pill-icon">🔄</text>
            <text class="tab-pill-label">可交易</text>
            <text class="tab-pill-count">{{categoryStats.tradable_item}}</text>
          </view>
          <view
            class="tab-pill {{currentCategory === 'service' ? 'active' : ''}}"
            bind:tap="onCategoryChange"
            data-category="service"
          >
            <text class="tab-pill-icon">🎁</text>
            <text class="tab-pill-label">服务</text>
            <text class="tab-pill-count">{{categoryStats.service}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ====== 搜索 + 排序工具栏 ====== -->
    <view class="search-toolbar">
      <view class="search-pill">
        <text class="search-pill-icon">🔍</text>
        <input
          class="search-pill-input"
          placeholder="搜索物品名称..."
          value="{{searchKeyword}}"
          bind:input="onSearchInput"
        />
      </view>
      <view class="sort-btn" bind:tap="onShowFilter">
        <text class="sort-btn-icon">⚙️</text>
        <text class="sort-btn-text">排序</text>
      </view>
    </view>

    <!-- ====== 物品列表区域 ====== -->
    <view class="items-area">
      <!-- 加载骨架屏 -->
      <view class="skeleton-list" wx:if="{{loading}}">
        <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
          <view class="skeleton-icon"></view>
          <view class="skeleton-lines">
            <view class="skeleton-line long"></view>
            <view class="skeleton-line short"></view>
          </view>
        </view>
      </view>

      <!-- 错误状态 -->
      <view class="error-card" wx:elif="{{hasError}}">
        <text class="error-emoji">😵</text>
        <text class="error-msg">{{errorMessage}}</text>
        <text class="error-sub">{{errorDetail}}</text>
        <button class="retry-action-btn" bind:tap="initPage">重新加载</button>
      </view>

      <!-- 物品卡片列表 -->
      <view class="item-grid" wx:else>
        <block wx:if="{{filteredItems.length > 0}}">
          <view
            class="item-card rarity-border-{{item.rarity_code || 'common'}}"
            wx:for="{{filteredItems}}"
            wx:key="item_id"
            bind:tap="onViewItem"
            data-item="{{item}}"
          >
            <!-- 稀有度光效条 -->
            <view class="rarity-glow rarity-glow-{{item.rarity_code || 'common'}}"></view>

            <!-- 卡片主体 -->
            <view class="item-card-body">
              <!-- 左侧：图标 -->
              <view class="item-avatar rarity-bg-{{item.rarity_code || 'common'}}">
                <text class="item-avatar-icon">{{helper.getItemIcon(item.item_type)}}</text>
              </view>

              <!-- 中间：信息 -->
              <view class="item-info">
                <view class="item-name-row">
                  <text class="item-card-name">{{item.item_name}}</text>
                  <text
                    class="item-rarity-tag rarity-tag-{{item.rarity_code || 'common'}}"
                    wx:if="{{item.rarity_code && item.rarity_code !== 'common'}}"
                    >{{item.rarity_display}}</text
                  >
                </view>

                <!-- 品质等级 + 限量编号（后端 instance_attributes / serial_number） -->
                <view class="item-quality-row" wx:if="{{item._qualityGrade || item._editionText}}">
                  <view
                    class="quality-badge {{item._qualityCssClass}}"
                    wx:if="{{item._qualityGrade}}"
                    style="border-color: {{item._qualityColorHex}}"
                  >
                    <text class="quality-badge-text" style="color: {{item._qualityColorHex}}"
                      >{{item._qualityGrade}}</text
                    >
                    <text
                      class="quality-score-text"
                      wx:if="{{item._qualityScore}}"
                      style="color: {{item._qualityColorHex}}"
                      >{{item._qualityScore}}</text
                    >
                  </view>
                  <text class="edition-tag" wx:if="{{item._editionText}}"
                    >{{item._editionText}}</text
                  >
                  <text class="pattern-tag" wx:if="{{item._patternId}}"
                    >纹理#{{item._patternId}}</text
                  >
                </view>

                <view class="item-tracking-row" wx:if="{{item.tracking_code}}">
                  <text class="tracking-code-text">{{item.tracking_code}}</text>
                  <view
                    class="tracking-timeline-btn"
                    catchtap="onViewTimeline"
                    data-item="{{item}}"
                  >
                    <text class="tracking-timeline-btn-icon">📜</text>
                    <text class="tracking-timeline-btn-text">流转</text>
                  </view>
                </view>
                <text class="item-type-label" wx:if="{{item.item_type_display}}"
                  >{{item.item_type_display}}</text
                >
                <view class="item-merchant-tag" wx:if="{{item.merchant_name}}">
                  <text class="merchant-tag-icon">🏪</text>
                  <text class="merchant-tag-text">来自：{{item.merchant_name}}</text>
                </view>
                <text class="item-brief" wx:if="{{item.item_description}}"
                  >{{item.item_description}}</text
                >
              </view>

              <!-- 右侧：状态 -->
              <view class="item-status-col">
                <view class="item-status-pill status-pill-{{item.status}}">
                  <text>{{item.status_display || '可用'}}</text>
                </view>
              </view>
            </view>

            <!-- 交易冷却期倒计时（后端 item_holds hold_type='trade_cooldown'） -->
            <view class="item-cooldown-row" wx:if="{{item._hasCooldown}}">
              <text class="cooldown-icon">🔒</text>
              <text class="cooldown-text">交易冷却中 · 剩余 {{item._cooldownRemaining}}</text>
            </view>

            <!-- 过期/时间提示 -->
            <view class="item-meta-row" wx:if="{{item.expires_at}}">
              <text class="meta-clock">⏰</text>
              <text class="meta-text {{helper.isExpiringSoon(item.expires_at) ? 'expiring' : ''}}">
                {{helper.isExpiringSoon(item.expires_at) ? '即将过期 · ' :
                ''}}{{helper.formatTime(item.expires_at)}}
              </text>
            </view>

            <!-- 操作按钮组 -->
            <view
              class="item-action-bar"
              wx:if="{{item.can_use || item.can_generate_code || item.can_view_code || item.can_sell}}"
            >
              <button
                class="item-action-btn action-use"
                wx:if="{{item.can_use}}"
                catchtap="onUseItem"
                data-item="{{item}}"
              >
                <text>✨ 使用</text>
              </button>
              <button
                class="item-action-btn action-code"
                wx:if="{{item.can_generate_code}}"
                catchtap="onGenerateCode"
                data-item="{{item}}"
              >
                <text wx:if="{{item.item_type === 'product'}}">🎫 到店领取</text>
                <text wx:elif="{{item.item_type === 'voucher'}}">🎫 到店使用</text>
                <text wx:else>🎫 核销码</text>
              </button>
              <button
                class="item-action-btn action-code"
                wx:if="{{item.can_view_code}}"
                catchtap="onViewExistingCode"
                data-item="{{item}}"
              >
                <text>📱 查看兑换码</text>
              </button>
              <button
                class="item-action-btn action-sell"
                wx:if="{{item.can_sell}}"
                catchtap="onSellItem"
                data-item="{{item}}"
              >
                <text>🏪 上架</text>
              </button>
            </view>
          </view>
        </block>

        <!-- ====== 加载更多提示 ====== -->
        <view class="load-more-tip" wx:if="{{filteredItems.length > 0 && hasMoreItems}}">
          <text class="load-more-text">上滑加载更多...</text>
        </view>
        <view
          class="load-more-tip"
          wx:if="{{filteredItems.length > 0 && !hasMoreItems && filteredItems.length >= 50}}"
        >
          <text class="load-more-text">已显示全部物品</text>
        </view>

        <!-- ====== 空仓库引导 ====== -->
        <view class="empty-warehouse" wx:if="{{!loading && filteredItems.length === 0}}">
          <view class="empty-chest">
            <view class="chest-body">
              <view class="chest-lid"></view>
              <view class="chest-box"></view>
              <view class="chest-sparkle s1">✨</view>
              <view class="chest-sparkle s2">⭐</view>
              <view class="chest-sparkle s3">💫</view>
            </view>
          </view>
          <text class="empty-title-text">仓库还是空的呢</text>
          <text class="empty-subtitle-text">参与活动赢取奖品，填满你的仓库吧！</text>

          <view class="empty-guide-flow">
            <view class="guide-step">
              <view class="guide-step-circle">🎰</view>
              <text class="guide-step-label">参与抽奖</text>
            </view>
            <text class="guide-arrow">→</text>
            <view class="guide-step">
              <view class="guide-step-circle">🏆</view>
              <text class="guide-step-label">赢取奖品</text>
            </view>
            <text class="guide-arrow">→</text>
            <view class="guide-step">
              <view class="guide-step-circle">🏰</view>
              <text class="guide-step-label">收入仓库</text>
            </view>
          </view>

          <button class="go-lottery-btn" bind:tap="goToLottery">
            <text>🎉 立即抽奖</text>
          </button>
        </view>
      </view>
    </view>

    <!-- ====== 底部使用小贴士 ====== -->
    <view class="tips-bar" wx:if="{{!loading && filteredItems.length > 0}}">
      <view class="tips-bar-inner">
        <text class="tips-bar-icon">💡</text>
        <text class="tips-bar-text">点击物品查看详情 · 注意查看有效期 · 核销码仅显示一次</text>
      </view>
    </view>

    <!-- ====== 物品详情半屏面板（替代 wx.showModal 纯文本弹窗） ====== -->
    <view class="detail-overlay" wx:if="{{showItemDetail}}" catchtap="closeItemDetail">
      <view class="detail-sheet" catchtap="">
        <view class="detail-loading" wx:if="{{itemDetailLoading}}">
          <text class="detail-loading-icon">⏳</text>
          <text class="detail-loading-text">加载物品详情...</text>
        </view>
        <block wx:elif="{{itemDetail}}">
          <view class="detail-header">
            <view class="detail-header-left">
              <view class="detail-icon-circle rarity-bg-{{itemDetail.rarity_code || 'common'}}">
                <text class="detail-icon-emoji">{{helper.getItemIcon(itemDetail.item_type)}}</text>
              </view>
              <view class="detail-title-area">
                <view class="detail-name-row">
                  <text class="detail-item-name">{{itemDetail.item_name}}</text>
                  <text
                    class="detail-rarity-tag rarity-tag-{{itemDetail.rarity_code || 'common'}}"
                    wx:if="{{itemDetail.rarity_code && itemDetail.rarity_code !== 'common'}}"
                    >{{itemDetail.rarity_display}}</text
                  >
                </view>
                <text class="detail-type-text">{{itemDetail.item_type_display}}</text>
              </view>
            </view>
            <view class="detail-close-btn" bindtap="closeItemDetail">
              <text class="detail-close-icon">✕</text>
            </view>
          </view>
          <view class="detail-rarity-bar rarity-glow-{{itemDetail.rarity_code || 'common'}}"></view>
          <view class="detail-tracking" wx:if="{{itemDetail.tracking_code}}">
            <view class="tracking-info">
              <text class="tracking-label">追踪码</text>
              <text class="tracking-value">{{itemDetail.tracking_code}}</text>
            </view>
            <view class="tracking-copy-btn" bindtap="onCopyTrackingCode">
              <text class="tracking-copy-text">复制</text>
            </view>
          </view>
          <!-- 品质等级+限量编号区域（后端 instance_attributes / serial_number / edition_total） -->
          <view
            class="detail-quality-section"
            wx:if="{{itemDetail._qualityGrade || itemDetail._editionText}}"
          >
            <view class="detail-quality-card" wx:if="{{itemDetail._qualityGrade}}">
              <view class="detail-quality-header">
                <text class="detail-quality-label">品质等级</text>
                <text class="detail-quality-grade" style="color: {{itemDetail._qualityColorHex}}"
                  >{{itemDetail._qualityGrade}}</text
                >
              </view>
              <view class="detail-quality-score-row" wx:if="{{itemDetail._qualityScore}}">
                <text class="detail-quality-score-label">品质分</text>
                <text
                  class="detail-quality-score-value"
                  style="color: {{itemDetail._qualityColorHex}}"
                  >{{itemDetail._qualityScore}}</text
                >
              </view>
              <view class="detail-pattern-row" wx:if="{{itemDetail._patternId}}">
                <text class="detail-pattern-label">纹理编号</text>
                <text class="detail-pattern-value">#{{itemDetail._patternId}}</text>
              </view>
            </view>
            <view class="detail-edition-card" wx:if="{{itemDetail._editionText}}">
              <text class="detail-edition-label">限量编号</text>
              <text class="detail-edition-value">{{itemDetail._editionText}}</text>
            </view>
          </view>

          <!-- 冷却期提示（后端 holds 中 trade_cooldown） -->
          <view class="detail-cooldown-bar" wx:if="{{itemDetail._hasCooldown}}">
            <text class="detail-cooldown-icon">🔒</text>
            <text class="detail-cooldown-text"
              >交易冷却中 · 剩余 {{itemDetail._cooldownRemaining}}</text
            >
          </view>

          <view class="detail-grid">
            <view class="detail-grid-item" wx:if="{{itemDetail.status_display}}">
              <text class="grid-label">状态</text>
              <view class="grid-value-row">
                <view class="mini-status-pill status-pill-{{itemDetail.status}}">
                  <text>{{itemDetail.status_display}}</text>
                </view>
              </view>
            </view>
            <view class="detail-grid-item" wx:if="{{itemDetail.item_value}}">
              <text class="grid-label">价值</text>
              <text class="grid-value highlight">{{itemDetail.item_value}} 积分</text>
            </view>
            <view class="detail-grid-item" wx:if="{{itemDetail.acquired_at}}">
              <text class="grid-label">获得时间</text>
              <text class="grid-value">{{helper.formatTime(itemDetail.acquired_at)}}</text>
            </view>
            <view class="detail-grid-item" wx:if="{{itemDetail.expires_at}}">
              <text class="grid-label">过期时间</text>
              <text
                class="grid-value {{helper.isExpiringSoon(itemDetail.expires_at) ? 'expiring' : ''}}"
                >{{helper.formatTime(itemDetail.expires_at)}}</text
              >
            </view>
            <view class="detail-grid-item" wx:if="{{itemDetail.merchant_name}}">
              <text class="grid-label">商家来源</text>
              <view class="grid-value-row">
                <view class="merchant-source-badge">
                  <text class="merchant-source-icon">🏪</text>
                  <text class="merchant-source-name">{{itemDetail.merchant_name}}</text>
                </view>
              </view>
            </view>
            <view class="detail-grid-item full-width" wx:if="{{itemDetail.has_redemption_code}}">
              <text class="grid-label">核销码</text>
              <view class="grid-value-row">
                <text class="grid-value">已生成</text>
                <view class="detail-view-code-btn" bindtap="onViewCodeFromDetail">
                  <text class="view-code-btn-text">查看兑换码</text>
                  <text class="view-code-btn-arrow">›</text>
                </view>
              </view>
            </view>
          </view>
          <view class="detail-desc-area" wx:if="{{itemDetail.item_description}}">
            <text class="detail-desc-label">物品描述</text>
            <text class="detail-desc-content">{{itemDetail.item_description}}</text>
          </view>
          <view class="detail-actions" wx:if="{{itemDetail.tracking_code}}">
            <view class="detail-timeline-btn" bindtap="onViewTimelineFromDetail">
              <text class="timeline-btn-icon">📜</text>
              <text class="timeline-btn-text">查看流转记录</text>
              <text class="timeline-btn-arrow">›</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- ====== 核销码QR码展示弹窗（模型A：O2O动态码） ====== -->
    <!--
    业务流程（文档步骤1.9）:
    用户在背包点击"到店领取"/"到店使用" → 生成核销码 → 展示动态QR码（5分钟自动刷新）
    + 底部12位文本码（备用：扫码不便时口述给商家）
    商家扫码核销: POST /api/v4/shop/redemption/scan（RQRV1_前缀QR码）
    商家输码核销: POST /api/v4/shop/redemption/fulfill（12位Base32文本码）
  -->
    <view class="redemption-qr-overlay" wx:if="{{showRedemptionQR}}" catchtap="closeRedemptionQR">
      <view class="redemption-qr-modal" catchtap="">
        <!-- 弹窗标题 -->
        <view class="rqr-header">
          <text class="rqr-title">{{redemptionActionLabel}}码</text>
          <view class="rqr-close" bindtap="closeRedemptionQR">
            <text class="rqr-close-icon">✕</text>
          </view>
        </view>

        <!-- 物品信息 -->
        <view class="rqr-item-info">
          <text class="rqr-item-name">{{redemptionItemName}}</text>
          <text class="rqr-item-tip"
            >请在有效期内到店出示此码，由店员扫码完成{{redemptionActionLabel}}</text
          >
        </view>

        <!-- QR码展示区域 -->
        <view class="rqr-code-area">
          <!-- Canvas（隐藏，仅用于绘制QR码导出图片） -->
          <canvas
            id="redemptionQRCanvas"
            type="2d"
            class="rqr-canvas-hidden"
            style="width: 400px; height: 400px; position: fixed; left: -9999px; top: -9999px"
          ></canvas>

          <!-- QR码图片展示 -->
          <view class="rqr-image-wrapper" wx:if="{{redemptionQRImage && !qrExpired}}">
            <image class="rqr-image" src="{{redemptionQRImage}}" mode="aspectFit" />
          </view>

          <!-- QR码过期/刷新中占位 -->
          <view class="rqr-image-wrapper rqr-expired" wx:elif="{{qrExpired || qrRefreshing}}">
            <text class="rqr-expired-icon" wx:if="{{qrRefreshing}}">⏳</text>
            <text class="rqr-expired-icon" wx:else>🔄</text>
            <text class="rqr-expired-text" wx:if="{{qrRefreshing}}">刷新中...</text>
            <text class="rqr-expired-text" wx:else>QR码已过期</text>
            <view class="rqr-refresh-btn" wx:if="{{!qrRefreshing}}" bindtap="onRefreshRedemptionQR">
              <text class="rqr-refresh-text">点击刷新</text>
            </view>
          </view>

          <!-- QR码加载中（首次生成） -->
          <view
            class="rqr-image-wrapper rqr-loading"
            wx:elif="{{!redemptionQRImage && !qrExpired}}"
          >
            <text class="rqr-loading-icon">⏳</text>
            <text class="rqr-loading-text">生成中...</text>
          </view>

          <!-- QR码倒计时 -->
          <view class="rqr-countdown" wx:if="{{qrCountdownText && !qrExpired}}">
            <text class="rqr-countdown-label">QR码有效期</text>
            <text class="rqr-countdown-value {{qrCountdown <= 60 ? 'expiring' : ''}}"
              >{{qrCountdownText}}</text
            >
          </view>
        </view>

        <!-- 分隔线 + 文本码备用 -->
        <view class="rqr-divider">
          <view class="rqr-divider-line"></view>
          <text class="rqr-divider-text">或出示文本码</text>
          <view class="rqr-divider-line"></view>
        </view>

        <view class="rqr-text-code">
          <text class="rqr-text-code-value">{{redemptionTextCode}}</text>
          <view class="rqr-copy-btn" bindtap="onCopyRedemptionCode">
            <text class="rqr-copy-text">复制</text>
          </view>
        </view>

        <!-- 核销码有效期 -->
        <view class="rqr-expires" wx:if="{{redemptionExpiresAt}}">
          <text class="rqr-expires-text">核销码有效期至：{{redemptionExpiresAt}}</text>
        </view>

        <!-- 注意事项 -->
        <view class="rqr-notice">
          <text class="rqr-notice-icon">⚠️</text>
          <text class="rqr-notice-text">核销码仅可使用一次，QR码每5分钟自动刷新</text>
        </view>
      </view>
    </view>

    <!-- ====== 物品流转时间线弹窗 ====== -->
    <!--
    后端API: GET /api/v4/backpack/items/:item_id/timeline
    数据来源: items + item_ledger + item_holds 表 JOIN
    事件类型: mint(铸造) / transfer(转移) / use(使用) / hold(锁定) / release(释放) / expire(过期)
  -->
    <view class="timeline-overlay" wx:if="{{showTimeline}}" catchtap="closeTimeline">
      <view class="timeline-modal" catchtap="">
        <view class="timeline-header">
          <text class="timeline-title">物品追踪</text>
          <view class="timeline-close" bindtap="closeTimeline">
            <text class="timeline-close-icon">✕</text>
          </view>
        </view>

        <view class="timeline-loading" wx:if="{{timelineLoading}}">
          <text class="timeline-loading-icon">⏳</text>
          <text class="timeline-loading-text">加载追踪信息...</text>
        </view>

        <view class="timeline-body" wx:elif="{{timelineEvents.length > 0}}">
          <view class="timeline-item-info">
            <text class="timeline-item-name">{{timelineItemName}}</text>
            <view class="timeline-meta-row" wx:if="{{timelineTrackingCode}}">
              <text class="timeline-meta-label">追踪码</text>
              <text class="timeline-meta-value monospace">{{timelineTrackingCode}}</text>
            </view>
            <view class="timeline-meta-row" wx:if="{{timelineSource}}">
              <text class="timeline-meta-label">来源</text>
              <text class="timeline-meta-value">{{timelineSource}}</text>
            </view>
          </view>

          <view class="timeline-divider"></view>

          <scroll-view
            type="list"
            class="timeline-scroll"
            scroll-y="true"
            enhanced="true"
            show-scrollbar="false"
          >
            <view class="timeline-track">
              <view class="timeline-event" wx:for="{{timelineEvents}}" wx:key="index">
                <view class="event-dot-col">
                  <view
                    class="event-dot {{index === 0 ? 'dot-first' : ''}} {{index === timelineEvents.length - 1 ? 'dot-last' : ''}}"
                  >
                    <text class="event-dot-icon">{{item.icon}}</text>
                  </view>
                  <view class="event-line" wx:if="{{index < timelineEvents.length - 1}}"></view>
                </view>
                <view class="event-content">
                  <text class="event-detail">{{item.detail}}</text>
                  <text class="event-time">{{item.formatted_time}}</text>
                </view>
              </view>
            </view>
          </scroll-view>

          <view class="timeline-ledger-check" wx:if="{{timelineLedgerStatus}}">
            <text class="ledger-icon">{{timelineLedgerStatus === 'balanced' ? '✅' : '⚠️'}}</text>
            <text class="ledger-text"
              >{{timelineLedgerStatus === 'balanced' ? '账本守恒验证通过' : '账本数据异常'}}</text
            >
          </view>
        </view>

        <view class="timeline-empty" wx:else>
          <t-empty description="暂无追踪记录" />
        </view>
      </view>
    </view>

    <!-- ====== 排序弹出面板 ====== -->
    <view class="sort-panel {{showFilterPanel ? 'visible' : ''}}" wx:if="{{showFilterPanel}}">
      <view class="sort-mask" bind:tap="onHideFilter"></view>
      <view class="sort-sheet">
        <view class="sort-sheet-header">
          <text class="sort-sheet-title">排序方式</text>
          <text class="sort-sheet-close" bind:tap="onHideFilter">✕</text>
        </view>
        <view class="sort-options">
          <view
            class="sort-option {{currentSort === 'newest' ? 'active' : ''}}"
            bind:tap="onSortChange"
            data-sort="newest"
          >
            <text class="sort-option-icon">🕐</text>
            <text>最新获得</text>
          </view>
          <view
            class="sort-option {{currentSort === 'oldest' ? 'active' : ''}}"
            bind:tap="onSortChange"
            data-sort="oldest"
          >
            <text class="sort-option-icon">📅</text>
            <text>最早获得</text>
          </view>
          <view
            class="sort-option {{currentSort === 'expire_soon' ? 'active' : ''}}"
            bind:tap="onSortChange"
            data-sort="expire_soon"
          >
            <text class="sort-option-icon">⏰</text>
            <text>即将过期</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
    <maintenance-overlay />
  </scroll-view>
</view>
