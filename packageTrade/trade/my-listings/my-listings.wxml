<!--packageTrade/trade/my-listings/my-listings.wxml - 我的挂单页面模板 -->

<view class="my-listings-container">
  <!-- 顶部统计卡片 -->
  <view class="stats-card">
    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-icon-wrap total-icon"><text>📋</text></view>
        <text class="stat-number">{{totalCount}}</text>
        <text class="stat-label">全部挂单</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon-wrap onsale-icon"><text>🏷️</text></view>
        <text class="stat-number stat-on-sale">{{statusTabs[1].count || 0}}</text>
        <text class="stat-label">在售中</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon-wrap sold-icon"><text>🎉</text></view>
        <text class="stat-number stat-sold">{{statusTabs[2].count || 0}}</text>
        <text class="stat-label">已成交</text>
      </view>
    </view>
  </view>

  <!-- 状态筛选标签页 -->
  <view class="status-tabs">
    <view
      class="tab-item {{currentStatus === item.key ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="key"
      bindtap="onStatusTabTap"
      data-status="{{item.key}}"
    >
      <text class="tab-label">{{item.label}}</text>
      <text class="tab-count" wx:if="{{item.count > 0}}">{{item.count}}</text>
    </view>
  </view>

  <!-- 操作指引提示 -->
  <view class="guide-tip" wx:if="{{!isEmpty && listings.length > 0}}">
    <text class="guide-icon">💡</text>
    <text class="guide-text">在售挂单可撤回 · 交易中请等待买家完成 · 已成交不可操作</text>
  </view>

  <!-- 挂单列表 -->
  <view class="listings-wrapper">
    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading && listings.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 挂单卡片列表 -->
    <block wx:if="{{!loading || listings.length > 0}}">
      <view class="listing-card status-{{item.status}}" wx:for="{{listings}}" wx:key="listing_id">
        <!-- 卡片头部：类型标签 + 状态标签 -->
        <view class="card-header">
          <view class="kind-tag {{item.listing_kind}}">
            <text>{{item.listing_kind === 'fungible_asset' ? '💎 资产' : '📦 物品'}}</text>
          </view>
          <view class="status-tag status-tag-{{item.status}}">
            <text>{{item.status_display}}</text>
          </view>
        </view>

        <!-- 卡片主体：商品信息 -->
        <view class="card-body">
          <view class="item-info">
            <text class="item-name">{{item.display_name}}</text>
            <view class="item-meta">
              <text
                class="meta-text"
                wx:if="{{item.listing_kind === 'fungible_asset' && item.offer_amount}}"
                >数量: {{item.offer_amount}}</text
              >
              <text class="meta-text" wx:if="{{item.offer_item_rarity}}"
                >稀有度: {{item.offer_item_rarity}}</text
              >
            </view>
          </view>
          <view class="price-info">
            <text class="price-label">售价</text>
            <view class="price-value-row">
              <text class="price-amount">{{item.price_amount}}</text>
              <text class="price-unit"
                >{{item.price_asset_code === 'DIAMOND' ? '💎' : item.price_asset_code}}</text
              >
            </view>
          </view>
        </view>

        <!-- 卡片底部：时间 + 操作 -->
        <view class="card-footer">
          <text class="created-time">{{item.formattedTime || item.created_at}}</text>
          <view class="card-actions">
            <button
              class="withdraw-btn"
              wx:if="{{item.status === 'active'}}"
              catchtap="onWithdrawListing"
              data-listing="{{item}}"
              disabled="{{withdrawingId === item.listing_id}}"
            >
              {{withdrawingId === item.listing_id ? '撤回中...' : '撤回挂单'}}
            </button>
            <view class="status-hint sold-hint" wx:elif="{{item.status === 'sold'}}">
              <text class="sold-label">✅ 交易完成</text>
              <button
                class="escrow-btn"
                wx:if="{{item.trade_order_id}}"
                catchtap="onViewEscrowCode"
                data-trade_order_id="{{item.trade_order_id}}"
              >
                查看担保状态
              </button>
            </view>
            <view class="status-hint" wx:elif="{{item.status === 'withdrawn'}}">
              <text class="withdrawn-label">已退回背包</text>
            </view>
            <view class="status-hint" wx:elif="{{item.status === 'expired'}}">
              <text class="withdrawn-label">已过期</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多提示 -->
      <view class="load-more" wx:if="{{listings.length > 0 && hasMore}}">
        <text class="load-more-text">{{loading ? '加载中...' : '上拉加载更多'}}</text>
      </view>
      <view class="load-more" wx:if="{{listings.length > 0 && !hasMore}}">
        <view class="no-more-line"></view>
        <text class="load-more-text no-more">已加载全部挂单</text>
        <view class="no-more-line"></view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && isEmpty}}">
      <view class="empty-illustration">
        <view class="empty-circle"></view>
        <text class="empty-icon">📋</text>
      </view>
      <text class="empty-title"
        >{{currentStatus === 'all' ? '暂无挂单记录' : '该状态下暂无挂单'}}</text
      >
      <text class="empty-desc">去仓库上架您的物品或资产，赚取收益吧</text>
      <view class="empty-actions">
        <button class="action-btn-primary" bindtap="goToInventory">📦 去上架</button>
        <button class="action-btn-outline" bindtap="goToMarket">🏪 逛市场</button>
      </view>
    </view>
  </view>

  <!-- 担保码状态弹窗（Phase 4：卖方查看交易担保状态） -->
  <!-- 注意：escrow-status API不返回明文担保码，仅返回状态信息 -->
  <view class="escrow-overlay" wx:if="{{showEscrowModal}}" catchtap="onCloseEscrowModal">
    <view class="escrow-modal" catchtap="">
      <view class="escrow-header">
        <text class="escrow-title">交易担保状态</text>
        <view class="escrow-close" bindtap="onCloseEscrowModal">
          <text class="escrow-close-icon">✕</text>
        </view>
      </view>

      <view class="escrow-loading" wx:if="{{escrowLoading}}">
        <text class="escrow-loading-text">查询担保状态中...</text>
      </view>

      <view class="escrow-body" wx:elif="{{escrowTradeOrderId}}">
        <view class="escrow-notice">
          <text class="escrow-notice-icon">🔑</text>
          <text class="escrow-notice-text"
            >担保码已生成，请当面交付物品后将担保码告知买家。买家输入担保码后交易完成。</text
          >
        </view>
        <view class="escrow-expire" wx:if="{{escrowExpiresAt}}">
          <text class="escrow-expire-text">有效期至 {{escrowExpiresAt}}</text>
        </view>
      </view>

      <view class="escrow-error" wx:else>
        <text class="escrow-error-text">担保状态不可用，请稍后重试</text>
      </view>
    </view>
  </view>
</view>
