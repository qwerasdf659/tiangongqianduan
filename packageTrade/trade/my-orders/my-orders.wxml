<!--买方订单管理页 — 订单列表 + 状态筛选 + 分页 + 担保码确认收货 + 取消交易-->
<!--后端API: GET /api/v4/marketplace/my-orders (status / page / limit)-->
<!--后端API: GET /api/v4/marketplace/trade-orders/:id/escrow-status-->
<!--后端API: POST /api/v4/marketplace/trade-orders/:id/confirm-delivery-->
<!--后端API: POST /api/v4/marketplace/trade-orders/:id/cancel-->

<view class="orders-container">
  <view class="page-header">
    <text class="page-header-title">我的交易订单</text>
    <text class="page-header-subtitle">购买的商品在此管理</text>
  </view>

  <!--状态筛选标签页（对齐 my-listings 页面模式）-->
  <view class="status-tabs">
    <view
      class="tab-item {{currentStatus === item.key ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="key"
      bindtap="onStatusTabTap"
      data-status="{{item.key}}"
    >
      <text class="tab-label">{{item.label}}</text>
      <text class="tab-count" wx:if="{{item.count > 0}}">{{item.count}}</text>
    </view>
  </view>

  <!--加载状态-->
  <view class="loading-state" wx:if="{{loading && orders.length === 0}}">
    <view class="loading-spinner">
      <view class="spinner-dot dot1"></view>
      <view class="spinner-dot dot2"></view>
      <view class="spinner-dot dot3"></view>
    </view>
    <text class="loading-text">加载中...</text>
  </view>

  <!--订单列表-->
  <block wx:if="{{!loading || orders.length > 0}}">
    <view class="order-list" wx:if="{{orders.length > 0}}">
      <view class="order-card" wx:for="{{orders}}" wx:key="trade_order_id">
        <!--订单头部：类型 + 状态-->
        <view class="order-header">
          <view class="order-kind-tag">
            <text>{{item.kindLabel}}</text>
          </view>
          <view class="order-status" style="color: {{item.statusColor}};">
            <text>{{item.statusLabel}}</text>
          </view>
        </view>

        <!--订单内容：商品名称 + 价格-->
        <view
          class="order-body"
          data-listing-id="{{item.market_listing_id}}"
          bindtap="onViewListing"
        >
          <view class="order-info">
            <text class="order-name">{{item.display_name}}</text>
            <text class="order-time">{{item.formattedTime}}</text>
          </view>
          <view class="order-price">
            <text class="order-price-value">{{item.price_amount}}</text>
            <text class="order-price-unit">{{item._priceAssetLabel}}</text>
          </view>
        </view>

        <!--手续费明细（后端 trade_orders 表 gross_amount / fee_amount / net_amount）-->
        <view
          class="order-fee-detail"
          wx:if="{{item.gross_amount || item.fee_amount || item.net_amount}}"
        >
          <view class="fee-row" wx:if="{{item.gross_amount}}">
            <text class="fee-label">总金额</text>
            <text class="fee-value">{{item.gross_amount}} {{item._priceAssetLabel}}</text>
          </view>
          <view class="fee-row" wx:if="{{item.fee_amount}}">
            <text class="fee-label">手续费</text>
            <text class="fee-value">{{item.fee_amount}} {{item._priceAssetLabel}}</text>
          </view>
          <view class="fee-row" wx:if="{{item.net_amount}}">
            <text class="fee-label">卖家实收</text>
            <text class="fee-value">{{item.net_amount}} {{item._priceAssetLabel}}</text>
          </view>
        </view>

        <!--订单操作按钮-->
        <view
          class="order-actions"
          wx:if="{{item.status === 'created' || item.status === 'frozen'}}"
        >
          <button
            wx:if="{{item.requires_escrow}}"
            class="action-btn primary-action"
            size="mini"
            data-order-id="{{item.trade_order_id}}"
            bindtap="onOpenEscrowInput"
          >
            输入担保码
          </button>
          <button
            wx:if="{{item.requires_escrow}}"
            class="action-btn"
            size="mini"
            data-order-id="{{item.trade_order_id}}"
            bindtap="onViewEscrowStatus"
          >
            查看状态
          </button>
          <button
            class="action-btn danger-action"
            size="mini"
            data-order-id="{{item.trade_order_id}}"
            disabled="{{cancellingOrderId === item.trade_order_id}}"
            bindtap="onCancelOrder"
          >
            {{cancellingOrderId === item.trade_order_id ? '取消中...' : '取消交易'}}
          </button>
        </view>
        <!--已完成订单的申诉入口（文档 5.4）-->
        <view class="order-actions" wx:if="{{item.status === 'completed'}}">
          <button
            class="action-btn"
            size="mini"
            data-order-id="{{item.trade_order_id}}"
            bindtap="onOpenDispute"
          >
            发起申诉
          </button>
        </view>

        <!--订单编号（后端 trade_orders.order_no，TO前缀16位定长编号）-->
        <view class="order-footer" wx:if="{{item.order_no}}">
          <text class="order-id-label" catchtap="onCopyOrderNo" data-order-no="{{item.order_no}}"
            >订单号: {{item.order_no}}</text
          >
        </view>
      </view>
    </view>

    <!--加载更多提示-->
    <view class="load-more" wx:if="{{orders.length > 0 && hasMore}}">
      <text class="load-more-text">{{loading ? '加载中...' : '上拉加载更多'}}</text>
    </view>
    <view class="load-more" wx:if="{{orders.length > 0 && !hasMore}}">
      <text class="load-more-text no-more">已加载全部订单</text>
    </view>
  </block>

  <!--空状态-->
  <view class="empty-state" wx:if="{{!loading && isEmpty}}">
    <text class="empty-icon">📋</text>
    <text class="empty-title">{{currentStatus === 'all' ? '暂无订单' : '该状态下暂无订单'}}</text>
    <text class="empty-subtitle">去交易市场看看有什么好物</text>
    <navigator url="/packageTrade/trade/market/market" class="empty-link">
      <text>逛逛市场</text>
    </navigator>
  </view>

  <!--错误状态-->
  <view class="empty-state" wx:if="{{!loading && hasError}}">
    <text class="empty-icon">⚠️</text>
    <text class="empty-title">{{errorMessage}}</text>
    <button class="retry-btn" size="mini" bindtap="onPullDownRefresh">重试</button>
  </view>
</view>

<!--担保码输入弹窗-->
<view class="modal-overlay" wx:if="{{showEscrowInput}}" bindtap="onCloseEscrowInput">
  <view class="modal-content" catchtap="">
    <text class="modal-title">输入担保码</text>
    <text class="modal-subtitle">请输入卖家提供的6位数字担保码</text>
    <view class="escrow-input-wrapper" bindtap="onFocusEscrowInput">
      <input
        class="escrow-input"
        id="escrowCodeInput"
        type="number"
        maxlength="6"
        placeholder=""
        value="{{escrowInputValue}}"
        bindinput="onEscrowInputChange"
        focus="{{escrowInputFocused}}"
      />
      <view class="escrow-input-dots">
        <view class="dot {{escrowInputValue.length > 0 ? 'filled' : ''}}"></view>
        <view class="dot {{escrowInputValue.length > 1 ? 'filled' : ''}}"></view>
        <view class="dot {{escrowInputValue.length > 2 ? 'filled' : ''}}"></view>
        <view class="dot {{escrowInputValue.length > 3 ? 'filled' : ''}}"></view>
        <view class="dot {{escrowInputValue.length > 4 ? 'filled' : ''}}"></view>
        <view class="dot {{escrowInputValue.length > 5 ? 'filled' : ''}}"></view>
      </view>
    </view>
    <view class="modal-actions">
      <button class="modal-btn secondary-btn" bindtap="onCloseEscrowInput">取消</button>
      <button
        class="modal-btn {{escrowInputValue.length < 6 ? 'btn-disabled' : ''}}"
        disabled="{{escrowInputValue.length < 6 || escrowConfirming}}"
        bindtap="onSubmitEscrowCode"
      >
        {{escrowConfirming ? '确认中...' : '确认收货'}}
      </button>
    </view>
  </view>
</view>

<!--担保码状态弹窗-->
<view class="modal-overlay" wx:if="{{showEscrowStatus}}" bindtap="onCloseEscrowStatus">
  <view class="modal-content" catchtap="">
    <text class="modal-title">担保码状态</text>
    <view wx:if="{{escrowStatusLoading}}" class="status-loading">
      <text>查询中...</text>
    </view>
    <view wx:elif="{{escrowStatusData}}" class="status-info">
      <view class="status-row" wx:if="{{escrowStatusData.order_no}}">
        <text class="status-label">订单号</text>
        <text class="status-value">{{escrowStatusData.order_no}}</text>
      </view>
      <view class="status-row" wx:if="{{escrowStatusData.expires_at}}">
        <text class="status-label">过期时间</text>
        <text class="status-value">{{escrowStatusData.expires_at}}</text>
      </view>
      <view class="status-row" wx:if="{{escrowStatusData.status}}">
        <text class="status-label">状态</text>
        <text class="status-value">{{escrowStatusData.status}}</text>
      </view>
    </view>
    <button class="modal-btn" bindtap="onCloseEscrowStatus">关闭</button>
  </view>

  <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
  <maintenance-overlay />
</view>
