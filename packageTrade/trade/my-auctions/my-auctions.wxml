<!--packageTrade/trade/my-auctions/my-auctions.wxml - 我的拍卖（卖方视角）-->
<!--后端API: GET /api/v4/marketplace/auctions/my-->

<view class="my-auctions-container">
  <!--状态筛选-->
  <scroll-view class="status-tabs-scroll" scroll-x enable-flex>
    <view
      class="status-tab {{currentStatus === item.key ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="key"
      data-status="{{item.key}}"
      bindtap="onStatusTabChange"
    >
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <!--加载中-->
  <view class="page-loading" wx:if="{{loading && auctions.length === 0}}">
    <loading-spinner text="加载中..." />
  </view>

  <!--错误-->
  <view class="page-error" wx:elif="{{hasError}}">
    <text class="error-text">{{errorMessage}}</text>
    <view class="retry-btn" bindtap="onRetry"><text>重试</text></view>
  </view>

  <!--空状态-->
  <view class="page-empty" wx:elif="{{isEmpty}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无拍卖记录</text>
    <view class="create-btn" bindtap="onCreateAuction"><text>发起拍卖</text></view>
  </view>

  <!--拍卖列表-->
  <view class="auction-list" wx:else>
    <view
      class="auction-item"
      wx:for="{{auctions}}"
      wx:key="auction_listing_id"
      data-auction="{{item}}"
      bindtap="onAuctionTap"
    >
      <image class="auction-thumb" src="{{item._displayImage}}" mode="aspectFill" lazy-load />
      <view class="auction-info">
        <text class="auction-name">{{item._displayName}}</text>
        <view class="auction-price-row">
          <text class="price-label">{{item._priceLabel}}</text>
          <text class="price-value">{{item._displayPrice}} {{item.price_asset_code}}</text>
        </view>
        <view class="auction-stats">
          <text class="stat-text">{{item.bid_count}}次出价 · {{item.unique_bidders}}人参与</text>
        </view>
        <view class="auction-status" style="color: {{item._statusColor}}">
          <text>{{item._statusLabel}}</text>
        </view>

        <!--结算信息-->
        <view class="settled-info" wx:if="{{item.status === 'settled'}}">
          <text class="settled-text">实收 {{item.net_amount}} {{item.price_asset_code}}</text>
        </view>
      </view>

      <!--取消按钮-->
      <view class="cancel-btn" wx:if="{{item._canCancel}}" data-auction="{{item}}" catchtap="onCancelAuction">
        <text>取消</text>
      </view>
    </view>

    <!--加载更多/没有更多-->
    <view class="list-footer">
      <loading-spinner text="加载更多..." wx:if="{{hasMore && loading}}" />
      <text class="no-more" wx:if="{{!hasMore && auctions.length > 0}}">— 没有更多了 —</text>
    </view>
  </view>
</view>
