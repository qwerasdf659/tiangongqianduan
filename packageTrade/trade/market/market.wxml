<!--packageTrade/trade/market/market.wxml - C2C交易市场瀑布流布局-->
<!--后端API: GET /api/v4/market/listings-->
<!--字段直接使用后端响应 + 以 _ 为前缀的计算展示字段-->

<view class="waterfall-market-container">
  <!-- 瀑布流主容器 -->
  <view class="waterfall-container" style="height: {{containerHeight}}px;">
    <view
      class="product-card waterfall-card {{item._rarityStyle.cssClass || ''}}"
      wx:for="{{products}}"
      wx:key="market_listing_id"
      style="left: {{item.layoutInfo.left}}px; top: {{item.layoutInfo.top}}px; width: {{item.layoutInfo.width}}px;"
      data-product="{{item}}"
      bindtap="onProductClick"
    >
      <!-- 商品图片区域 -->
      <view class="card-image-container">
        <image
          wx:if="{{!item._imageError}}"
          class="product-image card-image"
          src="{{item._displayImage}}"
          mode="aspectFill"
          lazy-load="{{true}}"
          data-index="{{index}}"
          binderror="onImageError"
        />
        <view wx:else class="image-fallback">
          <text class="fallback-icon">{{item._isFungibleAsset ? '💎' : '📦'}}</text>
          <text class="fallback-name">{{item._displayName}}</text>
        </view>

        <!-- 挂单类型标签 -->
        <view class="listing-kind-tag {{item._isFungibleAsset ? 'asset-tag' : 'item-tag'}}">
          <text>{{item._isFungibleAsset ? '资产' : '物品'}}</text>
        </view>

        <!-- 资产数量（仅 fungible_asset 类型显示） -->
        <view class="amount-badge" wx:if="{{item._isFungibleAsset && item._offerAmount}}">
          <text class="amount-text">×{{item._offerAmount}}</text>
        </view>

        <!-- 稀有度标识（仅 item 类型，非 common 时显示） -->
        <view
          class="rarity-badge"
          wx:if="{{!item._isFungibleAsset && item._rarityCode && item._rarityCode !== 'common'}}"
          style="background-color: {{item._rarityStyle.colorHex}};"
        >
          <text class="rarity-text">{{item._rarityStyle.displayName}}</text>
        </view>
      </view>

      <!-- 商品信息区域 -->
      <view class="card-content">
        <view class="product-title-section">
          <text class="product-title">{{item._displayName}}</text>
        </view>

        <!-- 价格信息（后端字段: price_amount + price_asset_code） -->
        <view class="price-section">
          <view class="price-row">
            <text class="current-price">{{item.price_amount}}</text>
            <text class="price-unit">{{item._priceLabel}}</text>
          </view>
        </view>

        <!-- 卖家信息（后端字段: seller_nickname） -->
        <view class="seller-info" wx:if="{{item.seller_nickname}}">
          <text class="seller-name">{{item.seller_nickname}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-section" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner">
        <view class="spinner-dot dot1"></view>
        <view class="spinner-dot dot2"></view>
        <view class="spinner-dot dot3"></view>
      </view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 无更多数据 -->
  <view class="no-more-data" wx:if="{{!hasMore && products.length > 0}}">
    <view class="no-more-content">
      <text class="no-more-text">已加载全部挂单</text>
      <text class="no-more-subtitle">共{{products.length}}件商品</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && products.length === 0 && !hasError}}">
    <view class="empty-content">
      <text class="empty-icon">🛒</text>
      <text class="empty-title">暂无挂单</text>
      <text class="empty-subtitle">市场暂时没有商品，稍后再来看看</text>
      <button class="empty-retry-btn" bindtap="onPullDownRefresh" size="mini">重新加载</button>
    </view>
  </view>

  <!-- 错误状态 -->
  <view class="empty-state" wx:if="{{hasError}}">
    <view class="empty-content">
      <text class="empty-icon">⚠️</text>
      <text class="empty-title">{{errorMessage || '加载失败'}}</text>
      <button class="empty-retry-btn" bindtap="onPullDownRefresh" size="mini">重试</button>
    </view>
  </view>

  <!-- 浮动操作 -->
  <view class="floating-actions">
    <view
      class="floating-btn back-to-top-btn"
      bindtap="scrollToTop"
      wx:if="{{products.length > 10}}"
    >
      <text class="btn-icon">↑</text>
    </view>
  </view>
</view>
