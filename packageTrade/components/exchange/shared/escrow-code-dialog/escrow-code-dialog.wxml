<view class="escrow-dialog-overlay" wx:if="{{visible}}" catchtap="onClose">
  <view class="escrow-dialog-modal" catchtap="">
    <view class="escrow-dialog-header">
      <text class="escrow-dialog-title">{{title}}</text>
      <view class="escrow-dialog-close" bindtap="onClose">
        <text>✕</text>
      </view>
    </view>
    <text class="escrow-dialog-hint">{{hint}}</text>
    <block wx:if="{{inputMode === 'dots'}}">
      <view class="escrow-dialog-dots-wrapper" bindtap="onFocusInput">
        <input
          class="escrow-dialog-hidden-input"
          type="number"
          maxlength="6"
          placeholder=""
          value="{{value}}"
          bindinput="onInput"
          focus="{{focused}}"
        />
        <view class="escrow-dialog-dots">
          <view
            class="escrow-dialog-dot {{value.length > 0 ? 'escrow-dialog-dot--filled' : ''}}"
          ></view>
          <view
            class="escrow-dialog-dot {{value.length > 1 ? 'escrow-dialog-dot--filled' : ''}}"
          ></view>
          <view
            class="escrow-dialog-dot {{value.length > 2 ? 'escrow-dialog-dot--filled' : ''}}"
          ></view>
          <view
            class="escrow-dialog-dot {{value.length > 3 ? 'escrow-dialog-dot--filled' : ''}}"
          ></view>
          <view
            class="escrow-dialog-dot {{value.length > 4 ? 'escrow-dialog-dot--filled' : ''}}"
          ></view>
          <view
            class="escrow-dialog-dot {{value.length > 5 ? 'escrow-dialog-dot--filled' : ''}}"
          ></view>
        </view>
      </view>
    </block>
    <input
      wx:else
      class="escrow-dialog-input"
      type="number"
      maxlength="6"
      placeholder="请输入6位担保码"
      value="{{value}}"
      bindinput="onInput"
    />
    <view class="escrow-dialog-actions">
      <view class="escrow-dialog-cancel" bindtap="onClose">
        <text>取消</text>
      </view>
      <view
        class="escrow-dialog-submit {{value.length !== 6 || submitting ? 'escrow-dialog-submit--disabled' : ''}}"
        bindtap="onSubmit"
      >
        <text>{{submitting ? '确认中...' : '确认收货'}}</text>
      </view>
    </view>
  </view>
</view>
