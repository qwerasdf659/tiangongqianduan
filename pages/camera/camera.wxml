<!--pages/camera/camera.wxml - 发现页面（活动聚合入口 - 方案C：标签页分类）-->

<view class="discover-container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索活动"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <text class="clear-icon" wx:if="{{searchKeyword}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- Tab 分类导航 -->
  <view class="tab-bar">
    <scroll-view class="tab-scroll" scroll-x="true" scroll-with-animation="true">
      <view class="tab-list">
        <view
          class="tab-item {{currentTab === item.key ? 'active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="key"
          data-tab="{{item.key}}"
          bindtap="onTabChange"
        >
          <text class="tab-icon">{{item.icon}}</text>
          <text class="tab-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 活动列表 -->
  <view class="activity-list">
    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{loading && !refreshing}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态提示 -->
    <view class="empty-state" wx:if="{{!loading && isEmpty}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">{{searchKeyword ? '没有找到相关活动' : '暂时没有活动'}}</text>
      <text class="empty-hint">换个关键词试试，或者浏览其他分类</text>
    </view>

    <!-- 错误提示 -->
    <view class="error-state" wx:if="{{!loading && errorMessage}}">
      <text class="error-icon">❌</text>
      <text class="error-text">{{errorMessage}}</text>
      <button class="retry-btn" bindtap="initializePage">重新加载</button>
    </view>

    <!-- 活动卡片列表 -->
    <view class="activity-items" wx:if="{{!loading && !isEmpty && !errorMessage}}">
      <view
        class="activity-card"
        wx:for="{{filteredActivities}}"
        wx:key="id"
        data-activity="{{item}}"
        bindtap="onActivityTap"
      >
        <!-- 活动封面 -->
        <view class="card-cover">
          <image class="cover-image" src="{{item.cover}}" mode="aspectFill"></image>
          <!-- 状态标签 -->
          <view class="status-badge status-{{item.status}}">
            <text
              >{{item.status === 'ongoing' ? '进行中' : item.status === 'upcoming' ? '即将开始' :
              '已结束'}}</text
            >
          </view>
          <!-- 热门标签 -->
          <view class="hot-badge" wx:if="{{item.hot_score >= 90}}">
            <text>🔥 热门</text>
          </view>
        </view>

        <!-- 活动信息 -->
        <view class="card-content">
          <!-- 标题和副标题 -->
          <view class="card-header">
            <text class="card-title">{{item.title}}</text>
            <text class="card-subtitle">{{item.subtitle}}</text>
          </view>

          <!-- 活动数据 -->
          <view class="card-data">
            <!-- 参与人数 -->
            <view class="data-item" wx:if="{{item.participants_count}}">
              <text class="data-icon">👥</text>
              <text class="data-text">{{item.participants_count}}人参与</text>
            </view>

            <!-- 名额信息 -->
            <view class="data-item" wx:if="{{item.quota_total}}">
              <text class="data-icon">📊</text>
              <text class="data-text">剩余{{item.quota_left}}/{{item.quota_total}}</text>
            </view>

            <!-- 奖励信息 -->
            <view class="data-item" wx:if="{{item.reward_type === 'points' && item.reward_value}}">
              <text class="data-icon">🎁</text>
              <text class="data-text">{{item.reward_value}}积分</text>
            </view>
          </view>

          <!-- 标签 -->
          <view class="card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
          </view>

          <!-- CTA按钮 -->
          <view class="card-footer">
            <button class="cta-btn {{item.status === 'ongoing' ? 'primary' : 'secondary'}}">
              {{item.cta_text}}
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more-tip" wx:if="{{filteredActivities.length > 0 && !loading}}">
      <text class="tip-text">已显示全部活动</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="bottom-tip" wx:if="{{!loading && filteredActivities.length > 0}}">
    <text class="tip-icon">💡</text>
    <text class="tip-text">点击活动卡片查看详情并参与</text>
  </view>
</view>
