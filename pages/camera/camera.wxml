<!--pages/camera/camera.wxml - 发现页面（抽奖活动聚合入口）-->

<view class="discover-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 🎨 顶部沉浸式横幅区域（运营可配，后端 ad-delivery?slot_type=top_banner&position=camera） -->
    <view class="immersive-top-banner">
      <!-- 运营轮播多图 -->
      <swiper
        wx:if="{{topBannerReady && topBannerCarousel}}"
        class="top-banner-image"
        autoplay="{{true}}"
        circular="{{true}}"
        interval="{{topBannerInterval}}"
        indicator-dots="{{topBannerItems.length > 1}}"
        indicator-color="rgba(255,255,255,0.4)"
        indicator-active-color="#ffffff"
        bindchange="onTopBannerChange"
      >
        <swiper-item wx:for="{{topBannerItems}}" wx:key="ad_campaign_id">
          <image
            class="top-banner-image"
            src="{{item.image_url}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onTopBannerTap"
            binderror="onTopBannerImageError"
          />
        </swiper-item>
      </swiper>
      <!-- 运营单图 -->
      <image
        wx:elif="{{topBannerReady}}"
        class="top-banner-image"
        src="{{topBannerItems[0].image_url}}"
        mode="aspectFill"
        data-index="0"
        bindtap="onTopBannerTap"
        binderror="onTopBannerImageError"
      />
      <!-- 无运营配置：占位框 -->
      <view class="top-banner-placeholder" wx:else>
        <text class="placeholder-text">顶部横幅图片位置</text>
      </view>
    </view>

    <!-- 页面标题（视觉锚点） -->
    <view class="page-header">
      <text class="page-title">发现好活动</text>
      <text class="page-subtitle">今日回馈·限时福利·新鲜上线</text>
    </view>

    <!-- 顶部搜索栏 -->
    <view class="search-bar">
      <view class="search-input-wrapper">
        <t-icon name="search" size="28rpx" class="search-icon" />
        <input
          class="search-input"
          type="text"
          placeholder="搜索活动"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
        />
        <text class="clear-icon" wx:if="{{searchKeyword}}" bindtap="onClearSearch">✕</text>
      </view>
    </view>

    <!-- 活动列表 -->
    <view class="activity-list">
      <!-- 加载状态 -->
      <view class="loading-container" wx:if="{{loading && !refreshing}}">
        <t-loading loading="{{true}}" text="加载中..." theme="spinner" />
      </view>

      <!-- 未登录提示已移除 — 未登录也可浏览活动 -->

      <!-- 空状态提示 -->
      <t-empty
        wx:if="{{!loading && isEmpty}}"
        description="{{searchKeyword ? '没有找到相关活动' : '暂时没有进行中的活动'}}"
      >
        <view slot="image">📭</view>
        <view slot="description" class="empty-hint"
          >{{searchKeyword ? '换个关键词试试' : '敬请期待新活动上线'}}</view
        >
      </t-empty>

      <!-- 错误提示 -->
      <view class="error-state" wx:if="{{!loading && errorMessage}}">
        <t-icon name="close-circle-filled" size="48rpx" class="error-icon" />
        <text class="error-text">{{errorMessage}}</text>
        <button class="retry-btn" bindtap="initializePage">重新加载</button>
      </view>

      <!-- 活动卡片列表 -->
      <view class="activity-items" wx:if="{{!loading && !isEmpty && !errorMessage}}">
        <view
          class="activity-card"
          wx:for="{{filteredCampaigns}}"
          wx:key="campaign_code"
          data-campaign="{{item}}"
          bindtap="onActivityTap"
        >
          <!-- 活动信息 -->
          <view class="card-content">
            <!-- 标题 -->
            <view class="card-header">
              <text class="card-title">{{item.campaign_name}}</text>
              <text class="card-subtitle">{{item.campaign_type}}</text>
            </view>

            <!-- 状态标签 -->
            <view class="status-badge status-{{item.status}}">
              <text
                >{{item.status === 'active' ? '进行中' : item.status === 'upcoming' ? '即将开始' :
                '已结束'}}</text
              >
            </view>

            <!-- 精选标签 -->
            <view class="hot-badge" wx:if="{{item.is_featured}}">
              <text><t-icon name="star-filled" size="22rpx" /> 精选</text>
            </view>

            <!-- 展示标签 -->
            <view class="card-tags" wx:if="{{item.display_tags && item.display_tags.length > 0}}">
              <text class="tag" wx:for="{{item.display_tags}}" wx:for-item="tag" wx:key="*this"
                >{{tag}}</text
              >
            </view>

            <!-- 时间信息 -->
            <view class="card-data">
              <view class="data-item" wx:if="{{item.start_time}}">
                <text class="data-icon">🕐</text>
                <text class="data-text">{{item.start_time}}</text>
              </view>
              <view class="data-item" wx:if="{{item.end_time}}">
                <text class="data-icon">⏰</text>
                <text class="data-text">{{item.end_time}}</text>
              </view>
            </view>

            <!-- 操作按钮 -->
            <view class="card-footer">
              <button class="cta-btn primary">去领回馈</button>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部提示 -->
      <view class="load-more-tip" wx:if="{{filteredCampaigns.length > 0 && !loading}}">
        <text class="tip-text">已显示全部活动</text>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="bottom-tip" wx:if="{{!loading && filteredCampaigns.length > 0}}">
      <t-icon name="tips-filled" size="28rpx" class="tip-icon" />
      <text class="tip-text">点击活动卡片进入回馈</text>
    </view>

    <!-- 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
    <maintenance-overlay />
  </scroll-view>

  <!-- 登录弹窗 -->
  <login-popup
    visible="{{loginPopupVisible}}"
    bind:close="onLoginPopupClose"
    bind:loginsuccess="onLoginSuccess"
  />
</view>
