<!--
  DIY tab 入口页
  直接在 tabBar 页面内展示设计入口，底部 tab 始终可见
-->
<view class="diy-select-page">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 🎨 顶部沉浸式横幅区域（运营可配，后端 ad-delivery?slot_type=top_banner&position=diy） -->
    <view class="immersive-top-banner">
      <!-- 运营轮播多图 -->
      <swiper
        wx:if="{{topBannerReady && topBannerCarousel}}"
        class="top-banner-image"
        autoplay="{{true}}"
        circular="{{true}}"
        interval="{{topBannerInterval}}"
        indicator-dots="{{topBannerItems.length > 1}}"
        indicator-color="rgba(255,255,255,0.4)"
        indicator-active-color="#ffffff"
        bindchange="onTopBannerChange"
      >
        <swiper-item wx:for="{{topBannerItems}}" wx:key="ad_campaign_id">
          <image
            class="top-banner-image"
            src="{{item.image_url}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onTopBannerTap"
          />
        </swiper-item>
      </swiper>
      <!-- 运营单图 -->
      <image
        wx:elif="{{topBannerReady}}"
        class="top-banner-image"
        src="{{topBannerItems[0].image_url}}"
        mode="aspectFill"
        data-index="0"
        bindtap="onTopBannerTap"
      />
      <!-- 无运营配置：占位框 -->
      <view class="top-banner-placeholder" wx:else>
        <text class="placeholder-text">顶部横幅图片位置</text>
      </view>
    </view>

    <!-- 页面标题区域 -->
    <view class="page-title-section">
      <text class="page-main-title">开始您的饰品设计之旅</text>
      <text class="page-sub-title">选择您喜欢的设计方式</text>
    </view>

    <!-- 我的设计入口卡片（橙色背景） -->
    <view class="my-design-card" bindtap="onGoToMyWorks">
      <view class="my-design-info">
        <text class="my-design-title">我的设计</text>
        <text class="my-design-desc">查看已保存的设计记录</text>
      </view>
      <view class="my-design-arrow">
        <text class="arrow-icon">></text>
      </view>
    </view>

    <!-- 自由定制饰品卡片 -->
    <view class="design-mode-card" bindtap="onFreeDesign">
      <view class="mode-icon-wrap">
        <image
          wx:if="{{freeDesignIcon}}"
          class="mode-icon-img"
          src="{{freeDesignIcon}}"
          mode="aspectFit"
        />
        <view wx:else class="mode-icon-placeholder mode-icon-free" />
      </view>
      <text class="mode-title">自由定制饰品</text>
      <text class="mode-desc"
        >从零开始，发挥您的创意，自由选择材料形状和尺寸，打造您最满意的饰品</text
      >
    </view>

    <!-- 设计广场卡片 -->
    <view class="design-mode-card" bindtap="onDesignPlaza">
      <view class="mode-icon-wrap">
        <image
          wx:if="{{designPlazaIcon}}"
          class="mode-icon-img"
          src="{{designPlazaIcon}}"
          mode="aspectFit"
        />
        <view wx:else class="mode-icon-placeholder mode-icon-plaza" />
      </view>
      <text class="mode-title">设计广场</text>
      <text class="mode-desc">汲取灵感，查看来自世界各地的珠宝设计，选择一款作为您的蓝图</text>
    </view>
  </scroll-view>

  <!-- 登录弹窗 -->
  <login-popup
    visible="{{loginPopupVisible}}"
    bind:close="onLoginPopupClose"
    bind:loginsuccess="onLoginSuccess"
  />

  <!-- 功能后续开放蒙版：遮挡整页并拦截所有交互 -->
  <view
    class="coming-soon-mask"
    wx:if="{{comingSoonVisible}}"
    catchtap="onComingSoonMaskTap"
    catchtouchmove="onComingSoonMaskTap"
  >
    <view class="coming-soon-card">
      <view class="coming-soon-icon">
        <t-icon name="tools-filled" size="80rpx" color="#C5A572" />
      </view>
      <text class="coming-soon-title">功能即将开放</text>
      <text class="coming-soon-desc">DIY 饰品工坊正在精心打磨，敬请期待</text>
      <!-- 离线演示入口：正式功能未开放前，先体验本地手串设计 Demo -->
      <view class="coming-soon-lite-btn" catchtap="onGoToLite">
        <text class="coming-soon-lite-text">先试玩离线演示</text>
      </view>
    </view>
  </view>
</view>
