<!--pages/user/user.wxml - 用户中心页面模板 -->

<view class="user-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 🎨 顶部沉浸式横幅区域（图片延伸到状态栏后面） -->
    <view class="immersive-top-banner">
      <image
        class="top-banner-image"
        src="{{topBannerUrl || ''}}"
        mode="aspectFill"
        wx:if="{{topBannerUrl}}"
      />
      <view class="top-banner-placeholder" wx:else>
        <text class="placeholder-text">顶部横幅图片位置</text>
      </view>
    </view>

    <!-- 积分余额卡片 -->
    <view class="points-card">
      <view class="points-header">
        <text class="points-title">我的积分</text>
        <view class="points-detail-btn" bindtap="{{isLoggedIn ? 'onPointsTap' : 'redirectToAuth'}}">
          <t-icon name="wallet-filled" size="28rpx" color="currentColor" />
          <text class="points-detail-text">积分明细</text>
        </view>
      </view>
      <view class="points-amount">
        <block wx:if="{{isLoggedIn}}">
          <text class="points-number">{{totalPoints}}</text>
          <text class="points-unit">分</text>
        </block>
        <view wx:else class="points-hidden" bindtap="redirectToAuth">
          <t-icon name="browse-off" size="40rpx" color="#999" />
          <text class="points-hidden-text">登录查看</text>
        </view>
      </view>
      <view class="points-trend">
        <view class="trend-item" bindtap="{{isLoggedIn ? '' : 'redirectToAuth'}}">
          <text class="trend-label">今日获得积分</text>
          <text class="trend-value earned" wx:if="{{isLoggedIn}}">+{{todayEarned || 0}}</text>
          <t-icon wx:else name="browse-off" size="32rpx" color="#ccc" />
        </view>
        <view class="trend-item" bindtap="{{isLoggedIn ? '' : 'redirectToAuth'}}">
          <text class="trend-label">今日消费积分</text>
          <text class="trend-value consumed" wx:if="{{isLoggedIn}}">{{todayConsumed || 0}}</text>
          <t-icon wx:else name="browse-off" size="32rpx" color="#ccc" />
        </view>
      </view>
    </view>

    <!-- 功能菜单网格（4列2行） -->
    <view class="menu-grid">
      <view
        class="menu-grid-item"
        wx:for="{{menuItems}}"
        wx:key="id"
        wx:if="{{item.id !== 'logout'}}"
        bindtap="{{isLoggedIn ? 'onMenuItemTap' : 'redirectToAuth'}}"
        data-item="{{item}}"
      >
        <view class="menu-grid-icon">
          <t-icon name="{{item.tdIcon}}" size="52rpx" color="{{item.color}}" />
        </view>
        <text class="menu-grid-name">{{item.name}}</text>
      </view>
    </view>

    <!-- 商家工作台 -->
    <view class="mw-section" wx:if="{{isLoggedIn && isMerchant}}">
      <view class="mw-header">
        <view class="mw-header-left">
          <view class="mw-header-icon"><t-icon name="store-filled" size="36rpx" color="currentColor" /></view>
          <view class="mw-header-info">
            <text class="mw-header-title">商家工作台</text>
            <text class="mw-header-role"
              >{{isAdmin ? '管理员' : (isManager ? '店长' : '店员')}}</text
            >
          </view>
        </view>
      </view>

      <view class="mw-cards">
        <view class="mw-card" bindtap="goToScanVerify">
          <view class="mw-card-body">
            <text class="mw-card-title">扫码核销 ›</text>
            <text class="mw-card-desc">扫描用户核销码，完成商品兑换核销</text>
            <view class="mw-card-steps">
              <text class="mw-step">用户出示核销码</text>
              <text class="mw-step-arrow">→</text>
              <text class="mw-step">扫码验证</text>
              <text class="mw-step-arrow">→</text>
              <text class="mw-step">核销完成</text>
            </view>
          </view>
          <view class="mw-card-go">
            <text class="mw-go-icon">›</text>
          </view>
        </view>

        <view class="mw-card" bindtap="goToConsumeSubmit">
          <view class="mw-card-body">
            <text class="mw-card-title">消费录入 ›</text>
            <text class="mw-card-desc">录入顾客本次消费金额，赚取积分</text>
            <view class="mw-card-steps">
              <text class="mw-step">扫码识别顾客</text>
              <text class="mw-step-arrow">→</text>
              <text class="mw-step">输入金额</text>
              <text class="mw-step-arrow">→</text>
              <text class="mw-step">提交审核</text>
            </view>
          </view>
          <view class="mw-card-go">
            <text class="mw-go-icon">›</text>
          </view>
        </view>

        <view class="mw-card" wx:if="{{isReviewer}}" bindtap="goToAuditList">
          <view class="mw-card-body">
            <text class="mw-card-title">审核管理 ›</text>
            <text class="mw-card-desc">审核店员提交的消费记录，通过后自动发放积分</text>
            <view class="mw-card-steps">
              <text class="mw-step">查看待审核</text>
              <text class="mw-step-arrow">→</text>
              <text class="mw-step">审核通过/拒绝</text>
              <text class="mw-step-arrow">→</text>
              <text class="mw-step">积分自动到账</text>
            </view>
          </view>
          <view class="mw-card-go">
            <text class="mw-go-icon">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="logout">
            <t-icon name="logout" size="32rpx" color="currentColor" />
      <text class="logout-text">退出登录</text>
    </view>

    <!-- 加载遮罩层 -->
    <view class="loading-overlay" wx:if="{{loading}}">
      <view class="loading-content">
        <t-loading loading="{{true}}" text="加载中..." theme="spinner" />
      </view>
    </view>

    <popup-banner
      visible="{{showPopupBanner}}"
      banners="{{popupBanners}}"
      bind:close="onPopupBannerClose"
      bind:action="onPopupBannerAction"
    />

    <maintenance-overlay />
  </scroll-view>

  <!-- 登录弹窗 -->
  <login-popup
    visible="{{loginPopupVisible}}"
    bind:close="onLoginPopupClose"
    bind:loginsuccess="onLoginSuccess"
  />
</view>
