<!--pages/user/user.wxml - 用户中心页面模板 -->

<view class="user-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <!-- 已登录状态 -->
    <view class="user-info-full" wx:if="{{isLoggedIn}}">
      <view class="user-name" bindtap="onPhoneTap">
        <text class="name-text">{{userInfo.mobile || userInfo.phone || '点击登录'}}</text>
        <text class="edit-phone">✏️</text>
      </view>
    </view>

    <!-- 未登录状态 -->
    <view class="login-prompt" wx:else bindtap="redirectToAuth">
      <view class="login-avatar">👤</view>
      <text class="login-text">点击登录</text>
      <text class="login-desc">登录后查看完整功能</text>
    </view>
  </view>

  <!-- 积分余额卡片 -->
  <view class="points-card" bindtap="onPointsTap" wx:if="{{isLoggedIn}}">
    <view class="points-header">
      <text class="points-title">我的积分</text>
      <view class="header-tips">
        <text class="points-tips">点击查看明细 👇</text>
      </view>
    </view>
    <view class="points-amount">
      <text class="points-number">{{totalPoints}}</text>
      <text class="points-unit">分</text>
    </view>

    <!-- 积分趋势 -->
    <view class="points-trend">
      <view class="trend-item">
        <text class="trend-label">今日获得</text>
        <text class="trend-value earned">+{{todayEarned || 0}}</text>
      </view>
      <view class="trend-item">
        <text class="trend-label">今日消费</text>
        <text class="trend-value consumed"
          >{{todayConsumed > 0 ? '-' : ''}}{{todayConsumed || 0}}</text
        >
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="section-title">
      <text>🔧 功能菜单</text>
    </view>
    <view class="menu-grid">
      <view
        class="menu-item"
        wx:for="{{menuItems}}"
        wx:key="id"
        bindtap="onMenuItemTap"
        data-item="{{item}}"
        style="border-left: 4rpx solid {{item.color}}"
      >
        <view class="menu-icon" style="color: {{item.color}}">{{item.icon}}</view>
        <view class="menu-content">
          <text class="menu-name">{{item.name}}</text>
          <text class="menu-desc">{{item.description}}</text>
        </view>
        <text class="menu-arrow">▶</text>
      </view>
    </view>
  </view>

  <!-- 🏪 商家工作台 - 商家店员(role_level>=20)及以上可见 -->
  <view class="merchant-workspace-section" wx:if="{{isLoggedIn && isMerchant}}">
    <view class="section-title">
      <text>🏪 商家工作台</text>
    </view>
    <view class="menu-grid">
      <!-- 📱 扫码核销 - 商家店员(level>=20)可用 -->
      <view class="menu-item" bindtap="goToScanVerify" style="border-left: 4rpx solid #e91e63">
        <view class="menu-icon" style="color: #e91e63">📱</view>
        <view class="menu-content">
          <text class="menu-name">扫码核销</text>
          <text class="menu-desc">扫描用户核销码完成核销</text>
        </view>
        <text class="menu-arrow">▶</text>
      </view>

      <!-- 📋 消费录入 - 商家店员(level>=20)可用 -->
      <view class="menu-item" bindtap="goToConsumeSubmit" style="border-left: 4rpx solid #ff9800">
        <view class="menu-icon" style="color: #ff9800">📋</view>
        <view class="menu-content">
          <text class="menu-name">消费录入</text>
          <text class="menu-desc">扫码录入用户消费金额</text>
        </view>
        <text class="menu-arrow">▶</text>
      </view>

      <!-- ✅ 审批管理 - 商家店长(level>=40)可用 -->
      <view
        class="menu-item"
        wx:if="{{isAdmin}}"
        bindtap="goToAuditList"
        style="border-left: 4rpx solid #4caf50"
      >
        <view class="menu-icon" style="color: #4caf50">✅</view>
        <view class="menu-content">
          <text class="menu-name">审批管理</text>
          <text class="menu-desc">审核待审批的消费记录</text>
        </view>
        <text class="menu-arrow">▶</text>
      </view>
    </view>
  </view>

  <!-- 加载遮罩层 - 页面初始化时显示，数据加载完成后自动隐藏 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
