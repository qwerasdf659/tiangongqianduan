<!--pages/lottery/lottery.wxml - 薄壳页面模板（任务8瘦身后v2.0.0）
  抽奖核心UI已迁移到 lottery-activity 万能组件
  本模板仅保留：页面壳、用户信息、二维码、管理员功能条、审核弹窗、弹窗横幅
-->

<view class="lottery-container">
  <!-- 🔴 首次加载遮罩：覆盖整个页面，数据+弹窗图片全部就绪后才消失 -->
  <view class="first-load-mask" wx:if="{{loading}}">
    <view class="first-load-spinner">
      <text class="spinner-icon">🎰</text>
      <text class="spinner-text">正在加载...</text>
    </view>
  </view>

  <!-- 页面头部 -->
  <view class="header">
    <!-- 🆕 整合布局：用户信息 + 二维码横向排列 -->
    <view class="header-content">
      <!-- 左侧：用户信息和积分（横向布局） -->
      <view class="user-info-section">
        <!-- 欢迎语 + 审核记录徽章 -->
        <view class="welcome-text">
          <text>欢迎，{{userInfo.mobile || userInfo.nickname || '用户'}}</text>

          <!-- 🆕 积分审核记录查询按钮 - 带图标+文字+角标 -->
          <view class="audit-badge-container" bindtap="viewRecentAudits">
            <!-- 按钮主体：图标 + 文字 -->
            <view class="audit-badge-btn {{auditRecordsCount > 0 ? 'has-records' : 'no-records'}}">
              <text class="badge-icon">📋</text>
              <text class="badge-label">审核</text>
            </view>

            <!-- 数字角标（仅当有记录时显示） -->
            <view class="badge-number" wx:if="{{auditRecordsCount > 0}}">
              <text>{{auditRecordsCount > 99 ? '99+' : auditRecordsCount}}</text>
            </view>
          </view>
        </view>

        <!-- 积分横向容器 -->
        <view class="points-row">
          <!-- 可用积分 - ✅ 响应式字体 + 千分位分隔符 -->
          <view class="points-item">
            <text class="points-label">可用积分</text>
            <view class="points-value">
              <text class="points-number {{pointsClass}}">{{pointsBalanceFormatted}}</text>
              <text class="points-icon">💰</text>
            </view>
          </view>

          <!-- 冻结积分 - ✅ 响应式字体 + 千分位分隔符 -->
          <view class="points-item">
            <text class="points-label">冻结积分</text>
            <view class="points-value">
              <text class="points-number {{frozenClass}}">{{frozenPointsFormatted}}</text>
              <text class="points-icon">🔒</text>
            </view>
          </view>

          <!-- 🆕 仓库入口按钮 - 与审核按钮同风格布局 -->
          <view class="inventory-badge-container" bindtap="goToInventory">
            <!-- 按钮主体：图标 + 文字（与审核按钮一致） -->
            <view class="inventory-badge-btn">
              <text class="badge-icon">📦</text>
              <text class="badge-label">仓库</text>
            </view>

            <!-- 数字角标（物品数量，仅有物品时显示） -->
            <view class="inventory-badge-number" wx:if="{{inventoryItemCount > 0}}">
              <text>{{inventoryItemCount > 99 ? '99+' : inventoryItemCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 右侧：V2动态二维码区域（含倒计时和过期状态） -->
      <view class="qrcode-section-inline">
        <view class="qrcode-container" bindtap="enlargeQRCode">
          <!-- 加载中状态 -->
          <view class="qrcode-loading" wx:if="{{!qrCodeImage && !qrExpired}}">
            <text class="loading-icon">⏳</text>
            <text class="loading-text">生成中...</text>
          </view>

          <!-- 二维码图片（未过期时显示） -->
          <block wx:elif="{{qrCodeImage && !qrExpired}}">
            <image class="qrcode-image" src="{{qrCodeImage}}" mode="aspectFit" show-menu-by-longpress="{{true}}" />
            <view class="qrcode-hint" wx:if="{{qrCodeImage}}">
              <text class="hint-icon">🔍</text>
            </view>
          </block>

          <!-- 已过期状态 -->
          <view class="qrcode-expired-inline" wx:elif="{{qrExpired}}" catchtap="onRefreshQRCode">
            <text class="expired-icon-small">⚠️</text>
            <text class="expired-text-small">已过期</text>
            <text class="refresh-text-small">点击刷新</text>
          </view>
        </view>

        <!-- V2倒计时（二维码下方显示） -->
        <view class="qr-countdown-inline" wx:if="{{qrCodeImage && !qrExpired}}">
          <text class="countdown-text-small {{qrCountdown <= 60 ? 'countdown-urgent' : ''}}">{{qrCountdownText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 🔴 管理员专属功能条 - 仅管理员可见 -->
  <view wx:if="{{isAdmin}}" class="admin-scan-bar">
    <!-- 左侧：静态文字 -->
    <view class="admin-scan-label">
      <text>商家扫码</text>
    </view>

    <!-- 中间：扫一扫功能 -->
    <view class="admin-scan-button" bindtap="onScanTap">
      <text class="scan-icon">📷</text>
      <text class="scan-text">扫一扫</text>
    </view>

    <!-- 右侧：审核详情跳转 -->
    <view class="admin-audit-button" bindtap="onAuditTap">
      <text class="audit-text">审核详情</text>
      <text class="arrow-icon">→</text>
    </view>
  </view>

  <!-- 🎠 轮播图区域（后端API: GET /api/v4/system/carousel-items） -->
  <view class="carousel-section" wx:if="{{showCarousel && carouselItems.length > 0}}">
    <swiper class="carousel-swiper" autoplay="{{true}}" circular="{{true}}" interval="{{carouselInterval}}"
      indicator-dots="{{carouselItems.length > 1}}" indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#ffffff" bindchange="onCarouselChange" current="{{carouselCurrent}}">
      <swiper-item wx:for="{{carouselItems}}" wx:key="carousel_item_id">
        <view class="carousel-item" data-index="{{index}}" bindtap="onCarouselItemTap">
          <image class="carousel-image" src="{{item.image_url}}" mode="aspectFill" lazy-load="{{true}}" />
          <view class="carousel-title-bar" wx:if="{{item.title}}">
            <text class="carousel-title-text">{{item.title}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 抽奖万能组件 - 主活动（动态加载，位置配置驱动） -->
  <lottery-activity wx:if="{{mainCampaign}}" campaignCode="{{mainCampaign.campaign_code}}"
    size="{{mainCampaign.placement.size || 'full'}}" bind:pointsupdate="onPointsUpdate" />
  <!-- 降级兜底：活动列表未加载时使用默认 -->
  <lottery-activity wx:else campaignCode="BASIC_LOTTERY" size="full" bind:pointsupdate="onPointsUpdate" />

  <!-- 其他活动（secondary/floating等位置，尺寸由位置配置决定） -->
  <block wx:for="{{extraCampaigns}}" wx:key="campaign_code">
    <view class="extra-activity-slot">
      <lottery-activity campaignCode="{{item.campaign_code}}" size="{{item.placement.size || 'medium'}}"
        bind:pointsupdate="onPointsUpdate" />
    </view>
  </block>

  <!-- 🆕 隐藏的Canvas用于生成正方形高分辨率二维码（方案B：428×428正方形） -->
  <canvas canvas-id="qrcodeCanvas" style="width: 428px; height: 428px; position: fixed; left: -9999px; top: -9999px" />

  <!-- 🆕 放大的二维码弹窗 -->
  <view class="qrcode-enlarged-modal" wx:if="{{qrCodeEnlarged}}" bindtap="closeEnlargedQRCode">
    <view class="qrcode-enlarged-container" catchtap="{{''}}">
      <!-- 关闭按钮 -->
      <view class="qrcode-close-btn" bindtap="closeEnlargedQRCode">
        <text class="close-icon">✕</text>
      </view>

      <!-- 放大的二维码 -->
      <view class="qrcode-enlarged-content">
        <!-- 🔴 方案B：正方形容器(500×500) + 正方形图片(428×428) = 完美填充 -->
        <image class="qrcode-enlarged-image" src="{{qrCodeImage}}" mode="aspectFit" show-menu-by-longpress="{{true}}" />

        <!-- 提示文字 -->
        <view class="qrcode-enlarged-tips">
          <text class="enlarged-tip">👆 长按保存二维码</text>
          <text class="enlarged-tip">或供商家扫码验证</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 🆕 审核记录弹窗 -->
  <view class="audit-modal" wx:if="{{showAuditModal}}" bindtap="closeAuditModal">
    <view class="audit-modal-content" catchtap="{{''}}">
      <!-- 关闭按钮 -->
      <view class="audit-modal-close" bindtap="closeAuditModal">
        <text class="close-icon">✕</text>
      </view>

      <!-- 弹窗标题 -->
      <view class="audit-modal-header">
        <text class="modal-title">📋 最近5笔积分审核记录</text>
      </view>

      <!-- 记录列表 -->
      <scroll-view class="audit-records-list" scroll-y="{{true}}">
        <view class="audit-record-card {{item.status}}" wx:for="{{auditRecordsData}}" wx:key="id">
          <!-- 记录编号 + 状态 -->
          <view class="record-header">
            <text class="record-number">🎯 记录 #{{index + 1}}</text>
            <view class="record-status" style="background: {{item.statusInfo.bgColor}}">
              <text class="status-icon">{{item.statusInfo.icon}}</text>
              <text class="status-text" style="color: {{item.statusInfo.color}}">
                {{item.statusInfo.text}}
              </text>
            </view>
          </view>

          <!-- 消费金额 -->
          <view class="record-row">
            <text class="row-icon">💰</text>
            <text class="row-label">消费金额：</text>
            <text class="row-value amount">¥{{item.formattedAmount}}</text>
          </view>

          <!-- 预计积分 -->
          <view class="record-row">
            <text class="row-icon">🎁</text>
            <text class="row-label">
              {{item.status === 'approved' ? '已奖励：' : '预计奖励：'}}
            </text>
            <text class="row-value points">+{{item.points_to_award}} 积分</text>
          </view>

          <!-- 商家信息 -->
          <view class="record-row" wx:if="{{item.merchant_info}}">
            <text class="row-icon">🏪</text>
            <text class="row-label">商家：</text>
            <text class="row-value">{{item.merchant_info.name || '天工餐厅'}}</text>
          </view>

          <!-- 商家备注 -->
          <view class="record-row" wx:if="{{item.merchant_notes}}">
            <text class="row-icon">📝</text>
            <text class="row-label">备注：</text>
            <text class="row-value">{{item.merchant_notes}}</text>
          </view>

          <!-- 提交时间 -->
          <view class="record-row">
            <text class="row-icon">🕐</text>
            <text class="row-label">提交时间：</text>
            <text class="row-value time">{{item.formattedTime}}</text>
          </view>
        </view>
      </scroll-view>

      <!-- 底部关闭按钮 -->
      <view class="audit-modal-footer">
        <button class="modal-close-btn" bindtap="closeAuditModal">关闭</button>
      </view>
    </view>
  </view>

  <!-- 🎨 弹窗横幅组件（后端API: GET /api/v4/system/popup-banners） -->
  <popup-banner visible="{{showPopupBanner}}" banners="{{popupBanners}}" bind:close="onPopupBannerClose"
    bind:action="onPopupBannerAction" />
</view>