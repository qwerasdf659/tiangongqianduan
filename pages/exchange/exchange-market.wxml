<!-- exchange-market.wxml - 交易市场 Tab 模板（通过 include 引入 exchange.wxml） -->
<!-- 数据绑定和事件处理仍由 exchange.ts Page 方法管理 -->

<!-- 交易市场内容区域 -->
<view wx:if="{{currentTab === 'market'}}" class="exchange-content">
  <!-- 🔒 固定头部区域：积分信息 + 快捷操作 + 搜索 + 筛选（不随滚动移动） -->
  <view class="header exchange-market-sticky-header">
    <view class="user-info">
      <!-- 可用积分 -->
      <view class="points-info">
        <text class="points-label">可用积分：</text>
        <text class="points-value">{{totalPoints}}</text>
      </view>
      <!-- 搜索框 - 嵌入积分行中间 -->
      <view class="header-search-box">
        <input
          class="header-search-input"
          placeholder="搜索商品名称..."
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
        />
        <text class="header-search-icon">🔍</text>
      </view>
      <!-- 快捷操作按钮 -->
      <view class="header-quick-actions">
        <view class="header-action-btn" bindtap="onRefreshProducts">🔄 刷新</view>
        <view class="header-action-btn" bindtap="onSortByPoints">📊 按售价排序</view>
        <!-- 视图切换 -->
        <view class="view-toggle">
          <view
            class="toggle-btn {{viewMode === 'grid' ? 'active' : ''}}"
            bindtap="onToggleViewMode"
            data-mode="grid"
            >⊞</view
          >
          <view
            class="toggle-btn {{viewMode === 'list' ? 'active' : ''}}"
            bindtap="onToggleViewMode"
            data-mode="list"
            >☰</view
          >
        </view>
      </view>
    </view>

    <!-- 筛选功能（动态渲染，由后端 market_filters 配置下发） -->
    <view class="search-filter">
      <view class="filter-buttons">
        <button
          wx:for="{{marketTypeFilters}}"
          wx:key="value"
          class="filter-btn {{currentFilter === item.value ? 'active' : ''}}"
          bindtap="onFilterChange"
          data-filter="{{item.value}}"
        >
          {{item.label}}{{item.showCount && item.value === 'all' ? '(' + products.length + ')' :
          ''}}
        </button>
        <button
          class="advanced-filter-btn {{showAdvancedFilter ? 'active' : ''}}"
          bindtap="onToggleAdvancedFilter"
        >
          高级筛选 {{showAdvancedFilter ? '🔼' : '🔽'}}
        </button>
      </view>

      <!-- 高级筛选面板（交易市场专用，由 market_filters 配置驱动） -->
      <view class="advanced-filter-panel" wx:if="{{showAdvancedFilter}}">
        <!-- 挂单类型筛选 -->
        <view class="filter-row">
          <text class="filter-label">挂单类型</text>
          <view class="filter-options">
            <button
              wx:for="{{marketCategoryFilters}}"
              wx:key="value"
              class="option-btn {{categoryFilter === item.value ? 'active' : ''}}"
              bindtap="onCategoryFilterChange"
              data-category="{{item.value}}"
            >
              {{item.label}}
            </button>
          </view>
        </view>

        <!-- 排序方式 -->
        <view class="filter-row">
          <text class="filter-label">排序方式</text>
          <view class="filter-options">
            <button
              wx:for="{{marketSortOptions}}"
              wx:key="value"
              class="option-btn {{sortBy === item.value ? 'active' : ''}}"
              bindtap="onSortByChange"
              data-sort="{{item.value}}"
            >
              {{item.label}}
            </button>
          </view>
        </view>

        <!-- 筛选操作 -->
        <view class="filter-actions">
          <button class="reset-btn" bindtap="onResetFilters">重置筛选</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 📜 可滚动商品列表区域（含下拉刷新） -->
  <scroll-view
    class="exchange-market-scroll-body"
    scroll-y="true"
    enhanced="true"
    show-scrollbar="false"
    bounces="true"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onScrollViewRefresh"
  >
    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 交易市场挂单列表（C2C用户交易） -->
    <view class="products-section" wx:else>
      <!-- 挂单网格布局 — 统一卡片主题系统 -->
      <view class="unified-cards-grid {{viewMode === 'list' ? 'grid-list-mode' : ''}}">
        <view
          class="unified-card theme-{{cardTheme}} market-card {{effects.grain ? 'grain-overlay' : ''}} {{viewMode === 'list' ? 'list-mode' : ''}} {{item._isLegendary && effects.holo ? 'holo-effect' : ''}} {{effects.fullbleed && item._hasImage ? 'fullbleed-mode' : ''}} {{item.status !== 'on_sale' ? 'sold-out' : ''}}"
          wx:for="{{filteredProducts}}"
          wx:key="market_listing_id"
          bindtap="onProductTap"
          bindtouchstart="onCardTouchStart"
          data-product="{{item}}"
          data-card-index="{{index}}"
          data-tab="market"
        >
          <!-- 顶部类型色条 -->
          <view
            class="type-bar {{item.listing_kind === 'fungible_asset' ? 'asset' : 'item'}}"
          ></view>

          <!-- 图片区域 -->
          <view class="card-image-area">
            <image
              src="{{item.image}}"
              mode="aspectFill"
              binderror="onImageError"
              bindload="onImageLoad"
              data-index="{{index}}"
              lazy-load="{{true}}"
            />
            <!-- 彩色占位（图片加载失败或无图） -->
            <view
              class="image-fallback {{item.listing_kind === 'fungible_asset' ? 'asset-type' : 'item-type'}}"
              wx:if="{{!item.image || item.imageStatus === 'error'}}"
            >
              <text class="fallback-icon"
                >{{item.listing_kind === 'fungible_asset' ? '💎' : '📦'}}</text
              >
              <text class="fallback-name">{{item.item_name}}</text>
            </view>
            <!-- 左上角稀有度飘带标签 -->
            <view
              class="badge-tag {{item._rarityClass || 'rare'}}"
              wx:if="{{item.offer_item_rarity}}"
              >{{item.offer_item_rarity}}</view
            >
            <!-- 右下角类型胶囊 -->
            <view
              class="type-capsule {{item.listing_kind === 'fungible_asset' ? 'asset-capsule' : 'item-capsule'}}"
              >{{item.listing_kind === 'fungible_asset' ? '💎 资产' : '📦 物品'}}</view
            >
            <!-- 已售出/已下架遮罩 -->
            <view class="sold-overlay" wx:if="{{item.status === 'sold'}}"><text>已售出</text></view>
            <view class="sold-overlay" wx:if="{{item.status === 'withdrawn'}}"
              ><text>已下架</text></view
            >
          </view>

          <!-- 卡片内容区 -->
          <view class="card-body">
            <view class="product-name">{{item.item_name}}</view>
            <view class="product-desc" wx:if="{{item.description}}">{{item.description}}</view>
            <!-- 价格高亮行 -->
            <view class="price-row">
              <text class="price-unit">{{item._priceLabel || item.price_asset_code}}</text>
              <text class="price-current">{{item.price_amount}}</text>
            </view>
            <!-- CTA按钮 -->
            <button
              class="cta-btn {{item.status !== 'on_sale' ? 'btn-disabled' : ''}}"
              disabled="{{item.status !== 'on_sale'}}"
            >
              {{item.status === 'sold' ? '已售出' : (item.status === 'withdrawn' ? '已下架' :
              '立即购买')}}
            </button>
          </view>

          <!-- 涟漪层（墨水扩散效果） -->
          <view
            class="ripple-layer {{item._rippleActive ? 'ripple-active' : ''}}"
            wx:if="{{effects.ripple && item._rippleActive}}"
            style="left: {{item._rippleX}}px; top: {{item._rippleY}}px"
          ></view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!loading && filteredProducts.length === 0}}">
        <view class="empty-icon">🏪</view>
        <text class="empty-text">{{searchKeyword ? '没有找到相关挂单' : '交易市场暂无挂单'}}</text>
        <button class="retry-btn" bindtap="onClearSearch" wx:if="{{searchKeyword}}">
          清除搜索
        </button>
        <button class="retry-btn" bindtap="onRefreshProducts" wx:else>重新加载</button>
      </view>

      <!-- 分页导航 -->
      <view class="pagination" wx:if="{{!loading && filteredProducts.length > 0}}">
        <view class="pagination-info">
          <text>第 {{currentPage}}/{{totalPages}} 页 · 共 {{totalProducts}} 件商品</text>
        </view>
        <view class="pagination-row unified-controls">
          <button
            class="page-btn prev-btn {{currentPage === 1 ? 'disabled' : ''}}"
            bindtap="onPrevPage"
            disabled="{{currentPage === 1}}"
          >
            ‹
          </button>
          <view class="page-numbers inline-numbers">
            <block wx:if="{{totalPages <= 7}}">
              <block wx:for="{{totalPages}}" wx:key="*this">
                <view
                  class="page-number {{currentPage === (item + 1) ? 'active' : ''}}"
                  bindtap="onPageChange"
                  data-page="{{item + 1}}"
                  >{{item + 1}}</view
                >
              </block>
            </block>
            <block wx:else>
              <view
                class="page-number {{currentPage === 1 ? 'active' : ''}}"
                bindtap="onPageChange"
                data-page="1"
                >1</view
              >
              <text class="page-ellipsis" wx:if="{{currentPage > 4}}">...</text>
              <block wx:for="{{totalPages}}" wx:key="*this">
                <view
                  class="page-number {{currentPage === (item + 1) ? 'active' : ''}}"
                  bindtap="onPageChange"
                  data-page="{{item + 1}}"
                  wx:if="{{(item + 1) > 1 && (item + 1) < totalPages && (item + 1) >= (currentPage - 2) && (item + 1) <= (currentPage + 2)}}"
                  >{{item + 1}}</view
                >
              </block>
              <text class="page-ellipsis" wx:if="{{currentPage < totalPages - 3}}">...</text>
              <view
                class="page-number {{currentPage === totalPages ? 'active' : ''}}"
                bindtap="onPageChange"
                data-page="{{totalPages}}"
                wx:if="{{totalPages > 1}}"
                >{{totalPages}}</view
              >
            </block>
          </view>
          <button
            class="page-btn next-btn {{currentPage === totalPages ? 'disabled' : ''}}"
            bindtap="onNextPage"
            disabled="{{currentPage === totalPages}}"
          >
            ›
          </button>
        </view>
      </view>
    </view>

    <!-- 我的挂单快捷入口 -->
    <view class="my-listings-entry" wx:if="{{!loading}}" bindtap="goToMyListings">
      <view class="entry-icon-wrapper">
        <text class="entry-icon">📋</text>
      </view>
      <view class="entry-text">
        <text class="entry-title">我的挂单</text>
        <text class="entry-desc">查看和管理我的市场挂单商品</text>
      </view>
      <text class="entry-arrow">▶</text>
    </view>

    <!-- 规则说明 -->
    <view class="rules-section" wx:if="{{!loading}}">
      <view class="section-title"><text>交易规则</text></view>
      <view class="rules-content">
        <view class="rule-item">• 购买后资产/物品即时到账</view>
        <view class="rule-item">• 交易完成后不可退款</view>
        <view class="rule-item">• 不可购买自己上架的商品</view>
        <view class="rule-item">• 平台可能收取交易手续费</view>
      </view>
    </view>
  </scroll-view>

  <!-- 购买确认弹窗（放在scroll-view外部，避免被裁剪） -->
  <view class="confirm-modal" wx:if="{{showConfirm}}">
    <view class="modal-mask" bindtap="onCancelExchange"></view>
    <view class="modal-content">
      <view class="confirm-header">
        <text class="confirm-title">确认购买</text>
        <view class="close-btn" bindtap="onCancelExchange">×</view>
      </view>
      <view class="product-preview" wx:if="{{selectedProduct}}">
        <image class="preview-image" src="{{selectedProduct.image}}" mode="aspectFill" />
        <view class="preview-info">
          <text class="preview-name">{{selectedProduct.item_name}}</text>
          <text class="preview-desc">{{selectedProduct.description}}</text>
          <view class="preview-cost">
            <text class="cost-label">购买价格：</text>
            <text class="cost-points"
              >{{selectedProduct.price_amount}} {{selectedProduct.price_asset_code}}</text
            >
          </view>
          <view
            class="remaining-info"
            wx:if="{{selectedProduct.listing_kind === 'fungible_asset'}}"
          >
            <text class="remaining-label">资产数量：</text>
            <text class="remaining-points"
              >{{selectedProduct.offer_amount}} {{selectedProduct.offer_asset_code}}</text
            >
          </view>
        </view>
      </view>
      <view class="confirm-footer">
        <button class="cancel-btn" bindtap="onCancelExchange">取消</button>
        <button class="confirm-btn" bindtap="onConfirmExchange">确认购买</button>
      </view>
    </view>
  </view>

  <!-- 购买结果弹窗（放在scroll-view外部，避免被裁剪） -->
  <view class="result-modal" wx:if="{{showResult}}">
    <view class="modal-mask" bindtap="onCloseResult"></view>
    <view class="modal-content">
      <view class="result-header">
        <text class="result-title">🎉 购买成功</text>
        <view class="close-btn" bindtap="onCloseResult">×</view>
      </view>
      <view class="result-content" wx:if="{{resultData}}">
        <view class="success-icon">✅</view>
        <text class="success-text">恭喜您成功购买</text>
        <text class="product-name">{{resultData.product.item_name}}</text>
        <view class="result-details">
          <view class="detail-item">
            <text class="detail-label">交易编号：</text>
            <text class="detail-value">{{resultData.orderNo}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">支付：</text>
            <text class="detail-value">-{{resultData.payAmount}} {{resultData.payAssetCode}}</text>
          </view>
          <view class="detail-item" wx:if="{{resultData.feeAmount > 0}}">
            <text class="detail-label">手续费：</text>
            <text class="detail-value">{{resultData.feeAmount}} {{resultData.payAssetCode}}</text>
          </view>
        </view>
        <text class="pickup-notice">🏪 商品/资产已到账，请在背包中查看</text>
      </view>
      <view class="result-footer">
        <button class="continue-btn" bindtap="onCloseResult">继续浏览</button>
      </view>
    </view>
  </view>
</view>
