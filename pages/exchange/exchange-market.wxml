<!-- exchange-market.wxml - 交易市场 Tab 模板（通过 include 引入 exchange.wxml） -->
<!-- 数据绑定和事件处理仍由 exchange.ts Page 方法管理 -->

<!-- 交易市场内容区域 -->
<view wx:if="{{currentTab === 'exchange'}}" class="exchange-content">
  <!-- 🔒 固定头部区域：积分信息 + 快捷操作 + 搜索 + 筛选（不随滚动移动） -->
  <view class="header exchange-market-sticky-header">
    <view class="user-info">
      <!-- 可用积分 -->
      <view class="points-info">
        <text class="points-label">可用积分：</text>
        <text class="points-value">{{totalPoints}}</text>
      </view>
      <!-- 搜索框 - 嵌入积分行中间 -->
      <view class="header-search-box">
        <input
          class="header-search-input"
          placeholder="搜索商品名称..."
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
        />
        <text class="header-search-icon">🔍</text>
      </view>
      <!-- 快捷操作按钮 -->
      <view class="header-quick-actions">
        <view class="header-action-btn" bindtap="onRefreshProducts">🔄 刷新</view>
        <view class="header-action-btn" bindtap="onSortByPoints">📊 按售价排序</view>
      </view>
    </view>

    <!-- 筛选功能 -->
    <view class="search-filter">
      <view class="filter-buttons">
        <button
          class="filter-btn {{currentFilter === 'all' ? 'active' : ''}}"
          bindtap="onFilterChange"
          data-filter="all"
        >
          全部({{products.length}})
        </button>
        <button
          class="filter-btn {{currentFilter === 'item_instance' ? 'active' : ''}}"
          bindtap="onFilterChange"
          data-filter="item_instance"
        >
          物品
        </button>
        <button
          class="filter-btn {{currentFilter === 'fungible_asset' ? 'active' : ''}}"
          bindtap="onFilterChange"
          data-filter="fungible_asset"
        >
          资产
        </button>
        <button
          class="advanced-filter-btn {{showAdvancedFilter ? 'active' : ''}}"
          bindtap="onToggleAdvancedFilter"
        >
          高级筛选 {{showAdvancedFilter ? '🔼' : '🔽'}}
        </button>
      </view>

      <!-- 高级筛选面板（交易市场专用） -->
      <view class="advanced-filter-panel" wx:if="{{showAdvancedFilter}}">
        <!-- 挂单类型筛选 -->
        <view class="filter-row">
          <text class="filter-label">挂单类型</text>
          <view class="filter-options">
            <button
              class="option-btn {{categoryFilter === 'all' ? 'active' : ''}}"
              bindtap="onCategoryFilterChange"
              data-category="all"
            >
              全部
            </button>
            <button
              class="option-btn {{categoryFilter === 'item_instance' ? 'active' : ''}}"
              bindtap="onCategoryFilterChange"
              data-category="item_instance"
            >
              物品实例
            </button>
            <button
              class="option-btn {{categoryFilter === 'fungible_asset' ? 'active' : ''}}"
              bindtap="onCategoryFilterChange"
              data-category="fungible_asset"
            >
              可叠加资产
            </button>
          </view>
        </view>

        <!-- 排序方式 -->
        <view class="filter-row">
          <text class="filter-label">排序方式</text>
          <view class="filter-options">
            <button
              class="option-btn {{sortBy === 'default' ? 'active' : ''}}"
              bindtap="onSortByChange"
              data-sort="default"
            >
              默认
            </button>
            <button
              class="option-btn {{sortBy === 'newest' ? 'active' : ''}}"
              bindtap="onSortByChange"
              data-sort="newest"
            >
              最新上架
            </button>
            <button
              class="option-btn {{sortBy === 'price_asc' ? 'active' : ''}}"
              bindtap="onSortByChange"
              data-sort="price_asc"
            >
              价格升序
            </button>
            <button
              class="option-btn {{sortBy === 'price_desc' ? 'active' : ''}}"
              bindtap="onSortByChange"
              data-sort="price_desc"
            >
              价格降序
            </button>
          </view>
        </view>

        <!-- 筛选操作 -->
        <view class="filter-actions">
          <button class="reset-btn" bindtap="onResetFilters">重置筛选</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 📜 可滚动商品列表区域（含下拉刷新） -->
  <scroll-view
    class="exchange-market-scroll-body"
    scroll-y="true"
    enhanced="true"
    show-scrollbar="false"
    bounces="true"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onScrollViewRefresh"
  >
    <!-- 加载状态 -->
    <loading-spinner wx:if="{{loading}}" text="加载中..." />

    <!-- 交易市场挂单列表（C2C用户交易）- 暗色高级质感风格 -->
    <view class="products-section" wx:else>
      <view class="products-grid dark-grid">
        <view
          class="product-item dark-card {{item.status !== 'on_sale' ? 'sold-out' : ''}} {{item.listing_kind === 'fungible_asset' ? 'card-asset' : 'card-item'}}"
          wx:for="{{filteredProducts}}"
          wx:key="market_listing_id"
          bindtap="onProductTap"
          data-product="{{item}}"
        >
          <!-- 霓虹顶部光条 -->
          <view
            class="dark-card-glow-bar {{item.listing_kind === 'fungible_asset' ? 'glow-asset' : 'glow-item'}}"
          ></view>

          <!-- 商品图片区域 -->
          <view class="product-image-container dark-image-wrap">
            <view
              wx:if="{{item.imageStatus === 'loading'}}"
              class="image-loading dark-image-loading"
            >
              <view class="dark-loading-ring"></view>
            </view>
            <image
              class="product-image {{item.imageStatus === 'error' ? 'image-error' : ''}}"
              src="{{item.image}}"
              mode="aspectFill"
              binderror="onImageError"
              bindload="onImageLoad"
              data-index="{{index}}"
            />
            <!-- 图片加载失败占位 -->
            <view
              wx:if="{{item.imageStatus === 'error' || !item.image}}"
              class="dark-image-fallback {{item.listing_kind === 'fungible_asset' ? 'fallback-asset' : 'fallback-item'}}"
            >
              <text class="fallback-emoji"
                >{{item.listing_kind === 'fungible_asset' ? '💎' : '📦'}}</text
              >
              <text class="fallback-text"
                >{{item.listing_kind === 'fungible_asset' ? 'ASSET' : 'ITEM'}}</text
              >
            </view>
            <!-- 图片底部渐变遮罩 -->
            <view class="dark-image-overlay"></view>
            <!-- 霓虹类型标签 -->
            <view
              class="dark-type-badge {{item.listing_kind === 'fungible_asset' ? 'badge-asset' : 'badge-item'}}"
            >
              <text class="badge-dot"></text>
              <text>{{item.listing_kind === 'fungible_asset' ? '资产' : '物品'}}</text>
            </view>
            <!-- 稀有度标签 -->
            <view class="dark-rarity-badge" wx:if="{{item.offer_item_rarity}}">
              <text>{{item.offer_item_rarity}}</text>
            </view>
            <!-- 已售出 / 已下架遮罩 -->
            <view class="dark-sold-overlay" wx:if="{{item.status === 'sold'}}">
              <text class="sold-stamp">SOLD</text>
              <text class="sold-text-cn">已售出</text>
            </view>
            <view class="dark-sold-overlay withdrawn" wx:if="{{item.status === 'withdrawn'}}">
              <text class="sold-stamp">OFF</text>
              <text class="sold-text-cn">已下架</text>
            </view>
          </view>

          <!-- 商品信息区域 -->
          <view class="product-info dark-info">
            <view class="product-name dark-name">{{item.item_name}}</view>
            <view class="product-desc dark-desc" wx:if="{{item.description}}"
              >{{item.description}}</view
            >
            <!-- 价格高亮区域 -->
            <view class="dark-price-block">
              <view class="dark-price-main">
                <text class="dark-price-num">{{item.price_amount}}</text>
                <text class="dark-price-unit">{{item.price_asset_code}}</text>
              </view>
            </view>
          </view>

          <!-- 购买按钮 -->
          <view class="exchange-btn-container dark-btn-wrap">
            <button
              class="exchange-btn dark-buy-btn {{item.status !== 'on_sale' ? 'disabled' : ''}}"
              disabled="{{item.status !== 'on_sale'}}"
            >
              {{item.status === 'sold' ? '已售出' : (item.status === 'withdrawn' ? '已下架' :
              '立即购买')}}
            </button>
          </view>
        </view>
      </view>

      <!-- 空状态（复用通用empty-state组件） -->
      <empty-state
        wx:if="{{!loading && filteredProducts.length === 0 && searchKeyword}}"
        icon="🔍"
        title="没有找到相关挂单"
        subtitle="试试其他关键词"
        buttonText="清除搜索"
        bind:retry="onClearSearch"
      />
      <empty-state
        wx:if="{{!loading && filteredProducts.length === 0 && !searchKeyword}}"
        icon="🏪"
        title="交易市场暂无挂单"
        subtitle="暂时没有商品在售"
        buttonText="重新加载"
        bind:retry="onRefreshProducts"
      />

      <!-- 分页导航（复用通用pagination组件） -->
      <pagination
        wx:if="{{!loading && filteredProducts.length > 0}}"
        currentPage="{{currentPage}}"
        totalPages="{{totalPages}}"
        totalItems="{{totalProducts}}"
        itemUnit="件商品"
        bind:pagechange="onMarketPaginationChange"
      />
    </view>

    <!-- 我的挂单快捷入口 -->
    <view class="my-listings-entry" wx:if="{{!loading}}" bindtap="goToMyListings">
      <view class="entry-icon-wrapper">
        <text class="entry-icon">📋</text>
      </view>
      <view class="entry-text">
        <text class="entry-title">我的挂单</text>
        <text class="entry-desc">查看和管理我的市场挂单商品</text>
      </view>
      <text class="entry-arrow">▶</text>
    </view>

    <!-- 规则说明 -->
    <view class="rules-section" wx:if="{{!loading}}">
      <view class="section-title"><text>交易规则</text></view>
      <view class="rules-content">
        <view class="rule-item">• 购买后资产/物品即时到账</view>
        <view class="rule-item">• 交易完成后不可退款</view>
        <view class="rule-item">• 不可购买自己上架的商品</view>
        <view class="rule-item">• 平台可能收取交易手续费</view>
      </view>
    </view>
  </scroll-view>

  <!-- 购买确认弹窗（放在scroll-view外部，避免被裁剪） -->
  <view class="confirm-modal" wx:if="{{showConfirm}}">
    <view class="modal-mask" bindtap="onCancelExchange"></view>
    <view class="modal-content">
      <view class="confirm-header">
        <text class="confirm-title">确认购买</text>
        <view class="close-btn" bindtap="onCancelExchange">×</view>
      </view>
      <view class="product-preview" wx:if="{{selectedProduct}}">
        <image class="preview-image" src="{{selectedProduct.image}}" mode="aspectFill" />
        <view class="preview-info">
          <text class="preview-name">{{selectedProduct.item_name}}</text>
          <text class="preview-desc">{{selectedProduct.description}}</text>
          <view class="preview-cost">
            <text class="cost-label">购买价格：</text>
            <text class="cost-points"
              >{{selectedProduct.price_amount}} {{selectedProduct.price_asset_code}}</text
            >
          </view>
          <view
            class="remaining-info"
            wx:if="{{selectedProduct.listing_kind === 'fungible_asset'}}"
          >
            <text class="remaining-label">资产数量：</text>
            <text class="remaining-points"
              >{{selectedProduct.offer_amount}} {{selectedProduct.offer_asset_code}}</text
            >
          </view>
        </view>
      </view>
      <view class="confirm-footer">
        <button class="cancel-btn" bindtap="onCancelExchange">取消</button>
        <button class="confirm-btn" bindtap="onConfirmExchange">确认购买</button>
      </view>
    </view>
  </view>

  <!-- 购买结果弹窗（放在scroll-view外部，避免被裁剪） -->
  <view class="result-modal" wx:if="{{showResult}}">
    <view class="modal-mask" bindtap="onCloseResult"></view>
    <view class="modal-content">
      <view class="result-header">
        <text class="result-title">🎉 购买成功</text>
        <view class="close-btn" bindtap="onCloseResult">×</view>
      </view>
      <view class="result-content" wx:if="{{resultData}}">
        <view class="success-icon">✅</view>
        <text class="success-text">恭喜您成功购买</text>
        <text class="product-name">{{resultData.product.item_name}}</text>
        <view class="result-details">
          <view class="detail-item">
            <text class="detail-label">交易编号：</text>
            <text class="detail-value">{{resultData.orderNo}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">支付：</text>
            <text class="detail-value">-{{resultData.payAmount}} {{resultData.payAssetCode}}</text>
          </view>
          <view class="detail-item" wx:if="{{resultData.feeAmount > 0}}">
            <text class="detail-label">手续费：</text>
            <text class="detail-value">{{resultData.feeAmount}} {{resultData.payAssetCode}}</text>
          </view>
        </view>
        <text class="pickup-notice">🏪 商品/资产已到账，请在背包中查看</text>
      </view>
      <view class="result-footer">
        <button class="continue-btn" bindtap="onCloseResult">继续浏览</button>
      </view>
    </view>
  </view>
</view>
