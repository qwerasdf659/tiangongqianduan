<!-- pages/exchange/exchange.wxml — 兑换中心页面壳 -->
<!-- 组件化架构: exchange-shelf（商品兑换Tab）+ asset-conversion（资产转换Tab，后端tab key仍为exchange-rate） -->
<!-- D13决策: 使用 hidden 替代 wx:if，保留组件状态（筛选/分页/搜索/滚动位置） -->
<view class="exchange-container">
  <scroll-view
    type="list"
    scroll-y
    class="page-scroll-view"
    lower-threshold="120"
    scroll-into-view="{{pageScrollIntoView}}"
    bindscroll="onPageScroll"
    bindscrolltolower="onPageScrollToLower"
  >
    <view id="page-top"></view>
    <t-loading wx:if="{{loading}}" loading="{{true}}" text="加载中..." theme="spinner" />

    <t-empty wx:if="{{!loading && hasConfigError}}" description="{{configErrorMessage}}">
      <view slot="image"><t-icon name="error-triangle-filled" size="48rpx" color="#999" /></view>
      <view slot="action" class="exchange-empty-action" bindtap="onPullDownRefresh">重新加载</view>
    </t-empty>

    <!-- 页面标题（视觉锚点） -->
    <view class="page-header" wx:if="{{!loading && !hasConfigError}}">
      <text class="page-title">积分商城</text>
      <text class="page-subtitle">积分兑换·官方竞价·资产转换</text>
    </view>

    <!-- 🎨 顶部 Banner（运营可配，position=exchange；仅有运营配置时渲染，无则不占位不留白） -->
    <view class="exchange-top-banner" wx:if="{{!loading && !hasConfigError && topBannerReady}}">
      <swiper
        wx:if="{{topBannerCarousel}}"
        class="exchange-top-banner-media"
        autoplay="{{true}}"
        circular="{{true}}"
        interval="{{topBannerInterval}}"
        indicator-dots="{{topBannerItems.length > 1}}"
        indicator-color="rgba(255,255,255,0.4)"
        indicator-active-color="#ffffff"
        bindchange="onTopBannerChange"
      >
        <swiper-item wx:for="{{topBannerItems}}" wx:key="ad_campaign_id">
          <image
            class="exchange-top-banner-media"
            src="{{item.image_url}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onTopBannerTap"
          />
        </swiper-item>
      </swiper>
      <image
        wx:else
        class="exchange-top-banner-media"
        src="{{topBannerItems[0].image_url}}"
        mode="aspectFill"
        data-index="0"
        bindtap="onTopBannerTap"
      />
    </view>

    <view class="nav-module horizontal" hover-class="none" wx:if="{{!loading && !hasConfigError}}">
      <t-tabs
        value="{{currentTab}}"
        bind:change="onTabChange"
        theme="line"
        split="{{false}}"
        spaceEvenly="{{false}}"
        sticky="{{false}}"
        swipeable="{{false}}"
      >
        <t-tab-panel
          wx:for="{{tabs}}"
          wx:key="key"
          value="{{item.key}}"
          label="{{item.label}}"
        ></t-tab-panel>
      </t-tabs>
    </view>

    <view
      class="tab-content-wrapper"
      hidden="{{loading || hasConfigError || currentTab !== 'exchange'}}"
    >
      <exchange-shelf
        active="{{currentTab === 'exchange'}}"
        pointsBalance="{{totalPoints}}"
        frozenPoints="{{frozenPoints}}"
        assetBalances="{{assetBalances}}"
        effects="{{effects}}"
        viewMode="{{viewMode}}"
        spaceId="{{currentSpace}}"
        refreshToken="{{_shelfRefreshToken}}"
        isLoggedIn="{{isLoggedIn}}"
        bind:exchange="onExchangeSuccess"
        bind:pointsupdate="onPointsUpdate"
        bind:viewmodechange="onViewModeChange"
        bind:autherror="onAuthError"
        bind:needlogin="onShowLoginPopup"
      />
    </view>

    <view
      class="tab-content-wrapper"
      hidden="{{loading || hasConfigError || currentTab !== 'exchange-rate'}}"
    >
      <asset-conversion
        active="{{currentTab === 'exchange-rate'}}"
        pointsBalance="{{totalPoints}}"
        refreshToken="{{_exchangeRateRefreshToken}}"
        bind:conversionsuccess="onConversionSuccess"
      />
    </view>

    <!-- 道具商城 Tab（星石轨·零价值道具，后端 exchange_page 配置 key='prop' 启用时显示） -->
    <view
      class="tab-content-wrapper"
      hidden="{{loading || hasConfigError || currentTab !== 'prop'}}"
    >
      <props-mall
        id="props-mall"
        active="{{currentTab === 'prop'}}"
        pointsBalance="{{totalPoints}}"
        assetBalances="{{assetBalances}}"
        effects="{{effects}}"
        viewMode="{{viewMode}}"
        refreshToken="{{_propsMallRefreshToken}}"
        isLoggedIn="{{isLoggedIn}}"
        bind:exchange="onExchangeSuccess"
        bind:pointsupdate="onPointsUpdate"
        bind:autherror="onAuthError"
        bind:needlogin="onShowLoginPopup"
      />
    </view>

    <maintenance-overlay />
  </scroll-view>

  <!-- 回到顶部浮动按钮：仅道具商城 Tab、滚动超阈值时显示 -->
  <view
    class="page-back-to-top"
    wx:if="{{showBackToTop && currentTab === 'prop'}}"
    bindtap="onPageBackToTop"
  >
    <t-icon name="backtop" size="40rpx" />
  </view>

  <!-- 登录弹窗 -->
  <login-popup
    visible="{{loginPopupVisible}}"
    bind:close="onLoginPopupClose"
    bind:loginsuccess="onLoginSuccess"
  />
</view>
