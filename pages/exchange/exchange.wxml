<!-- pages/exchange/exchange.wxml — 兑换中心页面壳 -->
<!-- 组件化架构: exchange-shelf（商品兑换Tab）+ asset-conversion（资产转换Tab，后端tab key仍为exchange-rate） -->
<!-- D13决策: 使用 hidden 替代 wx:if，保留组件状态（筛选/分页/搜索/滚动位置） -->
<view class="exchange-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <t-loading wx:if="{{loading}}" loading="{{true}}" text="加载中..." theme="spinner" />

    <t-empty wx:if="{{!loading && hasConfigError}}" description="{{configErrorMessage}}">
      <view slot="image"><t-icon name="error-triangle-filled" size="48rpx" color="#999" /></view>
      <view slot="action" class="exchange-empty-action" bindtap="onPullDownRefresh">重新加载</view>
    </t-empty>

    <!-- 页面标题（视觉锚点） -->
    <view class="page-header" wx:if="{{!loading && !hasConfigError}}">
      <text class="page-title">积分商城</text>
      <text class="page-subtitle">积分兑换·官方竞价·资产转换</text>
    </view>

    <view class="nav-module horizontal" hover-class="none" wx:if="{{!loading && !hasConfigError}}">
      <t-tabs
        value="{{currentTab}}"
        bind:change="onTabChange"
        theme="line"
        split="{{false}}"
        spaceEvenly="{{false}}"
        sticky="{{false}}"
        swipeable="{{false}}"
      >
        <t-tab-panel
          wx:for="{{tabs}}"
          wx:key="key"
          value="{{item.key}}"
          label="{{item.label}}"
        ></t-tab-panel>
      </t-tabs>
    </view>

    <view
      class="tab-content-wrapper"
      hidden="{{loading || hasConfigError || currentTab !== 'exchange'}}"
    >
      <exchange-shelf
        active="{{currentTab === 'exchange'}}"
        pointsBalance="{{totalPoints}}"
        frozenPoints="{{frozenPoints}}"
        assetBalances="{{assetBalances}}"
        effects="{{effects}}"
        viewMode="{{viewMode}}"
        spaceId="{{currentSpace}}"
        refreshToken="{{_shelfRefreshToken}}"
        isLoggedIn="{{isLoggedIn}}"
        bind:exchange="onExchangeSuccess"
        bind:pointsupdate="onPointsUpdate"
        bind:viewmodechange="onViewModeChange"
        bind:autherror="onAuthError"
        bind:needlogin="onShowLoginPopup"
      />
    </view>

    <view
      class="tab-content-wrapper"
      hidden="{{loading || hasConfigError || currentTab !== 'exchange-rate'}}"
    >
      <asset-conversion
        active="{{currentTab === 'exchange-rate'}}"
        pointsBalance="{{totalPoints}}"
        refreshToken="{{_exchangeRateRefreshToken}}"
        bind:conversionsuccess="onConversionSuccess"
      />
    </view>

    <maintenance-overlay />
  </scroll-view>

  <!-- 登录弹窗 -->
  <login-popup
    visible="{{loginPopupVisible}}"
    bind:close="onLoginPopupClose"
    bind:loginsuccess="onLoginSuccess"
  />
</view>
