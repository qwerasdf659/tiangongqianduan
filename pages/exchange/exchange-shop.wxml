<!-- exchange-shop.wxml - 商品兑换/双空间 Tab 模板（通过 include 引入 exchange.wxml） -->
<!-- 包含：幸运空间（瀑布流）、臻选空间（混合展示）、竞价弹窗 -->
<!-- 数据绑定和事件处理仍由 exchange.ts Page 方法管理 -->

<!-- 🏪 双空间商品兑换系统 -->
<view wx:if="{{currentTab === 'market'}}" class="dual-space-market">
  <!-- 🔒 固定头部：空间切换导航 - 不随滚动移动 -->
  <view class="shop-sticky-header">
    <!-- 🎯 空间切换导航 - 增强版胶囊式切换器 -->
    <view class="space-selector-enhanced">
      <view class="selector-track">
        <!-- 滑动指示器背景 -->
        <view
          class="selector-slider {{currentSpace === 'premium' ? 'slide-right' : 'slide-left'}}"
        ></view>
        <!-- Tab按钮 -->
        <view
          class="space-tab-enhanced {{item.id === currentSpace ? 'active' : ''}} {{item.id === 'premium' && !premiumUnlocked ? 'locked' : ''}}"
          wx:for="{{spaceList}}"
          wx:key="id"
          data-space="{{item.id}}"
          bindtap="onSpaceChange"
        >
          <view class="tab-inner">
            <view class="tab-icon-row">
              <text class="tab-emoji">{{item.id === 'lucky' ? '🍀' : '💎'}}</text>
              <text class="tab-label {{item.id === currentSpace ? 'active-label' : ''}}">
                {{item.id === 'premium' && !premiumUnlocked ? '🔒 ' : ''}}{{item.name}}
              </text>
            </view>
            <text class="tab-desc {{item.id === currentSpace ? 'active-desc' : ''}}">
              {{item.id === 'premium' && !premiumUnlocked ? '达标可解锁' : item.subtitle}}
            </text>
          </view>
          <!-- 🔒 臻选空间解锁状态小标签 -->
          <view
            wx:if="{{item.id === 'premium'}}"
            class="unlock-badge {{premiumUnlocked ? 'unlocked' : 'locked'}}"
          >
            <text>{{premiumUnlocked ? '已解锁' : (premiumCanUnlock ? '可解锁' : '未解锁')}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 📊 积分信息 + 搜索 + 快捷操作 + 筛选（和交易市场一致，固定在空间切换器下方） -->
    <view class="header exchange-market-sticky-header">
      <view class="user-info">
        <!-- 可用积分 -->
        <view class="points-info">
          <text class="points-label">可用积分：</text>
          <text class="points-value">{{totalPoints}}</text>
        </view>
        <!-- 搜索框 - 嵌入积分行中间 -->
        <view class="header-search-box">
          <input
            class="header-search-input"
            placeholder="搜索商品名称..."
            value="{{luckySearchKeyword}}"
            bindinput="onLuckySearchInput"
          />
          <text class="header-search-icon">🔍</text>
        </view>
        <!-- 快捷操作按钮 -->
        <view class="header-quick-actions">
          <view class="header-action-btn" bindtap="onRefreshProducts">🔄 刷新</view>
          <view class="header-action-btn" bindtap="onShopSortByPoints">📊 按售价排序</view>
        </view>
      </view>

      <!-- 筛选功能 -->
      <view class="search-filter">
        <view class="filter-buttons">
          <button
            wx:for="{{luckyBasicFilters}}"
            wx:key="key"
            class="filter-btn {{luckyCurrentFilter === item.key ? 'active' : ''}}"
            bindtap="onLuckyFilterChange"
            data-filter="{{item.key}}"
          >
            {{item.showCount ? item.label + '(' + luckyTotalProducts + ')' : item.label}}
          </button>
          <button
            class="advanced-filter-btn {{showLuckyAdvancedFilter ? 'active' : ''}}"
            bindtap="onToggleLuckyAdvancedFilter"
          >
            高级筛选 {{showLuckyAdvancedFilter ? '🔼' : '🔽'}}
          </button>
        </view>

        <!-- 高级筛选面板 -->
        <view class="advanced-filter-panel" wx:if="{{showLuckyAdvancedFilter}}">
          <view class="filter-row">
            <text class="filter-label">商品分类</text>
            <view class="filter-options">
              <button
                wx:for="{{categoryOptions}}"
                wx:key="key"
                class="option-btn {{luckyCategoryFilter === item.key ? 'active' : ''}}"
                bindtap="onLuckyCategoryFilterChange"
                data-category="{{item.key}}"
              >
                {{item.label}}
              </button>
            </view>
          </view>
          <view class="filter-row">
            <text class="filter-label">积分范围</text>
            <view class="filter-options">
              <button
                wx:for="{{pointsRangeOptions}}"
                wx:key="key"
                class="option-btn {{luckyPointsRange === item.key ? 'active' : ''}}"
                bindtap="onLuckyPointsRangeChange"
                data-range="{{item.key}}"
              >
                {{item.label}}
              </button>
            </view>
          </view>
          <view class="filter-row">
            <text class="filter-label">库存状态</text>
            <view class="filter-options">
              <button
                wx:for="{{stockFilterOptions}}"
                wx:key="key"
                class="option-btn {{luckyStockFilter === item.key ? 'active' : ''}}"
                bindtap="onLuckyStockFilterChange"
                data-filter="{{item.key}}"
              >
                {{item.label}}
              </button>
            </view>
          </view>
          <view class="filter-row">
            <text class="filter-label">排序方式</text>
            <view class="filter-options">
              <button
                wx:for="{{sortByOptions}}"
                wx:key="key"
                class="option-btn {{luckySortBy === item.key ? 'active' : ''}}"
                bindtap="onLuckySortByChange"
                data-sort="{{item.key}}"
              >
                {{item.label}}
              </button>
            </view>
          </view>
          <view class="filter-actions">
            <button class="reset-btn" bindtap="onResetLuckyFilters">重置筛选</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 🔒 可滚动内容区域 - 商品列表随滚动移动（含下拉刷新） -->
  <scroll-view
    class="shop-scroll-body"
    scroll-y="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onScrollViewRefresh"
  >
    <!-- 🍀 幸运空间 - 瀑布流卡片布局 -->
    <view
      wx:if="{{currentSpace === 'lucky'}}"
      class="lucky-space-content waterfall-market-container"
    >
      <!-- 🌊 商品网格容器（Flex两列布局） -->
      <view
        class="waterfall-container modern-waterfall"
        wx:if="{{!loading && ((luckyFilteredProducts && luckyFilteredProducts.length > 0) || (waterfallProducts && waterfallProducts.length > 0))}}"
      >
        <view
          class="product-card waterfall-card modern-card"
          wx:for="{{luckyFilteredProducts.length > 0 ? luckyFilteredProducts : waterfallProducts}}"
          wx:key="id"
          style="width: calc(50% - 12rpx); margin-bottom: 16rpx"
          data-product="{{item}}"
          bindtap="onProductTap"
        >
          <!-- 卡片顶部类型渐变条带 -->
          <view class="card-type-stripe stripe-lucky">
            <text class="stripe-label">🍀 幸运好物</text>
            <view class="stripe-tags">
              <text class="stripe-tag hot" wx:if="{{item.is_hot}}">热销</text>
              <text class="stripe-tag new" wx:if="{{item.is_new}}">新品</text>
            </view>
          </view>

          <!-- 图片区域 -->
          <view class="card-image-container modern-image-container">
            <image
              class="product-image card-image waterfall-image"
              src="{{item.image}}"
              mode="aspectFill"
              lazy-load="{{true}}"
              binderror="onShopImageError"
              data-index="{{index}}"
              data-space="lucky"
            />
            <!-- 图片加载失败或无图时的彩色占位 -->
            <view
              class="image-fallback fallback-lucky"
              wx:if="{{!item.image || item.image === '/images/products/default-product.png'}}"
            >
              <text class="fallback-icon">🎁</text>
              <text class="fallback-text">{{item.name}}</text>
            </view>
            <!-- 图片底部渐变遮罩 -->
            <view class="image-gradient-mask"></view>
            <view class="lucky-badge modern-lucky-badge" wx:if="{{item.is_lucky}}">🍀</view>
            <view class="sales-badge modern-sales-badge" wx:if="{{item.sold_count > 0}}">
              <text class="sales-text">已售{{item.sold_count}}</text>
            </view>
          </view>

          <!-- 商品信息 -->
          <view class="card-content modern-card-content">
            <text class="product-title waterfall-title modern-title">{{item.name}}</text>
            <!-- 价格色块高亮 -->
            <view class="product-price-block price-lucky">
              <view class="price-main-row">
                <text class="price-currency"
                  >{{item.cost_asset_code === 'POINTS' ? '积分' : item.cost_asset_code}}</text
                >
                <text class="price-amount">{{item.cost_amount}}</text>
              </view>
            </view>
            <!-- 库存进度条 -->
            <view class="product-stock-bar" wx:if="{{item.stock !== undefined}}">
              <view class="stock-bar-track">
                <view
                  class="stock-bar-fill {{item.stock < 10 ? 'stock-low' : (item.stock < 50 ? 'stock-medium' : 'stock-high')}}"
                  style="width: {{item.stock > 100 ? 100 : item.stock}}%"
                ></view>
              </view>
              <text class="stock-bar-text {{item.stock < 10 ? 'text-low' : ''}}"
                >库存 {{item.stock}}</text
              >
            </view>
          </view>
        </view>
      </view>

      <!-- ⏳ 加载状态 -->
      <view class="loading-section modern-loading" wx:if="{{loading}}">
        <view class="loading-content modern-loading-content">
          <view class="loading-spinner modern-spinner">
            <view class="spinner-dot dot1"></view>
            <view class="spinner-dot dot2"></view>
            <view class="spinner-dot dot3"></view>
          </view>
          <text class="loading-text modern-loading-text">幸运好物加载中...</text>
        </view>
      </view>

      <!-- 幸运空间分页导航（复用通用pagination组件） -->
      <pagination
        wx:if="{{!loading && luckyTotalProducts > 0}}"
        currentPage="{{luckyCurrentPage}}"
        totalPages="{{luckyTotalPages}}"
        totalItems="{{luckyTotalProducts}}"
        itemUnit="件商品"
        bind:pagechange="onLuckyPaginationChange"
      />

      <!-- 幸运空间空状态（复用通用empty-state组件） -->
      <empty-state
        wx:if="{{!loading && luckyFilteredProducts.length === 0 && waterfallProducts.length === 0}}"
        icon="🍀"
        title="幸运空间准备中"
        subtitle="好运即将到来，请稍后再试"
        buttonText="重新加载"
        bind:retry="initLuckySpaceData"
      />
    </view>

    <!-- 💎 臻选空间 - 双列网格布局（与幸运空间统一风格） -->
    <view
      wx:if="{{currentSpace === 'premium'}}"
      class="premium-space-content premium-grid-container"
    >
      <!-- ⏳ 加载状态 -->
      <view class="premium-loading" wx:if="{{loading}}">
        <view class="premium-loading-inner">
          <view class="premium-spinner">
            <view class="spinner-ring"></view>
          </view>
          <text class="premium-loading-text">臻选好物加载中...</text>
        </view>
      </view>

      <!-- 🌊 臻选商品网格容器（Flex两列布局，与幸运空间一致） -->
      <view
        class="waterfall-container premium-waterfall"
        wx:if="{{!loading && premiumFilteredProducts && premiumFilteredProducts.length > 0}}"
      >
        <view
          class="product-card waterfall-card premium-card"
          wx:for="{{premiumFilteredProducts}}"
          wx:key="id"
          style="width: calc(50% - 12rpx); margin-bottom: 16rpx"
          data-product="{{item}}"
          bindtap="onProductTap"
        >
          <!-- 卡片顶部类型渐变条带 -->
          <view class="card-type-stripe stripe-premium">
            <text class="stripe-label">💎 臻选</text>
            <view class="stripe-tags">
              <text class="stripe-tag hot" wx:if="{{item.is_hot}}">🔥 热销</text>
              <text class="stripe-tag new" wx:if="{{item.is_new}}">✨ 新品</text>
            </view>
          </view>

          <!-- 图片区域 -->
          <view class="card-image-container premium-image-container">
            <image
              class="product-image card-image waterfall-image"
              src="{{item.image}}"
              mode="aspectFill"
              lazy-load="{{true}}"
              binderror="onShopImageError"
              data-index="{{index}}"
              data-space="premium"
            />
            <!-- 图片加载失败或无图时的彩色占位 -->
            <view
              class="image-fallback fallback-premium"
              wx:if="{{!item.image || item.image === '/images/products/default-product.png'}}"
            >
              <text class="fallback-icon">💎</text>
              <text class="fallback-text">{{item.name}}</text>
            </view>
            <!-- 图片底部渐变遮罩 -->
            <view class="image-gradient-mask"></view>
            <view class="sales-badge premium-sales-badge" wx:if="{{item.sold_count > 0}}">
              <text class="sales-text">已售{{item.sold_count}}</text>
            </view>
          </view>

          <!-- 商品信息 -->
          <view class="card-content premium-card-content">
            <text class="product-title waterfall-title premium-title">{{item.name}}</text>
            <!-- 价格色块高亮 -->
            <view class="product-price-block price-premium">
              <view class="price-main-row">
                <text class="price-currency"
                  >{{item.cost_asset_code === 'POINTS' ? '积分' : item.cost_asset_code}}</text
                >
                <text class="price-amount">{{item.cost_amount}}</text>
              </view>
              <text class="price-original" wx:if="{{item.original_price}}"
                >{{item.original_price}}</text
              >
            </view>
            <!-- 库存进度条 -->
            <view class="product-stock-bar" wx:if="{{item.stock !== undefined}}">
              <view class="stock-bar-track">
                <view
                  class="stock-bar-fill {{item.stock < 10 ? 'stock-low' : (item.stock < 50 ? 'stock-medium' : 'stock-high')}}"
                  style="width: {{item.stock > 100 ? 100 : item.stock}}%"
                ></view>
              </view>
              <text class="stock-bar-text {{item.stock < 10 ? 'text-low' : ''}}"
                >库存 {{item.stock}}</text
              >
            </view>
          </view>
        </view>
      </view>

      <!-- 🎯 竞价商品区域 — 后端API: GET /api/v4/backpack/bid/products -->
      <view
        class="bid-section-enhanced"
        wx:if="{{biddingProducts && biddingProducts.length > 0 && !loading}}"
      >
        <!-- 区域头部：标题 + 竞价历史入口 -->
        <view class="section-header-enhanced bid-section-header">
          <view class="section-header-left">
            <view class="section-dot bid-dot"></view>
            <text class="section-title-text">🎯 竞价拍卖</text>
          </view>
          <view class="bid-header-right">
            <text class="bid-live-dot"></text>
            <text class="bid-live-text">{{biddingProducts.length}}件竞拍中</text>
          </view>
        </view>

        <!-- 双列卡片网格布局 -->
        <view class="bid-card-grid">
          <view
            class="bid-card {{item.status === 'active' ? 'bid-card-active' : 'bid-card-pending'}}"
            wx:for="{{biddingProducts}}"
            wx:key="bid_product_id"
            data-product="{{item}}"
            bindtap="onBidTap"
          >
            <!-- 商品图片区域 -->
            <view class="bid-card-img-wrap">
              <image
                class="bid-card-img"
                src="{{item.image}}"
                mode="aspectFill"
                lazy-load="{{true}}"
                wx:if="{{item.image && item.image !== '/images/products/default-product.png'}}"
              />
              <!-- prettier-ignore -->
              <view wx:else
                style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #fff3e0, #ffe0b2); font-size: 50rpx;">
                <text>🎯</text>
              </view>
              <!-- 状态标签（左上角） -->
              <view class="bid-card-status {{item.status}}">
                <text class="bid-card-status-dot"></text>
                <text
                  >{{item.status === 'active' ? '竞价中' : (item.status === 'pending' ? '即将开始' :
                  '已结束')}}</text
                >
              </view>
              <!-- 出价热度（右上角） -->
              <view class="bid-card-heat" wx:if="{{item.bid_count > 0}}">
                <text>🔥 {{item.bid_count}}</text>
              </view>
            </view>

            <!-- 商品信息区域 -->
            <view class="bid-card-body">
              <text class="bid-card-name">{{item.name}}</text>

              <!-- 当前价格高亮显示 -->
              <view class="bid-card-price-block">
                <text class="bid-card-price-label">当前价</text>
                <view class="bid-card-price-main">
                  <text class="bid-card-price-num">{{item.current_price || item.start_price}}</text>
                  <text class="bid-card-price-unit">{{item.price_asset_code}}</text>
                </view>
              </view>

              <!-- 竞价热度进度条 -->
              <view class="bid-card-heat-bar" wx:if="{{item.bid_count > 0}}">
                <view class="heat-bar-track">
                  <view
                    class="heat-bar-fill"
                    style="width: {{item.bid_count > 10 ? 100 : item.bid_count * 10}}%"
                  >
                  </view>
                </view>
                <text class="heat-bar-label"
                  >{{item.bid_count > 10 ? '超火爆' : (item.bid_count > 5 ? '火热竞拍' :
                  '参与竞拍')}}</text
                >
              </view>

              <!-- 倒计时（竞价中状态显示） -->
              <view
                class="bid-card-countdown"
                wx:if="{{item.status === 'active' && item._countdownText}}"
              >
                <text class="countdown-icon">⏱</text>
                <text class="countdown-text">{{item._countdownText}}</text>
              </view>

              <!-- 出价按钮 -->
              <button
                class="bid-card-btn {{item.status !== 'active' ? 'btn-disabled' : ''}}"
                catchtap="onBidTap"
                data-product="{{item}}"
              >
                <text
                  >{{item.status === 'active' ? '立即出价' : (item.status === 'pending' ? '即将开始'
                  : '已结束')}}</text
                >
              </button>
            </view>
          </view>
        </view>
      </view>

      <!-- 臻选空间分页导航（复用通用pagination组件） -->
      <pagination
        wx:if="{{!loading && premiumTotalProducts > 0}}"
        currentPage="{{premiumCurrentPage}}"
        totalPages="{{premiumTotalPages}}"
        totalItems="{{premiumTotalProducts}}"
        itemUnit="件商品"
        bind:pagechange="onPremiumPaginationChange"
      />

      <!-- 🚫 空状态（臻选商品和竞价商品都为空时显示） -->
      <view
        class="premium-empty-state"
        wx:if="{{!loading && (!premiumFilteredProducts || premiumFilteredProducts.length === 0) && (!biddingProducts || biddingProducts.length === 0)}}"
      >
        <view class="empty-diamond-icon">
          <text class="diamond-emoji">💎</text>
          <view class="diamond-ring"></view>
        </view>
        <text class="empty-main-text">臻选空间即将精彩呈现</text>
        <text class="empty-sub-text">精品好物和竞价拍卖即将上架</text>
        <button class="empty-retry-btn modern-retry-btn" bindtap="initPremiumSpaceData" size="mini">
          重新加载
        </button>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 🎯 竞价弹窗 — 后端API: POST /api/v4/backpack/bid -->
<view class="bid-overlay" wx:if="{{showBidModal}}" bindtap="onCancelBid">
  <view class="bid-sheet" catchtap="">
    <!-- 竞价弹窗头部（含倒计时） -->
    <view class="bid-sheet-header">
      <view class="bid-header-bg"></view>
      <view class="bid-header-content">
        <text class="bid-header-icon">🎯</text>
        <view class="bid-header-text-block">
          <text class="bid-header-title">参与竞价</text>
          <!-- 倒计时显示 -->
          <view
            class="bid-modal-countdown"
            wx:if="{{selectedBidProduct.status === 'active' && bidModalCountdown}}"
          >
            <text class="modal-countdown-icon">⏱</text>
            <text class="modal-countdown-val">{{bidModalCountdown}}</text>
          </view>
        </view>
      </view>
      <view class="bid-close-btn" bindtap="onCancelBid">
        <text class="close-x">✕</text>
      </view>
    </view>

    <!-- 商品预览卡片（优化信息层级） -->
    <view class="bid-product-card" wx:if="{{selectedBidProduct}}">
      <view class="bid-product-visual">
        <image class="bid-img" src="{{selectedBidProduct.image}}" mode="aspectFill" />
        <view class="bid-product-overlay"></view>
        <!-- 出价人数角标 -->
        <view class="bid-img-badge" wx:if="{{selectedBidProduct.bid_count > 0}}">
          <text>🔥 {{selectedBidProduct.bid_count}}人</text>
        </view>
      </view>
      <view class="bid-product-meta">
        <text class="bid-pname">{{selectedBidProduct.name}}</text>
        <text class="bid-pcategory">{{selectedBidProduct.category}}</text>
        <!-- 当前最高价面板（高亮） -->
        <view class="bid-current-price-panel">
          <text class="bid-price-label">当前最高价</text>
          <view class="bid-price-display">
            <text class="bid-price-value"
              >{{selectedBidProduct.current_price || selectedBidProduct.start_price}}</text
            >
            <text class="bid-price-unit">{{selectedBidProduct.price_asset_code}}</text>
          </view>
        </view>
        <!-- 起拍价 -->
        <view class="bid-extra-info">
          <text class="bid-info-item"
            >起拍价: {{selectedBidProduct.start_price}}
            {{selectedBidProduct.price_asset_code}}</text
          >
        </view>
      </view>
    </view>

    <!-- 出价输入区域（增强交互） -->
    <view class="bid-input-area" wx:if="{{selectedBidProduct}}">
      <view class="bid-input-header">
        <text class="bid-input-title">输入竞价金额</text>
        <!-- 实时校验提示 -->
        <text class="bid-input-min {{bidAmountValid ? 'valid' : 'invalid'}}">
          {{bidAmountValid ? '✓ 金额有效' : '最低 ' + bidMinAmount + ' ' +
          selectedBidProduct.price_asset_code}}
        </text>
      </view>
      <!-- 输入框（增加校验状态样式） -->
      <view
        class="bid-input-box {{bidAmountValid ? 'input-valid' : (userBidAmount > 0 ? 'input-invalid' : '')}}"
      >
        <text class="bid-input-prefix">💰</text>
        <input
          class="bid-amount-input"
          type="number"
          placeholder="{{bidMinAmount}}"
          value="{{userBidAmount}}"
          bindinput="onBidAmountInput"
          adjust-position="{{true}}"
        />
        <text class="bid-input-suffix">{{selectedBidProduct.price_asset_code}}</text>
      </view>

      <!-- 快捷加价按钮（增强版 - 显示结果金额） -->
      <view class="bid-quick-buttons">
        <view
          class="quick-bid-btn"
          data-amount="{{selectedBidProduct.min_bid_increment}}"
          bindtap="onQuickBidAdd"
        >
          <text class="quick-btn-plus">+{{selectedBidProduct.min_bid_increment}}</text>
          <text class="quick-btn-label">最低加价</text>
        </view>
        <view
          class="quick-bid-btn"
          data-amount="{{selectedBidProduct.min_bid_increment * 5}}"
          bindtap="onQuickBidAdd"
        >
          <text class="quick-btn-plus">+{{selectedBidProduct.min_bid_increment * 5}}</text>
          <text class="quick-btn-label">5倍加价</text>
        </view>
        <view
          class="quick-bid-btn"
          data-amount="{{selectedBidProduct.min_bid_increment * 10}}"
          bindtap="onQuickBidAdd"
        >
          <text class="quick-btn-plus">+{{selectedBidProduct.min_bid_increment * 10}}</text>
          <text class="quick-btn-label">10倍加价</text>
        </view>
      </view>

      <!-- 一键最低出价按钮 -->
      <view class="bid-one-click" bindtap="onSetMinBid">
        <text class="one-click-text">一键填入最低出价 {{bidMinAmount}}</text>
      </view>
    </view>

    <!-- 竞价规则说明（可折叠） -->
    <view class="bid-rules-card" wx:if="{{selectedBidProduct}}">
      <view class="bid-rules-header" bindtap="onToggleBidRules">
        <view class="rules-header-left">
          <text class="rules-icon">📋</text>
          <text class="rules-title">竞价规则</text>
        </view>
        <text class="rules-toggle">{{showBidRules ? '收起' : '展开'}}</text>
      </view>
      <view class="bid-rules-list" wx:if="{{showBidRules}}">
        <view class="rule-row">
          <text class="rule-num">1</text>
          <text class="rule-text">出价后资产将被冻结，被超越时自动解冻</text>
        </view>
        <view class="rule-row">
          <text class="rule-num">2</text>
          <text class="rule-text"
            >每次加价不少于 {{selectedBidProduct.min_bid_increment}}
            {{selectedBidProduct.price_asset_code}}</text
          >
        </view>
        <view class="rule-row">
          <text class="rule-num">3</text>
          <text class="rule-text">竞价结束时最高价者获得商品</text>
        </view>
        <view class="rule-row">
          <text class="rule-num">4</text>
          <text class="rule-text">竞价到期自动结算，无人出价则流拍</text>
        </view>
      </view>
    </view>

    <!-- 底部操作栏（增强版 - 含金额预览） -->
    <view class="bid-action-bar">
      <button class="bid-cancel-btn" bindtap="onCancelBid">取消</button>
      <button
        class="bid-confirm-btn {{!bidAmountValid ? 'btn-disabled' : ''}}"
        bindtap="onConfirmBid"
        disabled="{{!bidAmountValid}}"
      >
        <text class="bid-confirm-text">{{bidSubmitting ? '提交中...' : '确认竞价'}}</text>
        <text class="bid-confirm-amount" wx:if="{{userBidAmount > 0 && bidAmountValid}}"
          >{{userBidAmount}} {{selectedBidProduct.price_asset_code}}</text
        >
      </button>
    </view>
  </view>
</view>

<!-- 🛒 商品兑换确认弹窗（幸运空间/臻选空间专用） -->
<!-- 后端API: POST /api/v4/backpack/exchange -->
<view class="shop-confirm-overlay" wx:if="{{showShopConfirm}}" bindtap="onCancelShopExchange">
  <view class="shop-confirm-sheet" catchtap="">
    <!-- 顶部渐变头部区域（含商品信息） -->
    <view class="shop-confirm-hero">
      <!-- 关闭按钮 -->
      <view class="shop-close-btn" bindtap="onCancelShopExchange">
        <text class="close-x">✕</text>
      </view>
      <!-- 商品图片 + 核心信息 -->
      <view class="shop-hero-content" wx:if="{{selectedShopProduct}}">
        <view class="shop-hero-img-wrap">
          <image
            class="shop-preview-img"
            src="{{selectedShopProduct.image || selectedShopProduct.image_url || '/images/products/default-product.png'}}"
            mode="aspectFill"
          />
          <view class="shop-preview-badges">
            <text class="shop-badge hot" wx:if="{{selectedShopProduct.is_hot}}">🔥 热销</text>
            <text class="shop-badge new" wx:if="{{selectedShopProduct.is_new}}">✨ 新品</text>
          </view>
        </view>
        <view class="shop-hero-info">
          <text class="shop-hero-name">{{selectedShopProduct.name || '未知商品'}}</text>
          <text class="shop-hero-desc" wx:if="{{selectedShopProduct.description}}"
            >{{selectedShopProduct.description}}</text
          >
          <text class="shop-hero-sell" wx:if="{{selectedShopProduct.sell_point}}"
            >{{selectedShopProduct.sell_point}}</text
          >
          <view class="shop-hero-price-row">
            <text class="shop-hero-price"> {{selectedShopProduct.cost_amount || 0}} </text>
            <text class="shop-hero-price-unit">
              {{(selectedShopProduct.cost_asset_code || 'POINTS') === 'POINTS' ? '积分' :
              selectedShopProduct.cost_asset_code}}
            </text>
            <view class="shop-hero-original" wx:if="{{selectedShopProduct.original_price}}">
              <text class="shop-original-value">{{selectedShopProduct.original_price}}</text>
            </view>
          </view>
          <view class="shop-hero-stock" wx:if="{{selectedShopProduct.stock !== undefined}}">
            <text
              class="shop-stock-dot {{selectedShopProduct.stock > 0 ? 'in-stock' : 'out-stock'}}"
            ></text>
            <text class="shop-stock-text {{selectedShopProduct.stock < 10 ? 'low-stock' : ''}}">
              {{selectedShopProduct.stock > 0 ? '库存 ' + selectedShopProduct.stock + ' 件' :
              '已售罄'}}
            </text>
          </view>
        </view>
      </view>
    </view>

    <!-- 白色内容区域（带圆角遮盖） -->
    <view class="shop-confirm-body">
      <!-- 兑换数量选择 -->
      <view class="shop-quantity-card" wx:if="{{selectedShopProduct}}">
        <text class="shop-quantity-label">兑换数量</text>
        <view class="shop-quantity-control">
          <view
            class="shop-qty-btn decrease {{shopExchangeQuantity <= 1 ? 'disabled' : ''}}"
            bindtap="onShopQuantityChange"
            data-action="decrease"
          >
            <text>−</text>
          </view>
          <text class="shop-qty-value">{{shopExchangeQuantity}}</text>
          <view
            class="shop-qty-btn increase {{selectedShopProduct.stock > 0 && shopExchangeQuantity >= selectedShopProduct.stock ? 'disabled' : ''}}"
            bindtap="onShopQuantityChange"
            data-action="increase"
          >
            <text>+</text>
          </view>
        </view>
      </view>

      <!-- 费用明细卡片 -->
      <view class="shop-cost-card" wx:if="{{selectedShopProduct}}">
        <view class="shop-cost-card-title">费用明细</view>
        <view class="shop-cost-row">
          <text class="shop-cost-label">单价</text>
          <text class="shop-cost-value">
            {{selectedShopProduct.cost_amount || 0}} {{(selectedShopProduct.cost_asset_code ||
            'POINTS') === 'POINTS' ? '积分' : selectedShopProduct.cost_asset_code}}
          </text>
        </view>
        <view class="shop-cost-row">
          <text class="shop-cost-label">数量</text>
          <text class="shop-cost-value">× {{shopExchangeQuantity}}</text>
        </view>
        <view class="shop-cost-divider"></view>
        <view class="shop-cost-row total">
          <text class="shop-cost-label">合计</text>
          <view class="shop-cost-total-wrap">
            <text class="shop-cost-total-symbol">
              {{(selectedShopProduct.cost_asset_code || 'POINTS') === 'POINTS' ? '积分' :
              selectedShopProduct.cost_asset_code}}
            </text>
            <text class="shop-cost-total">
              {{(selectedShopProduct.cost_amount || 0) * shopExchangeQuantity}}
            </text>
          </view>
        </view>
      </view>

      <!-- 余额提示条 -->
      <view
        class="shop-balance-bar {{totalPoints < (selectedShopProduct.cost_amount || 0) * shopExchangeQuantity ? 'insufficient' : 'sufficient'}}"
        wx:if="{{selectedShopProduct}}"
      >
        <view class="shop-balance-left">
          <text class="shop-balance-icon">💰</text>
          <text class="shop-balance-label">当前余额</text>
        </view>
        <text class="shop-balance-value">{{totalPoints}} 积分</text>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="shop-confirm-actions">
      <button class="shop-cancel-btn" bindtap="onCancelShopExchange">取消</button>
      <button
        class="shop-exchange-btn {{shopExchanging ? 'exchanging' : ''}}"
        bindtap="onConfirmShopExchange"
        disabled="{{shopExchanging || (selectedShopProduct.stock !== undefined && selectedShopProduct.stock <= 0)}}"
      >
        <text>{{shopExchanging ? '兑换中...' : '确认兑换'}}</text>
      </button>
    </view>
  </view>
</view>

<!-- 🎉 商品兑换成功结果弹窗 -->
<view class="shop-result-overlay" wx:if="{{showShopResult}}" bindtap="onCloseShopResult">
  <view class="shop-result-sheet" catchtap="">
    <view class="shop-result-header">
      <text class="shop-result-icon">🎉</text>
      <text class="shop-result-title">兑换成功</text>
      <view class="shop-close-btn" bindtap="onCloseShopResult">
        <text class="close-x">✕</text>
      </view>
    </view>
    <view class="shop-result-body" wx:if="{{shopResultData}}">
      <view class="shop-result-success-icon">✅</view>
      <text class="shop-result-congrats">恭喜您成功兑换</text>
      <text class="shop-result-product-name">{{shopResultData.product.name || '商品'}}</text>
      <view class="shop-result-details">
        <view class="shop-result-item" wx:if="{{shopResultData.orderNo}}">
          <text class="result-label">订单编号：</text>
          <text class="result-value">{{shopResultData.orderNo}}</text>
        </view>
        <view class="shop-result-item">
          <text class="result-label">支付：</text>
          <text class="result-value"
            >-{{shopResultData.payAmount}} {{shopResultData.payAssetCode === 'POINTS' ? '积分' :
            shopResultData.payAssetCode}}</text
          >
        </view>
        <view class="shop-result-item" wx:if="{{shopResultData.quantity > 1}}">
          <text class="result-label">数量：</text>
          <text class="result-value">{{shopResultData.quantity}}</text>
        </view>
      </view>
      <text class="shop-result-notice">🎁 商品已到账，请在背包中查看</text>
    </view>
    <view class="shop-result-footer">
      <button class="shop-result-btn" bindtap="onCloseShopResult">继续浏览</button>
    </view>
  </view>
</view>
