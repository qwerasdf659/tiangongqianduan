<!--pages/trade/market/market.wxml - 瀑布流卡片布局模板v1.0-->
<!--📋 基于交易市场UI布局优化方案技术文档 - 方案1：瀑布流卡片布局-->

<view class="waterfall-market-container">
  <!-- 🌊 瀑布流主容器 -->
  <view class="waterfall-container" style="height: {{containerHeight}}px;">
    <!-- 📦 商品卡片列表 - 绝对定位瀑布流 -->
    <view
      class="product-card waterfall-card"
      wx:for="{{products}}"
      wx:key="productId"
      style="left: {{item.layoutInfo.left}}px; top: {{item.layoutInfo.top}}px; width: {{item.layoutInfo.width}}px; z-index: {{item.layoutInfo.zIndex}};"
      data-product="{{item}}"
      bindtap="onProductClick"
    >
      <!-- 🖼️ 商品图片区域 - 支持懒加载 -->
      <view class="card-image-container">
        <image
          class="product-image card-image"
          src="{{item.image}}"
          mode="aspectFill"
          lazy-load="{{true}}"
          data-product-id="{{item.productId}}"
          show-menu-by-longpress="{{false}}"
        />

        <!-- 🏷️ 商品标签 -->
        <view class="product-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text
            class="product-tag {{item.isHot ? 'hot-tag' : ''}} {{item.isNew ? 'new-tag' : ''}}"
            wx:for="{{item.tags}}"
            wx:key="*this"
            wx:for-item="tag"
            >{{tag}}</text
          >
        </view>

        <!-- 📊 销量显示 -->
        <view class="sales-badge" wx:if="{{item.sales}}">
          <text class="sales-text">已售{{item.sales}}</text>
        </view>
      </view>

      <!-- 📝 商品信息区域 -->
      <view class="card-content">
        <!-- 📌 商品标题 -->
        <view class="product-title-section">
          <text class="product-title">{{item.name}}</text>
        </view>

        <!-- 💰 价格信息 -->
        <view class="price-section">
          <view class="price-row">
            <text class="current-price">¥{{item.currentPrice}}</text>
            <text
              class="original-price"
              wx:if="{{item.originalPrice && item.originalPrice > item.currentPrice}}"
              >¥{{item.originalPrice}}</text
            >
          </view>

          <!-- ⭐ 评分和评价 -->
          <view class="rating-section" wx:if="{{item.rating}}">
            <text class="rating-stars">★★★★★</text>
            <text class="rating-score">{{item.rating}}</text>
          </view>
        </view>

        <!-- 🏪 商家信息 -->
        <view class="seller-info" wx:if="{{item.seller}}">
          <text class="seller-name">{{item.seller.name}}</text>
          <text class="seller-rating" wx:if="{{item.seller.rating}}">{{item.seller.rating}}分</text>
        </view>
      </view>

      <!-- 🎭 卡片悬停效果遮罩 -->
      <view class="card-hover-mask"></view>
    </view>
  </view>

  <!-- ⏳ 加载状态显示 -->
  <view class="loading-section" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner">
        <view class="spinner-dot dot1"></view>
        <view class="spinner-dot dot2"></view>
        <view class="spinner-dot dot3"></view>
      </view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 📊 无更多数据提示 -->
  <view class="no-more-data" wx:if="{{!hasMore && products.length > 0}}">
    <view class="no-more-content">
      <text class="no-more-icon">🎉</text>
      <text class="no-more-text">已加载全部商品</text>
      <text class="no-more-subtitle">共{{products.length}}件好物等你发现</text>
    </view>
  </view>

  <!-- 🚫 空状态显示 -->
  <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
    <view class="empty-content">
      <text class="empty-icon">🛒</text>
      <text class="empty-title">暂无商品</text>
      <text class="empty-subtitle">快去上架一些好物吧</text>
      <button class="empty-retry-btn" bindtap="onPullDownRefresh" size="mini">重新加载</button>
    </view>
  </view>

  <!-- 🔄 下拉刷新提示 -->
  <view class="refresh-hint" wx:if="{{!loading && products.length > 0}}">
    <text class="refresh-text">下拉刷新获取最新商品</text>
  </view>

  <!-- 📱 浮动操作按钮 -->
  <view class="floating-actions">
    <!-- 🔝 回到顶部按钮 -->
    <view
      class="floating-btn back-to-top-btn"
      bindtap="scrollToTop"
      wx:if="{{products.length > 10}}"
    >
      <text class="btn-icon">↑</text>
    </view>

    <!-- 📊 性能统计按钮 (开发环境) -->
    <view
      class="floating-btn stats-btn"
      bindtap="showStats"
      wx:if="{{performanceStats.totalProducts > 0}}"
    >
      <text class="btn-icon">📊</text>
    </view>
  </view>
</view>

<!-- 📊 性能统计弹窗 -->
<view class="stats-modal" wx:if="{{showStatsModal}}">
  <view class="stats-mask" bindtap="hideStats"></view>
  <view class="stats-content">
    <view class="stats-header">
      <text class="stats-title">📊 性能统计</text>
      <text class="stats-close" bindtap="hideStats">✕</text>
    </view>
    <view class="stats-body">
      <view class="stats-item">
        <text class="stats-label">布局计算耗时:</text>
        <text class="stats-value">{{performanceStats.layoutCalculationTime}}ms</text>
      </view>
      <view class="stats-item">
        <text class="stats-label">商品总数:</text>
        <text class="stats-value">{{performanceStats.totalProducts}}个</text>
      </view>
      <view class="stats-item">
        <text class="stats-label">当前页码:</text>
        <text class="stats-value">第{{currentPage}}页</text>
      </view>
      <view class="stats-item">
        <text class="stats-label">容器尺寸:</text>
        <text class="stats-value">{{containerWidth}}×{{containerHeight}}px</text>
      </view>
    </view>
  </view>
</view>
