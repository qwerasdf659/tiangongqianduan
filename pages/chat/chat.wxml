<!--pages/chat/chat.wxml - 用户端聊天会话列表界面-->
<view class="chat-sessions-container">
  <!-- 顶部搜索栏 -->
  <view class="search-header">
    <view class="search-bar">
      <view class="search-icon">🔍</view>
      <input
        class="search-input"
        placeholder="搜索聊天记录"
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <view wx:if="{{searchKeyword}}" class="clear-search" bindtap="clearSearch">✕</view>
    </view>
    <view class="new-chat-btn" bindtap="startNewChat">
      <text class="new-chat-icon">✚</text>
    </view>
  </view>

  <!-- 会话列表主体 -->
  <scroll-view
    class="sessions-list"
    scroll-y="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <!-- ===== 状态1：加载中 - 骨架屏 ===== -->
    <block wx:if="{{sessionLoadStatus === 'loading'}}">
      <view
        wx:for="{{[1,2,3,4,5,6]}}"
        wx:key="*this"
        class="session-skeleton"
        style="animation-delay: {{index * 80}}ms;"
      >
        <view class="skeleton-avatar shimmer"></view>
        <view class="skeleton-content">
          <view class="skeleton-line skeleton-line-name shimmer"></view>
          <view class="skeleton-line skeleton-line-msg shimmer"></view>
        </view>
        <view class="skeleton-time shimmer"></view>
      </view>
    </block>

    <!-- ===== 状态2：加载失败 - 错误+重试 ===== -->
    <view wx:elif="{{sessionLoadStatus === 'error'}}" class="error-state">
      <view class="error-icon-wrapper">
        <text class="error-icon-text">📡</text>
      </view>
      <text class="error-title">会话加载失败</text>
      <text class="error-desc">请检查网络连接后重试</text>
      <view class="retry-btn" bindtap="retryLoadSession">
        <text class="retry-btn-text">重新加载</text>
      </view>
    </view>

    <!-- ===== 状态3：加载成功 - 会话列表 ===== -->
    <block wx:else>
      <!-- 空状态：暂无会话 -->
      <view wx:if="{{sessions.length === 0}}" class="error-state">
        <view class="error-icon-wrapper">
          <text class="error-icon-text">💬</text>
        </view>
        <text class="error-title">暂无会话记录</text>
        <text class="error-desc">点击右上角"+"开始新的客服咨询</text>
      </view>

      <!-- 会话列表（直接渲染后端sessions数组） -->
      <view
        wx:for="{{sessions}}"
        wx:key="sessionId"
        class="session-item"
        data-id="{{item.sessionId}}"
        bindtap="onSessionTap"
        style="animation-delay: {{index * 60}}ms;"
      >
        <!-- 头像区域 -->
        <view class="session-avatar">
          <view class="avatar-bg customer-service-bg">
            <text class="avatar-icon">{{item.icon}}</text>
          </view>
        </view>

        <!-- 会话内容 -->
        <view class="session-content">
          <view class="session-info">
            <text class="session-name">{{item.name}}</text>
            <text wx:if="{{item.time}}" class="session-time">{{item.time}}</text>
          </view>
          <view class="session-preview">
            <text class="last-message">{{item.preview || '暂无消息'}}</text>
            <view wx:if="{{item.unread > 0}}" class="unread-count">
              {{item.unread > 99 ? '99+' : item.unread}}
            </view>
          </view>
        </view>

        <!-- 状态标签 + 右箭头 -->
        <view class="session-arrow">›</view>
      </view>
    </block>
  </scroll-view>
</view>

<!-- ===== 聊天弹窗（全屏覆盖） ===== -->
<view class="chat-modal {{showChatModal ? 'show' : ''}}" bindtap="onModalMaskTap">
  <view class="modal-content" catchtap="onModalContentTap">
    <!-- 聊天头部 -->
    <view class="chat-header">
      <view class="header-left">
        <view class="back-btn-wrapper" bindtap="closeChatModal">
          <text class="back-btn">←</text>
        </view>
        <view class="current-session-avatar">
          <view class="avatar-bg customer-service-bg">
            <text class="avatar-icon">{{currentChatIcon}}</text>
          </view>
        </view>
        <view class="session-detail">
          <text class="session-name">{{currentChatName}}</text>
          <text class="session-status"
            >{{sessionStatus === 'active' ? '对话中' : (sessionStatus === 'waiting' ? '等待客服' :
            sessionStatus)}}</text
          >
        </view>
      </view>
      <view class="header-right">
        <view class="more-btn-wrapper" bindtap="showChatMenu">
          <text class="more-btn">⋯</text>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <scroll-view
      class="chat-messages"
      scroll-y="{{true}}"
      scroll-into-view="{{scrollToBottom ? 'message-bottom' : ''}}"
      scroll-with-animation="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
      catchtap="onMessagesAreaTap"
    >
      <!-- 历史消息加载中 -->
      <view wx:if="{{isLoadingHistory}}" class="loading-history">
        <view class="loading-spinner small"></view>
        <text class="loading-text">加载历史消息...</text>
      </view>

      <!-- 聊天空状态（无历史消息） -->
      <view
        wx:if="{{chatLoadStatus === 'empty' && messages.length === 0 && !isLoadingHistory}}"
        class="chat-empty-state"
      >
        <view class="chat-empty-icon-wrapper">
          <text class="chat-empty-icon">💬</text>
        </view>
        <text class="chat-empty-title">暂无消息记录</text>
        <text class="chat-empty-desc">发送消息开始对话</text>
      </view>

      <!-- 聊天加载失败 -->
      <view
        wx:if="{{chatLoadStatus === 'error' && messages.length === 0 && !isLoadingHistory}}"
        class="chat-error-state"
      >
        <text class="chat-error-icon">⚠️</text>
        <text class="chat-error-text">消息加载失败</text>
        <text class="chat-error-desc">请检查网络后重试</text>
      </view>

      <!-- 消息列表 -->
      <view
        wx:for="{{messages}}"
        wx:key="id"
        class="message-item {{item.isOwn ? 'own-message' : 'other-message'}}"
      >
        <!-- 时间分割线 -->
        <view wx:if="{{item.showTime}}" class="time-divider">
          <view class="time-line"></view>
          <text class="time-text">{{item.timeText}}</text>
          <view class="time-line"></view>
        </view>

        <!-- 消息内容 -->
        <view class="message-content">
          <!-- 对方头像 -->
          <view wx:if="{{!item.isOwn}}" class="message-avatar">
            <view class="avatar-bg customer-service-bg">
              <text class="avatar-icon">{{currentChatIcon}}</text>
            </view>
          </view>

          <!-- 消息气泡 -->
          <view class="message-bubble {{item.isOwn ? 'own-bubble' : 'other-bubble'}}">
            <!-- 文字消息 -->
            <text
              wx:if="{{item.messageType === 'text'}}"
              class="message-text"
              user-select="{{true}}"
              >{{item.content}}</text
            >

            <!-- 图片消息 -->
            <image
              wx:if="{{item.messageType === 'image'}}"
              class="message-image"
              src="{{item.attachments[0].url}}"
              mode="aspectFit"
              bindtap="previewImage"
              data-src="{{item.attachments[0].url}}"
            ></image>

            <!-- 系统消息 -->
            <text wx:if="{{item.messageType === 'system'}}" class="system-message"
              >{{item.content}}</text
            >
          </view>

          <!-- 消息状态 -->
          <view wx:if="{{item.isOwn}}" class="message-status">
            <text wx:if="{{item.status === 'sending'}}" class="status-icon sending">⏳</text>
            <text wx:if="{{item.status === 'sent'}}" class="status-icon sent">✓</text>
            <text wx:if="{{item.status === 'delivered'}}" class="status-icon delivered">✓✓</text>
            <text wx:if="{{item.status === 'read'}}" class="status-icon read">✓✓</text>
            <text wx:if="{{item.status === 'failed'}}" class="status-icon failed">❌</text>
          </view>
        </view>
      </view>

      <!-- 输入状态指示器 -->
      <view wx:if="{{showTypingIndicator}}" class="typing-indicator">
        <view class="typing-avatar">
          <view class="avatar-bg customer-service-bg">
            <text class="avatar-icon">{{currentChatIcon}}</text>
          </view>
        </view>
        <view class="typing-bubble">
          <text class="typing-text">{{typingUser || currentChatName}} 正在输入...</text>
          <view class="typing-animation">
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
          </view>
        </view>
      </view>

      <!-- 滚动锚点 -->
      <view id="message-bottom"></view>
    </scroll-view>

    <!-- 输入区域 -->
    <view class="chat-input-area" catchtap="onInputAreaTap">
      <view class="input-toolbar" catchtap="onInputToolbarTap">
        <view class="toolbar-actions">
          <view class="action-btn disabled" bindtap="sendImage">
            <text class="action-btn-icon">📷</text>
          </view>
          <view class="action-btn" bindtap="sendLocation">
            <text class="action-btn-icon">📍</text>
          </view>
          <view class="action-btn" bindtap="sendFile">
            <text class="action-btn-icon">📎</text>
          </view>
        </view>

        <view class="input-section" catchtap="onInputWrapperTap">
          <view class="input-wrapper">
            <textarea
              class="message-input"
              placeholder="输入消息..."
              placeholder-class="input-placeholder"
              value="{{inputContent}}"
              bindinput="onInputChange"
              bindfocus="onInputFocus"
              bindblur="onInputBlur"
              auto-height="{{true}}"
              show-confirm-bar="{{false}}"
              maxlength="500"
              catchtap="onTextareaTap"
            >
            </textarea>
            <view
              class="inline-send-btn {{inputContent.trim() ? 'active' : 'inactive'}}"
              catchtap="onInlineSendTap"
            >
              <text class="send-text">发送</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
