<!-- 扭蛋机抽奖组件 - 增强版 -->
<view class="gashapon-container">
  <!-- 🌟 背景浮动粒子特效 -->
  <view class="bg-particles" wx:if="{{particles.length > 0}}">
    <view
      class="particle"
      wx:for="{{particles}}"
      wx:key="id"
      style="left: {{item.x}}%; top: {{item.y}}%; animation-delay: {{item.delay}}s; animation-duration: {{item.duration}}s;"
    >
      <text class="particle-text">{{item.prize_icon}}</text>
    </view>
  </view>

  <!-- 扭蛋机主体 -->
  <view class="machine">
    <!-- 顶部透明圆顶 -->
    <view class="machine-dome">
      <!-- 内部胶囊球 - 增加数量和随机布局 -->
      <view
        class="capsule-ball"
        wx:for="{{8}}"
        wx:key="*this"
        style="background: {{capsuleColors[index % capsuleColors.length]}}; left: {{15 + (index % 4) * 22}}%; top: {{index < 4 ? '15' : '50'}}%; animation-delay: {{index * 0.3}}s;"
      ></view>
    </view>

    <!-- 出口区域 -->
    <view class="machine-outlet">
      <!-- 掉落的胶囊 — Worklet 驱动掉落动画 -->
      <view
        class="capsule-dropping"
        wx:if="{{machineState === 'dropping' || machineState === 'done'}}"
        style="background: {{currentCapsuleColor}};"
      >
        <text class="capsule-shine">✨</text>
      </view>
    </view>

    <!-- 手柄组件 — Worklet 驱动旋转，不再依赖 CSS class -->
    <view
      class="machine-handle"
      bindtap="onTurnHandle"
      hover-class="handle-active"
      hover-stay-time="100"
    >
      <view class="handle-knob"></view>
      <view class="handle-arm"></view>
    </view>
  </view>

  <!-- 🎉 庆祝特效（扭蛋获得后显示） -->
  <view class="celebration-effect" wx:if="{{showCelebration}}">
    <view class="celebration-burst">
      <text
        class="burst-item"
        wx:for="{{12}}"
        wx:key="*this"
        style="animation-delay: {{index * 0.05}}s;"
      >
        {{index % 2 === 0 ? '🎉' : '✨'}}
      </text>
    </view>
  </view>

  <!-- 状态提示文字 -->
  <view class="gashapon-hint">
    <text wx:if="{{machineState === 'idle'}}">🎮 转动手柄 获取扭蛋</text>
    <text wx:elif="{{machineState === 'turning'}}">⚙️ 扭动中...</text>
    <text wx:elif="{{machineState === 'dropping'}}">💫 扭蛋掉落中...</text>
    <text wx:else>🎁 扭蛋已获得！</text>
  </view>

  <!-- 消耗积分提示 -->
  <view class="gashapon-cost" wx:if="{{costPoints > 0}}">
    <text>💰 消耗 {{costPoints}} 积分</text>
  </view>

  <!-- 操作提示（仅在idle状态显示） -->
  <view class="operation-tip" wx:if="{{machineState === 'idle'}}">
    <view class="tip-arrow">👆</view>
    <text class="tip-text">点击红色手柄开始抽奖</text>
  </view>

  <!-- 奖品池预览（is_fallback / is_sold_out 视觉指示） -->
  <view class="gp-prizes" wx:if="{{prizesForPreview.length > 0}}">
    <view class="gp-prizes__header">
      <view class="gp-prizes__title-wrap">
        <text class="gp-prizes__dot"></text>
        <text class="gp-prizes__title">扭蛋奖品</text>
        <text class="gp-prizes__dot"></text>
      </view>
      <text class="gp-prizes__count">{{prizesForPreview.length}}种奖品</text>
    </view>
    <scroll-view
      type="custom"
      class="gp-prizes__scroll"
      scroll-x="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view class="gp-prizes__list">
        <rarity-effects
          rarity="{{item.rarity_code || 'common'}}"
          enabled="{{rarityEffects}}"
          wx:for="{{prizesForPreview}}"
          wx:key="lottery_prize_id"
          bindtap="onPrizeTap"
          data-prize="{{item}}"
        >
          <view
            class="gp-prizes__item {{item.is_fallback ? 'gp-prizes__item--fallback' : ''}} {{item.is_sold_out ? 'gp-prizes__item--sold-out' : ''}}"
          >
            <view class="gp-prizes__icon-wrap">
              <image
                wx:if="{{item.prize_image_url}}"
                class="gp-prizes__image"
                src="{{item.prize_image_url}}"
                mode="aspectFit"
                data-prize-idx="{{index}}"
                binderror="onPrizeImageError"
              /><text wx:else class="gp-prizes__icon">{{item.prize_icon}}</text>
              <text wx:if="{{item.is_sold_out}}" class="gp-prizes__sold-out">抢光</text>
            </view>
            <text class="gp-prizes__name">{{item.prize_name}}</text>
            <text wx:if="{{item.is_fallback}}" class="gp-prizes__fallback-tag">保底</text>
          </view>
        </rarity-effects>
      </view>
    </scroll-view>
  </view>
</view>
