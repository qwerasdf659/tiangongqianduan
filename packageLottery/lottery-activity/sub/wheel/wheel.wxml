<!-- 转盘抽奖组件 -->
<view class="wheel-container">
  <!-- 转盘主体 -->
  <view class="wheel-wrapper">
    <!-- 外圈装饰灯 -->
    <view class="wheel-outer-ring">
      <view
        class="wheel-light"
        wx:for="{{16}}"
        wx:key="*this"
        style="transform: rotate({{index * 22.5}}deg) translateY(-326rpx);"
      ></view>
    </view>

    <!-- 转盘盘面（旋转层，transform 由 Worklet applyAnimatedStyle 驱动） -->
    <view class="wheel-plate" style="background: {{conicGradient}};">
      <!-- 奖品文字（极坐标定位） -->
      <view
        class="wheel-prize {{item.rarity_code || 'common'}} {{item.is_sold_out ? 'wheel-prize--sold-out' : ''}} {{item.is_fallback ? 'wheel-prize--fallback' : ''}}"
        wx:for="{{prizes}}"
        wx:key="id"
        style="{{prizePositions[index]}}"
      >
        <image
          wx:if="{{item.prize_image_url}}"
          class="wheel-prize__image"
          src="{{item.prize_image_url}}"
          mode="aspectFit"
        />
        <text wx:elif="{{item.prize_icon}}" class="wheel-prize__icon">{{item.prize_icon}}</text>
        <t-icon wx:else name="gift" size="32rpx" class="wheel-prize__icon" />
        <text class="wheel-prize__label">{{item.is_sold_out ? '已抢光' : item._wheelLabel}}</text>
        <text wx:if="{{item.is_fallback}}" class="wheel-prize__badge">保底</text>
      </view>
    </view>

    <!-- 顶部指针（固定不动） -->
    <view class="wheel-pointer">
      <view class="pointer-arrow"></view>
    </view>

    <!-- 中心按钮 -->
    <view class="wheel-center-btn {{spinning ? 'disabled' : ''}}" bindtap="onDraw">
      <text class="center-btn-text">{{spinning ? '...' : '回馈'}}</text>
      <text class="center-btn-cost" wx:if="{{costPoints > 0 && !spinning}}"
        >{{costPoints}}积分</text
      >
    </view>
  </view>

  <!-- 奖品池预览（按稀有度降序，大奖前置） -->
  <view class="wheel-prizes" wx:if="{{prizesForPreview.length > 0}}">
    <view class="wheel-prizes__header">
      <view class="wheel-prizes__title-wrap">
        <text class="wheel-prizes__dot"></text>
        <text class="wheel-prizes__title">转盘奖品</text>
        <text class="wheel-prizes__dot"></text>
      </view>
      <text class="wheel-prizes__count">{{prizesForPreview.length}}种奖品</text>
    </view>
    <view class="wheel-prizes__scroll">
      <view
        class="wheel-prizes__track {{previewMarquee ? 'wheel-prizes__track--animate' : ''}}"
        style="{{previewMarquee ? 'animation-duration:' + previewMarqueeSpeed + 's' : ''}}"
      >
        <view class="wheel-prizes__list">
          <rarity-effects
            rarity="{{item.rarity_code || 'common'}}"
            enabled="{{rarityEffects}}"
            wx:for="{{prizesForPreview}}"
            wx:key="id"
            bindtap="onPrizeTap"
            data-prize="{{item}}"
          >
            <view
              class="wheel-prizes__item {{item.is_fallback ? 'wheel-prizes__item--fallback' : ''}} {{item.is_sold_out ? 'wheel-prizes__item--sold-out' : ''}}"
            >
              <view class="wheel-prizes__icon-wrap">
                <image
                  wx:if="{{item.prize_image_url}}"
                  class="wheel-prizes__image"
                  src="{{item.prize_image_url}}"
                  mode="aspectFit"
                  data-prize-idx="{{index}}"
                  binderror="onPrizeImageError"
                /><text wx:else class="wheel-prizes__icon">{{item.prize_icon}}</text>
                <text wx:if="{{item.is_sold_out}}" class="wheel-prizes__sold-out">抢光</text>
              </view>
              <text class="wheel-prizes__name">{{item.prize_name}}</text>
              <text wx:if="{{item.is_fallback}}" class="wheel-prizes__fallback-tag">保底</text>
            </view>
          </rarity-effects>
        </view>
        <!-- 复制一份奖品列表，实现无缝循环滚动（与砸金蛋一致） -->
        <view class="wheel-prizes__list" wx:if="{{previewMarquee}}">
          <rarity-effects
            rarity="{{item.rarity_code || 'common'}}"
            enabled="{{rarityEffects}}"
            wx:for="{{prizesForPreview}}"
            wx:key="id"
            bindtap="onPrizeTap"
            data-prize="{{item}}"
          >
            <view
              class="wheel-prizes__item {{item.is_fallback ? 'wheel-prizes__item--fallback' : ''}} {{item.is_sold_out ? 'wheel-prizes__item--sold-out' : ''}}"
            >
              <view class="wheel-prizes__icon-wrap">
                <image
                  wx:if="{{item.prize_image_url}}"
                  class="wheel-prizes__image"
                  src="{{item.prize_image_url}}"
                  mode="aspectFit"
                /><text wx:else class="wheel-prizes__icon">{{item.prize_icon}}</text>
                <text wx:if="{{item.is_sold_out}}" class="wheel-prizes__sold-out">抢光</text>
              </view>
              <text class="wheel-prizes__name">{{item.prize_name}}</text>
              <text wx:if="{{item.is_fallback}}" class="wheel-prizes__fallback-tag">保底</text>
            </view>
          </rarity-effects>
        </view>
      </view>
    </view>
  </view>
</view>
