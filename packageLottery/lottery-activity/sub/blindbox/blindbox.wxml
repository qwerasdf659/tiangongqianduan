<!--packageLottery/lottery-activity/sub/blindbox/blindbox.wxml - 虚拟盲盒（神秘礼盒开箱）-->
<view class="blindbox-wrap">
  <!-- 漂浮装饰星点 -->
  <view
    class="float-particle"
    wx:for="{{particles}}"
    wx:key="id"
    style="left:{{item.left}}%; animation-delay:{{item.delay}}s; animation-duration:{{item.duration}}s; width:{{item.size}}rpx; height:{{item.size}}rpx;"
  ></view>

  <!-- 标题 -->
  <view class="bb-header">
    <text class="bb-header__title">神秘盲盒</text>
    <text class="bb-header__sub">轻点礼盒，开启惊喜</text>
  </view>

  <!-- ====== 盲盒礼盒主体 ====== -->
  <view class="mystery-box" bindtap="onOpenBox">
    <!-- 光环底座 -->
    <view class="mystery-box__halo"></view>

    <!-- 盒盖（开箱时向上掀开） -->
    <view class="mystery-box__lid {{boxState}}">
      <view class="mystery-box__lid-top"></view>
      <view class="mystery-box__lid-bow">
        <view class="bow-left"></view>
        <view class="bow-right"></view>
        <view class="bow-knot"></view>
      </view>
    </view>

    <!-- 盒身 -->
    <view class="mystery-box__body {{boxState}}">
      <!-- 竖向丝带 -->
      <view class="mystery-box__ribbon-v"></view>
      <!-- 横向丝带 -->
      <view class="mystery-box__ribbon-h"></view>
      <!-- 问号徽记（待开状态） -->
      <view class="mystery-box__mark" wx:if="{{boxState === 'idle' || boxState === 'shaking'}}">
        <text class="mark-text">?</text>
      </view>
      <!-- 开箱光束（开盖时从盒内射出） -->
      <view
        class="mystery-box__beam"
        wx:if="{{boxState === 'opening' || boxState === 'opened'}}"
      ></view>
    </view>

    <!-- 开箱迸发粒子 -->
    <view class="burst-layer" wx:if="{{boxState === 'opening' || boxState === 'opened'}}">
      <view
        class="burst-particle"
        wx:for="{{burstParticles}}"
        wx:key="id"
        style="--bx:{{item.x}}rpx; --by:{{item.y}}rpx; --bd:{{item.delay}}s; --bs:{{item.scale}};"
      >
        <image class="burst-img" src="{{item.emoji}}" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 操作提示 -->
  <view class="stage-hint">
    <text wx:if="{{boxState === 'idle'}}" class="hint-tap">轻点盲盒开启惊喜</text>
    <text wx:elif="{{boxState === 'shaking'}}" class="hint-shaking">盲盒开启中...</text>
    <text wx:elif="{{boxState === 'opening'}}" class="hint-exploding">惊喜来了!</text>
    <text wx:else class="hint-tap">恭喜获得奖品</text>
  </view>

  <!-- 积分消耗 -->
  <view class="bb-cost" wx:if="{{costPoints > 0}}">
    <text class="bb-cost__label">单次消耗</text>
    <text class="bb-cost__value">{{costPoints}}</text>
    <text class="bb-cost__unit">积分</text>
    <text class="bb-cost__sep">|</text>
    <text class="bb-cost__balance">余额 {{pointsBalance}}</text>
  </view>

  <!-- 奖品池（跑马灯，与其它玩法一致） -->
  <view class="bb-prizes" wx:if="{{prizesForPreview.length > 0}}">
    <view class="bb-prizes__header">
      <view class="bb-prizes__title-wrap">
        <text class="bb-prizes__dot"></text>
        <text class="bb-prizes__title">盲盒奖品</text>
        <text class="bb-prizes__dot"></text>
      </view>
      <text class="bb-prizes__count">{{prizesForPreview.length}}种奖品</text>
    </view>
    <view class="bb-prizes__scroll">
      <view
        class="bb-prizes__track {{previewMarquee ? 'bb-prizes__track--animate' : ''}}"
        style="{{previewMarquee ? 'animation-duration:' + previewMarqueeSpeed + 's' : ''}}"
      >
        <view class="bb-prizes__list">
          <rarity-effects
            rarity="{{item.rarity_code || 'common'}}"
            enabled="{{rarityEffects}}"
            wx:for="{{prizesForPreview}}"
            wx:key="id"
            bindtap="onPrizeTap"
            data-prize="{{item}}"
          >
            <view
              class="bb-prizes__item {{item.is_fallback ? 'bb-prizes__item--fallback' : ''}} {{item.is_sold_out ? 'bb-prizes__item--sold-out' : ''}}"
            >
              <view class="bb-prizes__icon-wrap">
                <image
                  wx:if="{{item.prize_image_url}}"
                  class="bb-prizes__image"
                  src="{{item.prize_image_url}}"
                  mode="aspectFit"
                  data-prize-idx="{{index}}"
                  binderror="onPrizeImageError"
                /><text wx:else class="bb-prizes__icon">{{item.prize_icon}}</text>
                <text wx:if="{{item.is_sold_out}}" class="bb-prizes__sold-out">抢光</text>
              </view>
              <text class="bb-prizes__name">{{item.prize_name}}</text>
              <text wx:if="{{item.is_fallback}}" class="bb-prizes__fallback-tag">保底</text>
            </view>
          </rarity-effects>
        </view>
        <!-- 复制一份奖品列表，实现无缝循环滚动（与其它玩法一致） -->
        <view class="bb-prizes__list" wx:if="{{previewMarquee}}">
          <rarity-effects
            rarity="{{item.rarity_code || 'common'}}"
            enabled="{{rarityEffects}}"
            wx:for="{{prizesForPreview}}"
            wx:key="id"
            bindtap="onPrizeTap"
            data-prize="{{item}}"
          >
            <view
              class="bb-prizes__item {{item.is_fallback ? 'bb-prizes__item--fallback' : ''}} {{item.is_sold_out ? 'bb-prizes__item--sold-out' : ''}}"
            >
              <view class="bb-prizes__icon-wrap">
                <image
                  wx:if="{{item.prize_image_url}}"
                  class="bb-prizes__image"
                  src="{{item.prize_image_url}}"
                  mode="aspectFit"
                /><text wx:else class="bb-prizes__icon">{{item.prize_icon}}</text>
                <text wx:if="{{item.is_sold_out}}" class="bb-prizes__sold-out">抢光</text>
              </view>
              <text class="bb-prizes__name">{{item.prize_name}}</text>
              <text wx:if="{{item.is_fallback}}" class="bb-prizes__fallback-tag">保底</text>
            </view>
          </rarity-effects>
        </view>
      </view>
    </view>
  </view>
</view>
