<!-- 拆红包抽奖组件 -->
<view class="redpacket-container">
  <!-- ===== 单拆模式（3选1） ===== -->
  <block wx:if="{{!isMultiOpen}}">
    <view class="redpacket-title">
      <text>选一个红包拆开试试手气</text>
    </view>

    <view class="packets-row">
      <view
        class="packet-slot {{selectedPacket >= 0 && selectedPacket !== item.id && !item.opened ? 'is-dimmed' : ''}}"
        wx:for="{{packets}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onTapPacket"
      >
        <!-- 未拆开的红包 -->
        <view
          class="red-packet {{item.shaking ? 'is-shaking' : ''}} {{selectedPacket === item.id && !item.opened ? 'is-selected' : ''}} {{canSelect ? 'is-idle' : ''}}"
          wx:if="{{!item.opened}}"
        >
          <view class="packet-gold-circle">
            <text class="packet-text">开</text>
          </view>
          <view class="packet-decoration">
            <text class="deco-text">恭喜发财</text>
          </view>
          <!-- 编号 -->
          <view class="packet-number">
            <text>{{item.id + 1}}</text>
          </view>
          <!-- 点击提示 -->
          <view class="packet-tap-hint" wx:if="{{canSelect && selectedPacket < 0}}">
            <text>点我</text>
          </view>
        </view>

        <!-- 拆开状态 -->
        <view class="packet-opened" wx:else>
          <view class="packet-opened__burst"></view>
          <text class="packet-opened__icon">🧧</text>
          <text class="packet-opened__text">恭喜获得!</text>
          <text class="packet-opened__sparkle">✨</text>
        </view>
      </view>
    </view>

    <view class="redpacket-cost" wx:if="{{costPoints > 0}}">
      <text>消耗 {{costPoints}} 积分</text>
    </view>
  </block>

  <!-- ===== 连拆模式（N个红包） ===== -->
  <block wx:else>
    <view class="redpacket-title">
      <text>{{allOpened ? '全部拆开！' : '点击红包逐个拆开'}}</text>
    </view>

    <!-- 进度计数 -->
    <view class="multi-progress">
      <text class="multi-progress__text">{{openedCount}} / {{totalPackets}}</text>
      <view class="multi-progress__bar">
        <view
          class="multi-progress__fill"
          style="width: {{totalPackets > 0 ? openedCount / totalPackets * 100 : 0}}%"
        ></view>
      </view>
    </view>

    <!-- 红包阵列 -->
    <view class="multi-stage {{multiEntered ? 'is-entered' : ''}} {{sizeClass}}">
      <view class="multi-row" wx:for="{{packetRows}}" wx:for-index="rowIdx" wx:key="rowIdx">
        <view
          class="multi-packet-slot {{item.opened ? 'is-opened' : ''}} {{item.shaking ? 'is-shaking-slot' : ''}}"
          wx:for="{{item}}"
          wx:for-item="packet"
          wx:for-index="colIdx"
          wx:key="index"
          data-row="{{rowIdx}}"
          data-col="{{colIdx}}"
          bindtap="onTapMultiPacket"
          style="animation-delay: {{packet.enterDelay}}ms"
        >
          <!-- 未拆开 -->
          <view
            class="red-packet {{packet.shaking ? 'is-shaking' : ''}} {{!packet.opened ? 'is-idle' : ''}}"
            wx:if="{{!packet.opened}}"
          >
            <view class="packet-gold-circle">
              <text class="packet-text">开</text>
            </view>
            <view class="packet-decoration">
              <text class="deco-text">恭喜发财</text>
            </view>
            <view class="packet-number">
              <text>{{packet.index + 1}}</text>
            </view>
          </view>

          <!-- 拆开后显示奖品 -->
          <view class="multi-packet-prize" wx:else>
            <view class="multi-packet-prize__info">
              <text class="multi-packet-prize__icon">{{packet.prize_icon || '🎁'}}</text>
              <text class="multi-packet-prize__name">{{packet.prize_name || '奖品'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 一键全拆按钮 -->
    <view class="multi-actions" wx:if="{{!allOpened}}">
      <view class="multi-open-all-btn" bindtap="onOpenAll">
        <text>全部拆开</text>
      </view>
    </view>
  </block>

  <!-- 奖品池预览（is_fallback / is_sold_out 视觉指示） -->
  <view class="rp-prizes" wx:if="{{prizesForPreview.length > 0}}">
    <view class="rp-prizes__header">
      <view class="rp-prizes__title-wrap">
        <text class="rp-prizes__dot"></text>
        <text class="rp-prizes__title">红包好礼</text>
        <text class="rp-prizes__dot"></text>
      </view>
      <text class="rp-prizes__count">{{prizesForPreview.length}}种奖品</text>
    </view>
    <scroll-view
      class="rp-prizes__scroll"
      scroll-x="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view class="rp-prizes__list">
        <rarity-effects
          rarity="{{item.rarity_code || 'common'}}"
          enabled="{{rarityEffects}}"
          wx:for="{{prizesForPreview}}"
          wx:key="prize_id"
          bindtap="onPrizeTap"
          data-prize="{{item}}"
        >
          <view
            class="rp-prizes__item {{item.is_fallback ? 'rp-prizes__item--fallback' : ''}} {{item.is_sold_out ? 'rp-prizes__item--sold-out' : ''}}"
          >
            <view class="rp-prizes__icon-wrap">
              <text class="rp-prizes__icon">{{item.prize_icon}}</text>
              <text wx:if="{{item.is_sold_out}}" class="rp-prizes__sold-out">抢光</text>
            </view>
            <text class="rp-prizes__name">{{item.prize_name}}</text>
            <text wx:if="{{item.is_fallback}}" class="rp-prizes__fallback-tag">保底</text>
          </view>
        </rarity-effects>
      </view>
    </scroll-view>
  </view>
</view>
