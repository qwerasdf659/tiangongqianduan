<!--
  网格抽奖 子组件（动态格位：3×3 八格环形 / 4×3 十二格 / 4×4 十六格）
  布局来源: 后端 display.mode + display.grid_cols
    - centerButton=true（grid_3x3）: 经典九宫格 [0][1][2]/[7][BTN][3]/[6][5][4]，中央嵌按钮
    - centerButton=false（grid_4x3/grid_4x4）: 4 列线性格位，按钮独立在网格下方
  奖品数据来源: 后端 GET /api/v4/lottery/campaigns/:code/prizes
  后端返回字段（对接契约）: { id, prize_name, prize_type, prize_value, sort_order, rarity_code, image, is_fallback }
  稀有度光效: rarity_code → rarity-effects组件（5级: common/uncommon/rare/epic/legendary）
  兜底奖品: is_fallback=true → 降饱和度 + "保底"角标
  库存耗尽: is_sold_out=true → "已抢光"遮罩
-->
<view class="grid-container">
  <!-- ===== 经典九宫格（3×3，中央嵌抽奖按钮，环形 8 格） ===== -->
  <view wx:if="{{centerButton}}" class="prize-grid prize-grid--3x3">
    <!-- 渲染顺序与视觉位置对应: 0,1,2 / 7,BTN,3 / 6,5,4 -->
    <block wx:for="{{[0, 1, 2, 7]}}" wx:key="*this" wx:for-item="cellIdx">
      <view
        id="prize-cell-{{cellIdx}}"
        class="prize-area {{prizes[cellIdx].is_fallback ? 'prize-area--fallback' : ''}} {{prizes[cellIdx].is_sold_out ? 'prize-area--sold-out' : ''}}"
        data-index="{{cellIdx}}"
      >
        <rarity-effects
          rarity="{{prizes[cellIdx].rarity_code || 'common'}}"
          enabled="{{rarityEffects}}"
        >
          <view class="prize-content">
            <image
              wx:if="{{prizes[cellIdx].prize_image_url}}"
              class="prize-img"
              src="{{prizes[cellIdx].prize_image_url}}"
              mode="aspectFit"
              data-grid-idx="{{cellIdx}}"
              binderror="onGridPrizeImageError"
            />
            <t-icon wx:else name="gift" size="48rpx" class="prize-icon" />
            <text class="prize-name">{{prizes[cellIdx].prize_name || ''}}</text>
            <text wx:if="{{prizes[cellIdx].is_fallback}}" class="prize-badge--fallback">保底</text>
            <view wx:if="{{prizes[cellIdx].is_sold_out}}" class="prize-sold-out-mask">
              <text class="sold-out-text">已抢光</text>
            </view>
          </view>
        </rarity-effects>
      </view>
    </block>

    <!-- 中央抽奖按钮 -->
    <view class="lottery-center-button">
      <button
        class="center-draw-btn {{isInProgress ? 'drawing' : ''}}"
        disabled="{{isInProgress}}"
        bindtap="onDraw"
      >
        <text class="btn-text">{{isInProgress ? '回馈中...' : '开启回馈'}}</text>
      </button>
    </view>

    <block wx:for="{{[3, 4, 5, 6]}}" wx:key="*this" wx:for-item="cellIdx">
      <view
        id="prize-cell-{{cellIdx}}"
        class="prize-area {{prizes[cellIdx].is_fallback ? 'prize-area--fallback' : ''}} {{prizes[cellIdx].is_sold_out ? 'prize-area--sold-out' : ''}}"
        data-index="{{cellIdx}}"
      >
        <rarity-effects
          rarity="{{prizes[cellIdx].rarity_code || 'common'}}"
          enabled="{{rarityEffects}}"
        >
          <view class="prize-content">
            <image
              wx:if="{{prizes[cellIdx].prize_image_url}}"
              class="prize-img"
              src="{{prizes[cellIdx].prize_image_url}}"
              mode="aspectFit"
              data-grid-idx="{{cellIdx}}"
              binderror="onGridPrizeImageError"
            />
            <t-icon wx:else name="gift" size="48rpx" class="prize-icon" />
            <text class="prize-name">{{prizes[cellIdx].prize_name || ''}}</text>
            <text wx:if="{{prizes[cellIdx].is_fallback}}" class="prize-badge--fallback">保底</text>
            <view wx:if="{{prizes[cellIdx].is_sold_out}}" class="prize-sold-out-mask">
              <text class="sold-out-text">已抢光</text>
            </view>
          </view>
        </rarity-effects>
      </view>
    </block>
  </view>

  <!-- ===== 4 列网格（grid_4x3 / grid_4x4，线性格位 + 下方按钮） ===== -->
  <block wx:else>
    <view class="prize-grid prize-grid--4col">
      <view
        wx:for="{{cellIndexes}}"
        wx:key="*this"
        wx:for-item="cellIdx"
        id="prize-cell-{{cellIdx}}"
        class="prize-area prize-area--4col {{prizes[cellIdx].is_fallback ? 'prize-area--fallback' : ''}} {{prizes[cellIdx].is_sold_out ? 'prize-area--sold-out' : ''}}"
        data-index="{{cellIdx}}"
      >
        <rarity-effects
          rarity="{{prizes[cellIdx].rarity_code || 'common'}}"
          enabled="{{rarityEffects}}"
        >
          <view class="prize-content">
            <image
              wx:if="{{prizes[cellIdx].prize_image_url}}"
              class="prize-img"
              src="{{prizes[cellIdx].prize_image_url}}"
              mode="aspectFit"
              data-grid-idx="{{cellIdx}}"
              binderror="onGridPrizeImageError"
            />
            <t-icon wx:else name="gift" size="40rpx" class="prize-icon" />
            <text class="prize-name">{{prizes[cellIdx].prize_name || ''}}</text>
            <text wx:if="{{prizes[cellIdx].is_fallback}}" class="prize-badge--fallback">保底</text>
            <view wx:if="{{prizes[cellIdx].is_sold_out}}" class="prize-sold-out-mask">
              <text class="sold-out-text">已抢光</text>
            </view>
          </view>
        </rarity-effects>
      </view>
    </view>

    <!-- 4 列网格的抽奖按钮（独立于网格，置于下方整行） -->
    <view class="grid-draw-bar">
      <button
        class="grid-draw-btn {{isInProgress ? 'drawing' : ''}}"
        disabled="{{isInProgress}}"
        bindtap="onDraw"
      >
        <text class="btn-text">{{isInProgress ? '回馈中...' : '开启回馈'}}</text>
      </button>
    </view>
  </block>

  <!-- 奖品池预览（按稀有度降序，大奖前置） -->
  <view class="grid-prizes" wx:if="{{prizesForPreview.length > 0}}">
    <view class="grid-prizes__header">
      <view class="grid-prizes__title-wrap">
        <text class="grid-prizes__dot"></text>
        <text class="grid-prizes__title">奖品池</text>
        <text class="grid-prizes__dot"></text>
      </view>
      <text class="grid-prizes__count">{{prizesForPreview.length}}种奖品</text>
    </view>
    <scroll-view
      type="custom"
      class="grid-prizes__scroll"
      scroll-x="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view class="grid-prizes__list">
        <rarity-effects
          rarity="{{item.rarity_code || 'common'}}"
          enabled="{{rarityEffects}}"
          wx:for="{{prizesForPreview}}"
          wx:key="id"
          bindtap="onPrizeTap"
          data-prize="{{item}}"
        >
          <view
            class="grid-prizes__item {{item.is_fallback ? 'grid-prizes__item--fallback' : ''}} {{item.is_sold_out ? 'grid-prizes__item--sold-out' : ''}}"
          >
            <view class="grid-prizes__icon-wrap">
              <image
                wx:if="{{item.prize_image_url}}"
                class="grid-prizes__image"
                src="{{item.prize_image_url}}"
                mode="aspectFit"
              />
              <text wx:else class="grid-prizes__icon">{{item.prize_icon}}</text>
              <text wx:if="{{item.is_sold_out}}" class="grid-prizes__sold-out">抢光</text>
            </view>
            <text class="grid-prizes__name">{{item.prize_name}}</text>
            <text wx:if="{{item.is_fallback}}" class="grid-prizes__fallback-tag">保底</text>
          </view>
        </rarity-effects>
      </view>
    </scroll-view>
  </view>
</view>
