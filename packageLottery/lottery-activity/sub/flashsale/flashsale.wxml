<!-- 限时秒杀 V3 — 极限抢购体验 -->
<view class="fs {{entered ? 'entered' : ''}} urgency-{{urgencyLevel}}">
  <!-- ===== 氛围层：脉冲光环 + 斜角光束 + 火焰粒子 ===== -->
  <view class="fs-atmosphere">
    <view class="atmo-pulse" />
    <view class="atmo-beam beam1" />
    <view class="atmo-beam beam2" />
    <view class="fire-particle fp1" />
    <view class="fire-particle fp2" />
    <view class="fire-particle fp3" />
    <view class="fire-particle fp4" />
    <view class="fire-particle fp5" />
    <view class="fire-particle fp6" />
    <view class="fire-particle fp7" />
    <view class="fire-particle fp8" />
    <view class="fire-particle fp9" />
    <view class="fire-particle fp10" />
  </view>

  <!-- ===== 秒杀横幅（霓虹边框 + 徽章 + 倒计时） ===== -->
  <view class="fs-banner">
    <view class="banner-glow-border" />
    <view class="banner-inner">
      <view class="banner-badge">
        <t-icon name="flash" size="32rpx" class="badge-icon" />
        <text class="badge-text">限时秒杀</text>
      </view>
      <view class="banner-countdown" wx:if="{{hasCountdown}}">
        <text class="cd-label">距结束</text>
        <view class="cd-digits">
          <view class="cd-block {{countdownFlip ? 'flip-a' : 'flip-b'}}">
            <text class="cd-num">{{countdown.hours}}</text>
          </view>
          <text class="cd-sep">:</text>
          <view class="cd-block {{countdownFlip ? 'flip-a' : 'flip-b'}}">
            <text class="cd-num">{{countdown.minutes}}</text>
          </view>
          <text class="cd-sep">:</text>
          <view class="cd-block {{countdownFlip ? 'flip-a' : 'flip-b'}}">
            <text class="cd-num">{{countdown.seconds}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 滚动播报条 ===== -->
  <view class="fs-broadcast" wx:if="{{rollingMessages.length > 0}}">
    <t-icon name="sound" size="28rpx" class="bc-icon" />
    <view class="bc-track">
      <view class="bc-msg {{msgSliding ? 'bc-out' : 'bc-in'}}">
        <text class="bc-msg-text">{{rollingMessages[currentMsgIndex].text}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 奖品展示区 ===== -->
  <view class="fs-prizes">
    <!-- 聚光灯主奖品（大卡 + 全息光效） -->
    <view class="spotlight" wx:if="{{spotlightPrize}}">
      <view class="spot-glow" />
      <view class="spot-card">
        <view class="spot-holo" />
        <image
          wx:if="{{spotlightPrize.prize_image_url}}"
          class="spot-img"
          src="{{spotlightPrize.prize_image_url}}"
          mode="aspectFit"
        />
        <text wx:if="{{spotlightPrize.prize_icon}}" class="spot-emoji"
          >{{spotlightPrize.prize_icon}}</text
        >
        <t-icon wx:else name="gift" size="48rpx" class="spot-emoji" />
        <text class="spot-name"
          >{{spotlightPrize && spotlightPrize.prize_name ? spotlightPrize.prize_name : ''}}</text
        >
        <view class="spot-shine" />
        <view class="spot-tag">
          <text class="spot-tag-text">主打</text>
        </view>
      </view>
    </view>

    <!-- 缩略奖品横排（可横向滚动） -->
    <scroll-view
      type="custom"
      class="thumb-scroll"
      scroll-x
      enable-flex
      wx:if="{{thumbnailPrizes.length > 0}}"
    >
      <view class="thumb-row">
        <view
          class="thumb-item {{item.is_fallback ? 'thumb-item--fallback' : ''}} {{item.is_sold_out ? 'thumb-item--sold-out' : ''}}"
          wx:for="{{thumbnailPrizes}}"
          wx:key="index"
          style="animation-delay: {{0.25 + item.index * 0.1}}s;"
        >
          <view class="ti-border" />
          <image
            wx:if="{{item.prize_image_url}}"
            class="ti-img"
            src="{{item.prize_image_url}}"
            mode="aspectFit"
          />
          <text wx:if="{{item.prize_icon}}" class="ti-emoji">{{item.prize_icon}}</text>
          <t-icon wx:else name="gift" size="32rpx" class="ti-emoji" />
          <text class="ti-name">{{item.is_sold_out ? '已抢光' : item.prize_name}}</text>
          <text wx:if="{{item.is_fallback}}" class="ti-fallback-tag">保底</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ===== 库存进度区（百分比徽章 + 波浪进度条）— 仅后端下发真实库存时展示 ===== -->
  <view class="fs-stock stock-{{stockUrgency}}" wx:if="{{hasStock}}">
    <view class="stock-header">
      <view class="stock-pct-badge">
        <text class="spb-num">{{grabbedPercent}}</text>
        <text class="spb-pct">%</text>
        <text class="spb-label">已抢</text>
      </view>
      <view class="stock-detail">
        <view class="stock-status-row">
          <t-icon
            name="tips"
            size="28rpx"
            class="stock-fire"
            wx:if="{{stockUrgency !== 'normal'}}"
          />
          <text class="stock-label">
            {{stockUrgency === 'critical' ? '即将售罄' : stockUrgency === 'low' ? '库存紧张' :
            '火热进行中'}}
          </text>
        </view>
        <text class="stock-count">剩余 {{stockRemaining}} / {{stockTotal}}</text>
      </view>
    </view>
    <view class="stock-bar-wrap">
      <view class="stock-bar-bg" />
      <view class="stock-bar-fill" style="width: {{grabbedPercent}}%;">
        <view class="stock-bar-wave" />
        <view class="stock-bar-glow" />
      </view>
    </view>
  </view>

  <!-- ===== 抢购按钮区（脉冲环 + 涟漪） ===== -->
  <view class="fs-action">
    <view class="grab-wrap">
      <!-- 外围脉冲环 -->
      <view class="grab-ring ring1" wx:if="{{state === 'idle' && !isSoldOut}}" />
      <view class="grab-ring ring2" wx:if="{{state === 'idle' && !isSoldOut}}" />
      <!-- 按钮主体 -->
      <view
        class="grab-btn {{state !== 'idle' ? 'grab-btn-busy' : ''}} {{isSoldOut ? 'grab-btn-sold' : ''}}"
        bindtap="onGrab"
      >
        <view class="grab-btn-bg" />
        <view class="grab-btn-inner">
          <t-icon
            name="close-circle-filled"
            size="36rpx"
            class="grab-btn-icon"
            wx:if="{{isSoldOut}}"
          />
          <t-icon
            name="time"
            size="36rpx"
            class="grab-btn-icon"
            wx:elif="{{state === 'grabbing'}}"
          />
          <t-icon
            name="thumb-up"
            size="36rpx"
            class="grab-btn-icon"
            wx:elif="{{state === 'grabbed'}}"
          />
          <t-icon name="tips" size="36rpx" class="grab-btn-icon" wx:else />
          <text class="grab-btn-text">
            {{isSoldOut ? '已抢光' : state === 'idle' ? '立即抢购' : state === 'grabbing' ?
            '抢购中...' : '抢购成功!'}}
          </text>
        </view>
        <!-- 表面扫光 -->
        <view class="grab-btn-shine" wx:if="{{state === 'idle' && !isSoldOut}}" />
        <!-- 点击涟漪 — Worklet 驱动缩放和透明度 -->
        <view class="grab-ripple" />
      </view>
    </view>
    <view class="fs-cost-row" wx:if="{{costPoints > 0}}">
      <text class="fs-cost">消耗 <text class="cost-val">{{costPoints}}</text> 积分</text>
      <text class="fs-sep">|</text>
      <text class="fs-balance">余额 <text class="balance-val">{{pointsBalance}}</text></text>
    </view>
  </view>

  <!-- ===== 抢购成功弹层（全息卡 + 12粒子 + 文字动画） ===== -->
  <view class="success-overlay {{showSuccess ? 'show' : ''}}" catch:touchmove="noop">
    <view class="success-backdrop" />

    <!-- 庆祝粒子 -->
    <view class="success-particles" wx:if="{{showSuccess}}">
      <view class="sp sp1" /><view class="sp sp2" /><view class="sp sp3" />
      <view class="sp sp4" /><view class="sp sp5" /><view class="sp sp6" />
      <view class="sp sp7" /><view class="sp sp8" /><view class="sp sp9" />
      <view class="sp sp10" /><view class="sp sp11" /><view class="sp sp12" />
    </view>

    <!-- 成功揭晓卡 -->
    <view class="success-card {{showSuccess ? 'sc-enter' : ''}}">
      <view class="sc-glow" />
      <view class="sc-inner">
        <view class="sc-holo" />
        <t-icon name="thumb-up" size="48rpx" class="sc-emoji" />
        <view class="sc-divider" />
        <text class="sc-title">抢购成功</text>
        <text class="sc-sub">奖品已放入背包</text>
        <view class="sc-shine" />
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="success-hint {{showSuccess ? 'sh-enter' : ''}}">
      <text class="sh-text">点击任意处关闭</text>
    </view>

    <!-- 点击关闭层 -->
    <view class="success-close-area" bindtap="onCloseSuccess" />
  </view>

  <!-- 奖品池预览（按稀有度降序，大奖前置） -->
  <view class="fs-preview" wx:if="{{prizesForPreview.length > 0}}">
    <view class="fs-preview__header">
      <view class="fs-preview__title-wrap">
        <text class="fs-preview__dot"></text>
        <text class="fs-preview__title">秒杀奖品</text>
        <text class="fs-preview__dot"></text>
      </view>
      <text class="fs-preview__count">{{prizesForPreview.length}}种奖品</text>
    </view>
    <view class="fs-preview__scroll">
      <view
        class="fs-preview__track {{previewMarquee ? 'fs-preview__track--animate' : ''}}"
        style="{{previewMarquee ? 'animation-duration:' + previewMarqueeSpeed + 's' : ''}}"
      >
        <view class="fs-preview__list">
          <rarity-effects
            rarity="{{item.rarity_code || 'common'}}"
            enabled="{{rarityEffects}}"
            wx:for="{{prizesForPreview}}"
            wx:key="id"
            bindtap="onPrizeTap"
            data-prize="{{item}}"
          >
            <view
              class="fs-preview__item {{item.is_fallback ? 'fs-preview__item--fallback' : ''}} {{item.is_sold_out ? 'fs-preview__item--sold-out' : ''}}"
            >
              <view class="fs-preview__icon-wrap">
                <image
                  wx:if="{{item.prize_image_url}}"
                  class="fs-preview__image"
                  src="{{item.prize_image_url}}"
                  mode="aspectFit"
                  data-prize-idx="{{index}}"
                  binderror="onPrizeImageError"
                /><text wx:else class="fs-preview__icon">{{item.prize_icon}}</text>
                <text wx:if="{{item.is_sold_out}}" class="fs-preview__sold-out">抢光</text>
              </view>
              <text class="fs-preview__name">{{item.prize_name}}</text>
              <text wx:if="{{item.is_fallback}}" class="fs-preview__fallback-tag">保底</text>
            </view>
          </rarity-effects>
        </view>
        <!-- 复制一份奖品列表，实现无缝循环滚动（与其它玩法一致） -->
        <view class="fs-preview__list" wx:if="{{previewMarquee}}">
          <rarity-effects
            rarity="{{item.rarity_code || 'common'}}"
            enabled="{{rarityEffects}}"
            wx:for="{{prizesForPreview}}"
            wx:key="id"
            bindtap="onPrizeTap"
            data-prize="{{item}}"
          >
            <view
              class="fs-preview__item {{item.is_fallback ? 'fs-preview__item--fallback' : ''}} {{item.is_sold_out ? 'fs-preview__item--sold-out' : ''}}"
            >
              <view class="fs-preview__icon-wrap">
                <image
                  wx:if="{{item.prize_image_url}}"
                  class="fs-preview__image"
                  src="{{item.prize_image_url}}"
                  mode="aspectFit"
                /><text wx:else class="fs-preview__icon">{{item.prize_icon}}</text>
                <text wx:if="{{item.is_sold_out}}" class="fs-preview__sold-out">抢光</text>
              </view>
              <text class="fs-preview__name">{{item.prize_name}}</text>
              <text wx:if="{{item.is_fallback}}" class="fs-preview__fallback-tag">保底</text>
            </view>
          </rarity-effects>
        </view>
      </view>
    </view>
  </view>
</view>
