<!--
  🎨 popup-banner.wxml - 弹窗横幅组件模板
  
  数据来源: 后端 GET /api/v4/system/ad-delivery?slot_type=popup
  数据表: ad_campaigns + ad_creatives（统一内容投放系统）
  
  📐 显示模式由后端 display_mode 字段决定（运营在管理后台选择模板）：
    wide        → 宽屏模式（16:9）
    horizontal  → 横版模式（3:2）
    square      → 方图模式（1:1）
    tall        → 竖图模式（3:4）
    slim        → 窄长图模式（9:16）
    full_image  → 纯图模式，无白色卡片壳，图片即弹窗

  📐 图片显示模式：widthFix（动态适配）
    - 宽度撑满容器，高度由图片原始比例自动计算
    - 任何尺寸的图片都完整显示，不裁剪、不留白
    - 运营换图无需担心尺寸问题
-->

<!-- 弹窗最外层容器，visible控制是否渲染 -->
<view
  class="popup-banner-overlay {{animateIn ? 'animate-in' : ''}} {{animateOut ? 'animate-out' : ''}}"
  wx:if="{{visible && banners.length > 0}}"
  bindtap="handleOverlayTap"
>
  <!-- ============================== -->
  <!--  📐 纯图模式（full_image）     -->
  <!--  无白色卡片壳，图片即弹窗       -->
  <!-- ============================== -->
  <view
    class="popup-full-image-container"
    wx:if="{{banners[currentIndex].display_mode === 'full_image'}}"
    catchtap="preventBubble"
  >
    <!-- 🔴 关闭按钮（右上角悬浮，纯图模式专用样式）— force_show时隐藏关闭按钮 -->
    <view
      class="popup-close-btn popup-close-btn-fullimage"
      bindtap="handleClose"
      wx:if="{{!isForceShow}}"
    >
      <text class="close-icon">✕</text>
    </view>

    <!-- 🖼️ 纯图模式图片（宽度自适应，高度按原图比例）
         🔴 移除lazy-load：图片已在父页面预加载到缓存，无需懒加载 -->
    <image
      class="popup-full-image"
      wx:if="{{banners[currentIndex].image_url && !imageLoadFailed}}"
      src="{{banners[currentIndex].image_url}}"
      mode="widthFix"
      lazy-load="{{false}}"
      bindload="handleImageLoad"
      binderror="handleImageError"
    />

    <!-- 🔴 纯图模式图片加载失败时的降级显示 -->
    <view class="popup-decor-header popup-decor-header-fullimage" wx:if="{{imageLoadFailed}}">
      <view class="decor-circle decor-circle-1"></view>
      <view class="decor-circle decor-circle-2"></view>
      <view class="decor-circle decor-circle-3"></view>
      <text class="decor-emoji">🖼️</text>
      <text class="decor-fail-text">图片加载失败</text>
    </view>

    <!-- 📦 纯图模式尺寸信息（仅开发调试用，不展示给用户） -->
    <!-- <view class="popup-full-image-info" wx:if="{{banners[currentIndex].image_width}}">
      <text class="full-image-size-text">
        {{banners[currentIndex].image_width}}×{{banners[currentIndex].image_height}}
      </text>
    </view> -->

    <!-- ⚫ 多横幅指示器（纯图模式，2个及以上横幅时显示） -->
    <view class="popup-indicators popup-indicators-fullimage" wx:if="{{banners.length > 1}}">
      <block wx:for="{{banners}}" wx:key="ad_campaign_id">
        <view class="indicator-dot {{currentIndex === index ? 'active' : ''}}"></view>
      </block>
      <text class="indicator-text indicator-text-fullimage"
        >{{currentIndex + 1}} / {{banners.length}}</text
      >
    </view>

    <!-- 🔘 纯图模式操作按钮（悬浮在底部） -->
    <view class="popup-actions popup-actions-fullimage">
      <!-- system类型强制弹出: "我知道了"确认按钮（必须点此关闭） -->
      <button
        class="popup-action-btn primary popup-notice-confirm-btn"
        wx:if="{{currentBannerType === 'system' && isForceShow}}"
        bindtap="handleNoticeConfirm"
      >
        我知道了
      </button>

      <!-- 有链接时显示"查看详情"按钮 -->
      <button
        class="popup-action-btn primary"
        wx:if="{{banners[currentIndex].link_url && !(currentBannerType === 'system' && isForceShow)}}"
        bindtap="handleAction"
      >
        查看详情
      </button>

      <!-- 多个横幅时显示翻页按钮 -->
      <view class="popup-nav-row" wx:if="{{banners.length > 1}}">
        <button
          class="popup-action-btn secondary popup-nav-btn"
          wx:if="{{currentIndex > 0}}"
          bindtap="handlePrev"
        >
          上一条
        </button>
        <button
          class="popup-action-btn secondary popup-nav-btn"
          wx:if="{{currentIndex < banners.length - 1}}"
          bindtap="handleNext"
        >
          下一条
        </button>
      </view>
    </view>
  </view>

  <!-- ============================== -->
  <!--  🃏 常规模式（白色卡片壳）      -->
  <!--  wide/horizontal/square/tall/slim -->
  <!-- ============================== -->
  <view
    class="popup-banner-card"
    wx:if="{{banners[currentIndex].display_mode !== 'full_image'}}"
    catchtap="preventBubble"
  >
    <!-- 🔴 关闭按钮（右上角悬浮）— force_show时隐藏关闭按钮 -->
    <view class="popup-close-btn" bindtap="handleClose" wx:if="{{!isForceShow}}">
      <text class="close-icon">✕</text>
    </view>

    <!-- 🖼️ 横幅图片区域 -->
    <view
      class="popup-image-section image-{{banners[currentIndex].display_mode || 'wide'}}"
      wx:if="{{banners[currentIndex].image_url && !imageLoadFailed}}"
    >
      <image
        class="popup-image"
        src="{{banners[currentIndex].image_url}}"
        mode="widthFix"
        lazy-load="{{false}}"
        bindload="handleImageLoad"
        binderror="handleImageError"
      />
      <view class="image-gradient-overlay"></view>
    </view>

    <!-- 🎨 装饰性顶部条纹（没有图片 或 图片加载失败时 显示渐变装饰作为降级） -->
    <view
      class="popup-decor-header"
      wx:if="{{!banners[currentIndex].image_url || imageLoadFailed}}"
    >
      <view class="decor-circle decor-circle-1"></view>
      <view class="decor-circle decor-circle-2"></view>
      <view class="decor-circle decor-circle-3"></view>
      <text class="decor-emoji">🎉</text>
    </view>

    <!-- 📝 内容区域（纯文字创意 text_content 有值时显示） -->
    <view class="popup-content" wx:if="{{banners[currentIndex].text_content}}">
      <text class="popup-desc">{{banners[currentIndex].text_content}}</text>
    </view>

    <!-- ⚫ 多横幅指示器（2个及以上横幅时显示） -->
    <view class="popup-indicators" wx:if="{{banners.length > 1}}">
      <block wx:for="{{banners}}" wx:key="ad_campaign_id">
        <view class="indicator-dot {{currentIndex === index ? 'active' : ''}}"></view>
      </block>
      <text class="indicator-text">{{currentIndex + 1}} / {{banners.length}}</text>
    </view>

    <!-- 🔘 操作按钮区域 -->
    <view
      class="popup-actions"
      wx:if="{{banners[currentIndex].link_url || banners.length > 1 || (currentBannerType === 'system' && isForceShow)}}"
    >
      <!-- system类型强制弹出: "我知道了"确认按钮（必须点此关闭） -->
      <button
        class="popup-action-btn primary popup-notice-confirm-btn"
        wx:if="{{currentBannerType === 'system' && isForceShow}}"
        bindtap="handleNoticeConfirm"
      >
        我知道了
      </button>

      <!-- 有链接时显示"查看详情"按钮（system强制弹出模式下隐藏） -->
      <button
        class="popup-action-btn primary"
        wx:if="{{banners[currentIndex].link_url && !(currentBannerType === 'system' && isForceShow)}}"
        bindtap="handleAction"
      >
        查看详情
      </button>

      <!-- 多个横幅时显示翻页按钮 -->
      <view class="popup-nav-row" wx:if="{{banners.length > 1}}">
        <button
          class="popup-action-btn secondary popup-nav-btn"
          wx:if="{{currentIndex > 0}}"
          bindtap="handlePrev"
        >
          上一条
        </button>
        <button
          class="popup-action-btn secondary popup-nav-btn"
          wx:if="{{currentIndex < banners.length - 1}}"
          bindtap="handleNext"
        >
          下一条
        </button>
      </view>
    </view>
  </view>
</view>
