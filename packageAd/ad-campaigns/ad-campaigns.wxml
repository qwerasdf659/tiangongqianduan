<!--
  📢 我的广告活动列表
  数据来源: GET /api/v4/user/ad-campaigns
-->
<view class="ad-campaigns-page">
  <!-- 状态筛选Tab栏 -->
  <scroll-view
    class="status-tab-bar"
    scroll-x="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <view class="status-tab-list">
      <view
        wx:for="{{statusTabs}}"
        wx:key="value"
        class="status-tab-item {{currentStatusIndex === index ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="onStatusTabTap"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 广告活动列表 -->
  <scroll-view
    class="campaign-list-scroll"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <!-- 活动卡片 -->
    <view
      wx:for="{{campaigns}}"
      wx:key="ad_campaign_id"
      class="campaign-card"
      data-id="{{item.ad_campaign_id}}"
      bindtap="goToDetail"
    >
      <!-- 卡片头部: 活动名称 + 状态标签 -->
      <view class="card-header">
        <text class="campaign-name">{{item.campaign_name}}</text>
        <view
          class="status-badge"
          style="background: {{item.statusStyle.bgColor}}; color: {{item.statusStyle.color}}"
        >
          <text>{{item.statusStyle.text}}</text>
        </view>
      </view>

      <!-- 卡片信息行 -->
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">计费模式</text>
          <text class="info-value">{{item.billingModeText}}</text>
        </view>
        <view class="info-row" wx:if="{{item.billing_mode === 'fixed_daily'}}">
          <text class="info-label">投放天数</text>
          <text class="info-value">{{item.fixed_days}} 天</text>
        </view>
        <view class="info-row" wx:if="{{item.billing_mode === 'fixed_daily'}}">
          <text class="info-label">总费用</text>
          <text class="info-value highlight">{{item.fixed_total_diamond}} 💎</text>
        </view>
        <view class="info-row" wx:if="{{item.billing_mode === 'bidding'}}">
          <text class="info-label">日出价</text>
          <text class="info-value highlight">{{item.daily_bid_diamond}} 💎/天</text>
        </view>
        <view class="info-row" wx:if="{{item.billing_mode === 'bidding'}}">
          <text class="info-label">预算/已消耗</text>
          <text class="info-value"
            >{{item.budget_spent_diamond}}/{{item.budget_total_diamond}} 💎</text
          >
        </view>
        <view class="info-row" wx:if="{{item.start_date}}">
          <text class="info-label">投放周期</text>
          <text class="info-value">{{item.start_date}} ~ {{item.end_date || '持续'}}</text>
        </view>
      </view>

      <!-- 卡片底部操作区 -->
      <view
        class="card-footer"
        wx:if="{{item.status === 'draft' || item.status === 'pending_review'}}"
      >
        <view
          class="action-btn cancel-btn"
          wx:if="{{item.status === 'pending_review'}}"
          data-id="{{item.ad_campaign_id}}"
          catchtap="onCancelCampaign"
        >
          <text>取消活动</text>
        </view>
        <view class="action-btn edit-btn" wx:if="{{item.status === 'draft'}}">
          <text>编辑</text>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-more" wx:if="{{loading && campaigns.length > 0}}">
      <text>加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && campaigns.length > 0}}">
      <text>— 没有更多了 —</text>
    </view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty && !loading}}">
    <text class="empty-icon">📢</text>
    <text class="empty-title">暂无广告活动</text>
    <text class="empty-desc">投放广告让更多用户看到你的推广内容</text>
    <button class="create-btn-empty" bindtap="goToCreate">创建广告活动</button>
  </view>

  <!-- 首次加载 -->
  <view class="first-loading" wx:if="{{loading && campaigns.length === 0 && !isEmpty}}">
    <text class="loading-icon">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 底部创建按钮（悬浮） -->
  <view class="fab-create-btn" bindtap="goToCreate" wx:if="{{!isEmpty}}">
    <text class="fab-icon">+</text>
    <text class="fab-text">创建广告</text>
  </view>
</view>
