<!--packageAdmin/consume-submit/consume-submit.wxml - 商家消费录入页面-->
<!--业务流程: 商家进入页面 → 看到操作说明 → 扫描用户V2动态二维码 → 加载用户信息 → 录入消费金额 → POST /api/v4/shop/consumption/submit-->

<view class="consume-page">
  <!-- ========== 阶段一：扫码入口（商家先看到操作说明） ========== -->
  <block wx:if="{{pageStage === 'scan'}}">
    <!-- 操作说明卡片 -->
    <view class="guide-card">
      <view class="guide-icon-wrap">
        <text class="guide-icon-text">📷</text>
      </view>
      <view class="guide-title">扫描顾客二维码</view>
      <view class="guide-desc">请让顾客在小程序中打开「消费积分二维码」，然后用下方按钮扫描</view>
    </view>

    <!-- 操作步骤说明 -->
    <view class="guide-steps">
      <view class="guide-step-item">
        <view class="guide-step-num">1</view>
        <view class="guide-step-content">
          <view class="guide-step-title">顾客出示二维码</view>
          <view class="guide-step-desc"
            >顾客在小程序「抽奖」页面点击「消费积分二维码」，生成动态二维码</view
          >
        </view>
      </view>
      <view class="guide-step-item">
        <view class="guide-step-num">2</view>
        <view class="guide-step-content">
          <view class="guide-step-title">扫码识别顾客</view>
          <view class="guide-step-desc">点击下方「扫描二维码」按钮，扫描顾客出示的二维码</view>
        </view>
      </view>
      <view class="guide-step-item">
        <view class="guide-step-num">3</view>
        <view class="guide-step-content">
          <view class="guide-step-title">录入消费金额</view>
          <view class="guide-step-desc"
            >输入本次消费金额，提交后等待管理员审核，通过后积分自动发放</view
          >
        </view>
      </view>
    </view>

    <!-- 扫码按钮 -->
    <view class="scan-btn-area">
      <button class="scan-btn" bindtap="startScan">
        <text class="scan-btn-icon">📷</text>
        <text class="scan-btn-text">扫描顾客二维码</text>
      </button>
    </view>
  </block>

  <!-- ========== 阶段二：填写消费信息表单 ========== -->
  <block wx:if="{{pageStage === 'form'}}">
    <!-- 顶部进度指示 -->
    <view class="step-bar">
      <view class="step {{userInfo ? 'done' : 'active'}}">
        <view class="step-number">1</view>
        <text class="step-label">验证顾客</text>
      </view>
      <view class="step-line {{userInfo ? 'active' : ''}}"></view>
      <view class="step {{userInfo && !submitted ? 'active' : (submitted ? 'done' : '')}}">
        <view class="step-number">2</view>
        <text class="step-label">录入金额</text>
      </view>
      <view class="step-line {{submitted ? 'active' : ''}}"></view>
      <view class="step {{submitted ? 'done' : ''}}">
        <view class="step-number">3</view>
        <text class="step-label">提交完成</text>
      </view>
    </view>

    <!-- 门店选择（多门店时显示picker） -->
    <view class="form-card" wx:if="{{storeList.length > 1}}">
      <view class="card-title">
        <text class="title-icon">🏪</text>
        <text class="title-text">选择门店</text>
        <text class="required-mark">*</text>
      </view>
      <picker
        mode="selector"
        range="{{storeList}}"
        range-key="store_name"
        value="{{storeIndex}}"
        bindchange="onStoreChange"
      >
        <view class="picker-box {{storeId ? 'selected' : ''}}">
          <text class="picker-text"
            >{{storeId ? storeList[storeIndex].store_name : '请选择门店'}}</text
          >
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 单门店自动显示（无需选择） -->
    <view class="form-card" wx:elif="{{storeList.length === 1}}">
      <view class="card-title">
        <text class="title-icon">🏪</text>
        <text class="title-text">所属门店</text>
      </view>
      <view class="store-auto">
        <text class="store-name">{{storeList[0].store_name}}</text>
        <view class="auto-badge">
          <text class="auto-text">自动识别</text>
        </view>
      </view>
    </view>

    <!-- 用户信息展示区域 -->
    <view class="form-card">
      <view class="card-title">
        <text class="title-icon">👤</text>
        <text class="title-text">顾客信息</text>
        <!-- 重新扫码按钮（未提交时可用） -->
        <view class="rescan-btn" wx:if="{{!submitted}}" bindtap="onRescanCode">
          <text class="rescan-text">重新扫码</text>
        </view>
      </view>

      <!-- 加载状态 -->
      <view class="user-loading" wx:if="{{userInfoLoading}}">
        <view class="loading-spinner"></view>
        <text class="loading-label">正在获取顾客信息...</text>
      </view>

      <!-- 用户信息展示 -->
      <view class="user-info-box" wx:if="{{!userInfoLoading && userInfo}}">
        <view class="user-row">
          <text class="row-label">昵称</text>
          <text class="row-value">{{userInfo.nickname || '未设置'}}</text>
        </view>
        <view class="user-row">
          <text class="row-label">手机号</text>
          <text class="row-value">{{userInfo.mobile_display || userInfo.mobile}}</text>
        </view>
      </view>

      <!-- 需要选择门店提示（多门店且未选择时） -->
      <view
        class="hint-box warning"
        wx:if="{{!userInfoLoading && !userInfo && storeList.length > 1}}"
      >
        <text class="hint-icon">🏪</text>
        <text class="hint-text">请先在上方选择门店，系统将自动加载顾客信息</text>
      </view>

      <!-- 加载失败提示 -->
      <view
        class="hint-box error"
        wx:if="{{!userInfoLoading && !userInfo && storeList.length <= 1}}"
      >
        <text class="hint-icon">⚠️</text>
        <text class="hint-text">顾客信息加载失败，请检查二维码是否有效</text>
      </view>
    </view>

    <!-- 消费金额输入（必填） -->
    <view class="form-card">
      <view class="card-title">
        <text class="title-icon">💰</text>
        <text class="title-text">消费金额</text>
        <text class="required-mark">*</text>
      </view>
      <view class="amount-input-box">
        <text class="currency">¥</text>
        <input
          type="digit"
          class="amount-field"
          placeholder="请输入消费金额"
          value="{{consumeAmount}}"
          bindinput="onAmountInput"
          disabled="{{!userInfo || submitted}}"
        />
      </view>
      <view class="input-footer">
        <text class="input-hint">范围：0.01 ~ 99,999.99 元</text>
        <view class="points-hint" wx:if="{{consumeAmount}}">
          <text class="points-label">预计积分</text>
          <text class="points-value">≈ {{consumeAmount}} 分</text>
        </view>
      </view>
    </view>

    <!-- 商家备注输入（可选，500字限制） -->
    <view class="form-card">
      <view class="card-title">
        <text class="title-icon">📝</text>
        <text class="title-text">商家备注</text>
        <text class="optional-mark">选填</text>
      </view>
      <textarea
        class="notes-field"
        placeholder="请输入备注信息，如：消费2份套餐"
        value="{{merchantNotes}}"
        bindinput="onNotesInput"
        maxlength="500"
        auto-height
        disabled="{{!userInfo || submitted}}"
      />
      <view class="notes-counter">
        <text>{{merchantNotes.length || 0}}/500</text>
      </view>
    </view>

    <!-- 底部提交区域 -->
    <view class="submit-area">
      <button
        class="submit-btn {{(loading || submitted || !userInfo) ? 'disabled' : ''}}"
        bindtap="onSubmit"
        disabled="{{loading || submitted || !userInfo}}"
      >
        <text class="submit-text"
          >{{loading ? '提交中...' : (submitted ? '已提交' : '确认提交')}}</text
        >
      </button>
    </view>

    <!-- 加载遮罩 -->
    <view class="overlay" wx:if="{{loading}}">
      <view class="overlay-content">
        <view class="overlay-spinner"></view>
        <text class="overlay-text">提交中，请稍候...</text>
      </view>
    </view>
  </block>
</view>
