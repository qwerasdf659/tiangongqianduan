<!--packageAdmin/consume-submit/consume-submit.wxml - 商家消费录入页面-->
<!--业务流程: 商家先填写消费金额/备注 → 扫描用户V2动态二维码 → 获取用户信息 → 确认提交-->
<custom-navbar title="消费录入" bgColor="#667eea" textColor="#ffffff" showBack="{{true}}" />

<view class="consume-page">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 操作引导（帮助首次使用的商家理解流程） -->
    <view class="guide-tip">
      <text class="guide-icon">💡</text>
      <text class="guide-text">先填写消费金额 → 扫描顾客二维码 → 确认提交</text>
    </view>

    <!-- 顶部进度指示（始终显示，帮助用户了解当前所处步骤） -->
    <view class="step-bar">
      <view class="step {{consumeAmount ? 'done' : 'active'}}">
        <view class="step-circle">
          <text class="step-icon" wx:if="{{consumeAmount}}">✓</text>
          <text class="step-num" wx:else>1</text>
        </view>
        <text class="step-label">填写信息</text>
      </view>
      <view class="step-connector {{consumeAmount ? 'active' : ''}}"></view>
      <view class="step {{qrCode && userInfo ? 'done' : (consumeAmount ? 'active' : '')}}">
        <view class="step-circle">
          <text class="step-icon" wx:if="{{qrCode && userInfo}}">✓</text>
          <text class="step-num" wx:else>2</text>
        </view>
        <text class="step-label">扫码识别</text>
      </view>
      <view class="step-connector {{qrCode && userInfo ? 'active' : ''}}"></view>
      <view
        class="step {{submitted ? 'done' : (qrCode && userInfo && consumeAmount ? 'active' : '')}}"
      >
        <view class="step-circle">
          <text class="step-icon" wx:if="{{submitted}}">✓</text>
          <text class="step-num" wx:else>3</text>
        </view>
        <text class="step-label">确认提交</text>
      </view>
    </view>

    <!-- 消费金额输入（必填，最先填写） -->
    <view class="glass-card">
      <view class="card-header">
        <view class="header-left">
          <view class="header-icon amount-icon">
            <text class="amount-icon-text">¥</text>
          </view>
          <text class="header-title">消费金额</text>
        </view>
        <text class="required-badge">必填</text>
      </view>
      <view class="card-body">
        <view class="amount-input-wrapper">
          <text class="amount-symbol">¥</text>
          <input
            type="digit"
            class="amount-input"
            placeholder="请输入消费金额"
            value="{{consumeAmount}}"
            bindinput="onAmountInput"
            disabled="{{submitted}}"
          />
        </view>
        <view class="amount-footer">
          <text class="amount-range">范围：0.01 ~ 99,999.99 元</text>
          <view class="points-preview" wx:if="{{consumeAmount}}">
            <text class="points-tag">预计积分 ≈ {{consumeAmount}} 分</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 商家备注输入（可选，500字限制） -->
    <view class="glass-card">
      <view class="card-header">
        <view class="header-left">
          <view class="header-icon note-icon">
            <text class="note-icon-text">📝</text>
          </view>
          <text class="header-title">商家备注</text>
        </view>
        <text class="optional-badge">选填</text>
      </view>
      <view class="card-body">
        <textarea
          class="notes-textarea"
          placeholder="请输入备注信息，如：消费2份套餐"
          value="{{merchantNotes}}"
          bindinput="onNotesInput"
          maxlength="500"
          auto-height
          disabled="{{submitted}}"
        />
        <view class="notes-footer">
          <text class="char-counter">{{merchantNotes.length || 0}}/500</text>
        </view>
      </view>
    </view>

    <!-- 门店选择（多门店时显示picker） -->
    <view class="glass-card" wx:if="{{storeList.length > 1}}">
      <view class="card-header">
        <view class="header-left">
          <view class="header-icon store-icon">
            <text class="store-icon-text">🏪</text>
          </view>
          <text class="header-title">选择门店</text>
        </view>
        <text class="required-badge">必填</text>
      </view>
      <view class="card-body">
        <picker
          mode="selector"
          range="{{storeList}}"
          range-key="store_name"
          value="{{storeIndex}}"
          bindchange="onStoreChange"
        >
          <view class="store-picker {{storeId ? 'selected' : ''}}">
            <text class="picker-value"
              >{{storeId ? storeList[storeIndex].store_name : '请选择门店'}}</text
            >
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 单门店自动显示（无需选择） -->
    <view class="glass-card" wx:elif="{{storeList.length === 1}}">
      <view class="card-header">
        <view class="header-left">
          <view class="header-icon store-icon">
            <text class="store-icon-text">🏪</text>
          </view>
          <text class="header-title">所属门店</text>
        </view>
      </view>
      <view class="card-body">
        <view class="store-auto-row">
          <text class="store-auto-name">{{storeList[0].store_name}}</text>
          <view class="auto-tag">
            <text class="auto-tag-text">自动识别</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 扫码识别顾客区域 -->
    <view class="glass-card scan-card">
      <view class="card-header">
        <view class="header-left">
          <view class="header-icon customer-icon">
            <text class="customer-icon-text">👤</text>
          </view>
          <text class="header-title">顾客信息</text>
        </view>
        <!-- 重新扫码按钮（已扫码且未提交时可用） -->
        <view class="rescan-tag" wx:if="{{qrCode && !submitted}}" bindtap="onRescanCode">
          <text class="rescan-tag-text">重新扫码</text>
        </view>
      </view>
      <view class="card-body">
        <!-- 未扫码：显示扫码引导动画 -->
        <view class="scan-guide" wx:if="{{!qrCode && !userInfoLoading}}">
          <view class="scan-ring-wrapper" bindtap="startScan">
            <view class="scan-ring-pulse"></view>
            <view class="scan-ring-pulse delay"></view>
            <view class="scan-btn-core">
              <text class="scan-camera-emoji">📷</text>
            </view>
          </view>
          <text class="scan-cta">点击扫描顾客二维码</text>
          <text class="scan-hint">请让顾客在小程序中打开「消费积分二维码」</text>
        </view>

        <!-- 加载状态 -->
        <view class="user-loading-state" wx:if="{{userInfoLoading}}">
          <view class="loading-ring"></view>
          <text class="loading-msg">正在获取顾客信息...</text>
        </view>

        <!-- 用户信息展示 -->
        <view class="user-detail" wx:if="{{!userInfoLoading && userInfo}}">
          <view class="user-avatar-row">
            <view class="user-avatar-circle">
              <text class="avatar-letter">{{userInfo.nickname ? userInfo.nickname[0] : '用'}}</text>
            </view>
            <view class="user-meta">
              <text class="user-nickname">{{userInfo.nickname || '未设置昵称'}}</text>
              <text class="user-mobile">{{userInfo.mobile_display || userInfo.mobile}}</text>
            </view>
            <view class="verified-badge">
              <text class="verified-badge-text">已识别</text>
            </view>
          </view>
        </view>

        <!-- 需要选择门店提示（多门店且未选择时） -->
        <view
          class="tip-box warning-tip"
          wx:if="{{qrCode && !userInfoLoading && !userInfo && storeList.length > 1}}"
        >
          <text class="tip-emoji">🏪</text>
          <text class="tip-msg">请先在上方选择门店，系统将自动加载顾客信息</text>
        </view>

        <!-- 加载失败提示 -->
        <view
          class="tip-box error-tip"
          wx:if="{{qrCode && !userInfoLoading && !userInfo && storeList.length <= 1}}"
        >
          <text class="tip-emoji">⚠️</text>
          <text class="tip-msg">顾客信息加载失败，请检查二维码是否有效</text>
        </view>
      </view>
    </view>

    <!-- 提交前汇总预览（所有信息填写完毕且未提交时显示） -->
    <view class="glass-card summary-card" wx:if="{{consumeAmount && userInfo && !submitted}}">
      <view class="card-header">
        <view class="header-left">
          <view class="header-icon summary-icon">
            <text class="summary-icon-text">📋</text>
          </view>
          <text class="header-title">提交预览</text>
        </view>
      </view>
      <view class="card-body">
        <view class="summary-row">
          <text class="summary-label">顾客</text>
          <text class="summary-val">{{userInfo.nickname || userInfo.mobile}}</text>
        </view>
        <view class="summary-row">
          <text class="summary-label">消费金额</text>
          <text class="summary-val highlight">¥{{consumeAmount}}</text>
        </view>
        <view class="summary-row" wx:if="{{merchantNotes}}">
          <text class="summary-label">备注</text>
          <text class="summary-val">{{merchantNotes}}</text>
        </view>
        <view class="summary-notice">
          <text class="summary-notice-text"
            >提交后将生成待审核记录，管理员审核通过后自动发放积分</text
          >
        </view>
      </view>
    </view>

    <!-- 底部提交区域 -->
    <view class="submit-bar">
      <button
        class="submit-main-btn {{(loading || submitted || !userInfo || !consumeAmount) ? 'disabled' : ''}}"
        bindtap="onSubmit"
        disabled="{{loading || submitted || !userInfo || !consumeAmount}}"
      >
        <text class="submit-btn-text"
          >{{loading ? '提交中...' : (submitted ? '✓ 已提交' : '确认提交')}}</text
        >
      </button>
    </view>

    <!-- 加载遮罩 -->
    <view class="loading-overlay" wx:if="{{loading}}">
      <view class="loading-panel">
        <t-loading loading="{{true}}" text="提交中，请稍候..." theme="spinner" />
      </view>
    </view>

    <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
    <maintenance-overlay />
  </scroll-view>
</view>
