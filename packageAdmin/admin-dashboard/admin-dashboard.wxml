<!--pages/admin/admin-dashboard/admin-dashboard.wxml - 管理员仪表板页面模板-->

<view class="admin-dashboard-container">
  <!-- 🔧 修复：返回按钮始终可见，不受加载状态影响 -->
  <view class="fixed-back-button" bindtap="onBackTap">
    <text class="back-icon">◀</text>
  </view>

  <!-- 🔧 强化：主要内容区域 - 只有在所有条件满足时才显示完整内容 -->
  <view
    wx:if="{{!loading && initialized && accessChecked && contentReady && !renderLocked && isLoggedIn && isAdmin}}"
  >
    <!-- 页面头部 -->
    <view class="dashboard-header">
      <view class="header-content">
        <view class="header-title-full">
          <text class="title-text">👑 管理员仪表板</text>
          <text class="title-desc">Administrator Dashboard</text>
        </view>
        <view class="admin-badge">
          <text class="badge-text">ADMIN</text>
        </view>
      </view>
    </view>

    <!-- 用户信息卡片 -->
    <view class="user-info-card">
      <view class="user-avatar">
        <text class="avatar-icon">👑</text>
      </view>
      <view class="user-details">
        <text class="user-name">{{userInfo.mobile || '管理员'}}</text>
        <text class="user-role">系统管理员</text>
      </view>
      <view class="user-status">
        <text class="status-text">在线</text>
        <view class="status-dot"></view>
      </view>
    </view>

    <!-- 管理员功能菜单 -->
    <view class="admin-functions-section">
      <view class="section-title">
        <text class="title-text">🔧 管理功能</text>
        <text class="function-count">{{adminMenuItems.length}}个功能</text>
      </view>

      <view class="functions-grid">
        <view
          class="function-item"
          wx:for="{{adminMenuItems}}"
          wx:key="id"
          bindtap="onMenuItemTap"
          data-item="{{item}}"
          style="border-left: 4rpx solid {{item.color}}"
        >
          <view class="function-icon" style="color: {{item.color}}">
            <text class="icon-emoji">{{item.icon}}</text>
          </view>
          <view class="function-content">
            <text class="function-name">{{item.name}}</text>
            <text class="function-desc">{{item.description}}</text>
          </view>
          <view class="function-arrow">
            <text class="arrow-text">▶</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部信息 -->
    <view class="dashboard-footer">
      <text class="footer-text">餐厅积分抽奖系统 v2.0 管理员控制台</text>
      <text class="footer-copyright">© 2024 All Rights Reserved</text>
    </view>
  </view>

  <!-- 🔧 强化：加载状态 - 在任何条件不满足时显示 -->
  <view
    class="loading-overlay"
    wx:if="{{loading || !initialized || !accessChecked || !contentReady || renderLocked}}"
  >
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">
        {{loading ? '正在验证权限...' : (!accessChecked ? '检查权限中...' : (!contentReady ?
        '准备内容中...' : (renderLocked ? '内容加载中...' : '初始化中...')))}}
      </text>
      <text class="loading-desc">请稍候，确保内容完整加载</text>
    </view>
  </view>
</view>
