<!--pages/admin/chat-management/chat-management.wxml - 管理员聊天工作台-->
<view class="chat-management-container">
  <!-- 管理员状态栏 -->
  <view class="admin-status-bar">
    <view class="status-info">
      <text class="status-text">工作状态：</text>
      <text class="status-badge {{adminStatus}}">
        {{adminStatus === 'online' ? '🟢 在线服务' : adminStatus === 'busy' ? '🟡 忙碌中' : '🔴
        离线'}}
      </text>
    </view>
    <view class="connection-info">
      <text class="ws-status {{wsConnected ? 'connected' : 'disconnected'}}">
        {{wsConnected ? '🔗 连接正常' : '❌ 连接异常'}}
      </text>
    </view>
  </view>

  <!-- 聊天工作台主区域 -->
  <view class="chat-workspace">
    <!-- 会话列表面板 -->
    <view class="sessions-panel" wx:if="{{showSessionList}}">
      <view class="panel-header">
        <text class="panel-title">待处理会话 ({{sessions.length}})</text>
        <button class="refresh-btn" bindtap="loadSessions">刷新</button>
      </view>

      <scroll-view class="sessions-list" scroll-y>
        <view wx:if="{{loadingSessions}}" class="loading-sessions">
          <text class="loading-text">加载会话中...</text>
        </view>

        <view wx:if="{{!loadingSessions && sessions.length === 0}}" class="empty-sessions">
          <text class="empty-text">暂无待处理会话</text>
        </view>

        <view wx:else class="sessions-content">
          <view
            wx:for="{{sessions}}"
            wx:key="id"
            class="session-item {{item.id === currentSessionId ? 'active' : ''}}"
            bindtap="selectSession"
            data-session="{{item}}"
          >
            <view class="session-avatar">
              <text class="avatar-text"
                >{{item.userName ? item.userName.substring(0, 1) : '用'}}</text
              >
            </view>
            <view class="session-detail">
              <view class="session-header">
                <text class="session-name">{{item.userName || '匿名用户'}}</text>
                <text class="session-time">{{item.lastMessageTime}}</text>
              </view>
              <view class="session-preview">
                <text class="preview-text">{{item.lastMessage || '点击开始对话'}}</text>
                <view wx:if="{{item.unreadCount > 0}}" class="unread-badge">
                  <text class="unread-count">{{item.unreadCount}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 聊天区域 -->
    <view class="chat-panel">
      <!-- 聊天头部 -->
      <view class="chat-header" wx:if="{{currentSessionId}}">
        <view class="current-session-info">
          <view class="current-session-avatar">
            <text class="avatar-text">用</text>
          </view>
          <view class="session-detail">
            <text class="session-name">{{currentSessionUserName || '用户'}}</text>
            <text class="session-status">对话进行中</text>
          </view>
        </view>
        <view class="chat-actions">
          <button class="action-btn" bindtap="endSession">结束对话</button>
        </view>
      </view>

      <!-- 聊天消息区域 -->
      <scroll-view
        class="messages-container"
        scroll-y
        scroll-into-view="{{scrollToBottom ? 'message-bottom' : ''}}"
        scroll-with-animation
      >
        <view wx:if="{{!currentSessionId}}" class="no-session-selected">
          <text class="no-session-text">请从左侧选择一个会话开始对话</text>
        </view>

        <view wx:elif="{{currentMessages.length === 0}}" class="empty-messages">
          <text class="empty-text">会话开始，请礼貌回复用户</text>
        </view>

        <view wx:else class="messages-list">
          <view
            wx:for="{{currentMessages}}"
            wx:key="id"
            class="message-item {{item.senderType === 'admin' ? 'admin' : 'user'}}"
          >
            <view class="message-avatar">
              <text class="avatar-text">{{item.senderType === 'admin' ? '客' : '用'}}</text>
            </view>
            <view class="message-content">
              <view class="message-bubble">
                <text class="message-text">{{item.content}}</text>
              </view>
              <view class="message-meta">
                <text class="message-time">{{item.createdAt}}</text>
                <text
                  wx:if="{{item.senderType === 'admin'}}"
                  class="message-status {{item.status}}"
                >
                  {{item.status === 'sending' ? '发送中' : item.status === 'sent' ? '已发送' :
                  item.status === 'failed' ? '发送失败' : ''}}
                </text>
              </view>
            </view>
          </view>
        </view>
        <view id="message-bottom"></view>
      </scroll-view>

      <!-- 聊天输入区域 -->
      <view class="chat-input-container" wx:if="{{currentSessionId}}">
        <view class="input-toolbar">
          <view class="quick-reply-btn" bindtap="toggleQuickReplies">
            <text class="btn-icon">💬</text>
          </view>

          <view class="input-wrapper">
            <textarea
              class="message-input"
              value="{{inputContent}}"
              placeholder="输入回复内容..."
              bindinput="onInputChange"
              bindblur="stopTyping"
              bindfocus="startTyping"
              maxlength="500"
              auto-height
            >
            </textarea>
          </view>

          <button
            class="send-btn {{inputContent.trim() ? 'active' : ''}}"
            bindtap="sendMessage"
            disabled="{{!inputContent.trim()}}"
          >
            <text class="send-icon">📤</text>
          </button>
        </view>

        <!-- 快捷回复面板 -->
        <view class="quick-replies-panel" wx:if="{{showQuickReplies}}">
          <view class="quick-replies-header">
            <text class="panel-title">快捷回复</text>
            <button class="close-btn" bindtap="toggleQuickReplies">×</button>
          </view>
          <view class="quick-replies-list">
            <view
              wx:for="{{quickReplies}}"
              wx:key="id"
              class="quick-reply-item"
              bindtap="useQuickReply"
              data-content="{{item.content}}"
            >
              <text class="reply-title">{{item.title}}</text>
              <text class="reply-content">{{item.content}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 无会话提示 -->
      <view class="no-session-tips" wx:if="{{!currentSessionId}}">
        <text class="tips-text">选择左侧会话开始客服工作</text>
      </view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="stats-panel">
    <view class="stats-header">
      <text class="stats-title">今日统计</text>
    </view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{todayStats.totalSessions}}</text>
        <text class="stat-label">总会话</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{todayStats.completedSessions}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{todayStats.avgResponseTime}}</text>
        <text class="stat-label">平均响应</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{todayStats.customerSatisfaction}}%</text>
        <text class="stat-label">满意度</text>
      </view>
    </view>
  </view>
</view>
