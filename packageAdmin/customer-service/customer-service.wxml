<!--packageAdmin/customer-service/customer-service.wxml — 简版客服座席回复端-->
<custom-navbar title="客服回复" bgColor="#F5F0E8" textColor="#333333" showBack="{{true}}" />
<view class="cs-agent-container">
  <!-- 座席校验失败（后端 403）：整页提示 -->
  <view wx:if="{{forbidden}}" class="cs-forbidden">
    <t-icon name="lock-on" size="96rpx" color="var(--td-brand-color)" />
    <text class="cs-forbidden-title">仅客服座席可访问</text>
    <text class="cs-forbidden-desc">请联系管理员在后台「客服座席管理」中将本账号设为在岗座席</text>
  </view>

  <!-- ===== 会话列表视图 ===== -->
  <view wx:elif="{{!chatExpanded}}" class="cs-list-view">
    <view class="cs-list-header">
      <text class="cs-list-title">待回复会话</text>
      <text class="cs-list-count">{{sessions.length}}</text>
    </view>

    <view wx:if="{{loadingSessions && sessions.length === 0}}" class="cs-loading">
      <t-loading loading="{{true}}" text="加载会话中..." theme="spinner" size="40rpx" />
    </view>

    <view wx:elif="{{sessions.length === 0}}" class="cs-empty">
      <t-empty description="暂无待回复会话" />
    </view>

    <scroll-view
      wx:else
      type="list"
      class="cs-sessions-scroll"
      scroll-y="{{true}}"
      bindscrolltolower="loadMoreSessions"
      lower-threshold="100"
    >
      <view
        wx:for="{{sessions}}"
        wx:key="sessionId"
        class="cs-session-item"
        hover-class="cs-session-item-hover"
        data-session-id="{{item.sessionId}}"
        bindtap="onSelectSession"
      >
        <view class="cs-session-avatar">
          <text class="cs-avatar-text">{{item.avatarText}}</text>
        </view>
        <view class="cs-session-info">
          <view class="cs-session-row">
            <text class="cs-user-name">{{item.userName}}</text>
            <text class="cs-session-time">{{item.lastMessageTime}}</text>
          </view>
          <view class="cs-session-row">
            <text class="cs-last-message">{{item.lastMessage}}</text>
            <view wx:if="{{item.unreadCount > 0}}" class="cs-unread-badge">
              {{item.unreadCount > 99 ? '99+' : item.unreadCount}}
            </view>
          </view>
          <view class="cs-status-tag cs-status-{{item.status}}">
            <text class="cs-status-text">{{item.statusText}}</text>
          </view>
        </view>
      </view>

      <!-- 上拉加载更多状态提示 -->
      <view wx:if="{{loadingMoreSessions}}" class="cs-loadmore">
        <t-loading loading="{{true}}" text="加载更多..." theme="spinner" size="32rpx" />
      </view>
      <view wx:elif="{{!sessionHasMore && sessions.length > 0}}" class="cs-loadmore">
        <text class="cs-loadmore-text">没有更多会话了</text>
      </view>
    </scroll-view>
  </view>

  <!-- ===== 聊天视图 ===== -->
  <view wx:else class="cs-chat-view">
    <view class="cs-chat-header">
      <view class="cs-back-btn" hover-class="cs-back-btn-hover" bindtap="onBackToList">
        <t-icon name="chevron-left" size="40rpx" color="var(--td-brand-color)" />
        <text class="cs-back-text">会话</text>
      </view>
      <view class="cs-chat-title">
        <text class="cs-chat-user">{{currentSessionUserName}}</text>
        <view class="cs-chat-status">
          <view class="cs-ws-dot {{wsConnected ? 'cs-ws-on' : 'cs-ws-off'}}"></view>
          <text class="cs-chat-session-id"
            >{{wsConnected ? '实时' : '需手动刷新'}} · 会话 {{currentSessionId}}</text
          >
        </view>
      </view>
      <view class="cs-refresh-btn" hover-class="cs-back-btn-hover" bindtap="onRefreshMessages">
        <t-icon name="refresh" size="36rpx" color="var(--td-brand-color)" />
      </view>
    </view>

    <scroll-view
      type="list"
      class="cs-messages"
      scroll-y="{{true}}"
      scroll-into-view="{{scrollToBottom ? 'cs-msg-bottom' : ''}}"
      scroll-with-animation="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view wx:if="{{loadingMessages && currentMessages.length === 0}}" class="cs-loading">
        <t-loading loading="{{true}}" text="加载聊天记录..." theme="spinner" size="40rpx" />
      </view>

      <view wx:elif="{{currentMessages.length === 0}}" class="cs-msg-empty">
        <text class="cs-msg-empty-text">暂无消息，请礼貌回复用户</text>
      </view>

      <view
        wx:for="{{currentMessages}}"
        wx:key="id"
        class="cs-msg-item {{item.isOwn ? 'cs-msg-own' : 'cs-msg-other'}}"
      >
        <view class="cs-msg-avatar">
          <text class="cs-msg-avatar-text">{{item.isOwn ? '客' : '用'}}</text>
        </view>
        <view class="cs-msg-body">
          <view class="cs-msg-bubble {{item.isOwn ? 'cs-bubble-own' : 'cs-bubble-other'}}">
            <text wx:if="{{item.messageType === 'text'}}" class="cs-msg-text" user-select="{{true}}"
              >{{item.content}}</text
            >
            <image
              wx:elif="{{item.messageType === 'image'}}"
              class="cs-msg-image"
              src="{{item.content}}"
              mode="widthFix"
              data-url="{{item.content}}"
              bindtap="onPreviewImage"
            />
            <view
              wx:elif="{{item.messageType === 'file'}}"
              class="cs-msg-file"
              data-url="{{item.content}}"
              bindtap="onOpenFile"
            >
              <t-icon name="file" size="48rpx" color="var(--td-brand-color)" />
              <view class="cs-msg-file-info">
                <text class="cs-msg-file-name">{{item.fileName || '文件'}}</text>
                <text wx:if="{{item.fileSize}}" class="cs-msg-file-size">{{item.fileSize}}</text>
              </view>
            </view>
          </view>
          <text class="cs-msg-time">{{item.createdAt}}</text>
        </view>
      </view>
      <view id="cs-msg-bottom"></view>
    </scroll-view>

    <!-- 输入区 -->
    <view class="cs-input-bar">
      <view class="cs-image-btn" hover-class="cs-image-btn-hover" bindtap="onSendImage">
        <t-icon name="image" size="44rpx" color="var(--td-brand-color)" />
      </view>
      <view class="cs-image-btn" hover-class="cs-image-btn-hover" bindtap="onSendFile">
        <t-icon name="folder" size="44rpx" color="var(--td-brand-color)" />
      </view>
      <textarea
        class="cs-input"
        placeholder="输入回复内容..."
        value="{{inputContent}}"
        bindinput="onInputChange"
        maxlength="500"
        auto-height
        show-confirm-bar="{{false}}"
      ></textarea>
      <view
        class="cs-send-btn {{inputContent ? 'cs-send-active' : 'cs-send-disabled'}}"
        bindtap="onSendText"
      >
        <text class="cs-send-text">{{sending ? '发送中' : '发送'}}</text>
      </view>
    </view>
  </view>

  <!-- 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
  <maintenance-overlay />
</view>
