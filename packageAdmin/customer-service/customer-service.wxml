<!--pages/admin/customer-service/customer-service.wxml - з®ЎзҗҶе‘ҳе®ўжңҚз®ЎзҗҶйЎөйқ?->
<custom-navbar title="е®ўжңҚз®ЎзҗҶ" bgColor="#5B7A5E" textColor="#ffffff" showBack="{{true}}" />
<view class="customer-service-container">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- йЎөйқўж ҮйўҳеҢ?-->
    <view class="page-header">
      <view class="header-text">
        <text class="header-title">е®ўжңҚз®ЎзҗҶ</text>
        <text class="header-desc">е®һж—¶иҒҠеӨ©пјҢй«ҳж•ҲжңҚеҠ?/text>
      </view>
      <view class="header-decor-icon">
        <t-icon name="chat" size="128rpx" color="rgba(139, 115, 85, 0.12)" />
      </view>
    </view>

    <!-- рҹ”ҙ е®һж—¶иҒҠеӨ©жЁЎејҸ -->
    <view class="chat-mode-container">
      <!-- з®ЎзҗҶе‘ҳзҠ¶жҖҒж ҸпјҲзҠ¶жҖҒеҸҜеҲҮжҚў: online / busy / offlineпј?-->
      <view class="admin-status-bar">
        <view class="status-info">
          <text class="status-text">еҪ“еүҚзҠ¶жҖҒпјҡ</text>
          <text
            class="status-badge {{adminStatus}}"
            bindtap="onToggleAdminStatus"
            data-status="{{adminStatus === 'online' ? 'busy' : 'online'}}"
          >
            <view class="status-dot status-dot--{{adminStatus}}"></view>
            {{adminStatus === 'online' ? 'еңЁзәҝ' : adminStatus === 'busy' ? 'еҝҷзўҢ' : 'зҰ»зәҝ'}}
          </text>
        </view>
        <view class="connection-info">
          <text class="ws-status {{wsConnected ? 'connected' : 'disconnected'}}">
            <t-icon wx:if="{{wsConnected}}" name="link" size="28rpx" color="currentColor" /><t-icon
              wx:else
              name="close-circle-filled"
              size="28rpx"
              color="currentColor"
            />
            {{wsConnected ? 'е·ІиҝһжҺ? : 'жңӘиҝһжҺ?}}
          </text>
        </view>
      </view>

      <!-- иҒҠеӨ©е·ҘдҪңеҸ°дё»еҢәеҹҹ -->
      <view class="chat-workspace {{chatExpanded ? 'expanded' : ''}}">
        <!-- дјҡиҜқеҲ—иЎЁ -->
        <view wx:if="{{!chatExpanded}}" class="sessions-panel">
          <view class="panel-header">
            <text class="panel-title">жҙ»и·ғдјҡиҜқ</text>
            <text class="session-count">({{sessions.length}})</text>
          </view>

          <view wx:if="{{loadingSessions}}" class="loading-sessions">
            <text>еҠ иҪҪдјҡиҜқдё?..</text>
          </view>

          <view wx:elif="{{sessions.length === 0}}" class="empty-sessions">
            <t-empty description="жҡӮж— жҙ»и·ғдјҡиҜқ" />
          </view>

          <view wx:else class="sessions-list">
            <view
              wx:for="{{sessions}}"
              wx:key="sessionId"
              class="session-item {{currentSessionId === item.sessionId ? 'active' : ''}}"
              hover-class="session-item-hover"
              data-session-id="{{item.sessionId}}"
              bindtap="onSelectSession"
            >
              <view class="session-avatar">
                <text class="avatar-text"
                  >{{item.userInfo.nickname ? item.userInfo.nickname.charAt(0) : 'з”?}}</text
                >
              </view>
              <view class="session-info">
                <view class="session-header">
                  <text class="user-name">{{item.userInfo.nickname || 'з”ЁжҲ·' + item.userId}}</text>
                  <text class="session-time">{{item.lastMessageTime}}</text>
                </view>
                <view class="session-preview">
                  <text class="last-message">{{item.lastMessage || 'зӯүеҫ…е®ўжңҚеӣһеӨҚ...'}}</text>
                  <view wx:if="{{item.unreadCount > 0}}" class="unread-badge"
                    >{{item.unreadCount}}</view
                  >
                </view>
                <view class="session-status">
                  <text class="status-tag {{item.status}}">
                    {{item.status === 'waiting' ? 'зӯүеҫ…еӣһеӨҚ' : item.status === 'active' ? 'иҝӣиЎҢдё? :
                    'е·Із»“жқ?}}
                  </text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- иҒҠеӨ©еҢәеҹҹ -->
        <view class="chat-panel {{chatExpanded ? 'expanded' : ''}}">
          <view wx:if="{{!currentSessionId}}" class="no-session-selected">
            <text class="no-session-icon"><t-icon name="chat" size="28rpx" /></text>
            <text class="no-session-text">иҜ·йҖүжӢ©дёҖдёӘдјҡиҜқејҖе§ӢиҒҠеӨ?/text>
          </view>

          <view wx:else class="chat-container">
            <!-- иҒҠеӨ©еӨҙйғЁ -->
            <view class="chat-header">
              <view
                wx:if="{{chatExpanded}}"
                class="back-btn"
                hover-class="back-btn-hover"
                bindtap="onCloseChatExpanded"
              >
                <text class="back-icon">вҶ?/text>
                <text class="back-text">иҝ”еӣһеҲ—иЎЁ</text>
              </view>
              <view class="chat-user-info">
                <text class="chat-user-name">{{currentSessionUserName || 'з”ЁжҲ·'}}</text>
                <text class="chat-session-id">дјҡиҜқID: {{currentSessionId}}</text>
              </view>
              <view class="chat-actions">
                <button class="action-btn" bindtap="onEndSession">з»“жқҹдјҡиҜқ</button>
              </view>
            </view>

            <!-- иҒҠеӨ©ж¶ҲжҒҜеҢәеҹҹ -->
            <scroll-view
              type="list"
              class="messages-container"
              scroll-y
              scroll-top="{{scrollToBottom ? 99999 : 0}}"
              scroll-into-view="{{scrollToBottom ? 'message-bottom' : ''}}"
            >
              <view wx:if="{{currentMessages.length === 0}}" class="empty-messages">
                <text class="empty-text">дјҡиҜқејҖе§ӢпјҢиҜ·зӨјиІҢеӣһеӨҚз”ЁжҲ?/text>
              </view>

              <view wx:else class="messages-list">
                <view
                  wx:for="{{currentMessages}}"
                  wx:key="id"
                  class="message-item {{item.senderType === 'admin' ? 'admin' : 'user'}}"
                >
                  <view class="message-avatar">
                    <text class="avatar-text">{{item.senderType === 'admin' ? 'е®? : 'з”?}}</text>
                  </view>
                  <view class="message-content">
                    <view class="message-bubble">
                      <text class="message-text">{{item.content}}</text>
                    </view>
                    <view class="message-meta">
                      <text class="message-time">{{item.createdAt}}</text>
                      <text
                        wx:if="{{item.senderType === 'admin'}}"
                        class="message-status {{item.status}}"
                      >
                        {{item.status === 'sending' ? 'еҸ‘йҖҒдёӯ' : item.status === 'sent' ? 'е·ІеҸ‘йҖ? :
                        item.status === 'failed' ? 'еҸ‘йҖҒеӨұиҙ? : ''}}
                      </text>
                    </view>
                  </view>
                </view>
              </view>
              <view id="message-bottom"></view>
            </scroll-view>

            <!-- иҒҠеӨ©иҫ“е…ҘеҢәеҹҹ -->
            <view class="chat-input-container">
              <!-- иҫ“е…ҘжЎҶе’ҢеҸ‘йҖҒжҢүй’?-->
              <view class="input-area">
                <textarea
                  class="message-input"
                  placeholder="иҫ“е…ҘеӣһеӨҚеҶ…е®№..."
                  value="{{inputContent}}"
                  bindinput="onChatInputChange"
                  bindfocus="onChatInputFocus"
                  bindblur="onChatInputBlur"
                  maxlength="500"
                  auto-height
                  show-confirm-bar="{{false}}"
                ></textarea>
                <button
                  class="send-btn {{sendButtonEnabled ? 'active' : 'disabled'}}"
                  disabled="{{!sendButtonEnabled}}"
                  bindtap="sendChatMessage"
                >
                  <t-icon name="send" size="36rpx" class="send-icon" />
                  <text class="send-text">еҸ‘йҖ?/text>
                </button>
              </view>

              <!-- иҫ“е…ҘзҠ¶жҖҒжҸҗзӨ?-->
              <view wx:if="{{isTyping}}" class="typing-indicator">
                <text>жӯЈеңЁиҫ“е…Ҙ...</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- д»Ҡж—Ҙз»ҹи®Ў -->
      <view class="today-stats">
        <view class="stats-header">
          <text class="stats-title">д»Ҡж—Ҙз»ҹи®Ў</text>
        </view>
        <view class="stats-grid">
          <view class="stat-card">
            <text class="stat-number">{{todayStats.totalSessions}}</text>
            <text class="stat-label">жҖ»дјҡиҜқж•°</text>
          </view>
          <view class="stat-card">
            <text class="stat-number">{{todayStats.completedSessions}}</text>
            <text class="stat-label">е·Іе®ҢжҲ?/text>
          </view>
          <view class="stat-card">
            <text class="stat-number">{{todayStats.avgResponseTime}}</text>
            <text class="stat-label">е№іеқҮе“Қеә”</text>
          </view>
          <view class="stat-card">
            <text class="stat-number">{{todayStats.customerSatisfaction}}%</text>
            <text class="stat-label">ж»Ўж„Ҹеә?/text>
          </view>
        </view>
      </view>
    </view>

    <!-- рҹ”§ е…ЁеұҸз»ҙжҠӨйҒ®зҪ©пј?03 SYSTEM_MAINTENANCE ж—¶жҝҖжҙ»пјү -->
    <maintenance-overlay />
  </scroll-view>
</view>
