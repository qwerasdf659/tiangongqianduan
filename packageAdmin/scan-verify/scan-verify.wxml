<!--pages/admin/scan-verify/scan-verify.wxml - 商家扫码核销页面-->

<view class="scan-verify-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">📱 扫码核销</text>
    <text class="header-desc">扫描用户出示的核销码完成核销</text>
  </view>

  <!-- 未扫码状态 -->
  <view class="scan-prompt" wx:if="{{!hasScanned && !loading}}">
    <view class="scan-icon">📷</view>
    <text class="scan-text">请点击下方按钮扫描核销码</text>
    <button class="scan-btn" bindtap="startScan">开始扫码</button>
  </view>

  <!-- 加载状态 -->
  <view class="loading-section" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">核销中，请稍候...</text>
  </view>

  <!-- 核销成功 -->
  <view class="result-section success" wx:if="{{hasScanned && verifySuccess && !loading}}">
    <view class="result-icon">✅</view>
    <text class="result-title">核销成功</text>
    <view class="result-detail" wx:if="{{verifyResult}}">
      <view class="detail-row" wx:if="{{verifyResult.redemption_order_id}}">
        <text class="detail-label">订单编号</text>
        <text class="detail-value">{{verifyResult.redemption_order_id}}</text>
      </view>
      <view class="detail-row" wx:if="{{verifyResult.fulfilled_at}}">
        <text class="detail-label">核销时间</text>
        <text class="detail-value">{{verifyResult.fulfilled_at}}</text>
      </view>
    </view>
    <button class="action-btn" bindtap="onRescan">继续扫码</button>
  </view>

  <!-- 核销失败 -->
  <view class="result-section fail" wx:if="{{hasScanned && !verifySuccess && !loading && verifyResult}}">
    <view class="result-icon">❌</view>
    <text class="result-title">核销失败</text>
    <text class="result-error">{{verifyResult.error || '核销码无效或已过期'}}</text>
    <button class="action-btn" bindtap="onRescan">重新扫码</button>
  </view>
</view>

