<!--packageAdmin/audit-list/audit-list.wxml - 审核管理页面（V6.0 审核链对接版）-->
<!--双模式: 「消费审核」传统审核 + 「我的待办」审核链步骤-->

<view class="audit-page">
  <!-- 顶部标签页切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'consumption' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="consumption">
      <text class="tab-text">消费审核</text>
      <view class="tab-badge" wx:if="{{total > 0 && activeTab !== 'consumption'}}">
        <text>{{total > 99 ? '99+' : total}}</text>
      </view>
    </view>
    <view class="tab-item {{activeTab === 'myPending' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="myPending">
      <text class="tab-text">我的待办</text>
      <view class="tab-badge" wx:if="{{pendingTotal > 0 && activeTab !== 'myPending'}}">
        <text>{{pendingTotal > 99 ? '99+' : pendingTotal}}</text>
      </view>
    </view>
    <view class="tab-indicator {{activeTab === 'myPending' ? 'right' : 'left'}}"></view>
  </view>

  <!-- ===== 标签页一：消费审核（原有功能） ===== -->
  <block wx:if="{{activeTab === 'consumption'}}">
    <!-- 顶部统计面板 -->
    <view class="stats-panel">
      <view class="stats-main">
        <view class="stats-number-wrap">
          <text class="stats-number">{{total}}</text>
          <text class="stats-unit">条</text>
        </view>
        <text class="stats-label">待审核消费记录</text>
      </view>
      <view class="stats-hint">
        <text class="stats-hint-icon">💡</text>
        <text class="stats-hint-text">审核通过后积分自动发放</text>
      </view>
    </view>

    <!-- 操作工具栏（仅admin可批量操作） -->
    <view class="toolbar" wx:if="{{isAdminUser}}">
      <view class="toolbar-left">
        <view class="custom-checkbox {{allSelected ? 'checked' : ''}}" bindtap="toggleSelectAll">
          <text class="check-mark" wx:if="{{allSelected}}">✓</text>
        </view>
        <text class="toolbar-label">全选</text>
      </view>
      <view class="toolbar-right">
        <view class="batch-btn reject" wx:if="{{selectedCount > 0}}" bindtap="onBatchReject">
          <text>拒绝 ({{selectedCount}})</text>
        </view>
        <view class="batch-btn approve" wx:if="{{selectedCount > 0}}" bindtap="onBatchApprove">
          <text>通过 ({{selectedCount}})</text>
        </view>
        <text class="toolbar-tip" wx:if="{{selectedCount === 0 && records.length > 0}}">勾选记录可批量操作</text>
      </view>
    </view>

    <!-- 列表区域 -->
    <view class="list-section">
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
        <view class="empty-icon-wrap">
          <text class="empty-icon">✅</text>
        </view>
        <text class="empty-title">暂无待审核记录</text>
        <text class="empty-desc">所有消费记录已审核完成，下拉刷新检查新记录</text>
      </view>

      <!-- 记录卡片列表 -->
      <view class="record-card {{item.selected ? 'selected' : ''}}" wx:for="{{records}}" wx:key="record_id">
        <view class="card-header">
          <view class="header-left">
            <view class="custom-checkbox {{item.selected ? 'checked' : ''}}" catchtap="toggleSelect"
              data-index="{{index}}" wx:if="{{isAdminUser}}">
              <text class="check-mark" wx:if="{{item.selected}}">✓</text>
            </view>
            <view class="user-avatar">
              <text class="avatar-text">{{item.user_nickname ? item.user_nickname[0] : '用'}}</text>
            </view>
            <view class="user-info">
              <text class="user-name">{{item.user_nickname || '未知用户'}}</text>
              <text class="user-phone">{{item.user_mobile_display || item.user_mobile}}</text>
            </view>
          </view>
          <view class="status-tag pending">
            <view class="status-dot"></view>
            <text>待审核</text>
          </view>
        </view>

        <view class="card-amounts">
          <view class="amount-item">
            <text class="amount-label">消费金额</text>
            <view class="amount-value">
              <text class="currency">¥</text>
              <text class="number money">{{item.consumption_amount}}</text>
            </view>
          </view>
          <view class="amount-divider"></view>
          <view class="amount-item">
            <text class="amount-label">预计积分</text>
            <view class="amount-value">
              <text class="number points">{{item.points_to_award}}</text>
              <text class="unit">分</text>
            </view>
          </view>
        </view>

        <view class="card-details">
          <view class="detail-item" wx:if="{{item.merchant_notes}}">
            <text class="detail-key">商家备注</text>
            <text class="detail-val">{{item.merchant_notes}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-key">提交时间</text>
            <text class="detail-val muted">{{item.created_at_formatted}}</text>
          </view>
        </view>

        <view class="card-actions">
          <button class="btn-reject" bindtap="onReject" data-record="{{item}}" disabled="{{submitting}}">拒绝</button>
          <button class="btn-approve" bindtap="onApprove" data-record="{{item}}" disabled="{{submitting}}">通过</button>
        </view>
      </view>
    </view>

    <!-- 分页栏 -->
    <view class="pagination" wx:if="{{total_pages > 1}}">
      <view class="page-arrow {{page <= 1 ? 'disabled' : ''}}" bindtap="goToPrevPage">
        <text>‹</text>
      </view>
      <view class="page-nums">
        <view wx:for="{{pageNumbers}}" wx:key="*this" class="page-num {{item === page ? 'active' : ''}}"
          bindtap="goToPage" data-page="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
      <view class="page-arrow {{page >= total_pages ? 'disabled' : ''}}" bindtap="goToNextPage">
        <text>›</text>
      </view>
      <text class="page-info">{{page}}/{{total_pages}}</text>
    </view>
  </block>

  <!-- ===== 标签页二：我的待办（审核链步骤） ===== -->
  <block wx:if="{{activeTab === 'myPending'}}">
    <!-- 顶部统计面板 -->
    <view class="stats-panel">
      <view class="stats-main">
        <view class="stats-number-wrap">
          <text class="stats-number">{{pendingTotal}}</text>
          <text class="stats-unit">条</text>
        </view>
        <text class="stats-label">待我审核的步骤</text>
      </view>
      <view class="stats-hint">
        <text class="stats-hint-icon">⏳</text>
        <text class="stats-hint-text">超时12小时自动升级</text>
      </view>
    </view>

    <!-- 待办列表 -->
    <view class="list-section">
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!pendingLoading && pendingSteps.length === 0}}">
        <view class="empty-icon-wrap">
          <text class="empty-icon">✅</text>
        </view>
        <text class="empty-title">暂无待办事项</text>
        <text class="empty-desc">您没有需要审核的步骤，下拉刷新检查新任务</text>
      </view>

      <!-- 审核链步骤卡片 -->
      <view class="record-card chain-card" wx:for="{{pendingSteps}}" wx:key="step_id">
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="header-left">
            <view class="chain-type-badge">
              <text>{{item.auditable_type_text}}</text>
            </view>
            <view class="chain-meta">
              <text class="chain-step-label">{{item.is_final_text}}</text>
              <text class="chain-step-progress">{{item.step_progress}}</text>
            </view>
          </view>
          <view class="status-tag pending">
            <view class="status-dot"></view>
            <text>{{item.status_text}}</text>
          </view>
        </view>

        <!-- 审核链进度条 -->
        <view class="chain-progress-bar" wx:if="{{item.instance}}">
          <view class="progress-track">
            <view class="progress-fill"
              style="width: {{(item.instance.current_step / item.instance.total_steps) * 100}}%"></view>
          </view>
          <text class="progress-text">进度 {{item.instance.current_step}}/{{item.instance.total_steps}}</text>
        </view>

        <!-- 业务快照信息（TS层已预计算 snapshot_* 字段，避免WXML中复杂OR表达式） -->
        <view class="card-amounts" wx:if="{{item.has_snapshot}}">
          <view class="amount-item" wx:if="{{item.snapshot_consumption_amount}}">
            <text class="amount-label">消费金额</text>
            <view class="amount-value">
              <text class="currency">¥</text>
              <text class="number money">{{item.snapshot_consumption_amount}}</text>
            </view>
          </view>
          <view class="amount-divider" wx:if="{{item.snapshot_consumption_amount && item.snapshot_points_to_award}}">
          </view>
          <view class="amount-item" wx:if="{{item.snapshot_points_to_award}}">
            <text class="amount-label">预计积分</text>
            <view class="amount-value">
              <text class="number points">{{item.snapshot_points_to_award}}</text>
              <text class="unit">分</text>
            </view>
          </view>
        </view>

        <!-- 详情信息 -->
        <view class="card-details">
          <view class="detail-item" wx:if="{{item.instance && item.instance.submitted_by_name}}">
            <text class="detail-key">提交人</text>
            <text class="detail-val">{{item.instance.submitted_by_name}}</text>
          </view>
          <view class="detail-item">
            <text class="detail-key">创建时间</text>
            <text class="detail-val muted">{{item.created_at_formatted}}</text>
          </view>
          <view class="detail-item" wx:if="{{item.timeout_at_formatted}}">
            <text class="detail-key">超时截止</text>
            <text class="detail-val muted timeout">{{item.timeout_at_formatted}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="card-actions">
          <button class="btn-detail" bindtap="onViewChainDetail" data-instance-id="{{item.instance_id}}"
            wx:if="{{item.instance_id}}">详情</button>
          <button class="btn-reject" bindtap="onChainReject" data-step="{{item}}"
            disabled="{{chainSubmitting}}">拒绝</button>
          <button class="btn-approve" bindtap="onChainApprove" data-step="{{item}}"
            disabled="{{chainSubmitting}}">通过</button>
        </view>
      </view>
    </view>

    <!-- 分页栏 -->
    <view class="pagination" wx:if="{{pendingTotalPages > 1}}">
      <view class="page-arrow {{pendingPage <= 1 ? 'disabled' : ''}}" bindtap="goToPendingPrevPage">
        <text>‹</text>
      </view>
      <view class="page-nums">
        <view wx:for="{{pendingPageNumbers}}" wx:key="*this" class="page-num {{item === pendingPage ? 'active' : ''}}"
          bindtap="goToPendingPage" data-page="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
      <view class="page-arrow {{pendingPage >= pendingTotalPages ? 'disabled' : ''}}" bindtap="goToPendingNextPage">
        <text>›</text>
      </view>
      <text class="page-info">{{pendingPage}}/{{pendingTotalPages}}</text>
    </view>
  </block>

  <!-- ===== 首次加载 ===== -->
  <view class="loading-overlay"
    wx:if="{{(loading && records.length === 0 && activeTab === 'consumption') || (pendingLoading && pendingSteps.length === 0 && activeTab === 'myPending')}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载...</text>
    </view>
  </view>

  <!-- ===== 消费审核拒绝弹窗（单条/批量共用） ===== -->
  <view class="modal-overlay" wx:if="{{showRejectModal}}" bindtap="cancelReject">
    <view class="modal-dialog" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-header-left">
          <view class="modal-header-icon">
            <text>✕</text>
          </view>
          <text class="modal-title">{{batchRejectMode ? '批量拒绝' : '审核拒绝'}}</text>
        </view>
        <view class="modal-close" bindtap="cancelReject">
          <text>✕</text>
        </view>
      </view>

      <view class="modal-summary" wx:if="{{!batchRejectMode && selectedRecord}}">
        <text class="modal-summary-label">用户</text>
        <text class="modal-summary-val">{{selectedRecord.user_nickname || selectedRecord.user_mobile}}</text>
        <text class="modal-summary-divider">|</text>
        <text class="modal-summary-amount">¥{{selectedRecord.consumption_amount}}</text>
      </view>
      <view class="modal-summary batch" wx:if="{{batchRejectMode}}">
        <text class="modal-summary-batch">已选中 {{selectedCount}} 条记录，将统一拒绝</text>
      </view>

      <view class="modal-body">
        <text class="input-label">拒绝原因（必填，至少5个字符）</text>
        <textarea class="reject-textarea" placeholder="请输入拒绝原因，如：消费金额与实际不符" value="{{rejectReason}}"
          bindinput="onRejectReasonInput" maxlength="200" auto-height />
        <view class="input-meta">
          <text class="char-count">{{rejectReason.length || 0}}/200</text>
          <text class="warning-text">拒绝后用户将收到通知</text>
        </view>
      </view>

      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="cancelReject">取消</button>
        <button class="modal-btn confirm" bindtap="confirmReject" disabled="{{submitting}}">
          {{submitting ? '提交中...' : (batchRejectMode ? '确认批量拒绝' : '确认拒绝')}}
        </button>
      </view>
    </view>
  </view>

  <!-- ===== 审核链步骤拒绝弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{showChainRejectModal}}" bindtap="cancelChainReject">
    <view class="modal-dialog" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-header-left">
          <view class="modal-header-icon">
            <text>✕</text>
          </view>
          <text class="modal-title">审核链拒绝</text>
        </view>
        <view class="modal-close" bindtap="cancelChainReject">
          <text>✕</text>
        </view>
      </view>

      <view class="modal-summary" wx:if="{{selectedStep}}">
        <text class="modal-summary-label">{{selectedStep.auditable_type_text}}</text>
        <text class="modal-summary-divider">|</text>
        <text class="modal-summary-val">{{selectedStep.is_final_text}} · {{selectedStep.step_progress}}</text>
      </view>

      <view class="modal-body">
        <text class="input-label">拒绝原因（必填，至少5个字符）</text>
        <textarea class="reject-textarea" placeholder="请输入拒绝原因" value="{{chainRejectReason}}"
          bindinput="onChainRejectReasonInput" maxlength="500" auto-height />
        <view class="input-meta">
          <text class="char-count">{{chainRejectReason.length || 0}}/500</text>
          <text class="warning-text">拒绝后整个审核链将终止</text>
        </view>
      </view>

      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="cancelChainReject">取消</button>
        <button class="modal-btn confirm" bindtap="confirmChainReject" disabled="{{chainSubmitting}}">
          {{chainSubmitting ? '提交中...' : '确认拒绝'}}
        </button>
      </view>
    </view>
  </view>

  <!-- ===== 审核链详情弹窗（时间线） ===== -->
  <view class="modal-overlay" wx:if="{{showChainDetailModal}}" bindtap="closeChainDetailModal">
    <view class="modal-dialog chain-detail-dialog" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-header-left">
          <view class="modal-header-icon detail-icon">
            <text>📋</text>
          </view>
          <text class="modal-title">审核链详情</text>
        </view>
        <view class="modal-close" bindtap="closeChainDetailModal">
          <text>✕</text>
        </view>
      </view>

      <scroll-view scroll-y class="chain-detail-scroll" wx:if="{{chainDetail}}">
        <!-- 审核链基本信息 -->
        <view class="chain-detail-info">
          <view class="detail-row">
            <text class="detail-key">业务类型</text>
            <text class="detail-val">{{chainDetail.auditable_type_text}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-key">整体状态</text>
            <text class="detail-val chain-status-{{chainDetail.status}}">{{chainDetail.status_text}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-key">提交时间</text>
            <text class="detail-val muted">{{chainDetail.submitted_at_formatted}}</text>
          </view>
          <view class="detail-row" wx:if="{{chainDetail.completed_at_formatted}}">
            <text class="detail-key">完成时间</text>
            <text class="detail-val muted">{{chainDetail.completed_at_formatted}}</text>
          </view>
          <view class="detail-row" wx:if="{{chainDetail.final_reason}}">
            <text class="detail-key">审批意见</text>
            <text class="detail-val">{{chainDetail.final_reason}}</text>
          </view>
        </view>

        <!-- 审核链步骤时间线 -->
        <view class="chain-timeline">
          <text class="timeline-title">审核步骤</text>
          <view class="timeline-list">
            <view class="timeline-item {{stepItem.status}}" wx:for="{{chainDetail.steps}}" wx:for-item="stepItem"
              wx:key="step_id">
              <view class="timeline-dot {{stepItem.status}}"></view>
              <view class="timeline-line" wx:if="{{index < chainDetail.steps.length - 1}}"></view>
              <view class="timeline-content">
                <view class="timeline-header">
                  <text class="timeline-step-name">{{stepItem.node_name || ('第' + stepItem.step_number + '步')}}</text>
                  <text class="timeline-step-status {{stepItem.status}}">{{stepItem.status_text}}</text>
                </view>
                <view class="timeline-detail" wx:if="{{stepItem.actioned_at_formatted}}">
                  <text class="timeline-time">{{stepItem.actioned_at_formatted}}</text>
                </view>
                <view class="timeline-detail" wx:if="{{stepItem.action_reason}}">
                  <text class="timeline-reason">{{stepItem.action_reason}}</text>
                </view>
                <view class="timeline-detail" wx:if="{{stepItem.auto_approved}}">
                  <text class="timeline-auto">自动审批</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- ===== 批量操作进度弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{showBatchProgress}}">
    <view class="modal-dialog progress" catchtap="stopPropagation">
      <view class="progress-content">
        <view class="loading-spinner"></view>
        <text class="progress-title">{{batchProgressText}}</text>
        <text class="progress-detail">{{batchProgressDetail}}</text>
      </view>
    </view>
  </view>

  <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
  <maintenance-overlay />
</view>