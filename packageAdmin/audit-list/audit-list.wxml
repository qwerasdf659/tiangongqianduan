<!-- pages/admin/audit-list/audit-list.wxml -->
<view class="audit-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="page-title">审核列表</text>
    <view class="page-subtitle">
      <text>待审核：{{total}}条</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="records-list">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无待审核记录</text>
      <text class="empty-desc">所有消费记录已审核完成</text>
    </view>

    <!-- 记录卡片 -->
    <view class="record-card" wx:for="{{records}}" wx:key="record_id">
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="user-info">
          <text class="user-icon">👤</text>
          <view class="user-details">
            <text class="user-name">{{item.user_nickname || item.user_mobile}}</text>
            <text class="user-mobile">{{item.user_mobile}}</text>
          </view>
        </view>
        <view class="status-badge pending">
          <text>待审核</text>
        </view>
      </view>

      <!-- 卡片主体 -->
      <view class="card-body">
        <!-- 消费金额 -->
        <view class="info-row highlight">
          <text class="info-label">消费金额</text>
          <text class="info-value amount">¥{{item.consumption_amount}}</text>
        </view>

        <!-- 预计积分 -->
        <view class="info-row highlight">
          <text class="info-label">预计积分</text>
          <text class="info-value points">{{item.points_to_award}}分</text>
        </view>

        <!-- 商家备注 -->
        <view class="info-row" wx:if="{{item.merchant_notes}}">
          <text class="info-label">商家备注</text>
          <text class="info-value notes">{{item.merchant_notes}}</text>
        </view>

        <!-- 提交时间 -->
        <view class="info-row">
          <text class="info-label">提交时间</text>
          <text class="info-value time">{{item.created_at_formatted || item.created_at}}</text>
        </view>
        <!-- 时区标注 -->
        <view class="info-row">
          <text class="info-label timezone-note">（北京时间 GMT+8）</text>
        </view>
      </view>

      <!-- 卡片底部操作按钮 -->
      <view class="card-footer">
        <button
          class="action-btn reject-btn"
          bindtap="onReject"
          data-record="{{item}}"
          disabled="{{submitting}}"
        >
          <text class="btn-icon">❌</text>
          <text class="btn-text">拒绝</text>
        </button>
        <button
          class="action-btn approve-btn"
          bindtap="onApprove"
          data-record="{{item}}"
          disabled="{{submitting}}"
        >
          <text class="btn-icon">✅</text>
          <text class="btn-text">通过</text>
        </button>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{hasMore && !loading}}">
      <text class="load-more-text">{{loadingMore ? '加载中...' : '上拉加载更多'}}</text>
    </view>

    <!-- 没有更多数据提示 -->
    <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
      <text class="no-more-text">已加载全部记录</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading && !refreshing}}">
    <view class="loading-icon"></view>
    <text class="loading-text">正在加载...</text>
  </view>

  <!-- 审核拒绝弹窗 -->
  <view class="modal-mask" wx:if="{{showRejectModal}}" bindtap="cancelReject">
    <view class="modal-content" catchtap="{{''}}">
      <view class="modal-header">
        <text class="modal-title">审核拒绝</text>
        <view class="modal-close" bindtap="cancelReject">
          <text>✕</text>
        </view>
      </view>

      <view class="modal-body">
        <!-- 拒绝原因输入 -->
        <view class="input-label">拒绝原因（必填，至少5个字符）</view>
        <textarea
          class="reject-reason-input"
          placeholder="请输入拒绝原因，如：消费金额与实际不符"
          value="{{rejectReason}}"
          bindinput="onRejectReasonInput"
          maxlength="200"
          auto-height
        />
        <view class="input-tips">（拒绝后用户将收到通知，请谨慎操作）</view>
      </view>

      <view class="modal-footer">
        <button class="modal-btn cancel-btn" bindtap="cancelReject">取消</button>
        <button class="modal-btn confirm-btn" bindtap="confirmReject" disabled="{{submitting}}">
          {{submitting ? '提交中...' : '确认拒绝'}}
        </button>
      </view>
    </view>
  </view>
</view>
