<!--packageAdmin/audit-list/audit-list.wxml - 审批管理页面-->
<!--业务流程: 加载待审核消费记录 → 审核通过(自动发积分)/拒绝(填写原因) → 刷新列表-->

<view class="audit-page">
  <!-- 顶部统计栏 -->
  <view class="stat-bar">
    <view class="stat-item">
      <text class="stat-number">{{total}}</text>
      <text class="stat-label">待审核</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="records-list">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
      <view class="empty-icon-box">
        <text class="empty-icon">📭</text>
      </view>
      <text class="empty-title">暂无待审核记录</text>
      <text class="empty-desc">所有消费记录已审核完成</text>
    </view>

    <!-- 记录卡片 -->
    <view class="record-card" wx:for="{{records}}" wx:key="record_id">
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="user-info">
          <view class="avatar-box">
            <text class="avatar-text">{{item.user_nickname ? item.user_nickname[0] : '用'}}</text>
          </view>
          <view class="user-detail">
            <text class="user-name">{{item.user_nickname || '未知用户'}}</text>
            <text class="user-phone">{{item.user_mobile}}</text>
          </view>
        </view>
        <view class="status-tag pending">
          <text class="tag-dot"></text>
          <text class="tag-text">待审核</text>
        </view>
      </view>

      <!-- 金额信息高亮区 -->
      <view class="amount-highlight">
        <view class="amount-item">
          <text class="amount-label">消费金额</text>
          <text class="amount-value">¥{{item.consumption_amount}}</text>
        </view>
        <view class="amount-divider"></view>
        <view class="amount-item">
          <text class="amount-label">预计积分</text>
          <text class="amount-value points">{{item.points_to_award}}分</text>
        </view>
      </view>

      <!-- 详情信息 -->
      <view class="detail-section">
        <view class="detail-row" wx:if="{{item.merchant_notes}}">
          <text class="detail-label">商家备注</text>
          <text class="detail-value">{{item.merchant_notes}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">提交时间</text>
          <text class="detail-value time">{{item.created_at_formatted || item.created_at}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-bar">
        <button
          class="action-btn reject-btn"
          bindtap="onReject"
          data-record="{{item}}"
          disabled="{{submitting}}"
        >
          拒绝
        </button>
        <button
          class="action-btn approve-btn"
          bindtap="onApprove"
          data-record="{{item}}"
          disabled="{{submitting}}"
        >
          通过
        </button>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{hasMore && !loading}}">
      <text class="load-more-text">{{loadingMore ? '加载中...' : '上拉加载更多'}}</text>
    </view>

    <!-- 没有更多数据提示 -->
    <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
      <view class="no-more-line"></view>
      <text class="no-more-text">已加载全部</text>
      <view class="no-more-line"></view>
    </view>
  </view>

  <!-- 首次加载状态 -->
  <view class="page-loading" wx:if="{{loading && !refreshing && records.length === 0}}">
    <view class="page-spinner"></view>
    <text class="page-loading-text">正在加载...</text>
  </view>

  <!-- 审核拒绝弹窗 -->
  <view class="modal-mask" wx:if="{{showRejectModal}}" bindtap="cancelReject">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">审核拒绝</text>
        <view class="modal-close" bindtap="cancelReject">
          <text>✕</text>
        </view>
      </view>

      <!-- 被拒绝记录摘要 -->
      <view class="reject-summary" wx:if="{{selectedRecord}}">
        <text class="summary-text"
          >用户：{{selectedRecord.user_nickname || selectedRecord.user_mobile}} |
          ¥{{selectedRecord.consumption_amount}}</text
        >
      </view>

      <view class="modal-body">
        <text class="modal-label">拒绝原因（必填，至少5个字符）</text>
        <textarea
          class="reject-input"
          placeholder="请输入拒绝原因，如：消费金额与实际不符"
          value="{{rejectReason}}"
          bindinput="onRejectReasonInput"
          maxlength="200"
          auto-height
        />
        <view class="reject-footer">
          <text class="reject-counter">{{rejectReason.length || 0}}/200</text>
          <text class="reject-warn">拒绝后用户将收到通知，请谨慎操作</text>
        </view>
      </view>

      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="cancelReject">取消</button>
        <button class="modal-btn confirm" bindtap="confirmReject" disabled="{{submitting}}">
          {{submitting ? '提交中...' : '确认拒绝'}}
        </button>
      </view>
    </view>
  </view>
</view>
