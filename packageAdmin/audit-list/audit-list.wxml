<!--packageAdmin/audit-list/audit-list.wxml - 审批管理页面-->
<!--业务流程: 加载待审核消费记录 → 审核通过(自动发积分)/拒绝(填写原因) → 刷新列表-->

<view class="audit-page">
  <!-- 顶部统计区域（毛玻璃卡片） -->
  <view class="header-section">
    <view class="stats-card">
      <view class="stats-icon-wrap">
        <text class="stats-icon">📋</text>
      </view>
      <view class="stats-body">
        <view class="stats-number-row">
          <text class="stats-number">{{total}}</text>
          <text class="stats-unit">条</text>
        </view>
        <text class="stats-desc">待审核消费记录</text>
      </view>
    </view>
    <view class="guide-bar">
      <text class="guide-icon">💡</text>
      <text class="guide-text">审核通过后，积分将自动发放给顾客，请仔细核实消费信息</text>
    </view>
  </view>

  <!-- 记录列表区域 -->
  <view class="list-section">
    <!-- 空状态 -->
    <view class="empty-card" wx:if="{{!loading && records.length === 0}}">
      <view class="empty-visual">
        <view class="empty-glow"></view>
        <text class="empty-emoji">✅</text>
      </view>
      <text class="empty-heading">暂无待审核记录</text>
      <text class="empty-subtext">所有消费记录已审核完成，请稍后再来查看</text>
    </view>

    <!-- 记录卡片列表 -->
    <view class="record-card" wx:for="{{records}}" wx:key="record_id">
      <!-- 用户信息行 -->
      <view class="card-user-row">
        <view class="user-avatar">
          <text class="avatar-char">{{item.user_nickname ? item.user_nickname[0] : '用'}}</text>
        </view>
        <view class="user-info-col">
          <text class="user-nickname">{{item.user_nickname || '未知用户'}}</text>
          <text class="user-mobile">{{item.user_mobile_display || item.user_mobile}}</text>
        </view>
        <view class="pending-badge">
          <view class="badge-pulse-dot"></view>
          <text class="badge-label">待审核</text>
        </view>
      </view>

      <!-- 金额信息区 -->
      <view class="card-amount-area">
        <view class="amount-block">
          <text class="amount-caption">消费金额</text>
          <view class="amount-display">
            <text class="amount-symbol">¥</text>
            <text class="amount-figure">{{item.consumption_amount}}</text>
          </view>
        </view>
        <view class="amount-separator"></view>
        <view class="amount-block">
          <text class="amount-caption">预计积分</text>
          <view class="amount-display">
            <text class="amount-figure accent">{{item.points_to_award}}</text>
            <text class="amount-suffix">分</text>
          </view>
        </view>
      </view>

      <!-- 详情信息 -->
      <view class="card-detail-section">
        <view class="detail-row" wx:if="{{item.merchant_notes}}">
          <text class="detail-label">商家备注</text>
          <text class="detail-content">{{item.merchant_notes}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">提交时间</text>
          <text class="detail-content subdued">{{item.created_at_formatted}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="card-action-bar">
        <button class="action-reject" bindtap="onReject" data-record="{{item}}" disabled="{{submitting}}">拒绝</button>
        <button class="action-approve" bindtap="onApprove" data-record="{{item}}" disabled="{{submitting}}">通过</button>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more-area" wx:if="{{hasMore && !loading}}">
      <view class="load-more-spinner" wx:if="{{loadingMore}}">
        <view class="mini-spinner"></view>
        <text class="spinner-text">加载中...</text>
      </view>
      <text class="load-more-hint" wx:else>上拉加载更多</text>
    </view>

    <!-- 全部加载完毕 -->
    <view class="all-loaded-bar" wx:if="{{!hasMore && records.length > 0}}">
      <view class="loaded-divider"></view>
      <text class="loaded-label">已加载全部</text>
      <view class="loaded-divider"></view>
    </view>
  </view>

  <!-- 首次加载状态 -->
  <view class="initial-loading" wx:if="{{loading && !refreshing && records.length === 0}}">
    <view class="loading-content">
      <view class="loading-spinner-lg"></view>
      <text class="loading-title">正在加载...</text>
      <text class="loading-subtitle">获取待审核消费记录</text>
    </view>
  </view>

  <!-- 审核拒绝弹窗 -->
  <view class="reject-overlay" wx:if="{{showRejectModal}}" bindtap="cancelReject">
    <view class="reject-dialog" catchtap="stopPropagation">
      <view class="dialog-top">
        <text class="dialog-heading">审核拒绝</text>
        <view class="dialog-close-btn" bindtap="cancelReject">
          <text class="close-x">✕</text>
        </view>
      </view>

      <view class="dialog-record-summary" wx:if="{{selectedRecord}}">
        <text class="summary-info">用户：{{selectedRecord.user_nickname || selectedRecord.user_mobile}} |
          ¥{{selectedRecord.consumption_amount}}</text>
      </view>

      <view class="dialog-form">
        <text class="form-label">拒绝原因（必填，至少5个字符）</text>
        <textarea class="form-textarea" placeholder="请输入拒绝原因，如：消费金额与实际不符" value="{{rejectReason}}"
          bindinput="onRejectReasonInput" maxlength="200" auto-height />
        <view class="form-meta">
          <text class="char-counter">{{rejectReason.length || 0}}/200</text>
          <text class="caution-text">拒绝后用户将收到通知，请谨慎操作</text>
        </view>
      </view>

      <view class="dialog-buttons">
        <button class="dialog-cancel" bindtap="cancelReject">取消</button>
        <button class="dialog-confirm" bindtap="confirmReject" disabled="{{submitting}}">{{submitting ? '提交中...' :
          '确认拒绝'}}</button>
      </view>
    </view>
  </view>
</view>