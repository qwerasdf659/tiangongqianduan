<!--packageAdmin/audit-list/audit-list.wxml - 审核管理页面（审核链单一路径版）-->
<!--单一视图: 「我的待办」审核链步骤（通过/拒绝/批量 均走审核链 steps 接口）-->
<wxs src="./audit-list.wxs" module="auditHelper" />
<custom-navbar title="审批管理" bgColor="#F5F0E8" textColor="#333333" showBack="{{true}}" />

<view class="audit-page">
  <scroll-view type="list" scroll-y class="page-scroll-view">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-text">
        <text class="header-title">审批管理</text>
        <text class="header-desc">审核通过后积分自动发放</text>
      </view>
      <view class="header-decor-icon">
        <t-icon name="check-circle" size="128rpx" color="rgba(139, 115, 85, 0.12)" />
      </view>
    </view>

    <!-- ===== 顶部汇总条（§12.5 B 简洁看板：未审/已审/总数 + 超时预警） ===== -->
    <view class="summary-section" wx:if="{{summaryReady}}">
      <view class="summary-grid">
        <view class="summary-card pending">
          <view class="summary-icon-bg pending">
            <t-icon name="time" size="36rpx" color="#c5a572" />
          </view>
          <view class="summary-body">
            <text class="summary-label">未审核</text>
            <text class="summary-value pending">{{summaryPendingCount}}</text>
          </view>
        </view>

        <view class="summary-card approved">
          <view class="summary-icon-bg approved">
            <t-icon name="check-circle" size="36rpx" color="#27ae60" />
          </view>
          <view class="summary-body">
            <text class="summary-label">已审核</text>
            <text class="summary-value approved">{{summaryApprovedCount}}</text>
          </view>
        </view>

        <view class="summary-card total">
          <view class="summary-icon-bg total">
            <t-icon name="file-paste" size="36rpx" color="#8b7355" />
          </view>
          <view class="summary-body">
            <text class="summary-label">审核总数</text>
            <text class="summary-value total">{{summaryTotalCount}}</text>
          </view>
        </view>
      </view>

      <!-- 超时预警条（仅在有超时/临近超时时显示） -->
      <view
        class="summary-timeout-bar"
        wx:if="{{summaryOverdueCount > 0 || summaryNearDueCount > 0}}"
      >
        <t-icon name="error-circle" size="28rpx" color="#c44569" class="summary-timeout-icon" />
        <text class="summary-timeout-text" wx:if="{{summaryOverdueCount > 0}}"
          >已超时 {{summaryOverdueCount}} 单</text
        >
        <text
          class="summary-timeout-divider"
          wx:if="{{summaryOverdueCount > 0 && summaryNearDueCount > 0}}"
          >·</text
        >
        <text class="summary-timeout-text near" wx:if="{{summaryNearDueCount > 0}}"
          >临近超时 {{summaryNearDueCount}} 单</text
        >
      </view>

      <!-- ===== 本店核销概况卡（门店专属兑换券业务线，store-stats；无门店/无权限静默不显示） ===== -->
      <view class="redemption-stats" wx:if="{{redemptionStatsReady}}">
        <view class="redemption-stats-header">
          <t-icon name="shop" size="32rpx" color="#8b7355" class="redemption-stats-icon" />
          <text class="redemption-stats-title">本店核销概况</text>
          <view
            wx:if="{{canManageStaffPerm}}"
            class="redemption-stats-manage"
            bindtap="goStaffRedemptionPerm"
          >
            <text class="redemption-stats-manage-text">权限管理</text>
            <t-icon name="chevron-right" size="28rpx" color="#8b7355" />
          </view>
        </view>

        <!-- 多门店店长：门店切换器（与授权页口径一致，可查看各店核销概况） -->
        <picker
          wx:if="{{redemptionIsMultiStore}}"
          class="redemption-store-picker"
          mode="selector"
          range="{{redemptionStoreList}}"
          range-key="store_name"
          value="{{redemptionStoreIndex}}"
          bindchange="onRedemptionStoreChange"
        >
          <view class="redemption-store-picker-inner">
            <text class="redemption-store-picker-name">{{redemptionStoreName}}</text>
            <t-icon name="chevron-down" size="28rpx" color="#999999" />
          </view>
        </picker>

        <view class="redemption-stats-grid {{redemptionStatsLoading ? 'loading' : ''}}">
          <view class="redemption-stat-item pending">
            <text class="redemption-stat-value">{{redemptionPendingCount}}</text>
            <text class="redemption-stat-label">待核销</text>
          </view>
          <view class="redemption-stat-divider"></view>
          <view class="redemption-stat-item fulfilled">
            <text class="redemption-stat-value">{{redemptionFulfilledCount}}</text>
            <text class="redemption-stat-label">已核销</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 我的待办（审核链步骤，唯一视图） ===== -->
    <block>
      <!-- 顶部统计面板 -->
      <view class="stats-panel">
        <view class="stats-main">
          <view class="stats-number-wrap">
            <text class="stats-number">{{pendingTotal}}</text>
            <text class="stats-unit">条</text>
          </view>
          <text class="stats-label">待我审核的步骤</text>
        </view>
        <view class="stats-hint">
          <t-icon name="hourglass" size="24rpx" class="stats-hint-icon" />
          <text class="stats-hint-text">超时12小时自动升级</text>
        </view>
      </view>

      <!-- 批量操作工具栏（仅admin可批量操作）+ 列表区域 -->
      <sticky-section>
        <sticky-header wx:if="{{canBatchReview}}">
          <view class="toolbar">
            <view class="toolbar-left">
              <view
                class="custom-checkbox {{allSelected ? 'checked' : ''}}"
                bindtap="toggleSelectAllSteps"
              >
                <t-icon
                  name="check-circle-filled"
                  size="28rpx"
                  class="check-mark"
                  wx:if="{{allSelected}}"
                />
              </view>
              <text class="toolbar-label">全选</text>
            </view>
            <view class="toolbar-right">
              <view class="batch-btn reject" wx:if="{{selectedCount > 0}}" bindtap="onBatchReject">
                <text>拒绝 ({{selectedCount}})</text>
              </view>
              <view
                class="batch-btn approve"
                wx:if="{{selectedCount > 0}}"
                bindtap="onBatchApprove"
              >
                <text>通过 ({{selectedCount}})</text>
              </view>
              <text class="toolbar-tip" wx:if="{{selectedCount === 0 && pendingSteps.length > 0}}"
                >勾选步骤可批量操作</text
              >
            </view>
          </view>
        </sticky-header>

        <!-- 待办列表 -->
        <view class="list-section">
          <!-- 空状态 -->
          <t-empty
            wx:if="{{!pendingLoading && pendingSteps.length === 0}}"
            description="您没有需要审核的步骤，下拉刷新检查新任务"
          >
            <view slot="image"
              ><t-icon name="check-circle" size="120rpx" color="var(--td-brand-color)"
            /></view>
          </t-empty>

          <!-- 审核链步骤卡片 -->
          <view
            class="record-card chain-card {{item.selected ? 'selected' : ''}}"
            wx:for="{{pendingSteps}}"
            wx:key="step_id"
          >
            <!-- 卡片头部 -->
            <view class="card-header">
              <view class="header-left">
                <view
                  class="custom-checkbox {{item.selected ? 'checked' : ''}}"
                  catchtap="toggleStepSelect"
                  data-index="{{index}}"
                  wx:if="{{canBatchReview}}"
                >
                  <t-icon
                    name="check-circle-filled"
                    size="28rpx"
                    class="check-mark"
                    wx:if="{{item.selected}}"
                  />
                </view>
                <view class="chain-type-badge">
                  <text class="chain-type-badge-text">{{item.auditable_type_text}}</text>
                </view>
                <view class="chain-meta">
                  <text class="chain-step-label">{{item.is_final_text}}</text>
                  <text class="chain-step-progress">{{item.step_progress}}</text>
                </view>
              </view>
              <view class="status-tag pending">
                <view class="status-dot"></view>
                <text class="status-tag-text">{{item.status_text}}</text>
              </view>
            </view>

            <!-- 审核链进度条（TS 层已预计算 progress_*，避免 WXML 内联除法出现 NaN） -->
            <view class="chain-progress-bar" wx:if="{{item.has_progress}}">
              <view class="progress-track">
                <view class="progress-fill" style="width: {{item.progress_percent}}%"></view>
              </view>
              <text class="progress-text"
                >进度 {{item.progress_current}}/{{item.progress_total}}</text
              >
            </view>

            <!-- 业务快照信息（TS层已预计算 snapshot_* 字段，避免WXML中复杂OR表达式） -->
            <view class="card-amounts" wx:if="{{item.has_snapshot}}">
              <view class="amount-item" wx:if="{{item.snapshot_consumption_amount}}">
                <text class="amount-label">消费金额</text>
                <view class="amount-value">
                  <text class="currency">¥</text>
                  <text class="number money">{{item.snapshot_consumption_amount}}</text>
                </view>
              </view>
              <view
                class="amount-divider"
                wx:if="{{item.snapshot_consumption_amount && item.snapshot_points_to_award}}"
              >
              </view>
              <view class="amount-item" wx:if="{{item.snapshot_points_to_award}}">
                <text class="amount-label">预计积分</text>
                <view class="amount-value">
                  <text class="number points">{{item.snapshot_points_to_award}}</text>
                  <text class="unit">分</text>
                </view>
              </view>
            </view>

            <!-- 快照缺失时的优雅降级：引导点"详情"看完整业务信息（后端 my-pending 未下发 snapshot 时） -->
            <view class="snapshot-fallback" wx:if="{{!item.has_snapshot}}">
              <text class="snapshot-fallback-text">点击「详情」查看完整审核进度与业务信息</text>
            </view>

            <!-- 详情信息 -->
            <view class="card-details">
              <view
                class="detail-item"
                wx:if="{{item.instance && item.instance.submitted_by_name}}"
              >
                <text class="detail-key">提交人</text>
                <text class="detail-val">{{item.instance.submitted_by_name}}</text>
              </view>
              <view class="detail-item">
                <text class="detail-key">创建时间</text>
                <text class="detail-val muted">{{item.created_at_formatted}}</text>
              </view>
              <view class="detail-item" wx:if="{{item.timeout_at_formatted}}">
                <text class="detail-key">超时截止</text>
                <text class="detail-val muted timeout">{{item.timeout_at_formatted}}</text>
              </view>
            </view>

            <!-- 操作按钮 -->
            <view class="card-actions">
              <t-button
                wx:if="{{item.instance_id || item.auditable_id}}"
                theme="default"
                variant="outline"
                size="small"
                shape="round"
                data-instance-id="{{item.instance_id}}"
                data-auditable-type="{{item.auditable_type}}"
                data-auditable-id="{{item.auditable_id}}"
                bind:tap="onViewChainDetail"
              >
                详情
              </t-button>
              <t-button
                theme="danger"
                variant="outline"
                size="small"
                shape="round"
                data-step="{{item}}"
                bind:tap="onChainReject"
                disabled="{{chainSubmitting}}"
              >
                拒绝
              </t-button>
              <t-button
                theme="primary"
                size="small"
                shape="round"
                data-step="{{item}}"
                bind:tap="onChainApprove"
                disabled="{{chainSubmitting}}"
              >
                通过
              </t-button>
            </view>
          </view>

          <view class="list-footer" wx:if="{{pendingSteps.length > 0}}">
            <text class="footer-text" wx:if="{{pendingLoadingMore}}">加载更多待办步骤...</text>
            <text class="footer-text" wx:elif="{{pendingNoMore}}">— 已展示全部待办步骤 —</text>
          </view>
        </view>

        <view
          class="list-footer"
          wx:if="{{!pendingLoading && pendingSteps.length > 0 && pendingTotal > pendingSteps.length}}"
        >
          <text class="footer-text">当前已加载 {{pendingSteps.length}} / {{pendingTotal}} 条</text>
        </view>
      </sticky-section>
    </block>

    <!-- ===== 首次加载 ===== -->
    <view class="loading-overlay" wx:if="{{pendingLoading && pendingSteps.length === 0}}">
      <view class="loading-box">
        <t-loading loading="{{true}}" text="正在加载..." theme="spinner" />
      </view>
    </view>

    <!-- 底部安全区留白 -->
    <view style="height: calc(60rpx + env(safe-area-inset-bottom, 0px)); width: 100%"></view>

    <!-- 🔧 全屏维护遮罩（503 SYSTEM_MAINTENANCE 时激活） -->
    <maintenance-overlay />
  </scroll-view>

  <!-- ===== 审核链步骤拒绝弹窗（单条/批量共用） ===== -->
  <t-dialog
    wx:if="{{showChainRejectModal}}"
    visible="{{showChainRejectModal}}"
    title="{{batchRejectMode ? '批量拒绝' : '审核链拒绝'}}"
    closeBtn="{{true}}"
    closeOnOverlayClick="{{true}}"
    confirmBtn="{{auditHelper.chainRejectBtn(chainSubmitting)}}"
    cancelBtn="取消"
    bind:confirm="confirmChainReject"
    bind:close="cancelChainReject"
    bind:cancel="cancelChainReject"
  >
    <view slot="content" class="dialog-content">
      <view class="modal-summary batch" wx:if="{{batchRejectMode}}">
        <text class="modal-summary-batch">已选中 {{selectedCount}} 个步骤，将统一拒绝</text>
      </view>
      <view class="modal-summary" wx:elif="{{selectedStep}}">
        <text class="modal-summary-label">{{selectedStep.auditable_type_text}}</text>
        <text class="modal-summary-divider">|</text>
        <text class="modal-summary-val"
          >{{selectedStep.is_final_text}} · {{selectedStep.step_progress}}</text
        >
      </view>

      <view class="modal-body">
        <text class="input-label">拒绝原因（必填，至少5个字符）</text>
        <t-textarea
          value="{{chainRejectReason}}"
          placeholder="请输入拒绝原因"
          maxlength="500"
          indicator="{{true}}"
          autosize="{{autosizeLarge}}"
          bind:change="onChainRejectReasonInput"
        />
        <view class="input-meta">
          <text class="warning-text">拒绝后整个审核链将终止</text>
        </view>
      </view>
    </view>
  </t-dialog>

  <!-- ===== 审核链详情弹窗（时间线） ===== -->
  <t-dialog
    wx:if="{{showChainDetailModal}}"
    visible="{{showChainDetailModal}}"
    title="审核链详情"
    closeBtn="{{true}}"
    closeOnOverlayClick="{{true}}"
    confirmBtn="{{auditHelper.buildConfirmBtn('关闭', false, false)}}"
    bind:confirm="closeChainDetailModal"
    bind:close="closeChainDetailModal"
  >
    <scroll-view
      type="list"
      slot="content"
      scroll-y
      class="chain-detail-scroll"
      wx:if="{{chainDetail}}"
    >
      <!-- 审核链基本信息 -->
      <view class="chain-detail-info">
        <view class="detail-row">
          <text class="detail-key">业务类型</text>
          <text class="detail-val">{{chainDetail.auditable_type_text}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-key">整体状态</text>
          <text class="detail-val chain-status-{{chainDetail.status}}"
            >{{chainDetail.status_text}}</text
          >
        </view>
        <view class="detail-row">
          <text class="detail-key">提交时间</text>
          <text class="detail-val muted">{{chainDetail.submitted_at_formatted}}</text>
        </view>
        <view class="detail-row" wx:if="{{chainDetail.completed_at_formatted}}">
          <text class="detail-key">完成时间</text>
          <text class="detail-val muted">{{chainDetail.completed_at_formatted}}</text>
        </view>
        <view class="detail-row" wx:if="{{chainDetail.final_reason}}">
          <text class="detail-key">审批意见</text>
          <text class="detail-val">{{chainDetail.final_reason}}</text>
        </view>
      </view>

      <!-- 审核链步骤时间线 -->
      <view class="chain-timeline">
        <text class="timeline-title">审核步骤</text>
        <view class="timeline-list">
          <view
            class="timeline-item {{stepItem.status}}"
            wx:for="{{chainDetail.steps}}"
            wx:for-item="stepItem"
            wx:key="step_id"
          >
            <view class="timeline-dot {{stepItem.status}}"></view>
            <view class="timeline-line" wx:if="{{index < chainDetail.steps.length - 1}}"></view>
            <view class="timeline-content">
              <view class="timeline-header">
                <text class="timeline-step-name"
                  >{{stepItem.node_name || ('第' + (index + 1) + '步')}}</text
                >
                <text class="timeline-step-status {{stepItem.status}}"
                  >{{stepItem.status_text}}</text
                >
              </view>
              <view class="timeline-detail" wx:if="{{stepItem.actioned_at_formatted}}">
                <text class="timeline-time">{{stepItem.actioned_at_formatted}}</text>
              </view>
              <view class="timeline-detail" wx:if="{{stepItem.action_reason}}">
                <text class="timeline-reason">{{stepItem.action_reason}}</text>
              </view>
              <view class="timeline-detail" wx:if="{{stepItem.auto_approved}}">
                <text class="timeline-auto">自动审批</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </t-dialog>

  <!-- ===== 批量操作进度弹窗 ===== -->
  <t-dialog
    wx:if="{{showBatchProgress}}"
    visible="{{showBatchProgress}}"
    title="批量处理中"
    closeBtn="{{false}}"
    closeOnOverlayClick="{{false}}"
    confirmBtn="{{auditHelper.buildConfirmBtn('处理中', true, true)}}"
  >
    <view slot="content" class="progress-content">
      <t-loading loading="{{true}}" text="{{batchProgressText}}" theme="spinner" />
      <text class="progress-detail">{{batchProgressDetail}}</text>
    </view>
  </t-dialog>
</view>
