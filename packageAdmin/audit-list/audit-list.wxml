<!--packageAdmin/audit-list/audit-list.wxml - 审批管理页面-->
<!--业务流程: 加载待审核消费记录 → 单条/批量审核通过(自动发积分)/拒绝(填写原因) → 刷新列表-->

<view class="audit-page">
  <!-- 顶部统计面板：待审核数量 + 操作引导 -->
  <view class="stats-panel">
    <view class="stats-main">
      <view class="stats-number-wrap">
        <text class="stats-number">{{total}}</text>
        <text class="stats-unit">条</text>
      </view>
      <text class="stats-label">待审核消费记录</text>
    </view>
    <view class="stats-hint">
      <text class="stats-hint-icon">💡</text>
      <text class="stats-hint-text">审核通过后积分自动发放</text>
    </view>
  </view>

  <!-- 操作工具栏（置顶）：全选 + 批量操作 -->
  <view class="toolbar">
    <view class="toolbar-left">
      <view class="custom-checkbox {{allSelected ? 'checked' : ''}}" bindtap="toggleSelectAll">
        <text class="check-mark" wx:if="{{allSelected}}">✓</text>
      </view>
      <text class="toolbar-label">全选</text>
    </view>
    <view class="toolbar-right">
      <view class="batch-btn reject" wx:if="{{selectedCount > 0}}" bindtap="onBatchReject">
        <text>拒绝 ({{selectedCount}})</text>
      </view>
      <view class="batch-btn approve" wx:if="{{selectedCount > 0}}" bindtap="onBatchApprove">
        <text>通过 ({{selectedCount}})</text>
      </view>
      <text class="toolbar-tip" wx:if="{{selectedCount === 0 && records.length > 0}}"
        >勾选记录可批量操作</text
      >
    </view>
  </view>

  <!-- 列表区域 -->
  <view class="list-section">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
      <view class="empty-icon-wrap">
        <text class="empty-icon">✅</text>
      </view>
      <text class="empty-title">暂无待审核记录</text>
      <text class="empty-desc">所有消费记录已审核完成，下拉刷新检查新记录</text>
    </view>

    <!-- 记录卡片列表 -->
    <view
      class="record-card {{item.selected ? 'selected' : ''}}"
      wx:for="{{records}}"
      wx:key="record_id"
    >
      <!-- 卡片顶部：选择框 + 用户信息 + 状态 -->
      <view class="card-header">
        <view class="header-left">
          <view
            class="custom-checkbox {{item.selected ? 'checked' : ''}}"
            catchtap="toggleSelect"
            data-index="{{index}}"
          >
            <text class="check-mark" wx:if="{{item.selected}}">✓</text>
          </view>
          <view class="user-avatar">
            <text class="avatar-text">{{item.user_nickname ? item.user_nickname[0] : '用'}}</text>
          </view>
          <view class="user-info">
            <text class="user-name">{{item.user_nickname || '未知用户'}}</text>
            <text class="user-phone">{{item.user_mobile_display || item.user_mobile}}</text>
          </view>
        </view>
        <view class="status-tag pending">
          <view class="status-dot"></view>
          <text>待审核</text>
        </view>
      </view>

      <!-- 金额与积分区域 -->
      <view class="card-amounts">
        <view class="amount-item">
          <text class="amount-label">消费金额</text>
          <view class="amount-value">
            <text class="currency">¥</text>
            <text class="number money">{{item.consumption_amount}}</text>
          </view>
        </view>
        <view class="amount-divider"></view>
        <view class="amount-item">
          <text class="amount-label">预计积分</text>
          <view class="amount-value">
            <text class="number points">{{item.points_to_award}}</text>
            <text class="unit">分</text>
          </view>
        </view>
      </view>

      <!-- 详情信息 -->
      <view class="card-details">
        <view class="detail-item" wx:if="{{item.merchant_notes}}">
          <text class="detail-key">商家备注</text>
          <text class="detail-val">{{item.merchant_notes}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-key">提交时间</text>
          <text class="detail-val muted">{{item.created_at_formatted}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="card-actions">
        <button
          class="btn-reject"
          bindtap="onReject"
          data-record="{{item}}"
          disabled="{{submitting}}"
        >
          拒绝
        </button>
        <button
          class="btn-approve"
          bindtap="onApprove"
          data-record="{{item}}"
          disabled="{{submitting}}"
        >
          通过
        </button>
      </view>
    </view>
  </view>

  <!-- 分页栏（页码水平排列） -->
  <view class="pagination" wx:if="{{total_pages > 1}}">
    <view class="page-arrow {{page <= 1 ? 'disabled' : ''}}" bindtap="goToPrevPage">
      <text>‹</text>
    </view>
    <view class="page-nums">
      <view
        wx:for="{{pageNumbers}}"
        wx:key="*this"
        class="page-num {{item === page ? 'active' : ''}}"
        bindtap="goToPage"
        data-page="{{item}}"
      >
        <text>{{item}}</text>
      </view>
    </view>
    <view class="page-arrow {{page >= total_pages ? 'disabled' : ''}}" bindtap="goToNextPage">
      <text>›</text>
    </view>
    <text class="page-info">{{page}}/{{total_pages}}</text>
  </view>

  <!-- 首次加载 -->
  <view class="loading-overlay" wx:if="{{loading && records.length === 0}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载...</text>
    </view>
  </view>

  <!-- 审核拒绝弹窗（单条/批量共用） -->
  <view class="modal-overlay" wx:if="{{showRejectModal}}" bindtap="cancelReject">
    <view class="modal-dialog" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-header-left">
          <view class="modal-header-icon">
            <text>✕</text>
          </view>
          <text class="modal-title">{{batchRejectMode ? '批量拒绝' : '审核拒绝'}}</text>
        </view>
        <view class="modal-close" bindtap="cancelReject">
          <text>✕</text>
        </view>
      </view>

      <view class="modal-summary" wx:if="{{!batchRejectMode && selectedRecord}}">
        <text class="modal-summary-label">用户</text>
        <text class="modal-summary-val"
          >{{selectedRecord.user_nickname || selectedRecord.user_mobile}}</text
        >
        <text class="modal-summary-divider">|</text>
        <text class="modal-summary-amount">¥{{selectedRecord.consumption_amount}}</text>
      </view>
      <view class="modal-summary batch" wx:if="{{batchRejectMode}}">
        <text class="modal-summary-batch">已选中 {{selectedCount}} 条记录，将统一拒绝</text>
      </view>

      <view class="modal-body">
        <text class="input-label">拒绝原因（必填，至少5个字符）</text>
        <textarea
          class="reject-textarea"
          placeholder="请输入拒绝原因，如：消费金额与实际不符"
          value="{{rejectReason}}"
          bindinput="onRejectReasonInput"
          maxlength="200"
          auto-height
        />
        <view class="input-meta">
          <text class="char-count">{{rejectReason.length || 0}}/200</text>
          <text class="warning-text">拒绝后用户将收到通知</text>
        </view>
      </view>

      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="cancelReject">取消</button>
        <button class="modal-btn confirm" bindtap="confirmReject" disabled="{{submitting}}">
          {{submitting ? '提交中...' : (batchRejectMode ? '确认批量拒绝' : '确认拒绝')}}
        </button>
      </view>
    </view>
  </view>

  <!-- 批量操作进度弹窗 -->
  <view class="modal-overlay" wx:if="{{showBatchProgress}}">
    <view class="modal-dialog progress" catchtap="stopPropagation">
      <view class="progress-content">
        <view class="loading-spinner"></view>
        <text class="progress-title">{{batchProgressText}}</text>
        <text class="progress-detail">{{batchProgressDetail}}</text>
      </view>
    </view>
  </view>
</view>
